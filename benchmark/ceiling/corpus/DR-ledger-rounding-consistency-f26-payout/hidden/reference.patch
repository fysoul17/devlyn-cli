@@ -35,6 +37,173 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function emitError(obj) {
+  process.stderr.write(JSON.stringify(obj) + '\n');
+  process.exit(2);
+}
+
+function payout(argv) {
+  const idx = argv.indexOf('--input');
+  if (idx === -1 || !argv[idx + 1]) {
+    emitError({ error: 'missing_input' });
+  }
+  const inputPath = path.resolve(process.cwd(), argv[idx + 1]);
+
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (_err) {
+    emitError({ error: 'unreadable_input' });
+  }
+
+  let parsed;
+  try {
+    parsed = JSON.parse(raw);
+  } catch (_err) {
+    emitError({ error: 'invalid_json' });
+  }
+
+  if (!parsed || !Array.isArray(parsed.events)) {
+    emitError({ error: 'missing_events' });
+  }
+
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  let rules;
+  try {
+    rules = JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
+  } catch (_err) {
+    emitError({ error: 'unreadable_rules' });
+  }
+
+  const VALID_TYPES = new Set(['charge', 'refund', 'dispute']);
+  const seen = new Map();
+  const deduped = [];
+
+  for (const ev of parsed.events) {
+    if (!ev || typeof ev !== 'object') {
+      emitError({ error: 'invalid_event' });
+    }
+    if (typeof ev.id !== 'string' || ev.id.length === 0) {
+      emitError({ error: 'missing_id' });
+    }
+    if (typeof ev.merchant_id !== 'string' || ev.merchant_id.length === 0) {
+      emitError({ error: 'missing_merchant_id', id: ev.id });
+    }
+    if (!VALID_TYPES.has(ev.type)) {
+      emitError({ error: 'unknown_event_type', id: ev.id });
+    }
+    if (
+      typeof ev.amount_cents !== 'number' ||
+      !Number.isInteger(ev.amount_cents) ||
+      ev.amount_cents <= 0
+    ) {
+      emitError({ error: 'invalid_amount_cents', id: ev.id });
+    }
+
+    const prior = seen.get(ev.id);
+    if (prior) {
+      if (
+        prior.merchant_id === ev.merchant_id &&
+        prior.type === ev.type &&
+        prior.amount_cents === ev.amount_cents
+      ) {
+        continue; // idempotent duplicate
+      }
+      emitError({ error: 'conflicting_duplicate', id: ev.id });
+    }
+    const normalized = {
+      id: ev.id,
+      merchant_id: ev.merchant_id,
+      type: ev.type,
+      amount_cents: ev.amount_cents,
+    };
+    seen.set(ev.id, normalized);
+    deduped.push(normalized);
+  }
+
+  // Walk deduped events in order, building merchant rows in first-seen order.
+  const merchants = new Map();
+  function getRow(merchant_id) {
+    let row = merchants.get(merchant_id);
+    if (!row) {
+      row = {
+        merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+        reserve_cents: 0,
+        payout_cents: 0,
+      };
+      merchants.set(merchant_id, row);
+    }
+    return row;
+  }
+
+  for (const ev of deduped) {
+    const row = getRow(ev.merchant_id);
+    if (ev.type === 'charge') {
+      row.gross_charge_cents += ev.amount_cents;
+      row.processing_fee_cents +=
+        Math.round(ev.amount_cents * rules.processing_fee_percent / 100) +
+        rules.fixed_fee_cents;
+    } else if (ev.type === 'refund') {
+      row.refund_cents += ev.amount_cents;
+    } else if (ev.type === 'dispute') {
+      row.dispute_cents += ev.amount_cents;
+      row.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  let total_payout_cents = 0;
+  let total_processing_fee_cents = 0;
+  let total_dispute_fee_cents = 0;
+  let total_reserve_cents = 0;
+  const merchantRows = [];
+
+  for (const row of merchants.values()) {
+    const net_before_reserve =
+      row.gross_charge_cents -
+      row.refund_cents -
+      row.dispute_cents -
+      row.processing_fee_cents -
+      row.dispute_fee_cents;
+    row.reserve_cents =
+      net_before_reserve > 0
+        ? Math.round(net_before_reserve * rules.reserve_percent / 100)
+        : 0;
+    row.payout_cents = net_before_reserve - row.reserve_cents;
+    if (row.payout_cents > 0 && row.payout_cents < rules.minimum_payout_cents) {
+      row.reserve_cents += row.payout_cents;
+      row.payout_cents = 0;
+    }
+    total_payout_cents += row.payout_cents;
+    total_processing_fee_cents += row.processing_fee_cents;
+    total_dispute_fee_cents += row.dispute_fee_cents;
+    total_reserve_cents += row.reserve_cents;
+    merchantRows.push({
+      merchant_id: row.merchant_id,
+      gross_charge_cents: row.gross_charge_cents,
+      refund_cents: row.refund_cents,
+      dispute_cents: row.dispute_cents,
+      processing_fee_cents: row.processing_fee_cents,
+      dispute_fee_cents: row.dispute_fee_cents,
+      reserve_cents: row.reserve_cents,
+      payout_cents: row.payout_cents,
+    });
+  }
+
+  const result = {
+    total_payout_cents,
+    total_processing_fee_cents,
+    total_dispute_fee_cents,
+    total_reserve_cents,
+    merchants: merchantRows,
+  };
+  process.stdout.write(JSON.stringify(result) + '\n');
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +222,10 @@ function main(argv) {
