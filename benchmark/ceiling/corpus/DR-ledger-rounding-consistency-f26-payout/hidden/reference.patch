+
+test('payout: charges + refund + dispute with idempotent duplicate', () => {
+  const fixture = {
+    events: [
+      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
+      { id: 'c2', merchant_id: 'm2', type: 'charge', amount_cents: 8000 },
+      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
+      { id: 'r1', merchant_id: 'm1', type: 'refund', amount_cents: 2000 },
+      { id: 'd1', merchant_id: 'm1', type: 'dispute', amount_cents: 3000 },
+      { id: 'c3', merchant_id: 'm1', type: 'charge', amount_cents: 5000 },
+    ],
+  };
+  const file = path.join(os.tmpdir(), `payout-success-${process.pid}-${Date.now()}.json`);
+  fs.writeFileSync(file, JSON.stringify(fixture));
+
+  const out = run(['payout', '--input', file]);
+  const parsed = JSON.parse(out);
+
+  assert.deepStrictEqual(parsed, {
+    total_payout_cents: 14168,
+    total_processing_fee_cents: 757,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 1575,
+    merchants: [
+      {
+        merchant_id: 'm1',
+        gross_charge_cents: 15000,
+        refund_cents: 2000,
+        dispute_cents: 3000,
+        processing_fee_cents: 495,
+        dispute_fee_cents: 1500,
+        reserve_cents: 801,
+        payout_cents: 7204,
+      },
+      {
+        merchant_id: 'm2',
+        gross_charge_cents: 8000,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 262,
+        dispute_fee_cents: 0,
+        reserve_cents: 774,
+        payout_cents: 6964,
+      },
+    ],
+  });
+});
+
+test('payout: conflicting duplicate exits 2 with error to stderr and no stdout', () => {
+  const fixture = {
+    events: [
+      { id: 'x1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
+      { id: 'x1', merchant_id: 'm1', type: 'charge', amount_cents: 9999 },
+    ],
+  };
+  const file = path.join(os.tmpdir(), `payout-conflict-${process.pid}-${Date.now()}.json`);
+  fs.writeFileSync(file, JSON.stringify(fixture));
+
+  const result = spawnSync('node', [CLI, 'payout', '--input', file], { encoding: 'utf8' });
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  const err = JSON.parse(result.stderr);
+  assert.deepStrictEqual(err, { error: 'conflicting_duplicate', id: 'x1' });
+});
