// Tiny Express server with a deliberately small API surface.
const crypto = require('crypto');
const express = require('express');
const fs = require('fs');
const path = require('path');

const app = express();
const webhookSecret = fs.readFileSync(path.join(__dirname, '..', 'data', 'webhook-secret.txt'));
const acceptedWebhookIds = new Set();

app.use(express.json({ verify: (req, _res, buf) => { req.rawBody = buf; } }));

const items = [
  { id: 1, name: 'alpha', qty: 3 },
  { id: 2, name: 'beta', qty: 5 },
];

app.get('/health', (_req, res) => {
  res.json({ status: 'ok' });
});

app.get('/items', (_req, res) => {
  res.json({ items });
});

app.get('/items/:id', (req, res) => {
  const id = Number(req.params.id);
  const item = items.find((it) => it.id === id);
  if (!item) {
    res.status(404).json({ error: 'not_found', id });
    return;
  }
  res.json({ item });
});

app.post('/webhook', (req, res) => {
  const signature = req.get('X-Signature');
  const expectedSignature = crypto
    .createHmac('sha256', webhookSecret)
    .update(req.rawBody)
    .digest('hex');

  if (
    typeof signature !== 'string' ||
    !/^[0-9a-f]{64}$/i.test(signature) ||
    !crypto.timingSafeEqual(Buffer.from(expectedSignature, 'hex'), Buffer.from(signature, 'hex'))
  ) {
    res.status(401).json({ error: 'invalid_signature' });
    return;
  }

  const id = req.body && req.body.id;
  if (acceptedWebhookIds.has(id)) {
    res.status(409).json({ error: 'duplicate_event', id });
    return;
  }

  if (
    !req.body ||
    typeof req.body !== 'object' ||
    Array.isArray(req.body) ||
    typeof req.body.id !== 'string' ||
    req.body.id.length === 0 ||
    typeof req.body.type !== 'string' ||
    req.body.type.length === 0 ||
    typeof req.body.timestamp !== 'number' ||
    !req.body.data ||
    typeof req.body.data !== 'object' ||
    Array.isArray(req.body.data)
  ) {
    res.status(400).json({ error: 'invalid_body' });
    return;
  }

  acceptedWebhookIds.add(id);
  res.json({ accepted: true, id });
});

if (require.main === module) {
  const port = Number(process.env.PORT) || 3000;
  app.listen(port, () => {
    console.log(`harbor-tools server listening on :${port}`);
  });
}

module.exports = { app };
const { test } = require('node:test');
const assert = require('node:assert');
const crypto = require('node:crypto');
const fs = require('node:fs');
const http = require('node:http');
const path = require('node:path');
const { app } = require('../server');

const webhookSecret = fs.readFileSync(path.join(__dirname, '..', 'data', 'webhook-secret.txt'));

function startServer() {
  return new Promise((resolve) => {
    const server = http.createServer(app);
    server.listen(0, () => resolve(server));
  });
}

function get(server, path) {
  return new Promise((resolve, reject) => {
    const { port } = server.address();
    http
      .get(`http://127.0.0.1:${port}${path}`, (res) => {
        let body = '';
        res.on('data', (chunk) => (body += chunk));
        res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(body) }));
      })
      .on('error', reject);
  });
}

function webhookSignature(body) {
  return crypto.createHmac('sha256', webhookSecret).update(body).digest('hex');
}

function post(server, path, body, signature) {
  return new Promise((resolve, reject) => {
    const { port } = server.address();
    const request = http.request(
      `http://127.0.0.1:${port}${path}`,
      {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Content-Length': Buffer.byteLength(body),
          'X-Signature': signature,
        },
      },
      (res) => {
        let responseBody = '';
        res.on('data', (chunk) => (responseBody += chunk));
        res.on('end', () => {
          resolve({ status: res.statusCode, body: JSON.parse(responseBody) });
        });
      },
    );
    request.on('error', reject);
    request.end(body);
  });
}

test('GET /health returns ok', async () => {
  const server = await startServer();
  try {
    const { status, body } = await get(server, '/health');
    assert.strictEqual(status, 200);
    assert.deepStrictEqual(body, { status: 'ok' });
  } finally {
    server.close();
  }
});

test('GET /items returns list', async () => {
  const server = await startServer();
  try {
    const { status, body } = await get(server, '/items');
    assert.strictEqual(status, 200);
    assert.ok(Array.isArray(body.items));
    assert.ok(body.items.length >= 2);
  } finally {
    server.close();
  }
});

test('GET /items/:id returns 404 for missing', async () => {
  const server = await startServer();
  try {
    const { status, body } = await get(server, '/items/99999');
    assert.strictEqual(status, 404);
    assert.strictEqual(body.error, 'not_found');
  } finally {
    server.close();
  }
});

test('POST /webhook accepts a valid signed event', async () => {
  const server = await startServer();
  try {
    const body = JSON.stringify({
      id: 'webhook-happy-path',
      type: 'invoice.paid',
      timestamp: 1721574000,
      data: { invoiceId: 'inv_123' },
    });
    const response = await post(server, '/webhook', body, webhookSignature(body));
    assert.strictEqual(response.status, 200);
    assert.deepStrictEqual(response.body, { accepted: true, id: 'webhook-happy-path' });
  } finally {
    server.close();
  }
});

test('POST /webhook rejects a replayed signed event', async () => {
  const server = await startServer();
  try {
    const body = JSON.stringify({
      id: 'webhook-replay',
      type: 'invoice.paid',
      timestamp: 1721574001,
      data: { invoiceId: 'inv_456' },
    });
    const signature = webhookSignature(body);
    await post(server, '/webhook', body, signature);
    const response = await post(server, '/webhook', body, signature);
    assert.strictEqual(response.status, 409);
    assert.deepStrictEqual(response.body, { error: 'duplicate_event', id: 'webhook-replay' });
  } finally {
    server.close();
  }
});

test('POST /webhook rejects a tampered signed body', async () => {
  const server = await startServer();
  try {
    const signedBody = JSON.stringify({
      id: 'webhook-tampered',
      type: 'invoice.paid',
      timestamp: 1721574002,
      data: { invoiceId: 'inv_789' },
    });
    const tamperedBody = JSON.stringify({
      id: 'webhook-tampered',
      type: 'invoice.refunded',
      timestamp: 1721574002,
      data: { invoiceId: 'inv_789' },
    });
    const response = await post(server, '/webhook', tamperedBody, webhookSignature(signedBody));
    assert.strictEqual(response.status, 401);
    assert.deepStrictEqual(response.body, { error: 'invalid_signature' });
  } finally {
    server.close();
  }
});

