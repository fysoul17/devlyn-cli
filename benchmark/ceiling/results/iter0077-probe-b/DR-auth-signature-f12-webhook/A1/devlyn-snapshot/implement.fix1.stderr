codex
Loopback is also denied (`127.0.0.1` returns the same `EPERM`), so the suite’s socket-based tests cannot run in this environment. I’m checking the two repaired paths by dispatching real Express request streams in-process; this still exercises the JSON middleware, raw-body capture, and error middleware.
exec
/bin/zsh -lc "node <<'NODE'
const assert = require('node:assert');
const crypto = require('node:crypto');
const fs = require('node:fs');
const path = require('node:path');
const { Readable } = require('node:stream');
const { app } = require('./server');
const secret = fs.readFileSync(path.join(__dirname, 'data', 'webhook-secret.txt'));

function dispatch(body, signature) {
  return new Promise((resolve, reject) => {
    const req = new Readable({
      read() {
        this.push(body);
        this.push(null);
      },
    });
    req.method = 'POST';
    req.url = '/webhook';
    req.headers = {
      'content-type': 'application/json',
      'content-length': String(Buffer.byteLength(body)),
      'x-signature': signature,
    };

    const headers = new Map();
    const res = {
      statusCode: 200,
      setHeader(name, value) { headers.set(name.toLowerCase(), value); },
      getHeader(name) { return headers.get(name.toLowerCase()); },
      removeHeader(name) { headers.delete(name.toLowerCase()); },
      end(chunk) { resolve({ status: this.statusCode, body: JSON.parse(chunk) }); },
    };

    app.handle(req, res, reject);
  });
}

(async () => {
  const invalid = await dispatch('null', '0'.repeat(64));
  assert.deepStrictEqual(invalid, { status: 401, body: { error: 'invalid_signature' } });
  const body = 'null';
  const signature = crypto.createHmac('sha256', secret).update(body).digest('hex');
  const valid = await dispatch(body, signature);
  assert.deepStrictEqual(valid, { status: 400, body: { error: 'invalid_body' } });
  console.log('in-process webhook parse-error checks passed');
})().catch((err) => { console.error(err); process.exitCode = 1; });
