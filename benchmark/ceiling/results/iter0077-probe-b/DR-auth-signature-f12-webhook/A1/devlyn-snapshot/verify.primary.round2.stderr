     1	// Tiny Express server with a deliberately small API surface.
     2	const crypto = require('crypto');
     3	const express = require('express');
     4	const fs = require('fs');
     5	const path = require('path');
     6	
     7	const app = express();
     8	const webhookSecret = fs.readFileSync(path.join(__dirname, '..', 'data', 'webhook-secret.txt'));
     9	const acceptedWebhookIds = new Set();
    10	
    11	app.use(express.json({ verify: (req, _res, buf) => { req.rawBody = buf; } }));
    12	
    13	function hasValidWebhookSignature(req) {
    14	  const signature = req.get('X-Signature');
    15	  const expectedSignature = crypto
    16	    .createHmac('sha256', webhookSecret)
    17	    .update(req.rawBody)
    18	    .digest('hex');
    19	
    20	  return (
    21	    typeof signature === 'string' &&
    22	    /^[0-9a-f]{64}$/i.test(signature) &&
    23	    crypto.timingSafeEqual(Buffer.from(expectedSignature, 'hex'), Buffer.from(signature, 'hex'))
    24	  );
    25	}
    26	
