index 1c43fa2..3da6ea9 100644
--- a/server/index.js
+++ b/server/index.js
@@ -1,8 +1,28 @@
 // Tiny Express server with a deliberately small API surface.
+const crypto = require('crypto');
 const express = require('express');
+const fs = require('fs');
+const path = require('path');
 
 const app = express();
-app.use(express.json());
+const webhookSecret = fs.readFileSync(path.join(__dirname, '..', 'data', 'webhook-secret.txt'));
+const acceptedWebhookIds = new Set();
+
+app.use(express.json({ verify: (req, _res, buf) => { req.rawBody = buf; } }));
+
+function hasValidWebhookSignature(req) {
+  const signature = req.get('X-Signature');
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(req.rawBody)
+    .digest('hex');
+
+  return (
+    typeof signature === 'string' &&
+    /^[0-9a-f]{64}$/i.test(signature) &&
+    crypto.timingSafeEqual(Buffer.from(expectedSignature, 'hex'), Buffer.from(signature, 'hex'))
+  );
+}
 
 const items = [
   { id: 1, name: 'alpha', qty: 3 },
@@ -27,6 +47,58 @@ app.get('/items/:id', (req, res) => {
   res.json({ item });
 });
 
+app.post('/webhook', (req, res) => {
+  if (!hasValidWebhookSignature(req)) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  const id = req.body && req.body.id;
+  if (acceptedWebhookIds.has(id)) {
+    res.status(409).json({ error: 'duplicate_event', id });
+    return;
+  }
+
+  if (
+    !req.body ||
+    typeof req.body !== 'object' ||
+    Array.isArray(req.body) ||
+    typeof req.body.id !== 'string' ||
+    req.body.id.length === 0 ||
+    typeof req.body.type !== 'string' ||
+    req.body.type.length === 0 ||
+    typeof req.body.timestamp !== 'number' ||
+    !req.body.data ||
+    typeof req.body.data !== 'object' ||
+    Array.isArray(req.body.data)
+  ) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedWebhookIds.add(id);
+  res.json({ accepted: true, id });
+});
+
+app.use((err, req, res, next) => {
+  const isWebhookJsonParseError =
+    req.path === '/webhook' &&
+    (err.type === 'entity.parse.failed' ||
+      (err instanceof SyntaxError && (err.status === 400 || err.statusCode === 400)));
+
+  if (!isWebhookJsonParseError) {
+    next(err);
+    return;
+  }
+
+  if (!hasValidWebhookSignature(req)) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  res.status(400).json({ error: 'invalid_body' });
+});
+
