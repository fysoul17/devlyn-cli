+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  try {
+    const body = JSON.stringify({
+      id: 'webhook-happy-path',
+      type: 'invoice.paid',
+      timestamp: 1721574000,
+      data: { invoiceId: 'inv_123' },
+    });
+    const response = await post(server, '/webhook', body, webhookSignature(body));
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: 'webhook-happy-path' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed signed event', async () => {
+  const server = await startServer();
+  try {
+    const body = JSON.stringify({
+      id: 'webhook-replay',
+      type: 'invoice.paid',
+      timestamp: 1721574001,
+      data: { invoiceId: 'inv_456' },
+    });
+    const signature = webhookSignature(body);
+    await post(server, '/webhook', body, signature);
+    const response = await post(server, '/webhook', body, signature);
+    assert.strictEqual(response.status, 409);
+    assert.deepStrictEqual(response.body, { error: 'duplicate_event', id: 'webhook-replay' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a tampered signed body', async () => {
+  const server = await startServer();
+  try {
+    const signedBody = JSON.stringify({
+      id: 'webhook-tampered',
+      type: 'invoice.paid',
+      timestamp: 1721574002,
+      data: { invoiceId: 'inv_789' },
+    });
+    const tamperedBody = JSON.stringify({
+      id: 'webhook-tampered',
+      type: 'invoice.refunded',
+      timestamp: 1721574002,
+      data: { invoiceId: 'inv_789' },
+    });
+    const response = await post(server, '/webhook', tamperedBody, webhookSignature(signedBody));
+    assert.strictEqual(response.status, 401);
+    assert.deepStrictEqual(response.body, { error: 'invalid_signature' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook verifies malformed JSON before rejecting its body', async () => {
+  const server = await startServer();
+  try {
+    const response = await post(server, '/webhook', 'null', '0'.repeat(64));
+    assert.strictEqual(response.status, 401);
+    assert.deepStrictEqual(response.body, { error: 'invalid_signature' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook returns invalid_body for validly signed malformed JSON', async () => {
+  const server = await startServer();
+  try {
+    const body = 'null';
+    const response = await post(server, '/webhook', body, webhookSignature(body));
+    assert.strictEqual(response.status, 400);
+    assert.deepStrictEqual(response.body, { error: 'invalid_body' });
+  } finally {
+    server.close();
+  }
+});
