    52	    res.status(401).json({ error: 'invalid_signature' });
    53	    return;
    54	  }
    55	
    56	  const id = req.body && req.body.id;
    57	  if (acceptedWebhookIds.has(id)) {
    58	    res.status(409).json({ error: 'duplicate_event', id });
    59	    return;
    60	  }
    61	
    62	  if (
    63	    !req.body ||
    64	    typeof req.body !== 'object' ||
    65	    Array.isArray(req.body) ||
