diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..79c1a7c 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,21 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON format', () => {
+  const version = require('../package.json').version;
+  const out = run(['version', '--format', 'json']);
+  assert.equal(out, `${JSON.stringify({ version })}\n`);
+});
+
+test('version rejects unsupported format', () => {
+  assert.throws(
+    () => run(['version', '--format', 'yaml']),
+    (error) => {
+      assert.equal(error.status, 1);
+      assert.equal(error.stdout, '');
+      assert.equal(error.stderr, 'Unsupported format: yaml\n');
+      return true;
+    }
+  );
+});
