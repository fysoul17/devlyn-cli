+        id: 'room-b',
+        windows: [{ start: '09:00', end: '11:00' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'low', resource: 'room-a', start: '09:00', duration_min: 90, priority: 1, submitted_at: '2026-01-01T08:00:00Z',
+      },
+      {
+        id: 'high', resource: 'room-a', start: '09:30', duration_min: 30, priority: 2, submitted_at: '2026-01-01T08:30:00Z',
+      },
+      {
+        id: 'other', resource: 'room-b', start: '09:00', duration_min: 30, priority: 1, submitted_at: '2026-01-01T07:00:00Z',
