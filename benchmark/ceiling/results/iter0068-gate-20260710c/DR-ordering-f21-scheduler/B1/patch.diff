 }
 
+function parseTime(value) {
+  if (typeof value !== 'string' || !TIME_PATTERN.test(value)) return null;
+  const [hour, minute] = value.split(':').map(Number);
+  return hour * 60 + minute;
+}
+
+function formatTime(value) {
+  const hour = Math.floor(value / 60);
+  const minute = value % 60;
+  return `${String(hour).padStart(2, '0')}:${String(minute).padStart(2, '0')}`;
+}
+
+function compareText(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function isObject(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function parseRange(value) {
+  if (!isObject(value)) return null;
+  const start = parseTime(value.start);
+  const end = parseTime(value.end);
+  if (start === null || end === null || start >= end) return null;
+  return { start, end };
+}
+
+function normalizeScheduleInput(input) {
+  if (!isObject(input) || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    return null;
+  }
+
+  const resourceIds = new Set();
+  const resources = [];
+  for (const resource of input.resources) {
+    if (!isObject(resource)
+      || typeof resource.id !== 'string'
+      || resource.id.length === 0
+      || resourceIds.has(resource.id)
+      || !Array.isArray(resource.windows)
+      || !Array.isArray(resource.blocked)) {
+      return null;
+    }
+
+    const windows = resource.windows.map(parseRange);
+    const blocked = resource.blocked.map(parseRange);
+    if (windows.includes(null) || blocked.includes(null)) return null;
+
+    resourceIds.add(resource.id);
+    resources.push({
+      id: resource.id,
+      windows: windows.sort((left, right) => left.start - right.start || left.end - right.end),
+      busy: blocked,
+    });
+  }
+
+  const requestIds = new Set();
+  const requests = [];
+  for (let index = 0; index < input.requests.length; index += 1) {
+    const request = input.requests[index];
+    if (!isObject(request)
+      || typeof request.id !== 'string'
+      || request.id.length === 0
+      || requestIds.has(request.id)
+      || typeof request.resource !== 'string'
+      || typeof request.priority !== 'number'
+      || !Number.isFinite(request.priority)
+      || typeof request.submitted_at !== 'string'
+      || request.submitted_at.length === 0
+      || !Number.isInteger(request.duration_min)
+      || request.duration_min <= 0) {
+      return null;
+    }
+
+    const start = parseTime(request.start);
+    if (start === null) return null;
+
+    requestIds.add(request.id);
+    requests.push({
+      id: request.id,
+      resource: request.resource,
+      start,
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt: request.submitted_at,
+      inputIndex: index,
+    });
+  }
+
+  return { resources, requests };
+}
+
+function findEarliestSlot(resource, request) {
+  const busy = resource.busy.slice().sort((left, right) => left.start - right.start || left.end - right.end);
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(window.start, request.start);
+    if (candidate + request.duration > window.end) continue;
+
+    for (const interval of busy) {
+      if (interval.end <= candidate) continue;
+      if (interval.start >= candidate + request.duration) break;
+
+      candidate = interval.end;
+      if (candidate + request.duration > window.end) break;
+    }
+
+    if (candidate + request.duration <= window.end) return candidate;
+  }
+
+  return null;
+}
+
+function scheduleRequests(input) {
+  const resources = new Map(input.resources.map((resource) => [resource.id, resource]));
+  const processingOrder = input.requests.slice().sort((left, right) => {
+    if (left.priority !== right.priority) return left.priority > right.priority ? -1 : 1;
+    if (left.submittedAt !== right.submittedAt) return compareText(left.submittedAt, right.submittedAt);
+    return compareText(left.id, right.id);
+  });
+  const scheduled = [];
+  const rejected = [];
+
+  for (const request of processingOrder) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const start = findEarliestSlot(resource, request);
+    if (start === null) {
+      rejected.push({ id: request.id, reason: 'no_slot', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.busy.push({ start, end });
+    scheduled.push({
+      id: request.id,
+      resource: request.resource,
+      start: formatTime(start),
+      end: formatTime(end),
+      startValue: start,
+    });
+  }
+
+  scheduled.sort((left, right) => left.startValue - right.startValue
+    || compareText(left.resource, right.resource)
+    || compareText(left.id, right.id));
+  rejected.sort((left, right) => left.inputIndex - right.inputIndex);
+
+  return {
+    scheduled: scheduled.map(({ id, resource, start, end }) => ({ id, resource, start, end })),
+    rejected: rejected.map(({ id, reason }) => ({ id, reason })),
+  };
+}
+
+function writeScheduleError(error) {
+  process.stderr.write(`${JSON.stringify({ error })}\n`);
+  process.exitCode = 2;
+}
+
+function runSchedule(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    writeScheduleError('invalid_arguments');
+    return;
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(argv[1], 'utf8');
+  } catch (error) {
+    writeScheduleError('file_read_failed');
+    return;
+  }
+
+  let parsed;
+  try {
+    parsed = JSON.parse(raw);
+  } catch (error) {
+    writeScheduleError('invalid_input');
+    return;
+  }
+
+  const input = normalizeScheduleInput(parsed);
+  if (!input) {
+    writeScheduleError('invalid_input');
+    return;
+  }
+
+  process.stdout.write(`${JSON.stringify(scheduleRequests(input))}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
