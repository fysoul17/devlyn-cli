index 78fdd98..e9c6b5c 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -35,6 +35,164 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^(?:[01]\d|2[0-3]):[0-5]\d$/.test(value)) return null;
+  const [hours, minutes] = value.split(':').map(Number);
+  return hours * 60 + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = String(Math.floor(minutes / 60)).padStart(2, '0');
+  const remainder = String(minutes % 60).padStart(2, '0');
+  return `${hours}:${remainder}`;
+}
+
+function compareText(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function parseRanges(ranges) {
+  if (!Array.isArray(ranges)) return null;
+  const parsed = [];
+
+  for (const range of ranges) {
+    if (!Array.isArray(range) || range.length !== 2) return null;
+    const start = parseTime(range[0]);
+    const end = parseTime(range[1]);
+    if (start === null || end === null || start >= end) return null;
+    parsed.push({ start, end });
+  }
+
+  return parsed;
+}
+
+function parseScheduleData(data) {
+  if (!data || typeof data !== 'object' || Array.isArray(data)
+      || !Array.isArray(data.resources) || !Array.isArray(data.requests)) {
+    return { error: 'Input must contain resources and requests arrays' };
+  }
+
+  const resources = new Map();
+  for (const resource of data.resources) {
+    if (!resource || typeof resource !== 'object' || Array.isArray(resource)
+        || typeof resource.id !== 'string') {
+      return { error: 'Invalid resource' };
+    }
+    const windows = parseRanges(resource.windows);
+    const blocked = parseRanges(resource.blocked);
+    if (windows === null || blocked === null) return { error: 'Invalid resource ranges' };
+    windows.sort((left, right) => left.start - right.start || left.end - right.end);
+    resources.set(resource.id, { windows, blocked, accepted: [] });
+  }
+
+  const requestIds = new Set();
+  const requests = [];
+  for (const request of data.requests) {
+    if (!request || typeof request !== 'object' || Array.isArray(request)
+        || typeof request.id !== 'string' || typeof request.resource !== 'string'
+        || typeof request.priority !== 'number' || !Number.isFinite(request.priority)
+        || typeof request.submitted_at !== 'string'
+        || !Number.isInteger(request.duration_min) || request.duration_min <= 0) {
+      return { error: 'Invalid request' };
+    }
+    const start = parseTime(request.start);
+    if (start === null) return { error: 'Invalid request time' };
+    if (requestIds.has(request.id)) return { error: 'Duplicate request ID' };
+    requestIds.add(request.id);
+    requests.push({ ...request, startMinute: start });
+  }
+
+  return { resources, requests };
+}
+
+function readScheduleInput(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    return { error: 'schedule requires --input <path>' };
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(argv[1], 'utf8');
+  } catch (error) {
+    return { error: `Unable to read input: ${error.message}` };
+  }
+
+  let data;
+  try {
+    data = JSON.parse(raw);
+  } catch (error) {
+    return { error: `Invalid JSON: ${error.message}` };
+  }
+
+  return parseScheduleData(data);
+}
+
+function overlaps(intervals, start, end) {
+  return intervals.some((interval) => start < interval.end && end > interval.start);
+}
+
+function findStart(resource, requestedStart, duration) {
+  for (const window of resource.windows) {
+    const firstMinute = Math.max(window.start, requestedStart);
+    for (let start = firstMinute; start + duration <= window.end; start += 1) {
+      const end = start + duration;
+      if (!overlaps(resource.blocked, start, end)
+          && !overlaps(resource.accepted, start, end)) {
+        return start;
+      }
+    }
+  }
+  return null;
+}
+
+function schedule(data) {
+  const ordered = [...data.requests].sort((left, right) => (
+    right.priority - left.priority
+    || compareText(left.submitted_at, right.submitted_at)
+    || compareText(left.id, right.id)
+  ));
+  const scheduled = [];
+  const rejectedById = new Map();
+
+  for (const request of ordered) {
+    const resource = data.resources.get(request.resource);
+    if (!resource) {
+      rejectedById.set(request.id, 'unknown_resource');
+      continue;
+    }
+
+    const start = findStart(resource, request.startMinute, request.duration_min);
+    if (start === null) {
+      rejectedById.set(request.id, 'no_slot');
+      continue;
+    }
+
+    const end = start + request.duration_min;
+    resource.accepted.push({ start, end });
+    scheduled.push({ id: request.id, resource: request.resource, start, end });
+  }
+
+  scheduled.sort((left, right) => (
+    left.start - right.start
+    || compareText(left.resource, right.resource)
+    || compareText(left.id, right.id)
+  ));
+
+  return {
+    scheduled: scheduled.map((row) => ({
+      id: row.id,
+      resource: row.resource,
+      start: formatTime(row.start),
+      end: formatTime(row.end),
+    })),
+    rejected: data.requests
+      .filter((request) => rejectedById.has(request.id))
+      .map((request) => ({ id: request.id, reason: rejectedById.get(request.id) })),
+  };
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +211,16 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'schedule': {
+      const input = readScheduleInput(rest);
+      if (input.error) {
+        process.stderr.write(`${JSON.stringify({ error: input.error })}\n`);
+        process.exitCode = 2;
+        return;
+      }
+      process.stdout.write(`${JSON.stringify(schedule(input))}\n`);
+      return;
+    }
     default:
