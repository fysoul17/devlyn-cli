+
+test('schedule processes globally and emits exact ordered row shapes', () => {
+  const input = {
+    resources: [
+      { id: 'beta', windows: [['09:00', '10:00']], blocked: [] },
+      { id: 'alpha', windows: [['09:00', '12:00']], blocked: [] },
+    ],
+    requests: [
+      { id: 'low', resource: 'alpha', start: '09:00', duration_min: 30, priority: 1, submitted_at: '2026-01-01T07:00:00Z' },
+      { id: 'id-b', resource: 'alpha', start: '09:00', duration_min: 30, priority: 5, submitted_at: '2026-01-01T08:00:00Z' },
+      { id: 'beta-top', resource: 'beta', start: '09:00', duration_min: 30, priority: 9, submitted_at: '2026-01-01T09:00:00Z' },
+      { id: 'id-a', resource: 'alpha', start: '09:00', duration_min: 30, priority: 5, submitted_at: '2026-01-01T08:00:00Z' },
+      { id: 'submitted-first', resource: 'alpha', start: '09:00', duration_min: 30, priority: 5, submitted_at: '2026-01-01T06:00:00Z' },
+    ],
+  };
+
+  withInput(input, (inputPath) => {
+    const result = runResult(['schedule', '--input', inputPath]);
+    assert.equal(result.status, 0);
+    assert.equal(result.stderr, '');
+    const output = JSON.parse(result.stdout);
+    assert.deepStrictEqual(Object.keys(output), ['scheduled', 'rejected']);
+    assert.deepStrictEqual(output, {
+      scheduled: [
+        { id: 'submitted-first', resource: 'alpha', start: '09:00', end: '09:30' },
+        { id: 'beta-top', resource: 'beta', start: '09:00', end: '09:30' },
+        { id: 'id-a', resource: 'alpha', start: '09:30', end: '10:00' },
+        { id: 'id-b', resource: 'alpha', start: '10:00', end: '10:30' },
+        { id: 'low', resource: 'alpha', start: '10:30', end: '11:00' },
+      ],
+      rejected: [],
+    });
+    assert.equal(result.stdout, `${JSON.stringify(output)}\n`);
+  });
+});
+
+test('schedule honors half-open boundaries and preserves rejection input order', () => {
+  const input = {
+    resources: [
+      { id: 'exact', windows: [['09:00', '10:00']], blocked: [] },
+      { id: 'blocked', windows: [['09:00', '10:00']], blocked: [['09:30', '09:31']] },
+      { id: 'tight', windows: [['09:00', '10:00']], blocked: [['09:30', '09:31']] },
+    ],
+    requests: [
+      { id: 'unknown-first', resource: 'missing', start: '09:00', duration_min: 1, priority: 1, submitted_at: 'd' },
+      { id: 'no-slot-second', resource: 'tight', start: '09:29', duration_min: 30, priority: 9, submitted_at: 'a' },
+      { id: 'ends-at-window', resource: 'exact', start: '09:00', duration_min: 60, priority: 5, submitted_at: 'b' },
+      { id: 'skips-one-minute', resource: 'blocked', start: '09:29', duration_min: 2, priority: 4, submitted_at: 'c' },
+    ],
+  };
+
+  withInput(input, (inputPath) => {
+    const result = runResult(['schedule', '--input', inputPath]);
+    assert.equal(result.status, 0);
+    assert.equal(result.stderr, '');
+    const output = JSON.parse(result.stdout);
+    assert.deepStrictEqual(output, {
+      scheduled: [
+        { id: 'ends-at-window', resource: 'exact', start: '09:00', end: '10:00' },
+        { id: 'skips-one-minute', resource: 'blocked', start: '09:31', end: '09:33' },
+      ],
+      rejected: [
+        { id: 'unknown-first', reason: 'unknown_resource' },
+        { id: 'no-slot-second', reason: 'no_slot' },
+      ],
+    });
+  });
+});
+
+test('schedule rejects malformed input on stderr with exit 2', () => {
+  const resource = { id: 'room', windows: [['09:00', '10:00']], blocked: [] };
+  const request = {
+    id: 'request',
+    resource: 'room',
+    start: '09:00',
+    duration_min: 15,
+    priority: 1,
+    submitted_at: 'submitted',
+  };
+  const cases = [
+    ['malformed top level', { resources: [resource] }],
+    ['duplicate request IDs', { resources: [resource], requests: [request, { ...request }] }],
+    ['invalid time', { resources: [{ ...resource, windows: [['09:60', '10:00']] }], requests: [request] }],
+    ['nonpositive duration', { resources: [resource], requests: [{ ...request, duration_min: 0 }] }],
+    ['noninteger duration', { resources: [resource], requests: [{ ...request, duration_min: 1.5 }] }],
+  ];
+
+  for (const [name, input] of cases) {
+    withInput(input, (inputPath) => {
+      assertInvalid(runResult(['schedule', '--input', inputPath]), name);
+    });
+  }
+});
+
+test('schedule reports file-read and missing-input failures on stderr with exit 2', () => {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-missing-'));
+
+  try {
+    assertInvalid(runResult(['schedule', '--input', path.join(directory, 'missing.json')]));
+    assertInvalid(runResult(['schedule']));
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+});
