diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..5865b21 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
-const { execFileSync } = require('node:child_process');
+const { execFileSync, spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,33 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function runResult(args) {
+  return spawnSync('node', [CLI, ...args], { encoding: 'utf8' });
+}
+
+function withInput(input, callback) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  const inputPath = path.join(directory, 'input.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+
+  try {
+    return callback(inputPath);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
+function assertInvalid(result) {
+  assert.equal(result.status, 2);
+  assert.equal(result.signal, null);
+  assert.equal(result.stdout, '');
+  const error = JSON.parse(result.stderr);
+  assert.deepStrictEqual(Object.keys(error), ['error']);
+  assert.equal(typeof error.error, 'string');
+  assert.notEqual(error.error, '');
+  assert.equal(result.stderr, `${JSON.stringify(error)}\n`);
+}
+
 test('hello default', () => {
