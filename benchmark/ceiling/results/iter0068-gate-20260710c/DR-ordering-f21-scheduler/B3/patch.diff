 `;
 
+const TIME_PATTERN = /^(?:[01]\d|2[0-3]):[0-5]\d$/;
+
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
@@ -35,6 +39,152 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function minutes(value) {
+  if (typeof value !== 'string' || !TIME_PATTERN.test(value)) return null;
+  const [hour, minute] = value.split(':').map(Number);
+  return hour * 60 + minute;
+}
+
+function clock(value) {
+  const hour = String(Math.floor(value / 60)).padStart(2, '0');
+  const minute = String(value % 60).padStart(2, '0');
+  return `${hour}:${minute}`;
+}
+
+function isObject(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function parseRange(value) {
+  if (!isObject(value)) return null;
+  const start = minutes(value.start);
+  const end = minutes(value.end);
+  return start !== null && end !== null && start < end ? { start, end } : null;
+}
+
+function parseScheduleInput(value) {
+  if (!isObject(value) || !Array.isArray(value.resources) || !Array.isArray(value.requests)) {
+    return null;
+  }
+
+  const resources = new Map();
+  for (const resource of value.resources) {
+    if (!isObject(resource) || typeof resource.id !== 'string' || resource.id.length === 0 ||
+        !Array.isArray(resource.windows) || !Array.isArray(resource.blocked) || resources.has(resource.id)) {
+      return null;
+    }
+    const windows = resource.windows.map(parseRange);
+    const blocked = resource.blocked.map(parseRange);
+    if (windows.includes(null) || blocked.includes(null)) return null;
+    resources.set(resource.id, { windows, occupied: blocked });
+  }
+
+  const requestIds = new Set();
+  const requests = [];
+  for (let index = 0; index < value.requests.length; index += 1) {
+    const request = value.requests[index];
+    if (!isObject(request) || typeof request.id !== 'string' || request.id.length === 0 ||
+        typeof request.resource !== 'string' || request.resource.length === 0 ||
+        !Number.isInteger(request.duration_min) || request.duration_min <= 0 ||
+        typeof request.priority !== 'number' || !Number.isFinite(request.priority) ||
+        requestIds.has(request.id)) {
+      return null;
+    }
+    const start = minutes(request.start);
+    const submittedAt = minutes(request.submitted_at);
+    if (start === null || submittedAt === null) return null;
+    requestIds.add(request.id);
+    requests.push({ ...request, index, startMinutes: start, submittedAtMinutes: submittedAt });
+  }
+
+  return { resources, requests };
+}
+
+function firstFit(resource, request) {
+  let earliest = null;
+  for (const window of resource.windows) {
+    let candidate = Math.max(request.startMinutes, window.start);
+    while (candidate + request.duration_min <= window.end) {
+      let next = candidate;
+      for (const interval of resource.occupied) {
+        if (candidate < interval.end && interval.start < candidate + request.duration_min) {
+          next = Math.max(next, interval.end);
+        }
+      }
+      if (next === candidate) break;
+      candidate = next;
+    }
+    if (candidate + request.duration_min <= window.end && (earliest === null || candidate < earliest)) {
+      earliest = candidate;
+    }
+  }
+  return earliest;
+}
+
+function schedule(input) {
+  const ordered = [...input.requests].sort((left, right) => {
+    if (left.priority !== right.priority) return left.priority > right.priority ? -1 : 1;
+    if (left.submittedAtMinutes !== right.submittedAtMinutes) {
+      return left.submittedAtMinutes - right.submittedAtMinutes;
+    }
+    return left.id < right.id ? -1 : left.id > right.id ? 1 : 0;
+  });
+  const scheduled = [];
+  const rejectedByIndex = new Map();
+
+  for (const request of ordered) {
+    const resource = input.resources.get(request.resource);
+    if (!resource) {
+      rejectedByIndex.set(request.index, 'unknown_resource');
+      continue;
+    }
+    const start = firstFit(resource, request);
+    if (start === null) {
+      rejectedByIndex.set(request.index, 'no_slot');
+      continue;
+    }
+    const end = start + request.duration_min;
+    resource.occupied.push({ start, end });
+    scheduled.push({ id: request.id, resource: request.resource, start: clock(start), end: clock(end) });
+  }
+
+  scheduled.sort((left, right) => {
+    const byStart = minutes(left.start) - minutes(right.start);
+    if (byStart !== 0) return byStart;
+    if (left.resource !== right.resource) return left.resource < right.resource ? -1 : 1;
+    return left.id < right.id ? -1 : left.id > right.id ? 1 : 0;
+  });
+  const rejected = input.requests
+    .filter((request) => rejectedByIndex.has(request.index))
+    .map((request) => ({ id: request.id, reason: rejectedByIndex.get(request.index) }));
+  return { scheduled, rejected };
+}
+
+function scheduleError() {
+  process.stderr.write(`${JSON.stringify({ error: 'invalid_input' })}\n`);
+  process.exitCode = 2;
+}
+
+function runSchedule(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1] || argv[1].startsWith('-')) {
+    scheduleError();
+    return;
+  }
+  let value;
+  try {
+    value = JSON.parse(fs.readFileSync(argv[1], 'utf8'));
+  } catch {
+    scheduleError();
+    return;
+  }
+  const input = parseScheduleInput(value);
+  if (!input) {
+    scheduleError();
+    return;
+  }
+  process.stdout.write(`${JSON.stringify(schedule(input))}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +203,10 @@ function main(argv) {
       console.log(readPackageVersion());
