 });
+
+test('schedule places a compound workload at each earliest half-open fit', () => {
+  withInput({
+    resources: [
+      {
+        id: 'room-a',
+        windows: [{ start: '10:00', end: '12:00' }, { start: '09:00', end: '11:00' }],
+        blocked: [{ start: '09:30', end: '10:00' }],
+      },
+      {
+        id: 'room-b',
+        windows: [{ start: '09:00', end: '10:00' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'low', resource: 'room-a', start: '09:00', duration_min: 60,
+        priority: 1, submitted_at: '08:00',
+      },
+      {
+        id: 'edge', resource: 'room-b', start: '09:45', duration_min: 15,
+        priority: 2, submitted_at: '08:00',
+      },
+      {
+        id: 'high', resource: 'room-a', start: '09:00', duration_min: 30,
+        priority: 10, submitted_at: '08:05',
+      },
+    ],
+  }, (inputPath) => {
+    const result = runResult(['schedule', '--input', inputPath]);
+    assert.strictEqual(result.status, 0);
+    assert.strictEqual(result.stderr, '');
+    const output = JSON.parse(result.stdout);
+    assert.deepStrictEqual(output, {
+      scheduled: [
+        { id: 'high', resource: 'room-a', start: '09:00', end: '09:30' },
+        { id: 'edge', resource: 'room-b', start: '09:45', end: '10:00' },
+        { id: 'low', resource: 'room-a', start: '10:00', end: '11:00' },
+      ],
+      rejected: [],
+    });
+    assert.deepStrictEqual(Object.keys(output.scheduled[0]), ['id', 'resource', 'start', 'end']);
+  });
+});
+
+test('schedule applies global priority and preserves input order for rejections', () => {
+  withInput({
+    resources: [{
+      id: 'only',
+      windows: [{ start: '09:00', end: '10:00' }],
+      blocked: [],
+    }],
+    requests: [
+      {
+        id: 'unknown', resource: 'missing', start: '09:00', duration_min: 15,
+        priority: 0, submitted_at: '08:00',
+      },
+      {
+        id: 'loser', resource: 'only', start: '09:00', duration_min: 60,
+        priority: 1, submitted_at: '08:00',
+      },
+      {
+        id: 'winner', resource: 'only', start: '09:00', duration_min: 60,
+        priority: 10, submitted_at: '08:30',
+      },
+    ],
+  }, (inputPath) => {
+    const result = runResult(['schedule', '--input', inputPath]);
+    assert.strictEqual(result.status, 0);
+    assert.strictEqual(result.stderr, '');
+    assert.deepStrictEqual(JSON.parse(result.stdout), {
+      scheduled: [{ id: 'winner', resource: 'only', start: '09:00', end: '10:00' }],
+      rejected: [
+        { id: 'unknown', reason: 'unknown_resource' },
+        { id: 'loser', reason: 'no_slot' },
+      ],
+    });
+  });
+});
+
+test('schedule failures use one deterministic stderr JSON object and exit 2', () => {
+  assertScheduleFailure(runResult(['schedule']));
+  assertScheduleFailure(runResult(['schedule', '--input', '/definitely/missing/schedule.json']));
+
+  withInput('{broken', (inputPath) => {
+    assertScheduleFailure(runResult(['schedule', '--input', inputPath]));
+  });
+
+  withInput({
+    resources: [{ id: 'r', windows: [{ start: '09:00', end: '10:00' }], blocked: [] }],
+    requests: [
+      {
+        id: 'duplicate', resource: 'r', start: '09:00', duration_min: 1,
+        priority: 1, submitted_at: '08:00',
+      },
+      {
+        id: 'duplicate', resource: 'r', start: '09:00', duration_min: 1,
+        priority: 1, submitted_at: '08:00',
+      },
+    ],
+  }, (inputPath) => {
+    const first = runResult(['schedule', '--input', inputPath]);
+    const second = runResult(['schedule', '--input', inputPath]);
+    assertScheduleFailure(first);
+    assertScheduleFailure(second);
+    assert.strictEqual(first.stderr, second.stderr);
+  });
+
+  withInput({
+    resources: [{ id: 'r', windows: [{ start: '09:00', end: '10:00' }], blocked: [] }],
+    requests: [{
+      id: 'bad-duration', resource: 'r', start: '09:00', duration_min: 0,
+      priority: 1, submitted_at: '08:00',
+    }],
+  }, (inputPath) => {
+    assertScheduleFailure(runResult(['schedule', '--input', inputPath]));
+  });
+});
