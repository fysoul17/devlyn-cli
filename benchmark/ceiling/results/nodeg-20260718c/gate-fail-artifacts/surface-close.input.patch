+
+test('version with --format json prints the package version as JSON', () => {
+  const out = run(['version', '--format', 'json']);
+  const expected = { version: require('../package.json').version };
+  assert.equal(out, `${JSON.stringify(expected)}\n`);
+  assert.deepEqual(JSON.parse(out), expected);
