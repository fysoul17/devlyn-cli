const { mkdtempSync, writeFileSync, rmSync } = require('node:fs');
const { tmpdir } = require('node:os');
const { join } = require('node:path');
const { spawnSync } = require('node:child_process');

const directory = mkdtempSync(join(tmpdir(), 'bench-cli-validation-'));
const cli = join(process.cwd(), 'bin', 'cli.js');
const cases = [
  ['invalid_json', '{'],
  ['missing_items', JSON.stringify({ state: 'CA', coupon: null })],
  ['unknown_sku', JSON.stringify({ state: 'CA', coupon: null, items: [{ sku: 'NOPE', qty: 1 }, { sku: 'TEE', qty: 0 }] })],
  ['invalid_qty', JSON.stringify({ state: 'CA', coupon: null, items: [{ sku: 'TEE', qty: 0 }] })],
  ['unknown_coupon', JSON.stringify({ state: 'CA', coupon: 'NOPE', items: [] })],
  ['unknown_state', JSON.stringify({ state: 'NOPE', coupon: null, items: [] })],
];

try {
  for (const [expected, content] of cases) {
    const inputPath = join(directory, "'`${expected}.json`);
    writeFileSync(inputPath, content);
    const result = spawnSync('"'node', [cli, 'cart', '--input', inputPath], { encoding: 'utf8' });
    const actual = JSON.parse(result.stderr).error;
    if (result.status "'!== 2 || result.stdout !== '"'' || actual "'!== expected) {
      throw new Error(`${expected}: ${JSON.stringify({ status: result.status, stdout: result.stdout, stderr: result.stderr })}`);
    }
  }
  console.log('"'VALIDATION_ORDER_OK');
} finally {
  rmSync(directory, { recursive: true, force: true });
}
