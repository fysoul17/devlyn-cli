     1	#!/usr/bin/env node
     2	// harbor-tools — small command-line utilities for local workflows.
     3	// Keep the core commands minimal and easy to understand.
     4	
     5	const fs = require('fs');
     6	const path = require('path');
     7	
     8	const USAGE = `Usage: bench-cli <command> [options]
     9	
    10	Commands:
    11	  hello [--name NAME]        Print a greeting (default name: "world")
    12	  version                    Print the CLI version from package.json
    13	  cart --input PATH          Price a cart JSON file
    14	  --help, -h                 Show this help
    15	
    16	Examples:
    17	  bench-cli hello
    18	  bench-cli hello --name alice
    19	  bench-cli version
    20	  bench-cli cart --input cart.json
    21	`;
    22	
    23	function readPackageVersion() {
    24	  const pkgPath = path.join(__dirname, '..', 'package.json');
    25	  const raw = fs.readFileSync(pkgPath, 'utf8');
    26	  return JSON.parse(raw).version;
    27	}
    28	
    29	function parseNameFlag(argv) {
    30	  const idx = argv.indexOf('--name');
    31	  if (idx === -1) return 'world';
    32	  const value = argv[idx + 1];
    33	  if (!value || value.startsWith('-')) {
    34	    console.error('--name requires a value');
    35	    process.exit(1);
    36	  }
    37	  return value;
    38	}
    39	
    40	function parseInputFlag(argv) {
    41	  const idx = argv.indexOf('--input');
    42	  if (idx === -1) {
    43	    console.error('--input requires a value');
    44	    process.exit(1);
    45	  }
    46	  const value = argv[idx + 1];
    47	  if (!value || value.startsWith('-')) {
    48	    console.error('--input requires a value');
    49	    process.exit(1);
    50	  }
    51	  return value;
    52	}
    53	
    54	function cartError(error) {
    55	  process.stderr.write(`${JSON.stringify(error)}\n`);
    56	  process.exit(2);
    57	}
    58	
    59	function readCart(inputPath) {
    60	  try {
    61	    return JSON.parse(fs.readFileSync(inputPath, 'utf8'));
    62	  } catch {
    63	    cartError({ error: 'invalid_json' });
    64	  }
    65	}
    66	
    67	function readCatalog() {
    68	  const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
    69	  return JSON.parse(fs.readFileSync(catalogPath, 'utf8'));
    70	}
    71	
    72	function hasOwn(object, key) {
    73	  return Object.prototype.hasOwnProperty.call(object, key);
    74	}
    75	
    76	function priceCart(cart, catalog) {
    77	  if (!cart || !Array.isArray(cart.items)) {
    78	    cartError({ error: 'missing_items' });
    79	  }
    80	
    81	  for (const item of cart.items) {
    82	    if (!hasOwn(catalog.products, item?.sku)) {
    83	      cartError({ error: 'unknown_sku', sku: item?.sku });
    84	    }
    85	  }
    86	
    87	  for (const item of cart.items) {
    88	    if (typeof item?.qty !== 'number' || !Number.isInteger(item.qty) || item.qty <= 0) {
    89	      cartError({ error: 'invalid_qty', sku: item?.sku });
    90	    }
    91	  }
    92	
    93	  if (cart.coupon !== null && !hasOwn(catalog.coupons, cart.coupon)) {
    94	    cartError({ error: 'unknown_coupon', coupon: cart.coupon });
    95	  }
    96	
    97	  if (!hasOwn(catalog.tax_rates, cart.state)) {
    98	    cartError({ error: 'unknown_state', state: cart.state });
    99	  }
   100	
   101	  const quantities = new Map();
   102	  for (const item of cart.items) {
   103	    quantities.set(item.sku, (quantities.get(item.sku) || 0) + item.qty);
   104	  }
   105	
   106	  for (const [sku, qty] of quantities) {
   107	    const available = catalog.products[sku].stock;
   108	    if (qty > available) {
   109	      cartError({ error: 'invalid_stock', sku, available, requested: qty });
   110	    }
   111	  }
   112	
   113	  const promotions = new Map();
   114	  for (const promotion of catalog.line_promotions) {
   115	    promotions.set(promotion.sku, promotion);
   116	  }
   117	
   118	  let subtotalCents = 0;
   119	  let lineDiscountCents = 0;
   120	  let taxablePostLineDiscountCents = 0;
   121	  const items = [];
   122	
   123	  for (const [sku, qty] of quantities) {
   124	    const product = catalog.products[sku];
   125	    const lineSubtotalCents = qty * product.unit_cents;
   126	    const promotion = promotions.get(sku);
   127	    let lineDiscount = 0;
   128	
   129	    if (promotion?.type === 'buy_x_get_y_free') {
   130	      lineDiscount = Math.floor(qty / (promotion.buy_qty + promotion.free_qty))
   131	        * promotion.free_qty * product.unit_cents;
   132	    } else if (promotion?.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
   133	      lineDiscount = promotion.per_unit_discount_cents * qty;
   134	    }
   135	
   136	    const lineTotalCents = lineSubtotalCents - lineDiscount;
   137	    subtotalCents += lineSubtotalCents;
   138	    lineDiscountCents += lineDiscount;
   139	    if (catalog.taxable_codes[product.tax_code] === true) {
   140	      taxablePostLineDiscountCents += lineTotalCents;
   141	    }
   142	    items.push({
   143	      sku,
   144	      qty,
   145	      line_subtotal_cents: lineSubtotalCents,
   146	      line_discount_cents: lineDiscount,
   147	      line_total_cents: lineTotalCents,
   148	    });
   149	  }
   150	
   151	  const coupon = cart.coupon === null ? null : catalog.coupons[cart.coupon];
   152	  const postLineDiscountCents = subtotalCents - lineDiscountCents;
   153	  const couponDiscountCents = coupon && postLineDiscountCents >= coupon.min_subtotal_cents
   154	    ? Math.round(postLineDiscountCents * coupon.percent / 100)
   155	    : 0;
   156	  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[cart.state]);
   157	  const shippingCents = postLineDiscountCents - couponDiscountCents >= catalog.free_shipping_min_cents
   158	    ? 0
   159	    : catalog.shipping_cents;
   160	
   161	  return {
   162	    subtotal_cents: subtotalCents,
   163	    line_discount_cents: lineDiscountCents,
   164	    coupon_discount_cents: couponDiscountCents,
   165	    tax_cents: taxCents,
   166	    shipping_cents: shippingCents,
   167	    total_cents: postLineDiscountCents - couponDiscountCents + taxCents + shippingCents,
   168	    items,
   169	  };
   170	}
   171	
   172	function main(argv) {
   173	  const [command, ...rest] = argv;
   174	
   175	  if (!command || command === '--help' || command === '-h') {
   176	    process.stdout.write(USAGE);
   177	    return;
   178	  }
   179	
   180	  switch (command) {
   181	    case 'hello': {
   182	      const name = parseNameFlag(rest);
   183	      console.log(`Hello, ${name}!`);
   184	      return;
   185	    }
   186	    case 'version': {
   187	      console.log(readPackageVersion());
   188	      return;
   189	    }
   190	    case 'cart': {
   191	      const inputPath = parseInputFlag(rest);
   192	      const cart = readCart(inputPath);
   193	      const catalog = readCatalog();
   194	      console.log(JSON.stringify(priceCart(cart, catalog)));
   195	      return;
   196	    }
   197	    default:
   198	      console.error(`Unknown command: ${command}`);
   199	      process.stderr.write(USAGE);
   200	      process.exit(1);
   201	  }
   202	}
   203	
   204	main(process.argv.slice(2));

