ut), {\n53\t    subtotal_cents: 13900,\n54\t    line_discount_cents: 3500,\n55\t    coupon_discount_cents: 1040,\n56\t    tax_cents: 858,\n57\t    shipping_cents: 0,\n58\t    total_cents: 10218,\n59\t    items: [\n60\t      {\n61\t        sku: 'TEE',\n62\t        qty: 3,\n63\t        line_subtotal_cents: 7500,\n64\t        line_discount_cents: 2500,\n65\t        line_total_cents: 5000,\n66\t      },\n67\t      {\n68\t        sku: 'BAG',\n69\t        qty: 2,\n70\t        line_subtotal_cents: 6400,\n71\t        line_discount_cents: 1000,\n72\t        line_total_cents: 5400,\n73\t      },\n74\t    ],\n75\t  });\n76\t});\n77\t\n78\ttest('cart reports combined quantities over stock as a JSON error', () => {\n79\t  const result = withCartFile({\n80\t    state: 'CA',\n81\t    coupon: null,\n82\t    items: [\n83\t      { sku: 'TEE', qty: 7 },\n84\t      { sku: 'TEE', qty: 5 },\n85\t    ],\n86\t  }, (inputPath) => spawnSync('node', [CLI, 'cart', '--input', inputPath], {\n87\t    encoding: 'utf8',\n88\t  }));\n89\t\n90\t  assert.strictEqual(result.status, 2);\n91\t  assert.strictEqual(result.stdout, '');\n92\t  assert.deepStrictEqual(JSON.parse(result.stderr), {\n93\t    error: 'invalid_stock',\n94\t    sku: 'TEE',\n95\t    available: 10,\n96\t    requested: 12,\n97\t  });\n98\t});\n99\t"}]},"uuid":"91275c65-f725-4c75-917f-b24089ec60cb","timestamp":"2026-07-21T05:43:59.421Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/aipalm/.local/share/nx01/w/r500c824c689b/f38c9cf695c9e/A1/repo/tests/cli.test.js","content":"const { test } = require('node:test');\nconst assert = require('node:assert');\nconst { execFileSync, spawnSync } = require('node:child_process');\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\n\nconst CLI = path.join(__dirname, '..', 'bin', 'cli.js');\n\nfunction run(args) {\n  return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });\n}\n\nfunction withCartFile(cart, callback) {\n  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));\n  const inputPath = path.join(directory, 'cart.json');\n  fs.writeFileSync(inputPath, JSON.stringify(cart));\n\n  try {\n    return callback(inputPath);\n  } finally {\n    fs.rmSync(directory, { recursive: true, force: true });\n  }\n}\n\ntest('hello default', () => {\n  const out = run(['hello']);\n  assert.match(out, /Hello, world!/);\n});\n\ntest('hello with --name', () => {\n  const out = run(['hello', '--name', 'alice']);\n  assert.match(out, /Hello, alice!/);\n});\n\ntest('version prints package version', () => {\n  const out = run(['version']);\n  assert.match(out, /\\d+\\.\\d+\\.\\d+/);\n});\n\ntest('cart combines duplicate items and applies pricing rules', () => {\n  const output = withCartFile({\n    state: 'CA',\n    coupon: 'ORDER10',\n    items: [\n      { sku: 'TEE', qty: 1 },\n      { sku: 'BAG', qty: 2 },\n      { sku: 'TEE', qty: 2 },\n    ],\n  }, (inputPath) => run(['cart', '--input', inputPath]));\n\n  assert.deepStrictEqual(JSON.parse(output), {\n    subtotal_cents: 13900,\n    line_discount_cents: 3500,\n    coupon_discount_cents: 1040,\n    tax_cents: 858,\n    shipping_cents: 0,\n    total_cents: 10218,\n    items: [\n      {\n        sku: 'TEE',\n        qty: 3,\n        line_subtotal_cents: 7500,\n        line_discount_cents: 2500,\n        line_total_cents: 5000,\n      },\n      {\n        sku: 'BAG',\n        qty: 2,\n        line_subtotal_cents: 6400,\n        line_discount_cents: 1000,\n        line_total_cents: 5400,\n      },\n    ],\n  });\n});\n\ntest('cart reports combined quantities over stock as a JSON error', () => {\n  const result = withCartFile({\n    state: 'CA',\n    coupon: null,\n    items: [\n      { sku: 'TEE', qty: 7 },\n      { sku: 'TEE', qty: 5 },\n    ],\n  }, (inputPath) => spawnSync('node', [CLI, 'cart', '--input', inputPath], {\n    encoding: 'utf8',\n  }));\n\n  assert.strictEqual(result.status, 2);\n  assert.strictEqual(result.stdout, '');\n  assert.deepStrictEqual(JSON.parse(result.stderr), {\n    error: 'invalid_stock',\n    sku: 'TEE',\n    available: 10,\n    requested: 12,\n  });\n});\n","numLines":99,"startLine":1,"totalLines":99}},"sourceToolAssistantUUID":"23a973e7-78b6-47be-8769-24aee0caf196","userType":"external","entrypoint":"sdk-cli","cwd":"/Users/aipalm/.local/share/nx01/w/r500c824c689b/f38c9cf695c9e/A1/repo","sessionId":"237dfa2d-2325-4dd1-b6ac-709286bc3e4d","version":"2.1.215","gitBranch":"master"}
