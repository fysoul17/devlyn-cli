+    def max_runs(self, n: int):
+        """
+        Schedule job to run at most ``n`` times.
+
+        :param n: Maximum number of times the job can run.
+        :return: The invoked job instance
+        """
+        if not isinstance(n, int) or n < 1:
+            raise ValueError("max_runs() requires an integer greater than or equal to 1")
+        self.run_limit = n
+        return self
+
     def do(self, job_func: Callable, *args, **kwargs):
         """
         Specifies the job_func that should be called every time the
@@ -689,10 +705,11 @@ class Job:

         logger.debug("Running job %s", self)
         ret = self.job_func()
+        self.run_count += 1
         self.last_run = datetime.datetime.now()
         self._schedule_next_run()

-        if self._is_overdue(self.next_run):
+        if self._is_overdue(self.next_run) or self._is_run_budget_exhausted():
             logger.debug("Cancelling job %s", self)
             return CancelJob
         return ret
@@ -819,6 +836,9 @@ class Job:
     def _is_overdue(self, when: datetime.datetime):
         return self.cancel_after is not None and when > self.cancel_after

+    def _is_run_budget_exhausted(self):
+        return self.run_limit is not None and self.run_count >= self.run_limit
