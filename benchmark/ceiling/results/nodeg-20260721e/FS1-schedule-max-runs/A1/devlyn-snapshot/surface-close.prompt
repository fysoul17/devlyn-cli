diff --git a/test_schedule.py b/test_schedule.py
index f497826..61db0a8 100644
--- a/test_schedule.py
+++ b/test_schedule.py
@@ -1522,6 +1522,116 @@ class SchedulerTests(TestCase):
         schedule.cancel_job(mj)
         assert len(schedule.jobs) == 0

+    def test_max_runs_is_chainable_before_do(self):
+        mock_job = make_mock_job()
+
+        first = every(5).seconds
+        assert first.max_runs(3) is first
+        first = first.do(mock_job)
+        second = every().max_runs(2).seconds.do(mock_job)
+
+        assert first.run_limit == 3
+        assert second.run_limit == 2
+
+    def test_max_runs_validates_its_argument(self):
+        for value in (0, -1, 1.5, "1", None):
+            with self.assertRaises(ValueError) as context:
+                every().max_runs(value)
+            assert type(context.exception) is ValueError
+
+    def test_max_runs_cancels_after_budgeted_run_all_executions(self):
+        mock_job = make_mock_job()
+        job = every().second.max_runs(3).do(mock_job)
+
+        schedule.run_all()
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert job in schedule.jobs
+
+        schedule.run_all()
+        assert mock_job.call_count == 3
+        assert job not in schedule.jobs
+
+        schedule.run_all()
+        assert mock_job.call_count == 3
+
+    def test_max_runs_cancels_after_budgeted_run_pending_executions(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            job = every().second.max_runs(2).do(mock_job)
+            with mock_datetime(2020, 1, 1, 11, 35, 11):
+                schedule.run_pending()
+            with mock_datetime(2020, 1, 1, 11, 35, 12):
+                schedule.run_pending()
+            with mock_datetime(2020, 1, 1, 11, 35, 13):
+                schedule.run_pending()
+
+        assert mock_job.call_count == 2
+        assert job not in schedule.jobs
+
+    def test_max_runs_last_call_wins(self):
+        mock_job = make_mock_job()
+        job = every().second.max_runs(1).max_runs(2).do(mock_job)
+
+        schedule.run_all()
+        assert job in schedule.jobs
+        schedule.run_all()
+
+        assert mock_job.call_count == 2
+        assert job not in schedule.jobs
+
+    def test_max_runs_and_until_cancel_at_the_first_limit(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            budget_first = (
+                every().second.max_runs(1).until(datetime.time(11, 35, 20)).do(mock_job)
+            )
+            schedule.run_all()
+
+        assert mock_job.call_count == 1
+        assert budget_first not in schedule.jobs
+
+        schedule.clear()
+        mock_job.reset_mock()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            deadline_first = (
+                every().second.max_runs(3).until(datetime.time(11, 35, 11)).do(mock_job)
+            )
+            schedule.run_all()
+            assert deadline_first in schedule.jobs
+            with mock_datetime(2020, 1, 1, 11, 35, 11):
+                schedule.run_all()
+
+        assert mock_job.call_count == 2
+        assert deadline_first not in schedule.jobs
+
+    def test_max_runs_budgets_are_per_job(self):
+        first_mock_job = make_mock_job("first")
+        second_mock_job = make_mock_job("second")
+        first = every().second.max_runs(1).do(first_mock_job)
+        second = every().second.max_runs(2).do(second_mock_job)
+
+        schedule.run_all()
+        assert first_mock_job.call_count == 1
+        assert second_mock_job.call_count == 1
+        assert first not in schedule.jobs
+        assert second in schedule.jobs
+
+        schedule.run_all()
+        assert second_mock_job.call_count == 2
+        assert second not in schedule.jobs
+
+    def test_max_runs_removal_updates_next_run_and_idle_seconds(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 12, 9, 21, 46):
+            every().hour.max_runs(1).do(mock_job)
+            assert schedule.next_run() == datetime.datetime(2020, 12, 9, 22, 46)
+            assert schedule.idle_seconds() == 60 * 60
+
+            schedule.run_all()
+            assert schedule.next_run() is None
+            assert schedule.idle_seconds() is None
+
