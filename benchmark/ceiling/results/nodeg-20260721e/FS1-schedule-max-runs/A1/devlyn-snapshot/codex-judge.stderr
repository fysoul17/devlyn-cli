         assert "job1" in jobs[0].tags
 
         # Test multiple jobs found.
         jobs = schedule.get_jobs("tag4")
         assert len(jobs) == 2
         assert "job1" not in {*jobs[0].tags, *jobs[1].tags}
 
         # Test no tag.
         jobs = schedule.get_jobs("tag5")
         assert len(jobs) == 0
         schedule.clear()
