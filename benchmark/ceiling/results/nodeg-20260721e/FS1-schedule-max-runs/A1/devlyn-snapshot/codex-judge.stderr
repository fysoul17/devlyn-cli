import json
import schedule

results = {}

accepted = schedule.Scheduler().every().max_runs(True)
results[\"bool_validation\"] = {
    \"returned_job\": isinstance(accepted, schedule.Job),
    \"stored_limit\": accepted.run_limit,
}

s = schedule.Scheduler()
calls = []
def flaky():
    calls.append(\"call\")
    if len(calls) == 1:
        raise RuntimeError(\"boom\")
job = s.every().second.max_runs(1).do(flaky)
try:
    s.run_all()
except RuntimeError:
    pass
first_state = {\"calls\": len(calls), \"run_count\": job.run_count, \"still_scheduled\": job in s.jobs}
s.run_all()
results[\"exception_path\"] = {
    \"after_first\": first_state,
    \"after_second\": {\"calls\": len(calls), \"run_count\": job.run_count, \"still_scheduled\": job in s.jobs},
}

s = schedule.Scheduler()
calls = []
def duplicate_fn():
    calls.append(\"call\")
job = s.every().second.max_runs(1)
job.do(duplicate_fn)
job.do(duplicate_fn)
s.run_all()
results[\"duplicate_registration\"] = {
    \"calls\": len(calls),
    \"run_count\": job.run_count,
    \"still_scheduled\": job in s.jobs,
}

print(json.dumps(results, sort_keys=True))
