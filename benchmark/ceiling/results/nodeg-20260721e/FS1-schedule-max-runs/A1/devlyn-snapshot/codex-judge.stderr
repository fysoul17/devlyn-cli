/bin/zsh -lc "PYTHONDONTWRITEBYTECODE=1 python3 -c '
import datetime
import json
import schedule

def record(bucket, name):
    return lambda: bucket.append(name)

results = {}

# First-limit-wins through run_pending(): budget first and deadline first.
now = datetime.datetime.now()
s = schedule.Scheduler()
calls = []
budget_pending = s.every().second.max_runs(1).until(now + datetime.timedelta(seconds=60)).do(record(calls, \"budget_pending\"))
deadline_pending = s.every().second.max_runs(3).until(now + datetime.timedelta(milliseconds=500)).do(record(calls, \"deadline_pending\"))
budget_pending.next_run = now - datetime.timedelta(seconds=1)
deadline_pending.next_run = now - datetime.timedelta(seconds=1)
s.run_pending()
results[\"pending_limits\"] = {
    \"calls\": calls,
    \"budget_removed\": budget_pending not in s.jobs,
    \"deadline_removed\": deadline_pending not in s.jobs,
    \"counts\": [budget_pending.run_count, deadline_pending.run_count],
}

# First-limit-wins through run_all(): budget first and deadline first.
now = datetime.datetime.now()
s = schedule.Scheduler()
calls = []
budget_all = s.every().second.max_runs(1).until(now + datetime.timedelta(seconds=60)).do(record(calls, \"budget_all\"))
deadline_all = s.every().second.max_runs(3).until(now + datetime.timedelta(milliseconds=500)).do(record(calls, \"deadline_all\"))
s.run_all()
results[\"all_limits\"] = {
    \"calls\": calls,
    \"budget_removed\": budget_all not in s.jobs,
    \"deadline_removed\": deadline_all not in s.jobs,
    \"counts\": [budget_all.run_count, deadline_all.run_count],
}

# Adversarial mixed jobs with alternating dispatch paths.
now = datetime.datetime.now()
s = schedule.Scheduler()
calls = []
a = s.every().second.max_runs(2).until(now + datetime.timedelta(seconds=60)).do(record(calls, \"a\"))
b = s.every().second.max_runs(4).until(now + datetime.timedelta(seconds=60)).do(record(calls, \"b\"))
s.run_all()
a.next_run = datetime.datetime.now() - datetime.timedelta(seconds=1)
b.next_run = datetime.datetime.now() - datetime.timedelta(seconds=1)
s.run_pending()
b.cancel_after = datetime.datetime.now() + datetime.timedelta(milliseconds=500)
s.run_all()
results[\"adversarial\"] = {
    \"calls\": calls,
    \"a_count\": a.run_count,
    \"b_count\": b.run_count,
    \"jobs_remaining\": len(s.jobs),
}

# Partial removal must leave next_run/idle_seconds tied to the survivor.
s = schedule.Scheduler()
gone = s.every().hour.max_runs(1).do(lambda: None)
survivor = s.every(2).hours.max_runs(3).do(lambda: None)
s.run_all()
results[\"partial_removal\"] = {
    \"gone_removed\": gone not in s.jobs,
    \"survivor_present\": survivor in s.jobs,
    \"next_is_survivor\": s.next_run == survivor.next_run,
    \"idle_is_number\": isinstance(s.idle_seconds, float),
}

# Last call wins in the reverse overwrite direction.
s = schedule.Scheduler()
calls = []
last = s.every().second.max_runs(3).max_runs(1).do(record(calls, \"last\"))
s.run_all()
results[\"last_call_wins\"] = {
    \"calls\": len(calls),
    \"stored_limit\": last.run_limit,
    \"removed\": last not in s.jobs,
}

print(json.dumps(results, sort_keys=True))
