/bin/zsh -lc "node <<'NODE'
const assert = require('node:assert');
const crypto = require('node:crypto');
const fs = require('node:fs');
const path = require('node:path');
const { Readable, Writable } = require('node:stream');
const { app } = require('./server');

const secret = fs.readFileSync(path.join('data', 'webhook-secret.txt'), 'utf8').trim();

function invoke(body, signature) {
  return new Promise((resolve, reject) => {
    const req = Readable.from([body]);
    req.method = 'POST';
    req.url = '/webhook';
    req.headers = {
      'content-type': 'application/json',
      'content-length': String(Buffer.byteLength(body)),
      'x-signature': signature,
    };
    req.httpVersion = '1.1';

    const chunks = [];
    const headers = new Map();
    const res = new Writable({
      write(chunk, _encoding, callback) {
        chunks.push(Buffer.from(chunk));
        callback();
      },
    });
    res.statusCode = 200;
    res.setHeader = (name, value) => headers.set(name.toLowerCase(), value);
    res.getHeader = (name) => headers.get(name.toLowerCase());
    res.removeHeader = (name) => headers.delete(name.toLowerCase());
    res.on('finish', () => resolve({ status: res.statusCode, body: JSON.parse(Buffer.concat(chunks).toString()) }));
    res.on('error', reject);
    app.handle(req, res);
  });
}

function sign(body) {
  return crypto.createHmac('sha256', secret).update(body).digest('hex');
}

(async () => {
  const happyBody = JSON.stringify({ id: 'evt-inprocess-happy', type: 'order.created', timestamp: 1700000000, data: {} });
  const happy = await invoke(happyBody, sign(happyBody));
  assert.deepStrictEqual(happy, { status: 200, body: { accepted: true, id: 'evt-inprocess-happy' } });

  const replayBody = JSON.stringify({ id: 'evt-inprocess-replay', type: 'order.created', timestamp: 1700000001, data: {} });
  const replayFirst = await invoke(replayBody, sign(replayBody));
  const replaySecond = await invoke(replayBody, sign(replayBody));
  assert.strictEqual(replayFirst.status, 200);
  assert.deepStrictEqual(replaySecond, { status: 409, body: { error: 'duplicate_event', id: 'evt-inprocess-replay' } });

  const signedBody = JSON.stringify({ id: 'evt-inprocess-tampered', type: 'order.created', timestamp: 1700000002, data: {} });
  const tamperedBody = JSON.stringify({ id: 'evt-inprocess-tampered', type: 'order.created', timestamp: 1700000002, data: { changed: true } });
  const tampered = await invoke(tamperedBody, sign(signedBody));
  assert.deepStrictEqual(tampered, { status: 401, body: { error: 'invalid_signature' } });

  const invalidBody = JSON.stringify({ id: '', type: 'order.created', timestamp: 1700000003, data: {} });
  const invalid = await invoke(invalidBody, sign(invalidBody));
  assert.deepStrictEqual(invalid, { status: 400, body: { error: 'invalid_body' } });

  console.log('in-process webhook contract PASS');
})().catch((error) => {
  console.error(error);
  process.exitCode = 1;
});
