+test('payout rejects invalid input with JSON errors and no stdout', (t) => {
+  const cases = [
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'unknown', amount_cents: 100 }] },
+      error: 'invalid_event_type'
+    },
+    {
+      contents: { events: [{ id: 'event-1', type: 'charge', amount_cents: 100 }] },
+      error: 'missing_merchant_id'
+    },
+    {
+      contents: { events: [{ merchant_id: 'm1', type: 'charge', amount_cents: 100 }] },
+      error: 'missing_id'
+    },
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'charge', amount_cents: 0 }] },
+      error: 'invalid_amount_cents'
+    },
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'charge', amount_cents: 1.5 }] },
