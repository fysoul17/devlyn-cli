       process.stderr.write(USAGE);
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..8d3989f 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
 const { execFileSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,29 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function writePayoutInput(t, contents) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
+  t.after(() => fs.rmSync(directory, { recursive: true, force: true }));
+  const inputPath = path.join(directory, 'events.json');
+  fs.writeFileSync(
+    inputPath,
+    typeof contents === 'string' ? contents : JSON.stringify(contents)
+  );
+  return inputPath;
+}
+
+function expectPayoutFailure(args, expectedError) {
+  assert.throws(
+    () => run(['payout', ...args]),
+    (error) => {
+      assert.strictEqual(error.status, 2);
+      assert.strictEqual(error.stdout, '');
+      assert.deepStrictEqual(JSON.parse(error.stderr), expectedError);
+      return true;
+    }
+  );
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +48,102 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('payout applies rules and folds a below-threshold payout into reserve', (t) => {
+  const inputPath = writePayoutInput(t, {
+    events: [
+      { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
+      { id: 'refund-1', merchant_id: 'm1', type: 'refund', amount_cents: 2000 },
+      { id: 'dispute-1', merchant_id: 'm1', type: 'dispute', amount_cents: 500 },
+      { id: 'charge-2', merchant_id: 'm2', type: 'charge', amount_cents: 500 }
+    ]
+  });
+
+  assert.deepStrictEqual(JSON.parse(run(['payout', '--input', inputPath])), {
+    total_payout_cents: 5112,
+    total_processing_fee_cents: 365,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 1023,
+    merchants: [
+      {
+        merchant_id: 'm1',
+        gross_charge_cents: 10000,
+        refund_cents: 2000,
+        dispute_cents: 500,
+        processing_fee_cents: 320,
+        dispute_fee_cents: 1500,
+        reserve_cents: 568,
+        payout_cents: 5112
+      },
+      {
+        merchant_id: 'm2',
+        gross_charge_cents: 500,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 45,
+        dispute_fee_cents: 0,
+        reserve_cents: 455,
+        payout_cents: 0
+      }
+    ]
+  });
+});
+
+test('payout applies identical duplicate events once', (t) => {
+  const event = { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 1000 };
+  const inputPath = writePayoutInput(t, { events: [event, event] });
+
+  const result = JSON.parse(run(['payout', '--input', inputPath]));
+  assert.strictEqual(result.merchants.length, 1);
+  assert.strictEqual(result.merchants[0].gross_charge_cents, 1000);
+});
+
+test('payout rejects conflicting duplicate events before writing totals', (t) => {
+  const inputPath = writePayoutInput(t, {
+    events: [
+      { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 1000 },
+      { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 2000 }
