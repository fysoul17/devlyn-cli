   191	  const rules = readJsonFile(rulesPath, 'payout_rules_error', 'payout_rules_error');
   192	
   193	  validatePayoutRules(rules);
   194	  validatePayoutEvents(input && input.events);
   195	  return calculatePayout(deduplicateEvents(input.events), rules);
   196	}
