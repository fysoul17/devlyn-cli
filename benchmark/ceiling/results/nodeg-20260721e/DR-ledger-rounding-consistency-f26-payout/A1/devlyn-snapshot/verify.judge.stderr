diff --git a/bin/cli.js b/bin/cli.js
index 9cc9b24..1e315a0 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -35,6 +35,166 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function fail(error) {
+  process.stderr.write(`${JSON.stringify(error)}\n`);
+  process.exit(2);
+}
+
+function readJsonFile(filePath, readError, parseError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch (error) {
+    fail({ error: readError });
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch (error) {
+    fail({ error: parseError });
+  }
+}
+
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  if (idx === -1) return undefined;
+  const value = argv[idx + 1];
+  if (!value || value.startsWith('-')) return undefined;
+  return value;
+}
+
+function validatePayoutRules(rules) {
+  if (
+    !rules ||
+    !Number.isFinite(rules.processing_fee_percent) ||
+    !Number.isInteger(rules.fixed_fee_cents) ||
+    !Number.isInteger(rules.dispute_fee_cents) ||
+    !Number.isFinite(rules.reserve_percent) ||
+    !Number.isInteger(rules.minimum_payout_cents)
+  ) {
+    fail({ error: 'invalid_payout_rules' });
+  }
+}
+
+function validatePayoutEvents(events) {
+  if (!Array.isArray(events)) {
+    fail({ error: 'missing_events' });
+  }
+
+  for (const event of events) {
+    if (!event || typeof event !== 'object' || Array.isArray(event)) {
+      fail({ error: 'invalid_event' });
+    }
+    if (typeof event.id !== 'string' || event.id.length === 0) {
+      fail({ error: 'missing_id' });
+    }
+    if (typeof event.merchant_id !== 'string' || event.merchant_id.length === 0) {
+      fail({ error: 'missing_merchant_id' });
+    }
+    if (!['charge', 'refund', 'dispute'].includes(event.type)) {
+      fail({ error: 'invalid_event_type' });
+    }
+    if (!Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
+      fail({ error: 'invalid_amount_cents' });
+    }
+  }
+}
+
+function deduplicateEvents(events) {
+  const eventById = new Map();
+  const uniqueEvents = [];
+
+  for (const event of events) {
+    const serialized = JSON.stringify(event);
+    const existing = eventById.get(event.id);
+    if (existing === undefined) {
+      eventById.set(event.id, serialized);
+      uniqueEvents.push(event);
+    } else if (existing !== serialized) {
+      fail({ error: 'conflicting_duplicate', id: event.id });
+    }
+  }
+
+  return uniqueEvents;
+}
+
+function calculatePayout(events, rules) {
+  const merchantsById = new Map();
+
+  for (const event of events) {
+    let merchant = merchantsById.get(event.merchant_id);
+    if (!merchant) {
+      merchant = {
+        merchant_id: event.merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+        reserve_cents: 0,
+        payout_cents: 0
+      };
+      merchantsById.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        event.amount_cents * rules.processing_fee_percent / 100
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchants = [...merchantsById.values()];
+  for (const merchant of merchants) {
+    const netBeforeReserve = merchant.gross_charge_cents - merchant.refund_cents -
+      merchant.dispute_cents - merchant.processing_fee_cents - merchant.dispute_fee_cents;
+    merchant.reserve_cents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  return {
+    total_payout_cents: merchants.reduce((total, merchant) => total + merchant.payout_cents, 0),
+    total_processing_fee_cents: merchants.reduce(
+      (total, merchant) => total + merchant.processing_fee_cents,
+      0
+    ),
+    total_dispute_fee_cents: merchants.reduce(
+      (total, merchant) => total + merchant.dispute_fee_cents,
+      0
+    ),
+    total_reserve_cents: merchants.reduce((total, merchant) => total + merchant.reserve_cents, 0),
+    merchants
+  };
+}
+
+function runPayout(argv) {
+  const inputPath = parseInputFlag(argv);
+  if (!inputPath) {
+    fail({ error: 'unreadable_input' });
+  }
+
+  const input = readJsonFile(inputPath, 'unreadable_input', 'invalid_json');
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  const rules = readJsonFile(rulesPath, 'payout_rules_error', 'payout_rules_error');
+
+  validatePayoutRules(rules);
+  validatePayoutEvents(input && input.events);
+  return calculatePayout(deduplicateEvents(input.events), rules);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +213,10 @@ function main(argv) {
