const assert = require(\"node:assert/strict\");
const fs = require(\"node:fs\");
const { spawnSync } = require(\"node:child_process\");
const path = require(\"node:path\");
const current = JSON.parse(fs.readFileSync(\"data/payout-rules.json\", \"utf8\"));
const input = JSON.stringify({ events: [
  { id: \"charge\", merchant_id: \"m\", type: \"charge\", amount_cents: 5000 },
  { id: \"dispute\", merchant_id: \"m\", type: \"dispute\", amount_cents: 100 }
] });
const bootstrap = "'`
const fs = require("node:fs");
const path = require("node:path");
const original = fs.readFileSync;
const input = process.argv[1];
const rules = process.argv[2];
fs.readFileSync = (filePath, encoding) => {
  const value = String(filePath);
  if (value.endsWith(path.join("data", "payout-rules.json"))) return rules;
  if (value === "/virtual/events.json") return input;
  return original(filePath, encoding);
};
const cli = path.resolve("bin/cli.js");
process.argv = [process.execPath, cli, "payout", "--input", "/virtual/events.json"];
require(cli);
`;
function execute(rules) {
  const r = spawnSync(process.execPath, ["-e", bootstrap, input, JSON.stringify(rules)], { encoding: "utf8" });
  assert.equal(r.status, 0, r.stderr);
  assert.equal(r.stderr, "");
  return JSON.parse(r.stdout);
}
const base = execute(current);
const variants = {
  processing_fee_percent: { ...current, processing_fee_percent: current.processing_fee_percent + 1 },
  fixed_fee_cents: { ...current, fixed_fee_cents: current.fixed_fee_cents + 1 },
  dispute_fee_cents: { ...current, dispute_fee_cents: current.dispute_fee_cents + 1 },
  reserve_percent: { ...current, reserve_percent: current.reserve_percent + 1 },
  minimum_payout_cents: { ...current, minimum_payout_cents: 4000 }
};
const observed = {};
for (const [name, rules] of Object.entries(variants)) {
  const changed = execute(rules);
  assert.notDeepEqual(changed, base, name + " did not affect output");
  observed[name] = {
    payout: changed.total_payout_cents,
    processing: changed.total_processing_fee_cents,
    dispute: changed.total_dispute_fee_cents,
    reserve: changed.total_reserve_cents
  };
}
process.stdout.write(JSON.stringify({ base: {
  payout: base.total_payout_cents,
  processing: base.total_processing_fee_cents,
  dispute: base.total_dispute_fee_cents,
  reserve: base.total_reserve_cents
}, observed }) + "'"\\n\");
