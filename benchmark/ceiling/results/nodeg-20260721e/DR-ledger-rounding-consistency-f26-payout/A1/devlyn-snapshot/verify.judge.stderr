   100	  }
   101	}
   102	
   103	function deduplicateEvents(events) {
   104	  const eventById = new Map();
   105	  const uniqueEvents = [];
   106	
   107	  for (const event of events) {
   108	    const serialized = JSON.stringify(event);
   109	    const existing = eventById.get(event.id);
   110	    if (existing === undefined) {
   111	      eventById.set(event.id, serialized);
   112	      uniqueEvents.push(event);
   113	    } else if (existing !== serialized) {
   114	      fail({ error: 'conflicting_duplicate', id: event.id });
   115	    }
   116	  }
   117	
   118	  return uniqueEvents;
   119	}
   120	
   121	function calculatePayout(events, rules) {
   122	  const merchantsById = new Map();
   123	
   124	  for (const event of events) {
   125	    let merchant = merchantsById.get(event.merchant_id);
   126	    if (!merchant) {
   127	      merchant = {
   128	        merchant_id: event.merchant_id,
   129	        gross_charge_cents: 0,
   130	        refund_cents: 0,
   131	        dispute_cents: 0,
   132	        processing_fee_cents: 0,
   133	        dispute_fee_cents: 0,
   134	        reserve_cents: 0,
   135	        payout_cents: 0
   136	      };
   137	      merchantsById.set(event.merchant_id, merchant);
   138	    }
   139	
   140	    if (event.type === 'charge') {
   141	      merchant.gross_charge_cents += event.amount_cents;
   142	      merchant.processing_fee_cents += Math.round(
   143	        event.amount_cents * rules.processing_fee_percent / 100
   144	      ) + rules.fixed_fee_cents;
   145	    } else if (event.type === 'refund') {
   146	      merchant.refund_cents += event.amount_cents;
   147	    } else {
   148	      merchant.dispute_cents += event.amount_cents;
   149	      merchant.dispute_fee_cents += rules.dispute_fee_cents;
   150	    }
   151	  }
   152	
   153	  const merchants = [...merchantsById.values()];
   154	  for (const merchant of merchants) {
   155	    const netBeforeReserve = merchant.gross_charge_cents - merchant.refund_cents -
   156	      merchant.dispute_cents - merchant.processing_fee_cents - merchant.dispute_fee_cents;
   157	    merchant.reserve_cents = netBeforeReserve > 0
   158	      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
   159	      : 0;
   160	    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
   161	
   162	    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
   163	      merchant.reserve_cents += merchant.payout_cents;
   164	      merchant.payout_cents = 0;
   165	    }
   166	  }
   167	
   168	  return {
   169	    total_payout_cents: merchants.reduce((total, merchant) => total + merchant.payout_cents, 0),
   170	    total_processing_fee_cents: merchants.reduce(
   171	      (total, merchant) => total + merchant.processing_fee_cents,
   172	      0
   173	    ),
   174	    total_dispute_fee_cents: merchants.reduce(
   175	      (total, merchant) => total + merchant.dispute_fee_cents,
   176	      0
   177	    ),
   178	    total_reserve_cents: merchants.reduce((total, merchant) => total + merchant.reserve_cents, 0),
   179	    merchants
   180	  };
   181	}
   182	
   183	function runPayout(argv) {
