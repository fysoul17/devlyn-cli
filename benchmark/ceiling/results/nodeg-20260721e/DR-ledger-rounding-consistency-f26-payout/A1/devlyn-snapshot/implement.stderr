+        gross_charge_cents: 500,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 45,
+        dispute_fee_cents: 0,
+        reserve_cents: 455,
+        payout_cents: 0
+      }
+    ]
+  });
+});
+
+test('payout applies identical duplicate events once', (t) => {
+  const event = { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 1000 };
+  const inputPath = writePayoutInput(t, { events: [event, event] });
+
+  const result = JSON.parse(run(['payout', '--input', inputPath]));
+  assert.strictEqual(result.merchants.length, 1);
+  assert.strictEqual(result.merchants[0].gross_charge_cents, 1000);
+});
+
+test('payout rejects conflicting duplicate events before writing totals', (t) => {
+  const inputPath = writePayoutInput(t, {
+    events: [
+      { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 1000 },
+      { id: 'charge-1', merchant_id: 'm1', type: 'charge', amount_cents: 2000 }
+    ]
+  });
+
+  expectPayoutFailure(['--input', inputPath], {
+    error: 'conflicting_duplicate',
+    id: 'charge-1'
+  });
+});
+
+test('payout rejects invalid input with JSON errors and no stdout', (t) => {
+  const cases = [
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'unknown', amount_cents: 100 }] },
+      error: 'invalid_event_type'
+    },
+    {
+      contents: { events: [{ id: 'event-1', type: 'charge', amount_cents: 100 }] },
+      error: 'missing_merchant_id'
+    },
+    {
+      contents: { events: [{ merchant_id: 'm1', type: 'charge', amount_cents: 100 }] },
+      error: 'missing_id'
+    },
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'charge', amount_cents: 0 }] },
+      error: 'invalid_amount_cents'
+    },
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'charge', amount_cents: 1.5 }] },
+      error: 'invalid_amount_cents'
+    },
+    { contents: {}, error: 'missing_events' },
+    { contents: '{', error: 'invalid_json' }
+  ];
+
+  for (const testCase of cases) {
+    const inputPath = writePayoutInput(t, testCase.contents);
+    expectPayoutFailure(['--input', inputPath], { error: testCase.error });
+  }
+
+  expectPayoutFailure(['--input', path.join(os.tmpdir(), 'missing-payout-input.json')], {
+    error: 'unreadable_input'
+  });
+});

