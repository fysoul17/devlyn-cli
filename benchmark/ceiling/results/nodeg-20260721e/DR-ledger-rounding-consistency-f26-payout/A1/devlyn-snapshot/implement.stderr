+    },
+    {
+      contents: { events: [{ merchant_id: 'm1', type: 'charge', amount_cents: 100 }] },
+      error: 'missing_id'
+    },
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'charge', amount_cents: 0 }] },
+      error: 'invalid_amount_cents'
+    },
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'charge', amount_cents: 1.5 }] },
+      error: 'invalid_amount_cents'
+    },
+    { contents: {}, error: 'missing_events' },
+    { contents: '{', error: 'invalid_json' }
+  ];
+
+  for (const testCase of cases) {
+    const inputPath = writePayoutInput(t, testCase.contents);
+    expectPayoutFailure(['--input', inputPath], { error: testCase.error });
+  }
+
+  expectPayoutFailure(['--input', path.join(os.tmpdir(), 'missing-payout-input.json')], {
