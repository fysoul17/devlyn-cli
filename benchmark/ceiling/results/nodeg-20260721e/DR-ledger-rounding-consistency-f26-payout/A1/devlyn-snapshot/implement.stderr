+test('payout rejects invalid input with JSON errors and no stdout', (t) => {
+  const cases = [
+    {
+      contents: { events: [{ id: 'event-1', merchant_id: 'm1', type: 'unknown', amount_cents: 100 }] },
+      error: 'invalid_event_type'
