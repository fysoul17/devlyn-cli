 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
-  version                    Print the CLI version from package.json
+  version [--format json]    Print the CLI version from package.json
   --help, -h                 Show this help
 
 Examples:
@@ -41,6 +41,21 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseVersionFormat(argv) {
+  const idx = argv.indexOf('--format');
+  if (idx === -1) return 'plain';
+  const value = argv[idx + 1];
+  if (!value || value.startsWith('-')) {
+    console.error('--format requires a value');
+    process.exit(1);
+  }
+  if (value !== 'json') {
+    console.error(`Unsupported version format: ${value}`);
+    process.exit(1);
+  }
+  return value;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -57,6 +72,11 @@ function main(argv) {
       return;
     }
     case 'version': {
+      const format = parseVersionFormat(rest);
+      if (format === 'json') {
+        console.log(JSON.stringify({ version: readPackageVersion() }));
+        return;
+      }
       console.log(readPackageVersion());
       return;
     }
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..6ce6f7e 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,13 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.match(out, /^\{"version":"\d+\.\d+\.\d+"\}\n$/);
+  assert.doesNotThrow(() => JSON.parse(out));
+});
+
+test('version rejects unsupported --format value', () => {
+  assert.throws(() => run(['version', '--format', 'yaml']));
+});
