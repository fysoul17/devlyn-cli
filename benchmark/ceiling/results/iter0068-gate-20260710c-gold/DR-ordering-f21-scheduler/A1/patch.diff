+function runSchedule(input) {
+  const tmp = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-schedule-'));
+  const inputPath = path.join(tmp, 'input.json');
+  try {
+    fs.writeFileSync(inputPath, JSON.stringify(input), 'utf8');
+    const result = spawnSync('node', [CLI, 'schedule', '--input', inputPath], {
+      encoding: 'utf8',
+    });
+    assert.strictEqual(result.status, 0);
+    assert.strictEqual(result.stderr, '');
+    return JSON.parse(result.stdout);
+  } finally {
+    fs.rmSync(tmp, { recursive: true, force: true });
+  }
+}
+
 test('hello default', () => {
