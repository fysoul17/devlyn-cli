@@ -23,3 +41,41 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('schedule processes higher priority requests first', () => {
+  const result = runSchedule({
+    resources: [
+      { id: 'room', windows: [{ start: '09:00', end: '10:00' }], blocked: [] },
+    ],
+    requests: [
+      { id: 'low', resource: 'room', start: '09:00', duration_min: 30, priority: 1, submitted_at: '2026-01-01T09:00:00Z' },
+      { id: 'high', resource: 'room', start: '09:00', duration_min: 30, priority: 10, submitted_at: '2026-01-01T09:01:00Z' },
+    ],
+  });
+  assert.deepStrictEqual(result, {
+    scheduled: [
+      { id: 'high', resource: 'room', start: '09:00', end: '09:30' },
+      { id: 'low', resource: 'room', start: '09:30', end: '10:00' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports rejections in original input order', () => {
+  const result = runSchedule({
+    resources: [
+      { id: 'room', windows: [{ start: '09:00', end: '09:30' }], blocked: [] },
+    ],
+    requests: [
+      { id: 'missing', resource: 'other', start: '09:00', duration_min: 5, priority: 1, submitted_at: '2026-01-01T09:02:00Z' },
+      { id: 'too-long', resource: 'room', start: '09:00', duration_min: 45, priority: 10, submitted_at: '2026-01-01T09:00:00Z' },
+    ],
+  });
+  assert.deepStrictEqual(result, {
+    scheduled: [],
+    rejected: [
+      { id: 'missing', reason: 'unknown_resource' },
+      { id: 'too-long', reason: 'no_slot' },
+    ],
+  });
+});
