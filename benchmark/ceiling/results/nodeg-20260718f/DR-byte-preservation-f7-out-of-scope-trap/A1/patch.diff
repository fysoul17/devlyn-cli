diff --git a/bin/cli.js b/bin/cli.js
index fcff156..c7395df 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -41,6 +41,17 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseVersionFormat(argv) {
+  const idx = argv.indexOf('--format');
+  if (idx === -1) return 'plain';
+  const value = argv[idx + 1];
+  if (value !== 'json') {
+    console.error('--format must be json');
+    process.exit(1);
+  }
+  return value;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -57,7 +68,9 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
+      const format = parseVersionFormat(rest);
+      const version = readPackageVersion();
+      console.log(format === 'json' ? JSON.stringify({ version }) : version);
       return;
     }
     default:
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..a3bc23c 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,15 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON when requested', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.equal(out, '{"version":"0.1.0"}\n');
+});
+
+test('version rejects unsupported formats', () => {
+  assert.throws(
+    () => run(['version', '--format', 'bogus']),
+    (error) => error.status === 1 && /--format must be json/.test(error.stderr),
+  );
+});
