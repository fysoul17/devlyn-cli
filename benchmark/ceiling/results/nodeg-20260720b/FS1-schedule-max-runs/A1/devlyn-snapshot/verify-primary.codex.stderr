  1636	    def test_idle_seconds(self):
  1637	        assert schedule.default_scheduler.next_run is None
  1638	        assert schedule.idle_seconds() is None
  1639	
  1640	        mock_job = make_mock_job()
  1641	        with mock_datetime(2020, 12, 9, 21, 46):
  1642	            job = every().hour.do(mock_job)
  1643	            assert schedule.idle_seconds() == 60 * 60
  1644	            schedule.cancel_job(job)
  1645	            assert schedule.next_run() is None
  1646	            assert schedule.idle_seconds() is None
  1647	
  1648	    def test_cancel_job(self):
  1649	        def stop_job():
  1650	            return schedule.CancelJob
  1651	
  1652	        mock_job = make_mock_job()
  1653	
  1654	        every().second.do(stop_job)
  1655	        mj = every().second.do(mock_job)
  1656	        assert len(schedule.jobs) == 2
  1657	
  1658	        schedule.run_all()
  1659	        assert len(schedule.jobs) == 1
  1660	        assert schedule.jobs[0] == mj
  1661	
  1662	        schedule.cancel_job("Not a job")
  1663	        assert len(schedule.jobs) == 1
  1664	        schedule.default_scheduler.cancel_job("Not a job")
  1665	        assert len(schedule.jobs) == 1
  1666	
  1667	        schedule.cancel_job(mj)
  1668	        assert len(schedule.jobs) == 0
