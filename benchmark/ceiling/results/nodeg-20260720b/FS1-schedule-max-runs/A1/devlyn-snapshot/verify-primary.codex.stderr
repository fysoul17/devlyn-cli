  1301	    def test_align_utc_offset_no_timezone(self):
  1302	        job = schedule.every().day.at("10:00").do(make_mock_job())
  1303	        now = datetime.datetime(2024, 5, 11, 10, 30, 55, 0)
  1304	        aligned_time = job._correct_utc_offset(now, fixate_time=True)
  1305	        self.assertEqual(now, aligned_time)
  1306	
  1307	    def setup_utc_offset_test(self):
  1308	        try:
  1309	            import pytz
  1310	        except ModuleNotFoundError:
  1311	            self.skipTest("pytz unavailable")
  1312	        job = (
  1313	            schedule.every()
  1314	            .day.at("10:00", "Europe/Berlin")
  1315	            .do(make_mock_job("tz-test"))
  1316	        )
  1317	        tz = pytz.timezone("Europe/Berlin")
  1318	        return (job, tz)
  1319	
  1320	    def test_align_utc_offset_no_change(self):
  1321	        (job, tz) = self.setup_utc_offset_test()
  1322	        now = tz.localize(datetime.datetime(2023, 3, 26, 1, 30))
  1323	        aligned_time = job._correct_utc_offset(now, fixate_time=False)
  1324	        self.assertEqual(now, aligned_time)
  1325	
  1326	    def test_align_utc_offset_with_dst_gap(self):
  1327	        (job, tz) = self.setup_utc_offset_test()
  1328	        # Non-existent time in Berlin timezone
  1329	        gap_time = tz.localize(datetime.datetime(2024, 3, 31, 2, 30, 0))
  1330	        aligned_time = job._correct_utc_offset(gap_time, fixate_time=True)
  1331	
  1332	        assert aligned_time.utcoffset() == datetime.timedelta(hours=2)
  1333	        assert aligned_time.day == 31
  1334	        assert aligned_time.hour == 3
  1335	        assert aligned_time.minute == 30
  1336	
  1337	    def test_align_utc_offset_with_dst_fold(self):
  1338	        (job, tz) = self.setup_utc_offset_test()
  1339	        # This time exists twice, this is the first occurance
  1340	        overlap_time = tz.localize(datetime.datetime(2024, 10, 27, 2, 30))
  1341	        aligned_time = job._correct_utc_offset(overlap_time, fixate_time=False)
  1342	        # Since the time exists twice, no fixate_time flag should yield the first occurrence
  1343	        first_occurrence = tz.localize(datetime.datetime(2024, 10, 27, 2, 30, fold=0))
  1344	        self.assertEqual(first_occurrence, aligned_time)
  1345	
  1346	    def test_align_utc_offset_with_dst_fold_fixate_1(self):
  1347	        (job, tz) = self.setup_utc_offset_test()
  1348	        # This time exists twice, this is the 1st occurance
  1349	        overlap_time = tz.localize(datetime.datetime(2024, 10, 27, 1, 30), is_dst=True)
  1350	        overlap_time += datetime.timedelta(
  1351	            hours=1
  1352	        )  # puts it at 02:30+02:00 (Which exists once)
  1353	
  1354	        aligned_time = job._correct_utc_offset(overlap_time, fixate_time=True)
  1355	        # The time should not have moved, because the original time is valid
  1356	        assert aligned_time.utcoffset() == datetime.timedelta(hours=2)
  1357	        assert aligned_time.hour == 2
  1358	        assert aligned_time.minute == 30
  1359	        assert aligned_time.day == 27
  1360	
  1361	    def test_align_utc_offset_with_dst_fold_fixate_2(self):
  1362	        (job, tz) = self.setup_utc_offset_test()
  1363	        # 02:30 exists twice, this is the 2nd occurance
  1364	        overlap_time = tz.localize(datetime.datetime(2024, 10, 27, 2, 30), is_dst=False)
  1365	        # The time 2024-10-27 02:30:00+01:00 exists once
  1366	
  1367	        aligned_time = job._correct_utc_offset(overlap_time, fixate_time=True)
  1368	        # The time was valid, should not have been moved
  1369	        assert aligned_time.utcoffset() == datetime.timedelta(hours=1)
  1370	        assert aligned_time.hour == 2
  1371	        assert aligned_time.minute == 30
  1372	        assert aligned_time.day == 27
  1373	
  1374	    def test_align_utc_offset_after_fold_fixate(self):
  1375	        (job, tz) = self.setup_utc_offset_test()
  1376	        # This time is 30 minutes after a folded hour.
  1377	        duplicate_time = tz.localize(datetime.datetime(2024, 10, 27, 2, 30))
  1378	        duplicate_time += datetime.timedelta(hours=1)
  1379	
  1380	        aligned_time = job._correct_utc_offset(duplicate_time, fixate_time=False)
  1381	
  1382	        assert aligned_time.utcoffset() == datetime.timedelta(hours=1)
  1383	        assert aligned_time.hour == 3
  1384	        assert aligned_time.minute == 30
  1385	        assert aligned_time.day == 27
  1386	
