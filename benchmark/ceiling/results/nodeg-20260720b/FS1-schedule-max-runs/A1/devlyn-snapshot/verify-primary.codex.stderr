  1492	        assert "foo" in s
  1493	        assert "bar=23" in s
  1494	
  1495	        # test repr when at_time is not None
  1496	        s2 = repr(every().day.at("00:00").do(job_fun, "foo", bar=23))
  1497	        assert s2.startswith(
  1498	            (
  1499	                "Every 1 day at 00:00:00 do job_fun('foo', "
  1500	                "bar=23) (last run: [never], next run: "
  1501	            )
  1502	        )
  1503	
  1504	        # Ensure Job.__repr__ does not throw exception on a partially-composed Job
  1505	        s3 = repr(schedule.every(10))
  1506	        assert s3 == "Every 10 None do [None] (last run: [never], next run: [never])"
