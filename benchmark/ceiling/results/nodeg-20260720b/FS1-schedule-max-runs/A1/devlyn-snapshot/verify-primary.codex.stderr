  1228	    def test_tz_daily_skip_dst_change(self):
  1229	        mock_job = self.make_tz_mock_job()
  1230	        with mock_datetime(2024, 11, 3, 10, 0):
  1231	            # At 3 November 2024, 02:00:00 clocks are turned backward 1 hour
  1232	            # The job skips the whole DST change becaus it runs at 14:00
  1233	            # Current time Berlin:     3 Nov, 10:00
  1234	            # Current time Anchorage:  3 Nov, 00:00 (UTC-08:00)
  1235	            # Expected time Anchorage: 3 Nov, 14:00 (UTC-09:00)
  1236	            # Expected time Berlin:    4 Nov, 00:00
  1237	            schedule.clear()
  1238	            next = (
  1239	                schedule.every()
  1240	                .day.at("14:00", "America/Anchorage")
  1241	                .do(mock_job)
  1242	                .next_run
  1243	            )
  1244	            assert next.day == 4
  1245	            assert next.hour == 0
  1246	            assert next.minute == 00
  1247	
  1248	    def test_tz_daily_different_simultaneous_dst_change(self):
  1249	        mock_job = self.make_tz_mock_job()
  1250	
  1251	        # TZ_BERLIN_EXTRA is the same as Berlin, but during summer time
  1252	        # moves the clock 2 hours forward instead of 1
  1253	        # This is a fictional timezone
  1254	        TZ_BERLIN_EXTRA = "CET-01CEST-03,M3.5.0,M10.5.0/3"
  1255	        with mock_datetime(2024, 3, 31, 0, 0, 0, TZ_BERLIN_EXTRA):
  1256	            # In Berlin at March 31 2024, 02:00:00 clocks were turned forward 1 hour
  1257	            # In Berlin Extra, the clocks move forward 2 hour at the same time
  1258	            # Current time Berlin Extra:  31 Mar, 00:00 (UTC+01:00)
  1259	            # Current time Berlin:        31 Mar, 00:00 (UTC+01:00)
  1260	            # Expected time Berlin:       31 Mar, 10:00 (UTC+02:00)
  1261	            # Expected time Berlin Extra: 31 Mar, 11:00 (UTC+03:00)
  1262	            schedule.clear()
  1263	            next = (
  1264	                schedule.every().day.at("10:00", "Europe/Berlin").do(mock_job).next_run
  1265	            )
  1266	            assert next.day == 31
  1267	            assert next.hour == 11
  1268	            assert next.minute == 00
  1269	
  1270	    def test_tz_daily_opposite_dst_change(self):
  1271	        mock_job = self.make_tz_mock_job()
  1272	
  1273	        # TZ_BERLIN_INVERTED changes in the opposite direction of Berlin
  1274	        # This is a fictional timezone
  1275	        TZ_BERLIN_INVERTED = "CET-1CEST,M10.5.0/3,M3.5.0"
  1276	        with mock_datetime(2024, 3, 31, 0, 0, 0, TZ_BERLIN_INVERTED):
  1277	            # In Berlin at March 31 2024, 02:00:00 clocks were turned forward 1 hour
  1278	            # In Berlin Inverted, the clocks move back 1 hour at the same time
  1279	            # Current time Berlin Inverted:  31 Mar, 00:00 (UTC+02:00)
  1280	            # Current time Berlin:           31 Mar, 00:00 (UTC+01:00)
  1281	            # Expected time Berlin:          31 Mar, 10:00 (UTC+02:00) +9 hour
  1282	            # Expected time Berlin Inverted: 31 Mar, 09:00 (UTC+01:00)
  1283	            schedule.clear()
  1284	            next = (
  1285	                schedule.every().day.at("10:00", "Europe/Berlin").do(mock_job).next_run
  1286	            )
  1287	            assert next.day == 31
  1288	            assert next.hour == 9
  1289	            assert next.minute == 00
  1290	
