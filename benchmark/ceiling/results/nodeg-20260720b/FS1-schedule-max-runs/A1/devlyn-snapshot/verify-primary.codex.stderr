  1532	    def test_run_pending(self):
  1533	        """Check that run_pending() runs pending jobs.
  1534	        We do this by overriding datetime.datetime with mock objects
  1535	        that represent increasing system times.
  1536	
  1537	        Please note that it is *intended behavior that run_pending() does not
  1538	        run missed jobs*. For example, if you've registered a job that
  1539	        should run every minute and you only call run_pending() in one hour
  1540	        increments then your job won't be run 60 times in between but
  1541	        only once.
  1542	        """
  1543	        mock_job = make_mock_job()
  1544	
  1545	        with mock_datetime(2010, 1, 6, 12, 15):
  1546	            every().minute.do(mock_job)
  1547	            every().hour.do(mock_job)
  1548	            every().day.do(mock_job)
  1549	            every().sunday.do(mock_job)
  1550	            schedule.run_pending()
  1551	            assert mock_job.call_count == 0
  1552	
  1553	        with mock_datetime(2010, 1, 6, 12, 16):
  1554	            schedule.run_pending()
  1555	            assert mock_job.call_count == 1
  1556	
  1557	        with mock_datetime(2010, 1, 6, 13, 16):
  1558	            mock_job.reset_mock()
  1559	            schedule.run_pending()
  1560	            assert mock_job.call_count == 2
  1561	
  1562	        with mock_datetime(2010, 1, 7, 13, 16):
  1563	            mock_job.reset_mock()
  1564	            schedule.run_pending()
  1565	            assert mock_job.call_count == 3
  1566	
  1567	        with mock_datetime(2010, 1, 10, 13, 16):
  1568	            mock_job.reset_mock()
  1569	            schedule.run_pending()
  1570	            assert mock_job.call_count == 4
  1571	
