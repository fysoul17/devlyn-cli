  1081	    def test_tz_minutes_year_round(self):
  1082	        mock_job = self.make_tz_mock_job()
  1083	        # Test a full year of scheduling across timezones, where one timezone
  1084	        # is in the northern hemisphere and the other in the southern hemisphere
  1085	        # These two timezones are also a bit exotic (not the usual UTC+1, UTC-1)
  1086	        # Local timezone: Newfoundland, Canada: UTC-2:30 / DST UTC-3:30
  1087	        # Remote timezone: Chatham Islands, New Zealand: UTC+12:45 / DST UTC+13:45
  1088	        schedule.clear()
  1089	        job = schedule.every(20).minutes.at(":13", "Canada/Newfoundland").do(mock_job)
  1090	        with mock_datetime(2024, 9, 29, 2, 20, 0, TZ_CHATHAM):
  1091	            # First run, nothing special, no utc-offset change
  1092	            # Current time: 29 sept, 02:20:00  Chatham
  1093	            # Current time: 28 sept, 11:05:00  Newfoundland
  1094	            # Expected time: 28 sept, 11:20:13 Newfoundland
  1095	            # Expected time: 29 sept, 02:40:13 Chatham
  1096	            job.run()
  1097	            assert job.next_run.day == 29
  1098	            assert job.next_run.hour == 2
  1099	            assert job.next_run.minute == 40
  1100	            assert job.next_run.second == 13
  1101	        with mock_datetime(2024, 9, 29, 2, 40, 14, TZ_CHATHAM):
  1102	            # next-schedule happens 1 second behind schedule
  1103	            job.run()
  1104	            # On 29 Sep, 02:45 2024, in Chatham, the clock is moved +1 hour
  1105	            # Thus, the next run happens AFTER the local timezone exits DST
  1106	            # Current time:  29 sept, 02:40:14 Chatham      (UTC +12:45)
  1107	            # Current time:  28 sept, 11:25:14 Newfoundland (UTC -2:30)
  1108	            # Expected time: 28 sept, 11:45:13 Newfoundland (UTC -2:30)
  1109	            # Expected time: 29 sept, 04:00:13 Chatham      (UTC +13:45)
  1110	            assert job.next_run.day == 29
  1111	            assert job.next_run.hour == 4
  1112	            assert job.next_run.minute == 00
  1113	            assert job.next_run.second == 13
  1114	        with mock_datetime(2024, 11, 3, 2, 23, 55, TZ_CHATHAM, fold=0):
  1115	            # Time is right before Newfoundland exits DST
  1116	            # Local time will move 1 hour back at 03:00
  1117	
  1118	            job.run()
  1119	            # There are no timezone switches yet, nothing special going on:
  1120	            # Current time:  3 Nov, 02:23:55 Chatham
  1121	            # Expected time: 3 Nov, 02:43:13 Chatham
  1122	            assert job.next_run.day == 3
  1123	            assert job.next_run.hour == 2
  1124	            assert job.next_run.minute == 43  # Within the fold, first occurrence
  1125	            assert job.next_run.second == 13
  1126	        with mock_datetime(2024, 11, 3, 2, 23, 55, TZ_CHATHAM, fold=1):
  1127	            # Time is during the fold. Local time has moved back 1 hour, this is
  1128	            # the second occurrence of the 02:23 time.
  1129	
  1130	            job.run()
  1131	            # Current time:  3 Nov, 02:23:55 Chatham
  1132	            # Expected time: 3 Nov, 02:43:13 Chatham
  1133	            assert job.next_run.day == 3
  1134	            assert job.next_run.hour == 2
  1135	            assert job.next_run.minute == 43
  1136	            assert job.next_run.second == 13
  1137	        with mock_datetime(2025, 3, 9, 19, 00, 00, TZ_CHATHAM):
  1138	            # Time is right before Newfoundland enters DST
  1139	            # At 02:00, the remote clock will move forward 1 hour
  1140	
  1141	            job.run()
  1142	            # Current time:  9 March, 19:00:00 Chatham      (UTC +13:45)
  1143	            # Current time:  9 March, 01:45:00 Newfoundland (UTC -3:30)
  1144	            # Expected time: 9 March, 03:05:13 Newfoundland (UTC -2:30)
  1145	            # Expected time  9 March, 19:20:13 Chatham      (UTC +13:45)
  1146	
  1147	            assert job.next_run.day == 9
  1148	            assert job.next_run.hour == 19
  1149	            assert job.next_run.minute == 20
  1150	            assert job.next_run.second == 13
  1151	        with mock_datetime(2025, 4, 7, 17, 55, 00, TZ_CHATHAM):
  1152	            # Time is within the few hours before Catham exits DST
  1153	            # At 03:45, the local clock moves back 1 hour
  1154	
  1155	            job.run()
  1156	            # Current time:  7 April, 17:55:00 Chatham
  1157	            # Current time:  7 April, 02:40:00 Newfoundland
  1158	            # Expected time: 7 April, 03:00:13 Newfoundland
  1159	            # Expected time  7 April, 18:15:13 Chatham
  1160	            assert job.next_run.day == 7
  1161	            assert job.next_run.hour == 18
  1162	            assert job.next_run.minute == 15
  1163	            assert job.next_run.second == 13
  1164	        with mock_datetime(2025, 4, 7, 18, 55, 00, TZ_CHATHAM):
  1165	            # Schedule the next run exactly when the clock moved backwards
  1166	            # Curren time is before the clock-move, next run is after the clock change
  1167	
  1168	            job.run()
  1169	            # Current time:  7 April, 18:55:00 Chatham
  1170	            # Current time:  7 April, 03:40:00 Newfoundland
  1171	            # Expected time: 7 April, 03:00:13 Newfoundland (clock moved back)
  1172	            # Expected time  7 April, 19:15:13 Chatham
  1173	            assert job.next_run.day == 7
  1174	            assert job.next_run.hour == 19
  1175	            assert job.next_run.minute == 15
  1176	            assert job.next_run.second == 13
  1177	        with mock_datetime(2025, 4, 7, 19, 15, 13, TZ_CHATHAM):
  1178	            # Schedule during the fold in the remote timezone
  1179	
  1180	            job.run()
  1181	            # Current time:  7 April, 19:15:13 Chatham
  1182	            # Current time:  7 April, 03:00:13 Newfoundland (fold)
  1183	            # Expected time: 7 April, 03:20:13 Newfoundland (fold)
  1184	            # Expected time: 7 April, 19:35:13 Chatham
  1185	            assert job.next_run.day == 7
  1186	            assert job.next_run.hour == 19
  1187	            assert job.next_run.minute == 35
  1188	            assert job.next_run.second == 13
