   650	    def max_runs(self, n: int):
   651	        """
   652	        Schedule job to run at most ``n`` times.
   653	
   654	        :param n: Maximum number of times the job should run
   655	        :return: The invoked job instance
   656	        """
   657	        if not isinstance(n, int) or n < 1:
   658	            raise ScheduleValueError("max_runs() requires an integer greater than 0")
   659	        self._max_runs = n
   660	        return self
   661	
   662	    def do(self, job_func: Callable, *args, **kwargs):
   663	        """
   664	        Specifies the job_func that should be called every time the
   665	        job runs.
   666	
   667	        Any additional arguments are passed on to job_func when
   668	        the job runs.
   669	
   670	        :param job_func: The function to be scheduled
   671	        :return: The invoked job instance
   672	        """
   673	        self.job_func = functools.partial(job_func, *args, **kwargs)
   674	        functools.update_wrapper(self.job_func, job_func)
   675	        self._schedule_next_run()
   676	        if self.scheduler is None:
   677	            raise ScheduleError(
   678	                "Unable to a add job to schedule. "
   679	                "Job is not associated with an scheduler"
   680	            )
   681	        self.scheduler.jobs.append(self)
   682	        return self
