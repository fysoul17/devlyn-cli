  1625	    def test_next_run_property(self):
  1626	        original_datetime = datetime.datetime
  1627	        with mock_datetime(2010, 1, 6, 13, 16):
  1628	            hourly_job = make_mock_job("hourly")
  1629	            daily_job = make_mock_job("daily")
  1630	            every().day.do(daily_job)
  1631	            every().hour.do(hourly_job)
  1632	            assert len(schedule.jobs) == 2
  1633	            # Make sure the hourly job is first
  1634	            assert schedule.next_run() == original_datetime(2010, 1, 6, 14, 16)
