   678	        # this test schedules runs at :10 minutes, so job runs at
   679	        # 16:10 in Kathmandu, which is 13:25 in Berlin
   680	        # in local time we don't run at :10, but at :25, offset of 15 minutes
   681	        self.tst_next_run_time_hour_end("Asia/Kathmandu", 15)
