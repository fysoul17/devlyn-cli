   683	    def tst_next_run_time_hour_end(self, tz, offsetMinutes):
   684	        mock_job = make_mock_job()
   685	
   686	        # So a job scheduled to run at :10 in Kathmandu, runs always 25 minutes
   687	        with mock_datetime(2010, 10, 10, 12, 0, 0):
   688	            job = every().hour.at(":10", tz).do(mock_job)
   689	            assert job.next_run.hour == 12
   690	            assert job.next_run.minute == 10 + offsetMinutes
   691	
   692	        with mock_datetime(2010, 10, 10, 13, 0, 0):
   693	            job.run()
   694	            assert job.next_run.hour == 13
   695	            assert job.next_run.minute == 10 + offsetMinutes
   696	
   697	        with mock_datetime(2010, 10, 10, 13, 30, 0):
   698	            job.run()
   699	            assert job.next_run.hour == 14
   700	            assert job.next_run.minute == 10 + offsetMinutes
