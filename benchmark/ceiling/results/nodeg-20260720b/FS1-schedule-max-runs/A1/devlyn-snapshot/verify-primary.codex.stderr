   631	    def test_next_run_time_day_end(self):
   632	        mock_job = make_mock_job()
   633	        # At day 1, schedule job to run at daily 23:30
   634	        with mock_datetime(2010, 12, 1, 23, 0, 0):
   635	            job = every().day.at("23:30").do(mock_job)
   636	            # first occurrence same day
   637	            assert job.next_run.day == 1
   638	            assert job.next_run.hour == 23
   639	
   640	        # Running the job 01:00 on day 2, afterwards the job should be
   641	        # scheduled at 23:30 the same day. This simulates a job that started
   642	        # on day 1 at 23:30 and took 1,5 hours to finish
   643	        with mock_datetime(2010, 12, 2, 1, 0, 0):
   644	            job.run()
   645	            assert job.next_run.day == 2
   646	            assert job.next_run.hour == 23
   647	
   648	        # Run the job at 23:30 on day 2, afterwards the job should be
   649	        # scheduled at 23:30 the next day
   650	        with mock_datetime(2010, 12, 2, 23, 30, 0):
   651	            job.run()
   652	            assert job.next_run.day == 3
   653	            assert job.next_run.hour == 23
