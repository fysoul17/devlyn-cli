  1190	    def test_tz_weekly_large_interval_forward(self):
  1191	        mock_job = self.make_tz_mock_job()
  1192	        # Testing scheduling large intervals that skip over clock move forward
  1193	        with mock_datetime(2024, 3, 28, 11, 0, 0, TZ_BERLIN):
  1194	            # At March 31st 2024, 02:00:00 clocks were turned forward 1 hour
  1195	            schedule.clear()
  1196	            next = (
  1197	                schedule.every(7)
  1198	                .days.at("11:00", "Europe/Berlin")
  1199	                .do(mock_job)
  1200	                .next_run
  1201	            )
  1202	            assert next.month == 4
  1203	            assert next.day == 4
  1204	            assert next.hour == 11
  1205	            assert next.minute == 0
  1206	            assert next.second == 0
  1207	
  1208	    def test_tz_weekly_large_interval_backward(self):
  1209	        mock_job = self.make_tz_mock_job()
  1210	        import pytz
  1211	
  1212	        # Testing scheduling large intervals that skip over clock move back
  1213	        with mock_datetime(2024, 10, 25, 11, 0, 0, TZ_BERLIN):
  1214	            # At March 31st 2024, 02:00:00 clocks were turned forward 1 hour
  1215	            schedule.clear()
  1216	            next = (
  1217	                schedule.every(7)
  1218	                .days.at("11:00", "Europe/Berlin")
  1219	                .do(mock_job)
  1220	                .next_run
  1221	            )
  1222	            assert next.month == 11
  1223	            assert next.day == 1
  1224	            assert next.hour == 11
  1225	            assert next.minute == 0
  1226	            assert next.second == 0
