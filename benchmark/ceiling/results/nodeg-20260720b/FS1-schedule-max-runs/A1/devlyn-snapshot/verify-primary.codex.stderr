   475	        return self
   476	
   477	    def at(self, time_str: str, tz: Optional[str] = None):
   478	        """
   479	        Specify a particular time that the job should be run at.
   480	
   481	        :param time_str: A string in one of the following formats:
   482	
   483	            - For daily jobs -> `HH:MM:SS` or `HH:MM`
   484	            - For hourly jobs -> `MM:SS` or `:MM`
   485	            - For minute jobs -> `:SS`
   486	
   487	            The format must make sense given how often the job is
   488	            repeating; for example, a job that repeats every minute
   489	            should not be given a string in the form `HH:MM:SS`. The
   490	            difference between `:MM` and `:SS` is inferred from the
   491	            selected time-unit (e.g. `every().hour.at(':30')` vs.
   492	            `every().minute.at(':30')`).
   493	
   494	        :param tz: The timezone that this timestamp refers to. Can be
   495	            a string that can be parsed by pytz.timezone(), or a pytz.BaseTzInfo object
   496	
   497	        :return: The invoked job instance
   498	        """
   499	        if self.unit not in ("days", "hours", "minutes") and not self.start_day:
   500	            raise ScheduleValueError(
   501	                "Invalid unit (valid units are `days`, `hours`, and `minutes`)"
   502	            )
   503	
   504	        if tz is not None:
   505	            import pytz
   506	
   507	            if isinstance(tz, str):
   508	                self.at_time_zone = pytz.timezone(tz)  # type: ignore
   509	            elif isinstance(tz, pytz.BaseTzInfo):
   510	                self.at_time_zone = tz
   511	            else:
   512	                raise ScheduleValueError(
   513	                    "Timezone must be string or pytz.timezone object"
   514	                )
   515	
   516	        if not isinstance(time_str, str):
   517	            raise TypeError("at() should be passed a string")
   518	        if self.unit == "days" or self.start_day:
   519	            if not re.match(r"^[0-2]\d:[0-5]\d(:[0-5]\d)?$", time_str):
   520	                raise ScheduleValueError(
   521	                    "Invalid time format for a daily job (valid format is HH:MM(:SS)?)"
   522	                )
   523	        if self.unit == "hours":
   524	            if not re.match(r"^([0-5]\d)?:[0-5]\d$", time_str):
   525	                raise ScheduleValueError(
   526	                    "Invalid time format for an hourly job (valid format is (MM)?:SS)"
   527	                )
   528	
   529	        if self.unit == "minutes":
   530	            if not re.match(r"^:[0-5]\d$", time_str):
   531	                raise ScheduleValueError(
   532	                    "Invalid time format for a minutely job (valid format is :SS)"
   533	                )
   534	        time_values = time_str.split(":")
   535	        hour: Union[str, int]
   536	        minute: Union[str, int]
   537	        second: Union[str, int]
   538	        if len(time_values) == 3:
   539	            hour, minute, second = time_values
   540	        elif len(time_values) == 2 and self.unit == "minutes":
   541	            hour = 0
   542	            minute = 0
   543	            _, second = time_values
   544	        elif len(time_values) == 2 and self.unit == "hours" and len(time_values[0]):
   545	            hour = 0
   546	            minute, second = time_values
   547	        else:
   548	            hour, minute = time_values
   549	            second = 0
   550	        if self.unit == "days" or self.start_day:
   551	            hour = int(hour)
   552	            if not (0 <= hour <= 23):
   553	                raise ScheduleValueError(
   554	                    "Invalid number of hours ({} is not between 0 and 23)"
   555	                )
   556	        elif self.unit == "hours":
   557	            hour = 0
   558	        elif self.unit == "minutes":
   559	            hour = 0
   560	            minute = 0
   561	        hour = int(hour)
   562	        minute = int(minute)
   563	        second = int(second)
   564	        self.at_time = datetime.time(hour, minute, second)
   565	        return self
   566	
   567	    def to(self, latest: int):
   568	        """
   569	        Schedule the job to run at an irregular (randomized) interval.
   570	
   571	        The job's interval will randomly vary from the value given
   572	        to  `every` to `latest`. The range defined is inclusive on
   573	        both ends. For example, `every(A).to(B).seconds` executes
   574	        the job function every N seconds such that A <= N <= B.
   575	
   576	        :param latest: Maximum interval between randomized job runs
   577	        :return: The invoked job instance
   578	        """
   579	        self.latest = latest
   580	        return self
   581	
   582	    def until(
   583	        self,
   584	        until_time: Union[datetime.datetime, datetime.timedelta, datetime.time, str],
   585	    ):
   586	        """
   587	        Schedule job to run until the specified moment.
   588	
   589	        The job is canceled whenever the next run is calculated and it turns out the
   590	        next run is after the until_time. The job is also canceled right before it runs,
   591	        if the current time is after until_time. This latter case can happen when the
   592	        the job was scheduled to run before until_time, but runs after until_time.
   593	
   594	        If until_time is a moment in the past, ScheduleValueError is thrown.
   595	
   596	        :param until_time: A moment in the future representing the latest time a job can
   597	           be run. If only a time is supplied, the date is set to today.
   598	           The following formats are accepted:
   599	
   600	           - datetime.datetime
   601	           - datetime.timedelta
   602	           - datetime.time
   603	           - String in one of the following formats: "%Y-%m-%d %H:%M:%S",
   604	             "%Y-%m-%d %H:%M", "%Y-%m-%d", "%H:%M:%S", "%H:%M"
   605	             as defined by strptime() behaviour. If an invalid string format is passed,
   606	             ScheduleValueError is thrown.
   607	
   608	        :return: The invoked job instance
   609	        """
   610	
   611	        if isinstance(until_time, datetime.datetime):
   612	            self.cancel_after = until_time
   613	        elif isinstance(until_time, datetime.timedelta):
   614	            self.cancel_after = datetime.datetime.now() + until_time
   615	        elif isinstance(until_time, datetime.time):
   616	            self.cancel_after = datetime.datetime.combine(
   617	                datetime.datetime.now(), until_time
   618	            )
   619	        elif isinstance(until_time, str):
   620	            cancel_after = self._decode_datetimestr(
   621	                until_time,
   622	                [
   623	                    "%Y-%m-%d %H:%M:%S",
   624	                    "%Y-%m-%d %H:%M",
   625	                    "%Y-%m-%d",
   626	                    "%H:%M:%S",
   627	                    "%H:%M",
   628	                ],
   629	            )
   630	            if cancel_after is None:
   631	                raise ScheduleValueError("Invalid string format for until()")
   632	            if "-" not in until_time:
   633	                # the until_time is a time-only format. Set the date to today
   634	                now = datetime.datetime.now()
   635	                cancel_after = cancel_after.replace(
   636	                    year=now.year, month=now.month, day=now.day
   637	                )
   638	            self.cancel_after = cancel_after
   639	        else:
   640	            raise TypeError(
   641	                "until() takes a string, datetime.datetime, datetime.timedelta, "
   642	                "datetime.time parameter"
   643	            )
   644	        if self.cancel_after < datetime.datetime.now():
   645	            raise ScheduleValueError(
   646	                "Cannot schedule a job to run until a time in the past"
   647	            )
   648	        return self
   649	
   650	    def max_runs(self, n: int):
   651	        """
   652	        Schedule job to run at most ``n`` times.
   653	
   654	        :param n: Maximum number of times the job should run
   655	        :return: The invoked job instance
   656	        """
   657	        if not isinstance(n, int) or n < 1:
   658	            raise ScheduleValueError("max_runs() requires an integer greater than 0")
   659	        self._max_runs = n
   660	        return self
   661	
   662	    def do(self, job_func: Callable, *args, **kwargs):
   663	        """
   664	        Specifies the job_func that should be called every time the
   665	        job runs.
   666	
   667	        Any additional arguments are passed on to job_func when
   668	        the job runs.
   669	
   670	        :param job_func: The function to be scheduled
   671	        :return: The invoked job instance
   672	        """
   673	        self.job_func = functools.partial(job_func, *args, **kwargs)
   674	        functools.update_wrapper(self.job_func, job_func)
   675	        self._schedule_next_run()
   676	        if self.scheduler is None:
   677	            raise ScheduleError(
   678	                "Unable to a add job to schedule. "
   679	                "Job is not associated with an scheduler"
   680	            )
   681	        self.scheduler.jobs.append(self)
   682	        return self
   683	
   684	    @property
   685	    def should_run(self) -> bool:
   686	        """
   687	        :return: ``True`` if the job should be run now.
   688	        """
   689	        assert self.next_run is not None, "must run _schedule_next_run before"
   690	        return datetime.datetime.now() >= self.next_run
   691	
   692	    def run(self):
   693	        """
   694	        Run the job and immediately reschedule it.
   695	        If the job's deadline is reached (configured using .until()), the job is not
   696	        run and CancelJob is returned immediately. If the next scheduled run exceeds
   697	        the job's deadline, CancelJob is returned after the execution. In this latter
   698	        case CancelJob takes priority over any other returned value.
   699	        If the job's run budget (configured using .max_runs()) is reached by this
   700	        execution, CancelJob is returned after the execution.
   701	
   702	        :return: The return value returned by the `job_func`, or CancelJob if the job's
   703	                 deadline or run budget is reached.
   704	
   705	        """
   706	        if self._is_overdue(datetime.datetime.now()):
   707	            logger.debug("Cancelling job %s", self)
   708	            return CancelJob
   709	        if self._max_runs is not None and self.run_count >= self._max_runs:
   710	            logger.debug("Cancelling job %s", self)
   711	            return CancelJob
   712	
   713	        logger.debug("Running job %s", self)
   714	        self.run_count += 1
   715	        ret = self.job_func()
   716	        self.last_run = datetime.datetime.now()
   717	        self._schedule_next_run()
   718	
   719	        if self._is_overdue(self.next_run):
   720	            logger.debug("Cancelling job %s", self)
   721	            return CancelJob
   722	        if self._max_runs is not None and self.run_count >= self._max_runs:
   723	            logger.debug("Cancelling job %s", self)
   724	            return CancelJob
   725	        return ret
   726	
   727	    def _schedule_next_run(self) -> None:
   728	        """
   729	        Compute the instant when this job should run next.
   730	        """
   731	        if self.unit not in ("seconds", "minutes", "hours", "days", "weeks"):
   732	            raise ScheduleValueError(
   733	                "Invalid unit (valid units are `seconds`, `minutes`, `hours`, "
   734	                "`days`, and `weeks`)"
   735	            )
