   743	    def test_tz(self):
   744	        mock_job = self.make_tz_mock_job()
   745	        with mock_datetime(2022, 2, 1, 23, 15):
   746	            # Current Berlin time: feb-1 23:15 (local)
   747	            # Current India time: feb-2 03:45
   748	            # Expected to run India time: feb-2 06:30
   749	            # Next run Berlin time: feb-2 02:00
   750	            next = every().day.at("06:30", "Asia/Kolkata").do(mock_job).next_run
   751	            assert next.day == 2
   752	            assert next.hour == 2
   753	            assert next.minute == 0
