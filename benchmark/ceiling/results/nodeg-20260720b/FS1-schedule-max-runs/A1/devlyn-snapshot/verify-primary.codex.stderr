   818	            # Next run should be at the first occurrence of 02:30
   819	            job = every().day.at("02:30", "Europe/Berlin").do(mock_job)
   820	            assert job.next_run.day == 29
   821	            assert job.next_run.hour == 2
   822	            assert job.next_run.minute == 30
