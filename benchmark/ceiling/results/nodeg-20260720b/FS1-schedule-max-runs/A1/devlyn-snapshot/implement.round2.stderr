"""Unit tests for schedule.py"""

import datetime
import functools
from unittest import mock, TestCase
import os
import time

# Silence "missing docstring", "method could be a function",
# "class already defined", and "too many public methods" messages:
# pylint: disable-msg=R0201,C0111,E0102,R0904,R0901

import schedule
from schedule import (
    every,
    repeat,
    ScheduleError,
    ScheduleValueError,
    IntervalError,
)

# POSIX TZ string format
TZ_BERLIN = "CET-1CEST,M3.5.0,M10.5.0/3"
TZ_AUCKLAND = "NZST-12NZDT,M9.5.0,M4.1.0/3"
TZ_CHATHAM = "<+1245>-12:45<+1345>,M9.5.0/2:45,M4.1.0/3:45"
TZ_UTC = "UTC0"

# Set timezone to Europe/Berlin (CEST) to ensure global reproducibility
os.environ["TZ"] = TZ_BERLIN
time.tzset()


def make_mock_job(name=None):
    job = mock.Mock()
    job.__name__ = name or "job"
    return job


class mock_datetime:
    """
    Monkey-patch datetime for predictable results
    """

    def __init__(self, year, month, day, hour, minute, second=0, zone=None, fold=0):
        self.year = year
        self.month = month
        self.day = day
        self.hour = hour
        self.minute = minute
        self.second = second
        self.zone = zone
        self.fold = fold
        self.original_datetime = None
        self.original_zone = None

    def __enter__(self):
        class MockDate(datetime.datetime):
            @classmethod
            def today(cls):
                return cls(self.year, self.month, self.day)

            @classmethod
            def now(cls, tz=None):
                mock_date = cls(
                    self.year,
                    self.month,
                    self.day,
                    self.hour,
                    self.minute,
                    self.second,
                    fold=self.fold,
                )
                if tz:
                    return mock_date.astimezone(tz)
                return mock_date

        self.original_datetime = datetime.datetime
        datetime.datetime = MockDate

        self.original_zone = os.environ.get("TZ")
        if self.zone:
            os.environ["TZ"] = self.zone
            time.tzset()

        return MockDate(
            self.year, self.month, self.day, self.hour, self.minute, self.second
        )

    def __exit__(self, *args, **kwargs):
        datetime.datetime = self.original_datetime
        if self.original_zone:
            os.environ["TZ"] = self.original_zone
            time.tzset()


class SchedulerTests(TestCase):
    def setUp(self):
        schedule.clear()

    def make_tz_mock_job(self, name=None):
        try:
            import pytz
        except ModuleNotFoundError:
            self.skipTest("pytz unavailable")
            return
        return make_mock_job(name)

    def test_time_units(self):
        assert every().seconds.unit == "seconds"
        assert every().minutes.unit == "minutes"
        self.assertRaises(TypeError, every().day.until, 123)
        self.assertRaises(ScheduleValueError, every().day.until, "123")
        self.assertRaises(ScheduleValueError, every().day.until, "01-01-3000")

        # Using .until() with moments in the passed
        self.assertRaises(
            ScheduleValueError,
            every().day.until,
            datetime.datetime(2019, 12, 31, 23, 59),
        )
        self.assertRaises(
            ScheduleValueError, every().day.until, datetime.timedelta(minutes=-1)
        )
        one_hour_ago = datetime.datetime.now() - datetime.timedelta(hours=1)
        self.assertRaises(ScheduleValueError, every().day.until, one_hour_ago)

        # Unschedule job after next_run passes the deadline
        schedule.clear()
        with mock_datetime(2020, 1, 1, 11, 35, 10):
            mock_job.reset_mock()
            every(5).seconds.until(datetime.time(11, 35, 20)).do(mock_job)
            with mock_datetime(2020, 1, 1, 11, 35, 15):
                schedule.run_pending()
                assert mock_job.call_count == 1
                assert len(schedule.jobs) == 1
            with mock_datetime(2020, 1, 1, 11, 35, 20):
                schedule.run_all()
                assert mock_job.call_count == 2
                assert len(schedule.jobs) == 0

        # Unschedule job because current execution time has passed deadline
        schedule.clear()
        with mock_datetime(2020, 1, 1, 11, 35, 10):
            mock_job.reset_mock()
            every(5).seconds.until(datetime.time(11, 35, 20)).do(mock_job)
            with mock_datetime(2020, 1, 1, 11, 35, 50):
                schedule.run_pending()
                assert mock_job.call_count == 0
                assert len(schedule.jobs) == 0

    def test_max_runs_chainability(self):
        mock_job = make_mock_job()

        job_after_unit = every(5).seconds.max_runs(3).do(mock_job)
        job_before_unit = every().max_runs(3).seconds.do(mock_job)

        assert job_after_unit._max_runs == 3
        assert job_before_unit._max_runs == 3

    def test_max_runs_with_run_pending(self):
        mock_job = make_mock_job()
        with mock_datetime(2020, 1, 1, 10, 0, 0):
            job = every().second.max_runs(2).do(mock_job)

        with mock_datetime(2020, 1, 1, 10, 0, 1):
            schedule.run_pending()
        with mock_datetime(2020, 1, 1, 10, 0, 2):
            schedule.run_pending()
        with mock_datetime(2020, 1, 1, 10, 0, 3):
            schedule.run_pending()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_with_run_all(self):
        mock_job = make_mock_job()
        job = every().second.max_runs(2).do(mock_job)

        schedule.run_all()
        schedule.run_all()
        schedule.run_all()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_lowered_after_run_prevents_extra_execution(self):
        mock_job = make_mock_job()
        job = every().second.max_runs(5).do(mock_job)

        job.run()
        job.max_runs(1)
        schedule.run_all()

        assert mock_job.call_count == 1
        assert job.run_count == 1
        assert job not in schedule.jobs

    def test_max_runs_budget_limit_wins_before_until(self):
        mock_job = make_mock_job()
        with mock_datetime(2020, 1, 1, 11, 35, 10):
            job = (
                every()
                .second.max_runs(1)
                .until(datetime.time(11, 35, 20))
                .do(mock_job)
            )
            schedule.run_all()

        assert mock_job.call_count == 1
        assert job.run_count == 1
        assert job not in schedule.jobs

    def test_max_runs_until_limit_wins_before_budget(self):
        mock_job = make_mock_job()
        with mock_datetime(2020, 1, 1, 11, 35, 10):
            job = (
                every(5)
                .seconds.max_runs(3)
                .until(datetime.time(11, 35, 20))
                .do(mock_job)
            )

        with mock_datetime(2020, 1, 1, 11, 35, 15):
            schedule.run_pending()
        with mock_datetime(2020, 1, 1, 11, 35, 20):
            schedule.run_pending()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_removal_updates_next_run_and_idle_seconds(self):
        limited_job = make_mock_job("limited")
        remaining_job = make_mock_job("remaining")
        with mock_datetime(2020, 12, 9, 21, 46):
            every().second.max_runs(1).do(limited_job)
            remaining = every().hour.do(remaining_job)

            schedule.run_all()

            assert schedule.next_run() == remaining.next_run
            assert schedule.idle_seconds() == 60 * 60

    def test_max_runs_rejects_invalid_values(self):
        for value in (1.5, "1", None, 0, -1):
            with self.assertRaises(ScheduleValueError):
                every().max_runs(value)
            with self.assertRaises(ValueError):
                every().max_runs(value)

    def test_max_runs_last_call_wins_and_remains_chainable(self):
        mock_job = make_mock_job()
        job = every().max_runs(1).max_runs(2).seconds.do(mock_job)

        schedule.run_all()
        schedule.run_all()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_budgets_are_per_job(self):
        first_job = make_mock_job("first")
        second_job = make_mock_job("second")
        first = every().second.max_runs(1).do(first_job)
        second = every().second.max_runs(2).do(second_job)

        schedule.run_all()

        assert first_job.call_count == 1
        assert second_job.call_count == 1
        assert first not in schedule.jobs
        assert second in schedule.jobs

        schedule.run_all()

        assert second_job.call_count == 2
        assert second not in schedule.jobs

    def test_weekday_at_todady(self):
        mock_job = make_mock_job()

        # This date is a wednesday
        with mock_datetime(2020, 11, 25, 22, 38, 5):
            job = every().wednesday.at("22:38:10").do(mock_job)
            assert job.next_run.hour == 22
            assert job.next_run.minute == 38
            assert job.next_run.second == 10
            assert job.next_run.year == 2020
    def run(self):
        """
        Run the job and immediately reschedule it.
        If the job's deadline is reached (configured using .until()), the job is not
        run and CancelJob is returned immediately. If the next scheduled run exceeds
        the job's deadline, CancelJob is returned after the execution. In this latter
        case CancelJob takes priority over any other returned value.
        If the job's run budget (configured using .max_runs()) is reached by this
        execution, CancelJob is returned after the execution.

        :return: The return value returned by the `job_func`, or CancelJob if the job's
                 deadline or run budget is reached.

        """
        if self._is_overdue(datetime.datetime.now()):
            logger.debug("Cancelling job %s", self)
            return CancelJob
        if self._max_runs is not None and self.run_count >= self._max_runs:
            logger.debug("Cancelling job %s", self)
            return CancelJob

        logger.debug("Running job %s", self)
        ret = self.job_func()
        self.last_run = datetime.datetime.now()
        self._schedule_next_run()
        self.run_count += 1

        if self._is_overdue(self.next_run):
            logger.debug("Cancelling job %s", self)
            return CancelJob
        if self._max_runs is not None and self.run_count >= self._max_runs:
            logger.debug("Cancelling job %s", self)
            return CancelJob
        return ret


codex
Baseline confirms the reported invariant: the counter is incremented only after `job_func` returns. I’m keeping exception propagation unchanged and testing repeated scheduler invocation after the initial raised exception.
