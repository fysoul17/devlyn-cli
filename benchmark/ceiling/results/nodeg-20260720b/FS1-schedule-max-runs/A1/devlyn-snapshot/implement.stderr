+    def test_max_runs_with_run_all(self):
+        mock_job = make_mock_job()
+        job = every().second.max_runs(2).do(mock_job)
+
+        schedule.run_all()
+        schedule.run_all()
+        schedule.run_all()
+
+        assert mock_job.call_count == 2
+        assert job.run_count == 2
+        assert job not in schedule.jobs
+
+    def test_max_runs_budget_limit_wins_before_until(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            job = (
+                every()
+                .second.max_runs(1)
+                .until(datetime.time(11, 35, 20))
+                .do(mock_job)
