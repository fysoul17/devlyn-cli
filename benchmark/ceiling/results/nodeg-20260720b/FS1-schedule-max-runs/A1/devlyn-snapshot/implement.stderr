728-
729-        period = datetime.timedelta(**{self.unit: interval})
730-        if interval != 1:
731-            next_run += period
732-
733-        while next_run <= now:
734-            next_run += period
735-
736-        next_run = self._correct_utc_offset(
737-            next_run, fixate_time=(self.at_time is not None)
738-        )
739-
740-        # To keep the api consistent with older versions, we have to set the 'next_run' to a naive timestamp in the local timezone.
