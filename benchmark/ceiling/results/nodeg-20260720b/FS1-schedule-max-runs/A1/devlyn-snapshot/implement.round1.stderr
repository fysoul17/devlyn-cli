    def test_max_runs_chainability(self):
        mock_job = make_mock_job()

        job_after_unit = every(5).seconds.max_runs(3).do(mock_job)
        job_before_unit = every().max_runs(3).seconds.do(mock_job)

        assert job_after_unit._max_runs == 3
        assert job_before_unit._max_runs == 3

    def test_max_runs_with_run_pending(self):
        mock_job = make_mock_job()
        with mock_datetime(2020, 1, 1, 10, 0, 0):
            job = every().second.max_runs(2).do(mock_job)

        with mock_datetime(2020, 1, 1, 10, 0, 1):
            schedule.run_pending()
        with mock_datetime(2020, 1, 1, 10, 0, 2):
            schedule.run_pending()
        with mock_datetime(2020, 1, 1, 10, 0, 3):
            schedule.run_pending()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_with_run_all(self):
        mock_job = make_mock_job()
        job = every().second.max_runs(2).do(mock_job)

        schedule.run_all()
        schedule.run_all()
        schedule.run_all()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_budget_limit_wins_before_until(self):
        mock_job = make_mock_job()
        with mock_datetime(2020, 1, 1, 11, 35, 10):
            job = (
                every()
                .second.max_runs(1)
                .until(datetime.time(11, 35, 20))
                .do(mock_job)
            )
            schedule.run_all()

        assert mock_job.call_count == 1
        assert job.run_count == 1
        assert job not in schedule.jobs

    def test_max_runs_until_limit_wins_before_budget(self):
        mock_job = make_mock_job()
        with mock_datetime(2020, 1, 1, 11, 35, 10):
            job = (
                every(5)
                .seconds.max_runs(3)
                .until(datetime.time(11, 35, 20))
                .do(mock_job)
            )

        with mock_datetime(2020, 1, 1, 11, 35, 15):
            schedule.run_pending()
        with mock_datetime(2020, 1, 1, 11, 35, 20):
            schedule.run_pending()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_removal_updates_next_run_and_idle_seconds(self):
        limited_job = make_mock_job("limited")
        remaining_job = make_mock_job("remaining")
        with mock_datetime(2020, 12, 9, 21, 46):
            every().second.max_runs(1).do(limited_job)
            remaining = every().hour.do(remaining_job)

            schedule.run_all()

            assert schedule.next_run() == remaining.next_run
            assert schedule.idle_seconds() == 60 * 60

    def test_max_runs_rejects_invalid_values(self):
        for value in (1.5, "1", None, 0, -1):
            with self.assertRaises(ScheduleValueError):
                every().max_runs(value)

    def test_max_runs_last_call_wins_and_remains_chainable(self):
        mock_job = make_mock_job()
        job = every().max_runs(1).max_runs(2).seconds.do(mock_job)

        schedule.run_all()
        schedule.run_all()

        assert mock_job.call_count == 2
        assert job.run_count == 2
        assert job not in schedule.jobs

    def test_max_runs_budgets_are_per_job(self):
        first_job = make_mock_job("first")
        second_job = make_mock_job("second")
        first = every().second.max_runs(1).do(first_job)
        second = every().second.max_runs(2).do(second_job)

        schedule.run_all()

