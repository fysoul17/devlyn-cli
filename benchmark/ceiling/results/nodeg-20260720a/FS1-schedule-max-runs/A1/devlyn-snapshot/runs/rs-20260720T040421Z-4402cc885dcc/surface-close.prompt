+    def test_max_runs(self):
+        job = every(5).seconds.max_runs(3)
+        assert job._remaining_runs == 3
+        assert every().max_runs(3).seconds._remaining_runs == 3
+        assert job.max_runs(2) is job
+        assert job._remaining_runs == 2
+        assert every().max_runs(True)._remaining_runs == 1
+
+        for invalid_value in (0, -1, None, 1.5, "3"):
+            with self.assertRaises(ValueError):
+                every().max_runs(invalid_value)
+
+    def test_max_runs_cancels_after_budget_with_run_pending(self):
