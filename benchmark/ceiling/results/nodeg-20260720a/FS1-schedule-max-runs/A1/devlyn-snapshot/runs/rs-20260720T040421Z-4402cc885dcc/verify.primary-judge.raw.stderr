   691	    def run(self):
   692	        """
   693	        Run the job and immediately reschedule it.
   694	        If the job's deadline is reached (configured using .until()), the job is not
   695	        run and CancelJob is returned immediately. If the next scheduled run exceeds
   696	        the job's deadline, CancelJob is returned after the execution. In this latter
   697	        case CancelJob takes priority over any other returned value.
   698	
   699	        If the job has a run budget (configured using .max_runs()), CancelJob is
   700	        also returned once the budget is exhausted, after the run that used it up.
   701	
   702	        :return: The return value returned by the `job_func`, or CancelJob if the job's
   703	                 deadline or run budget is reached.
   704	
   705	        """
   706	        if self._is_overdue(datetime.datetime.now()):
   707	            logger.debug("Cancelling job %s", self)
   708	            return CancelJob
   709	
   710	        logger.debug("Running job %s", self)
   711	        if self._remaining_runs is not None:
   712	            self._remaining_runs -= 1
   713	        ret = self.job_func()
   714	        self.last_run = datetime.datetime.now()
   715	        self._schedule_next_run()
   716	
   717	        if self._remaining_runs is not None and self._remaining_runs <= 0:
   718	            logger.debug("Cancelling job %s", self)
   719	            return CancelJob
   720	
   721	        if self._is_overdue(self.next_run):
   722	            logger.debug("Cancelling job %s", self)
   723	            return CancelJob
   724	        return ret
