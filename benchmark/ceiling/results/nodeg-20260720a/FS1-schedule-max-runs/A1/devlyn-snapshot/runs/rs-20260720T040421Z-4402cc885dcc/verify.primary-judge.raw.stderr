   726	    def _schedule_next_run(self) -> None:
   727	        """
   728	        Compute the instant when this job should run next.
   729	        """
   730	        if self.unit not in ("seconds", "minutes", "hours", "days", "weeks"):
   731	            raise ScheduleValueError(
   732	                "Invalid unit (valid units are `seconds`, `minutes`, `hours`, "
   733	                "`days`, and `weeks`)"
   734	            )
   735	        if self.latest is not None:
   736	            if not (self.latest >= self.interval):
   737	                raise ScheduleError("`latest` is greater than `interval`")
   738	            interval = random.randint(self.interval, self.latest)
   739	        else:
   740	            interval = self.interval
   741	
   742	        # Do all computation in the context of the requested timezone
   743	        now = datetime.datetime.now(self.at_time_zone)
   744	
   745	        next_run = now
   746	
   747	        if self.start_day is not None:
   748	            if self.unit != "weeks":
   749	                raise ScheduleValueError("`unit` should be 'weeks'")
   750	            next_run = _move_to_next_weekday(next_run, self.start_day)
   751	
   752	        if self.at_time is not None:
   753	            next_run = self._move_to_at_time(next_run)
   754	
   755	        period = datetime.timedelta(**{self.unit: interval})
   756	        if interval != 1:
   757	            next_run += period
   758	
   759	        while next_run <= now:
   760	            next_run += period
   761	
   762	        next_run = self._correct_utc_offset(
   763	            next_run, fixate_time=(self.at_time is not None)
   764	        )
   765	
   766	        # To keep the api consistent with older versions, we have to set the 'next_run' to a naive timestamp in the local timezone.
   767	        # Because we want to stay backwards compatible with older versions.
   768	        if self.at_time_zone is not None:
   769	            # Convert back to the local timezone
   770	            next_run = next_run.astimezone()
   771	
   772	            next_run = next_run.replace(tzinfo=None)
   773	
   774	        self.next_run = next_run
