   579	    def until(
   580	        self,
   581	        until_time: Union[datetime.datetime, datetime.timedelta, datetime.time, str],
   582	    ):
   583	        """
   584	        Schedule job to run until the specified moment.
   585	
   586	        The job is canceled whenever the next run is calculated and it turns out the
   587	        next run is after the until_time. The job is also canceled right before it runs,
   588	        if the current time is after until_time. This latter case can happen when the
   589	        the job was scheduled to run before until_time, but runs after until_time.
   590	
   591	        If until_time is a moment in the past, ScheduleValueError is thrown.
   592	
   593	        :param until_time: A moment in the future representing the latest time a job can
   594	           be run. If only a time is supplied, the date is set to today.
   595	           The following formats are accepted:
   596	
   597	           - datetime.datetime
   598	           - datetime.timedelta
   599	           - datetime.time
   600	           - String in one of the following formats: "%Y-%m-%d %H:%M:%S",
   601	             "%Y-%m-%d %H:%M", "%Y-%m-%d", "%H:%M:%S", "%H:%M"
   602	             as defined by strptime() behaviour. If an invalid string format is passed,
   603	             ScheduleValueError is thrown.
   604	
   605	        :return: The invoked job instance
   606	        """
   607	
   608	        if isinstance(until_time, datetime.datetime):
   609	            self.cancel_after = until_time
   610	        elif isinstance(until_time, datetime.timedelta):
   611	            self.cancel_after = datetime.datetime.now() + until_time
   612	        elif isinstance(until_time, datetime.time):
   613	            self.cancel_after = datetime.datetime.combine(
   614	                datetime.datetime.now(), until_time
   615	            )
   616	        elif isinstance(until_time, str):
   617	            cancel_after = self._decode_datetimestr(
   618	                until_time,
   619	                [
   620	                    "%Y-%m-%d %H:%M:%S",
   621	                    "%Y-%m-%d %H:%M",
   622	                    "%Y-%m-%d",
   623	                    "%H:%M:%S",
   624	                    "%H:%M",
   625	                ],
   626	            )
   627	            if cancel_after is None:
   628	                raise ScheduleValueError("Invalid string format for until()")
   629	            if "-" not in until_time:
   630	                # the until_time is a time-only format. Set the date to today
   631	                now = datetime.datetime.now()
   632	                cancel_after = cancel_after.replace(
   633	                    year=now.year, month=now.month, day=now.day
   634	                )
   635	            self.cancel_after = cancel_after
   636	        else:
   637	            raise TypeError(
   638	                "until() takes a string, datetime.datetime, datetime.timedelta, "
   639	                "datetime.time parameter"
   640	            )
   641	        if self.cancel_after < datetime.datetime.now():
   642	            raise ScheduleValueError(
   643	                "Cannot schedule a job to run until a time in the past"
   644	            )
