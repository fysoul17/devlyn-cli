   197	    @property
   198	    def idle_seconds(self) -> Optional[float]:
   199	        """
   200	        :return: Number of seconds until
   201	                 :meth:`next_run <Scheduler.next_run>`
   202	                 or None if no jobs are scheduled
   203	        """
   204	        if not self.next_run:
   205	            return None
   206	        return (self.next_run - datetime.datetime.now()).total_seconds()
