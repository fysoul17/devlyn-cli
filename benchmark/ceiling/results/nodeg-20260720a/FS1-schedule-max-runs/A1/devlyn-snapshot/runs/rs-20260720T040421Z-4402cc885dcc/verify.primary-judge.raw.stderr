   942	def _move_to_next_weekday(moment: datetime.datetime, weekday: str):
   943	    """
   944	    Move the given timestamp to the nearest given weekday. May be this week
   945	    or next week. If the timestamp is already at the given weekday, it is not
   946	    moved.
   947	    """
   948	    weekday_index = _weekday_index(weekday)
   949	
   950	    days_ahead = weekday_index - moment.weekday()
   951	    if days_ahead < 0:
   952	        # Target day already happened this week, move to next week
   953	        days_ahead += 7
   954	    return moment + datetime.timedelta(days=days_ahead)
   955	
   956	
   957	def _weekday_index(day: str) -> int:
   958	    weekdays = (
   959	        "monday",
   960	        "tuesday",
   961	        "wednesday",
   962	        "thursday",
   963	        "friday",
   964	        "saturday",
   965	        "sunday",
   966	    )
   967	    if day not in weekdays:
   968	        raise ScheduleValueError(
   969	            "Invalid start day (valid start days are {})".format(weekdays)
   970	        )
   971	    return weekdays.index(day)

