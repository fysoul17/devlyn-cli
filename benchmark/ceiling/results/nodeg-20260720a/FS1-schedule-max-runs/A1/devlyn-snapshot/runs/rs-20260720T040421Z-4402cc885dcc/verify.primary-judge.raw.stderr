 succeeded in 0ms:
   210	    def my_job():
   211	        print('Foo')
   212	
   213	    # Run every 5 to 10 seconds.
   214	    schedule.every(5).to(10).seconds.do(my_job)
   215	
   216	``every(A).to(B).seconds`` executes the job function every N seconds such that A <= N <= B.
   217	
   218	
   219	Run a job until a certain time
   220	~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
   221	
   222	.. code-block:: python
   223	
   224	    import schedule
   225	    from datetime import datetime, timedelta, time
   226	
   227	    def job():
   228	        print('Boo')
   229	
   230	    # run job until a 18:30 today
   231	    schedule.every(1).hours.until("18:30").do(job)
   232	
   233	    # run job until a 2030-01-01 18:33 today
   234	    schedule.every(1).hours.until("2030-01-01 18:33").do(job)
   235	
   236	    # Schedule a job to run for the next 8 hours
   237	    schedule.every(1).hours.until(timedelta(hours=8)).do(job)
   238	
   239	    # Run my_job until today 11:33:42
   240	    schedule.every(1).hours.until(time(11, 33, 42)).do(job)
   241	
   242	    # run job until a specific datetime
   243	    schedule.every(1).hours.until(datetime(2020, 5, 17, 11, 36, 20)).do(job)
   244	
   245	The ``until`` method sets the jobs deadline. The job will not run after the deadline.
   246	
   247	Run a job a limited number of times
   248	~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
   249	
   250	.. code-block:: python
   251	
   252	    # Run the job three times, then remove it from the scheduler.
   253	    schedule.every().hour.max_runs(3).do(job)
   254	
   255	Time until the next execution
   256	~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
   257	Use ``schedule.idle_seconds()`` to get the number of seconds until the next job is scheduled to run.
   258	The returned value is negative if the next scheduled jobs was scheduled to run in the past.
   259	Returns ``None`` if no jobs are scheduled.
   260	
   261	.. code-block:: python
   262	
   263	    import schedule
   264	    import time
   265	
   266	    def job():
   267	        print('Hello')
   268	
   269	    schedule.every(5).seconds.do(job)
   270	
   271	    while 1:
   272	        n = schedule.idle_seconds()
   273	        if n is None:
   274	            # no more jobs
   275	            break

