   776	    def _move_to_at_time(self, moment: datetime.datetime) -> datetime.datetime:
   777	        """
   778	        Takes a datetime and moves the time-component to the job's at_time.
   779	        """
   780	        if self.at_time is None:
   781	            return moment
   782	
   783	        kwargs = {"second": self.at_time.second, "microsecond": 0}
   784	
   785	        if self.unit == "days" or self.start_day is not None:
   786	            kwargs["hour"] = self.at_time.hour
   787	
   788	        if self.unit in ["days", "hours"] or self.start_day is not None:
   789	            kwargs["minute"] = self.at_time.minute
   790	
   791	        moment = moment.replace(**kwargs)  # type: ignore
   792	
   793	        # When we set the time elements, we might end up in a different UTC-offset than the current offset.
   794	        # This happens when we cross into or out of daylight saving time.
   795	        moment = self._correct_utc_offset(moment, fixate_time=True)
   796	
   797	        return moment
   798	
   799	    def _correct_utc_offset(
   800	        self, moment: datetime.datetime, fixate_time: bool
   801	    ) -> datetime.datetime:
   802	        """
   803	        Given a datetime, corrects any mistakes in the utc offset.
   804	        This is similar to pytz' normalize, but adds the ability to attempt
   805	        keeping the time-component at the same hour/minute/second.
   806	        """
   807	        if self.at_time_zone is None:
   808	            return moment
   809	        # Normalize corrects the utc-offset to match the timezone
   810	        # For example: When a date&time&offset does not exist within a timezone,
   811	        # the normalization will change the utc-offset to where it is valid.
   812	        # It does this while keeping the moment in time the same, by moving the
   813	        # time component opposite of the utc-change.
   814	        offset_before_normalize = moment.utcoffset()
   815	        moment = self.at_time_zone.normalize(moment)
   816	        offset_after_normalize = moment.utcoffset()
   817	
   818	        if offset_before_normalize == offset_after_normalize:
   819	            # There was no change in the utc-offset, datetime didn't change.
   820	            return moment
   821	
   822	        # The utc-offset and time-component has changed
   823	
   824	        if not fixate_time:
   825	            # No need to fixate the time.
   826	            return moment
   827	
   828	        offset_diff = offset_after_normalize - offset_before_normalize
   829	
   830	        # Adjust the time to reset the date-time to have the same HH:mm components
   831	        moment -= offset_diff
   832	
   833	        # Check if moving the timestamp back by the utc-offset-difference made it end up
   834	        # in a moment that does not exist within the current timezone/utc-offset
   835	        re_normalized_offset = self.at_time_zone.normalize(moment).utcoffset()
   836	        if re_normalized_offset != offset_after_normalize:
   837	            # We ended up in a DST Gap. The requested 'at' time does not exist
   838	            # within the current timezone/utc-offset. As a best effort, we will
   839	            # schedule the job 1 offset later than possible.
   840	            # For example, if 02:23 does not exist (because DST moves from 02:00
   841	            # to 03:00), this will schedule the job at 03:23.
   842	            moment += offset_diff
   843	        return moment
