     def test_max_runs(self):
         job = every(5).seconds.max_runs(3)
         assert job._remaining_runs == 3
         assert every().max_runs(3).seconds._remaining_runs == 3
         assert job.max_runs(2) is job
         assert job._remaining_runs == 2
         assert every().max_runs(True)._remaining_runs == 1
 
         for invalid_value in (0, -1, None, 1.5, "3"):
             with self.assertRaises(ValueError):
                 every().max_runs(invalid_value)
 
     def test_max_runs_cancels_after_budget_with_run_pending(self):
         mock_job = make_mock_job()
         with mock_datetime(2020, 1, 1, 11, 35, 10):
             every(5).seconds.max_runs(2).do(mock_job)
             with mock_datetime(2020, 1, 1, 11, 35, 15):
                 schedule.run_pending()
                 assert mock_job.call_count == 1
                 assert len(schedule.jobs) == 1
             with mock_datetime(2020, 1, 1, 11, 35, 20):
                 schedule.run_pending()
                 assert mock_job.call_count == 2
                 assert len(schedule.jobs) == 0
             with mock_datetime(2020, 1, 1, 11, 35, 25):
                 schedule.run_pending()
                 assert mock_job.call_count == 2
 
     def test_max_runs_cancels_after_budget_with_run_all(self):
         first_job = make_mock_job("first_job")
         second_job = make_mock_job("second_job")
         every().second.max_runs(1).do(first_job)
         every().second.max_runs(2).do(second_job)
 
         schedule.run_all()
         assert first_job.call_count == 1
         assert second_job.call_count == 1
         assert len(schedule.jobs) == 1
 
         schedule.run_all()
         assert first_job.call_count == 1
         assert second_job.call_count == 2
         assert len(schedule.jobs) == 0
 
