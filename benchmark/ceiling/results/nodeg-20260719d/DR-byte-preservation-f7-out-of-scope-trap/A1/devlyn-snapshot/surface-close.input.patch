diff --git a/bin/cli.js b/bin/cli.js
index fcff156..ed906d6 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -41,6 +41,21 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseVersionFormat(argv) {
+  const idx = argv.indexOf('--format');
+  if (idx === -1) return;
+  const value = argv[idx + 1];
+  if (!value || value.startsWith('-')) {
+    console.error('--format requires a value');
+    process.exit(1);
+  }
+  if (value !== 'json') {
+    console.error(`Unsupported format: ${value}`);
+    process.exit(1);
+  }
+  return value;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -57,7 +72,9 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
+      const format = parseVersionFormat(rest);
+      const version = readPackageVersion();
+      console.log(format === 'json' ? JSON.stringify({ version }) : version);
       return;
     }
     default:
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..5fd9f88 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,16 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON when requested', () => {
+  const out = run(['version', '--format', 'json']);
+  const parsed = JSON.parse(out);
+  assert.match(parsed.version, /^\d+\.\d+\.\d+$/);
+});
+
+test('version rejects unsupported formats', () => {
+  assert.throws(
+    () => run(['version', '--format', 'yaml']),
+    (error) => error.status === 1,
+  );
+});
