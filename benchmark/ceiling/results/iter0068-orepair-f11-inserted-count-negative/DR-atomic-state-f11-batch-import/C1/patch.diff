+test('POST /items/import appends a fully valid request in order', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'gamma', qty: 1 },
+        { name: 'delta', qty: 2 },
+      ],
+    });
+    const after = await get(server, '/items');
+    const appended = after.body.items.slice(before.body.items.length);
+    assert.strictEqual(response.status, 201);
+    assert.deepStrictEqual(response.body, { inserted: 2 });
+    assert.deepStrictEqual(appended.map(({ name, qty }) => ({ name, qty })), [
+      { name: 'gamma', qty: 1 },
+      { name: 'delta', qty: 2 },
+    ]);
+    assert.strictEqual(new Set(after.body.items.map((item) => item.id)).size, after.body.items.length);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import leaves the list unchanged after an invalid middle item', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'valid-prefix', qty: 1 },
+        { name: 'bad', qty: 0 },
+        { name: 'valid-suffix', qty: 2 },
+      ],
+    });
+    const after = await get(server, '/items');
+    assert.strictEqual(response.status, 400);
+    assert.deepStrictEqual(response.body, { error: 'invalid_batch', index: 1, field: 'qty' });
+    assert.deepStrictEqual(after.body, before.body);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import rejects a missing items array without changing the list', async () => {
