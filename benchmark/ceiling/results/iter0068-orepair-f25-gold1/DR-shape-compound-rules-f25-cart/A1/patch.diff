 });
+
+test('cart success: combines duplicates, applies line promos, coupon, tax, shipping', () => {
+  const catalog = JSON.parse(fs.readFileSync(CATALOG_PATH, 'utf8'));
+  // Interleaved duplicates: TEE qty=3 (triggers buy_2_get_1_free),
+  // BAG qty=2 (triggers per_unit_discount_cents 500*2),
+  // MUG qty=1 (non-taxable / exempt).
+  const inputItems = [
+    { sku: 'TEE', qty: 2 },
+    { sku: 'MUG', qty: 1 },
+    { sku: 'BAG', qty: 1 },
+    { sku: 'TEE', qty: 1 },
+    { sku: 'BAG', qty: 1 },
+  ];
+  const cart = { state: 'CA', coupon: 'ORDER10', items: inputItems };
+  const tmpFile = writeTempCart(cart);
+
+  let stdout;
+  try {
+    stdout = run(['cart', '--input', tmpFile]);
+  } finally {
+    fs.unlinkSync(tmpFile);
+  }
+  const actual = JSON.parse(stdout);
+
+  // Recompute expected from catalog directly so it tracks seed changes.
+  const combined = [];
+  const bySku = new Map();
+  for (const row of inputItems) {
+    if (!bySku.has(row.sku)) {
+      const entry = { sku: row.sku, qty: 0 };
+      bySku.set(row.sku, entry);
+      combined.push(entry);
+    }
+    bySku.get(row.sku).qty += row.qty;
+  }
+  function lineDisc(sku, qty) {
+    const p = catalog.line_promotions.find((p) => p.sku === sku);
+    if (!p) return 0;
+    if (p.type === 'buy_x_get_y_free') {
+      return Math.floor(qty / (p.buy_qty + p.free_qty)) * p.free_qty * catalog.products[sku].unit_cents;
+    }
+    if (p.type === 'per_unit_discount_cents' && qty >= p.min_qty) {
+      return p.per_unit_discount_cents * qty;
+    }
+    return 0;
+  }
+  const items = combined.map(({ sku, qty }) => {
+    const product = catalog.products[sku];
+    const ls = product.unit_cents * qty;
+    const ld = lineDisc(sku, qty);
+    return { sku, qty, line_subtotal_cents: ls, line_discount_cents: ld, line_total_cents: ls - ld };
+  });
+  const subtotal_cents = items.reduce((n, i) => n + i.line_subtotal_cents, 0);
+  const line_discount_cents = items.reduce((n, i) => n + i.line_discount_cents, 0);
+  const postLine = subtotal_cents - line_discount_cents;
+  const cp = catalog.coupons.ORDER10;
+  const coupon_discount_cents = postLine >= cp.min_subtotal_cents ? Math.round(postLine * cp.percent / 100) : 0;
+  const taxableBase = items.reduce(
+    (n, i) => n + (catalog.taxable_codes[catalog.products[i.sku].tax_code] === true ? i.line_total_cents : 0),
+    0,
+  );
+  const tax_cents = Math.round(taxableBase * catalog.tax_rates.CA);
+  const shipping_cents = (postLine - coupon_discount_cents) >= catalog.free_shipping_min_cents ? 0 : catalog.shipping_cents;
+  const expected = {
+    subtotal_cents,
+    line_discount_cents,
+    coupon_discount_cents,
+    tax_cents,
+    shipping_cents,
+    total_cents: subtotal_cents - line_discount_cents - coupon_discount_cents + tax_cents + shipping_cents,
+    items,
+  };
+
+  assert.deepStrictEqual(actual, expected);
+  // First-seen ordering: TEE, MUG, BAG.
+  assert.deepStrictEqual(actual.items.map((i) => i.sku), ['TEE', 'MUG', 'BAG']);
+});
+
+test('cart failure: combined stock over emits invalid_stock JSON to stderr, exit 2, empty stdout', () => {
+  const catalog = JSON.parse(fs.readFileSync(CATALOG_PATH, 'utf8'));
+  const stock = catalog.products.BAG.stock;
+  const first = Math.max(1, stock - 1);
+  const second = stock + 1 - first;
+  const cart = {
+    state: 'CA',
+    coupon: null,
+    items: [
+      { sku: 'BAG', qty: first },
+      { sku: 'TEE', qty: 1 },
+      { sku: 'BAG', qty: second },
+    ],
+  };
+  const tmpFile = writeTempCart(cart);
+
+  let result;
+  try {
+    result = runCapture(['cart', '--input', tmpFile]);
+  } finally {
+    fs.unlinkSync(tmpFile);
+  }
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  const stderrLines = result.stderr.replace(/\n+$/, '').split('\n');
+  assert.strictEqual(stderrLines.length, 1, 'stderr must be exactly one JSON line');
+  const errObj = JSON.parse(stderrLines[0]);
+  assert.strictEqual(errObj.error, 'invalid_stock');
+  assert.strictEqual(errObj.sku, 'BAG');
+  assert.strictEqual(errObj.available, stock);
+  assert.strictEqual(errObj.requested, stock + 1);
+});
