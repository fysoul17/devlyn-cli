 function readPackageVersion() {
@@ -35,6 +37,162 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function emitError(errObj) {
+  process.stderr.write(JSON.stringify(errObj) + '\n');
+  process.exit(2);
+}
+
+function parseCartInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  if (idx === -1) emitError({ error: 'invalid_input', reason: 'missing --input flag' });
+  const value = argv[idx + 1];
+  if (!value || value.startsWith('-')) {
+    emitError({ error: 'invalid_input', reason: '--input requires a path value' });
+  }
+  return value;
+}
+
+function loadCatalog() {
+  const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
+  let raw;
+  try {
+    raw = fs.readFileSync(catalogPath, 'utf8');
+  } catch (err) {
+    emitError({ error: 'catalog_read_failed', reason: err.code || err.message });
+  }
+  try {
+    return JSON.parse(raw);
+  } catch (err) {
+    emitError({ error: 'catalog_invalid_json', reason: err.message });
+  }
+}
+
+function readCartFile(inputPath) {
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (err) {
+    emitError({ error: 'input_read_failed', reason: err.code || err.message, path: inputPath });
+  }
+  try {
+    return JSON.parse(raw);
+  } catch (err) {
+    emitError({ error: 'invalid_json', reason: err.message });
+  }
+}
+
+function validateCart(cart, catalog) {
+  if (!cart || typeof cart !== 'object' || Array.isArray(cart)) {
+    emitError({ error: 'invalid_input', reason: 'cart must be a JSON object' });
+  }
+  if (!Array.isArray(cart.items) || cart.items.length === 0) {
+    emitError({ error: 'invalid_input', reason: 'items must be a non-empty array' });
+  }
+  if (typeof cart.state !== 'string' || !Object.prototype.hasOwnProperty.call(catalog.tax_rates, cart.state)) {
+    emitError({ error: 'unknown_state', state: cart.state });
+  }
+  if (cart.coupon !== null && cart.coupon !== undefined) {
+    if (typeof cart.coupon !== 'string' || !Object.prototype.hasOwnProperty.call(catalog.coupons, cart.coupon)) {
+      emitError({ error: 'unknown_coupon', coupon: cart.coupon });
+    }
+  }
+  for (const row of cart.items) {
+    if (!row || typeof row !== 'object' || typeof row.sku !== 'string') {
+      emitError({ error: 'invalid_input', reason: 'each item must be an object with a string sku' });
+    }
+    if (!Object.prototype.hasOwnProperty.call(catalog.products, row.sku)) {
+      emitError({ error: 'unknown_sku', sku: row.sku });
+    }
+    if (!Number.isInteger(row.qty) || row.qty <= 0) {
+      emitError({ error: 'invalid_qty', sku: row.sku, qty: row.qty });
+    }
+  }
+}
+
+function combineItems(items) {
+  const bySku = new Map();
+  const order = [];
+  for (const row of items) {
+    if (!bySku.has(row.sku)) {
+      bySku.set(row.sku, 0);
+      order.push(row.sku);
+    }
+    bySku.set(row.sku, bySku.get(row.sku) + row.qty);
+  }
+  return order.map((sku) => ({ sku, qty: bySku.get(sku) }));
+}
+
+function computeLineDiscount(sku, qty, catalog) {
+  const promo = catalog.line_promotions.find((p) => p.sku === sku);
+  if (!promo) return 0;
+  const unitCents = catalog.products[sku].unit_cents;
+  if (promo.type === 'buy_x_get_y_free') {
+    return Math.floor(qty / (promo.buy_qty + promo.free_qty)) * promo.free_qty * unitCents;
+  }
+  if (promo.type === 'per_unit_discount_cents') {
+    if (qty >= promo.min_qty) return promo.per_unit_discount_cents * qty;
+    return 0;
+  }
+  return 0;
+}
+
+function priceCart(cart, catalog) {
+  const combined = combineItems(cart.items);
+
+  for (const { sku, qty } of combined) {
+    const stock = catalog.products[sku].stock;
+    if (qty > stock) {
+      emitError({ error: 'invalid_stock', sku, available: stock, requested: qty });
+    }
+  }
+
+  const items = combined.map(({ sku, qty }) => {
+    const product = catalog.products[sku];
+    const lineSubtotal = product.unit_cents * qty;
+    const lineDiscount = computeLineDiscount(sku, qty, catalog);
+    return {
+      sku,
+      qty,
+      line_subtotal_cents: lineSubtotal,
+      line_discount_cents: lineDiscount,
+      line_total_cents: lineSubtotal - lineDiscount,
+    };
+  });
+
+  const subtotalCents = items.reduce((n, i) => n + i.line_subtotal_cents, 0);
+  const lineDiscountCents = items.reduce((n, i) => n + i.line_discount_cents, 0);
+  const postLineCents = subtotalCents - lineDiscountCents;
+
+  const taxableBase = items.reduce((n, i) => {
+    const taxable = catalog.taxable_codes[catalog.products[i.sku].tax_code] === true;
+    return taxable ? n + i.line_total_cents : n;
+  }, 0);
+  const taxCents = Math.round(taxableBase * catalog.tax_rates[cart.state]);
+
+  let couponDiscountCents = 0;
+  if (cart.coupon) {
+    const coupon = catalog.coupons[cart.coupon];
+    if (postLineCents >= coupon.min_subtotal_cents) {
+      couponDiscountCents = Math.round((subtotalCents - lineDiscountCents) * coupon.percent / 100);
+    }
+  }
+
+  const postCouponCents = subtotalCents - lineDiscountCents - couponDiscountCents;
+  const shippingCents = postCouponCents >= catalog.free_shipping_min_cents ? 0 : catalog.shipping_cents;
+
+  const totalCents = subtotalCents - lineDiscountCents - couponDiscountCents + taxCents + shippingCents;
+
+  return {
+    subtotal_cents: subtotalCents,
+    line_discount_cents: lineDiscountCents,
+    coupon_discount_cents: couponDiscountCents,
+    tax_cents: taxCents,
+    shipping_cents: shippingCents,
+    total_cents: totalCents,
+    items,
+  };
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +211,15 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'cart': {
+      const inputPath = parseCartInputFlag(rest);
+      const catalog = loadCatalog();
+      const cart = readCartFile(inputPath);
+      validateCart(cart, catalog);
+      const result = priceCart(cart, catalog);
+      process.stdout.write(JSON.stringify(result) + '\n');
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
