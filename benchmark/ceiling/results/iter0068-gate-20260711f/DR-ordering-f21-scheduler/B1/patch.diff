+function scheduleError(message) {
+  return new Error(message);
+}
+
+function parseTime(value, field) {
+  if (typeof value !== 'string' || !/^([01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    throw scheduleError(`${field} must be an HH:MM time`);
+  }
+
+  const [hours, minutes] = value.split(':').map(Number);
+  return (hours * 60) + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function validateRange(range, field) {
+  if (!range || typeof range !== 'object' || Array.isArray(range)) {
+    throw scheduleError(`${field} must be an object with start and end`);
+  }
+
+  const start = parseTime(range.start, `${field}.start`);
+  const end = parseTime(range.end, `${field}.end`);
+  if (start >= end) {
+    throw scheduleError(`${field} must have an end after its start`);
+  }
+  return { start, end };
+}
+
+function validateScheduleInput(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input) ||
+      !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    throw scheduleError('input must contain resources and requests arrays');
+  }
+
+  const resources = new Map();
+  for (const [index, resource] of input.resources.entries()) {
+    const field = `resources[${index}]`;
+    if (!resource || typeof resource !== 'object' || Array.isArray(resource) ||
+        typeof resource.id !== 'string' || resource.id.length === 0 ||
+        !Array.isArray(resource.windows) || !Array.isArray(resource.blocked)) {
+      throw scheduleError(`${field} is invalid`);
+    }
+    if (resources.has(resource.id)) {
+      throw scheduleError(`duplicate resource id: ${resource.id}`);
+    }
+
+    resources.set(resource.id, {
+      windows: resource.windows.map((range, rangeIndex) =>
+        validateRange(range, `${field}.windows[${rangeIndex}]`)),
+      blocked: resource.blocked.map((range, rangeIndex) =>
+        validateRange(range, `${field}.blocked[${rangeIndex}]`)),
+      accepted: [],
+    });
+  }
+
+  const requestIds = new Set();
+  const requests = input.requests.map((request, index) => {
+    const field = `requests[${index}]`;
+    if (!request || typeof request !== 'object' || Array.isArray(request) ||
+        typeof request.id !== 'string' || request.id.length === 0 ||
+        typeof request.resource !== 'string' || request.resource.length === 0 ||
+        !Number.isInteger(request.duration_min) || request.duration_min <= 0 ||
+        typeof request.priority !== 'number' || !Number.isFinite(request.priority)) {
+      throw scheduleError(`${field} is invalid`);
+    }
+    if (requestIds.has(request.id)) {
+      throw scheduleError(`duplicate request id: ${request.id}`);
+    }
+    requestIds.add(request.id);
+
+    return {
+      id: request.id,
+      resource: request.resource,
+      start: parseTime(request.start, `${field}.start`),
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt: parseTime(request.submitted_at, `${field}.submitted_at`),
+      inputIndex: index,
+    };
+  });
+
+  return { resources, requests };
+}
+
+function rangesOverlap(start, end, range) {
+  return start < range.end && range.start < end;
+}
+
+function findEarliestStart(resource, request) {
+  const unavailable = resource.blocked.concat(resource.accepted);
+  let earliestStart = null;
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(window.start, request.start);
+
+    while ((candidate + request.duration) <= window.end) {
+      const conflict = unavailable.find((range) =>
+        rangesOverlap(candidate, candidate + request.duration, range));
+      if (!conflict) break;
+      candidate = conflict.end;
+    }
+
+    if ((candidate + request.duration) <= window.end &&
+        (earliestStart === null || candidate < earliestStart)) {
+      earliestStart = candidate;
+    }
+  }
+
+  return earliestStart;
+}
+
+function schedule(input) {
+  const { resources, requests } = validateScheduleInput(input);
+  const rejected = [];
+  const scheduled = [];
+  const orderedRequests = [...requests].sort((left, right) =>
+    right.priority - left.priority ||
+    left.submittedAt - right.submittedAt ||
+    left.id.localeCompare(right.id));
+
+  for (const request of orderedRequests) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const start = findEarliestStart(resource, request);
+    if (start === null) {
+      rejected.push({ id: request.id, reason: 'no_slot', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.accepted.push({ start, end });
+    scheduled.push({ id: request.id, resource: request.resource, start, end });
+  }
+
+  scheduled.sort((left, right) =>
+    left.start - right.start ||
+    left.resource.localeCompare(right.resource) ||
+    left.id.localeCompare(right.id));
+  rejected.sort((left, right) => left.inputIndex - right.inputIndex);
+
+  return {
+    scheduled: scheduled.map((item) => ({
+      id: item.id,
+      resource: item.resource,
+      start: formatTime(item.start),
+      end: formatTime(item.end),
+    })),
+    rejected: rejected.map(({ id, reason }) => ({ id, reason })),
+  };
+}
+
+function scheduleFromFile(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    throw scheduleError('schedule requires --input PATH');
+  }
+
+  let input;
+  try {
+    input = JSON.parse(fs.readFileSync(argv[1], 'utf8'));
+  } catch (error) {
+    if (error instanceof SyntaxError) {
+      throw scheduleError('input file contains invalid JSON');
+    }
+    throw scheduleError(`could not read input file: ${error.message}`);
+  }
+
+  return schedule(input);
+}
+
+function runSchedule(argv) {
+  try {
+    process.stdout.write(JSON.stringify(scheduleFromFile(argv)));
+  } catch (error) {
+    const message = error && error.message ? error.message : 'invalid schedule input';
+    process.stderr.write(`${JSON.stringify({ error: message })}\n`);
+    process.exitCode = 2;
+  }
+}
+
