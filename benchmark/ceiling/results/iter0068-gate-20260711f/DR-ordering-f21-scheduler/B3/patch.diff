 const { test } = require('node:test');
 const assert = require('node:assert');
-const { execFileSync } = require('node:child_process');
+const { execFileSync, spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,18 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function runSchedule(input) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-schedule-'));
+  const inputPath = path.join(directory, 'input.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+
+  try {
+    return spawnSync('node', [CLI, 'schedule', '--input', inputPath], { encoding: 'utf8' });
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +37,68 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('schedule assigns requests by priority and earliest available slot', () => {
+  const result = runSchedule({
+    resources: [{
+      id: 'room-a',
+      windows: [{ start: '09:00', end: '12:00' }],
+      blocked: [{ start: '10:00', end: '10:30' }],
+    }],
+    requests: [
+      {
+        id: 'later-submission', resource: 'room-a', start: '09:00', duration_min: 30,
+        priority: 1, submitted_at: '2026-07-11T09:01:00Z',
+      },
+      {
+        id: 'high-priority', resource: 'room-a', start: '09:00', duration_min: 60,
+        priority: 2, submitted_at: '2026-07-11T09:02:00Z',
+      },
+      {
+        id: 'early-submission', resource: 'room-a', start: '09:00', duration_min: 30,
+        priority: 1, submitted_at: '2026-07-11T09:00:00Z',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'high-priority', resource: 'room-a', start: '09:00', end: '10:00' },
+      { id: 'early-submission', resource: 'room-a', start: '10:30', end: '11:00' },
+      { id: 'later-submission', resource: 'room-a', start: '11:00', end: '11:30' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports unknown resources and requests with no slot', () => {
+  const result = runSchedule({
+    resources: [{
+      id: 'room-a',
+      windows: [['09:00', '10:00']],
+      blocked: [['09:30', '10:00']],
+    }],
+    requests: [
+      {
+        id: 'missing-resource', resource: 'room-b', start: '09:00', duration_min: 15,
+        priority: 3, submitted_at: '2026-07-11T09:00:00Z',
+      },
+      {
+        id: 'cannot-fit', resource: 'room-a', start: '09:00', duration_min: 45,
+        priority: 2, submitted_at: '2026-07-11T09:01:00Z',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [],
+    rejected: [
+      { id: 'missing-resource', reason: 'unknown_resource' },
+      { id: 'cannot-fit', reason: 'no_slot' },
+    ],
+  });
+});
