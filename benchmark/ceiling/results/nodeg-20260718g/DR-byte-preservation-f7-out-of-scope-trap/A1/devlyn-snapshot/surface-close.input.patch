diff --git a/bin/cli.js b/bin/cli.js
index fcff156..881141f 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -57,7 +57,15 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
+      if (rest.length === 0) {
+        console.log(readPackageVersion());
+        return;
+      }
+      if (rest.length !== 2 || rest[0] !== '--format' || rest[1] !== 'json') {
+        console.error('--format must be json');
+        process.exit(1);
+      }
+      console.log(JSON.stringify({ version: readPackageVersion() }));
       return;
     }
     default:
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..0dfc6de 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,20 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.strictEqual(out, '{"version":"0.1.0"}\n');
+});
+
+test('version rejects unsupported formats', () => {
+  let error;
+  try {
+    run(['version', '--format', 'yaml']);
+  } catch (caught) {
+    error = caught;
+  }
+  assert.ok(error);
+  assert.strictEqual(error.status, 1);
+  assert.match(error.stderr, /--format must be json/);
+});
