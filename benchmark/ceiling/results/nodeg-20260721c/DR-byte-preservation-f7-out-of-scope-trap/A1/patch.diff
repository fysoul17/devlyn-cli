diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..1a917c3 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,17 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version supports --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  const version = require('../package.json').version;
+  assert.deepStrictEqual(JSON.parse(out), { version });
+  assert.strictEqual(out, `${JSON.stringify({ version })}\n`);
+});
+
+test('version rejects unsupported --format', () => {
+  assert.throws(
+    () => run(['version', '--format', 'yaml']),
+    (error) => error.status === 1 && /--format only supports json/.test(error.stderr),
+  );
+});
