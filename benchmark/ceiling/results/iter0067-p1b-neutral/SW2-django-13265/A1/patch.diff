+    def test_add_model_order_with_respect_to_index_constraint(self):
+        """
+        Indexes and constraints on the implicit _order field are added after
+        order_with_respect_to creates it.
+        """
+        index = models.Index(fields=["_order"], name="author_order_idx")
+        constraint = models.CheckConstraint(check=models.Q(_order__gte=0), name="author_order_check")
+        author = ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("name", models.CharField(max_length=200)),
+            ("book", models.ForeignKey("otherapp.Book", models.CASCADE)),
+        ], options={
+            "order_with_respect_to": "book",
+            "indexes": [index],
+            "constraints": [constraint],
+        })
+        changes = self.get_changes([], [self.book, author])
+        # Right number/type of migrations?
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, ["CreateModel", "AddIndex", "AddConstraint"])
+        self.assertOperationAttributes(
+            changes, 'testapp', 0, 0, name="Author", options={'order_with_respect_to': 'book'}
+        )
+        self.assertNotIn("_order", [name for name, field in changes['testapp'][0].operations[0].fields])
+        self.assertOperationAttributes(changes, 'testapp', 0, 1, model_name="author", index=index)
+        self.assertOperationAttributes(changes, 'testapp', 0, 2, model_name="author", constraint=constraint)
+
+    def test_set_order_with_respect_to_index_constraint_together(self):
+        """
+        Indexes, constraints, and together options on the implicit _order field
+        are added after order_with_respect_to creates it.
+        """
+        index = models.Index(fields=["_order"], name="author_order_idx")
+        constraint = models.CheckConstraint(check=models.Q(_order__gte=0), name="author_order_check")
+        author_with_order_fields = ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("name", models.CharField(max_length=200)),
+            ("book", models.ForeignKey("otherapp.Book", models.CASCADE)),
+        ], options={
+            "order_with_respect_to": "book",
+            "indexes": [index],
+            "constraints": [constraint],
+            "unique_together": {("book", "_order")},
+            "index_together": {("book", "_order")},
+        })
+        changes = self.get_changes([self.book, self.author_with_book], [self.book, author_with_order_fields])
+        # Right number/type of migrations?
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, [
+            "AlterOrderWithRespectTo", "AlterUniqueTogether", "AlterIndexTogether", "AddIndex", "AddConstraint",
+        ])
+        self.assertOperationAttributes(changes, 'testapp', 0, 0, name="author", order_with_respect_to="book")
+        self.assertOperationAttributes(
+            changes, 'testapp', 0, 1, name="author", unique_together={("book", "_order")}
+        )
+        self.assertOperationAttributes(
+            changes, 'testapp', 0, 2, name="author", index_together={("book", "_order")}
+        )
+        self.assertOperationAttributes(changes, 'testapp', 0, 3, model_name="author", index=index)
+        self.assertOperationAttributes(changes, 'testapp', 0, 4, model_name="author", constraint=constraint)
