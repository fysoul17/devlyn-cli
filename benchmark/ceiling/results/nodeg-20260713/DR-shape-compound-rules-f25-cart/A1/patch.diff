diff --git a/bin/cli.js b/bin/cli.js
index 9cc9b24..ee6532b 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -35,6 +35,141 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function cartError(error) {
+  console.error(JSON.stringify(error));
+  process.exit(2);
+}
+
+function readCartInput(argv) {
+  const idx = argv.indexOf('--input');
+  const inputPath = idx === -1 ? undefined : argv[idx + 1];
+
+  if (!inputPath || inputPath.startsWith('-')) {
+    cartError({ error: 'invalid_input', message: '--input requires a value' });
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    cartError({ error: 'invalid_input', message: error.message });
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch (error) {
+    cartError({ error: 'invalid_json' });
+  }
+}
+
+function readCatalog() {
+  const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
+  return JSON.parse(fs.readFileSync(catalogPath, 'utf8'));
+}
+
+function hasOwn(object, key) {
+  return Object.prototype.hasOwnProperty.call(object, key);
+}
+
+function runCart(argv) {
+  const input = readCartInput(argv);
+  const catalog = readCatalog();
+
+  if (!input || !Array.isArray(input.items)) {
+    cartError({ error: 'missing_items' });
+  }
+
+  const originalItems = input.items;
+  for (const item of originalItems) {
+    const sku = item && typeof item === 'object' ? item.sku : null;
+    if (typeof sku !== 'string' || !hasOwn(catalog.products, sku)) {
+      cartError({ error: 'unknown_sku', sku });
+    }
+
+    const qty = item.qty;
+    if (!Number.isInteger(qty) || qty <= 0) {
+      cartError({ error: 'invalid_quantity', sku, qty: qty === undefined ? null : qty });
+    }
+  }
+
+  const couponName = input.coupon;
+  if (couponName !== null && couponName !== undefined
+    && (typeof couponName !== 'string' || !hasOwn(catalog.coupons, couponName))) {
+    cartError({ error: 'unknown_coupon', coupon: couponName });
+  }
+
+  const state = input.state;
+  if (typeof state !== 'string' || !hasOwn(catalog.tax_rates, state)) {
+    cartError({ error: 'unknown_state', state: state === undefined ? null : state });
+  }
+
+  const quantities = new Map();
+  for (const item of originalItems) {
+    quantities.set(item.sku, (quantities.get(item.sku) || 0) + item.qty);
+  }
+
+  for (const [sku, qty] of quantities) {
+    const product = catalog.products[sku];
+    if (qty > product.stock) {
+      cartError({ error: 'invalid_stock', sku, available: product.stock, requested: qty });
+    }
+  }
+
+  let subtotalCents = 0;
+  let lineDiscountCents = 0;
+  let taxablePostLineDiscountCents = 0;
+  const items = [];
+
+  for (const [sku, qty] of quantities) {
+    const product = catalog.products[sku];
+    const lineSubtotalCents = qty * product.unit_cents;
+    const promotion = catalog.line_promotions.find((entry) => entry.sku === sku);
+    let itemLineDiscountCents = 0;
+
+    if (promotion && promotion.type === 'buy_x_get_y_free') {
+      itemLineDiscountCents = Math.floor(qty / (promotion.buy_qty + promotion.free_qty))
+        * promotion.free_qty * product.unit_cents;
+    } else if (promotion && promotion.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
+      itemLineDiscountCents = promotion.per_unit_discount_cents * qty;
+    }
+
+    const lineTotalCents = lineSubtotalCents - itemLineDiscountCents;
+    subtotalCents += lineSubtotalCents;
+    lineDiscountCents += itemLineDiscountCents;
+    if (catalog.taxable_codes[product.tax_code] === true) {
+      taxablePostLineDiscountCents += lineTotalCents;
+    }
+    items.push({
+      sku,
+      qty,
+      line_subtotal_cents: lineSubtotalCents,
+      line_discount_cents: itemLineDiscountCents,
+      line_total_cents: lineTotalCents,
+    });
+  }
+
+  const postLineDiscountCents = subtotalCents - lineDiscountCents;
+  const coupon = couponName === null || couponName === undefined ? null : catalog.coupons[couponName];
+  const couponDiscountCents = coupon && postLineDiscountCents >= coupon.min_subtotal_cents
+    ? Math.round(postLineDiscountCents * coupon.percent / 100)
+    : 0;
+  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[state]);
+  const shippingCents = postLineDiscountCents - couponDiscountCents >= catalog.free_shipping_min_cents
+    ? 0
+    : catalog.shipping_cents;
+  const totalCents = postLineDiscountCents - couponDiscountCents + taxCents + shippingCents;
+
+  console.log(JSON.stringify({
+    subtotal_cents: subtotalCents,
+    line_discount_cents: lineDiscountCents,
+    coupon_discount_cents: couponDiscountCents,
+    tax_cents: taxCents,
+    shipping_cents: shippingCents,
+    total_cents: totalCents,
+    items,
+  }));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +188,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'cart': {
+      runCart(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
