+
+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  try {
+    const event = { id: 'evt-test-happy-001', type: 'order.created', timestamp: 1, data: {} };
+    const body = Buffer.from(JSON.stringify(event));
+    const response = await post(server, body, sign(body));
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  try {
+    const event = { id: 'evt-test-replay-001', type: 'order.created', timestamp: 1, data: {} };
+    const body = Buffer.from(JSON.stringify(event));
+    await post(server, body, sign(body));
+    const response = await post(server, body, sign(body));
+    assert.strictEqual(response.status, 409);
+    assert.deepStrictEqual(response.body, { error: 'duplicate_event', id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a tampered body with its original signature', async () => {
+  const server = await startServer();
+  try {
+    const event = { id: 'evt-test-tamper-001', type: 'order.created', timestamp: 1, data: {} };
+    const originalBody = Buffer.from(JSON.stringify(event));
+    const tamperedBody = Buffer.from(JSON.stringify({ ...event, data: { tampered: true } }));
+    const response = await post(server, tamperedBody, sign(originalBody));
+    assert.strictEqual(response.status, 401);
+    assert.deepStrictEqual(response.body, { error: 'invalid_signature' });
+  } finally {
+    server.close();
+  }
+});
