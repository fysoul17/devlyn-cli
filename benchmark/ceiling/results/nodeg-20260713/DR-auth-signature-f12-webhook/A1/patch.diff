+app.post('/webhook', (req, res) => {
+  const signature = req.get('X-Signature');
+  const expectedSignature = crypto.createHmac('sha256', webhookSecret).update(req.rawBody).digest();
+
+  if (
+    typeof signature !== 'string' ||
+    !/^[0-9a-f]{64}$/.test(signature) ||
+    !crypto.timingSafeEqual(expectedSignature, Buffer.from(signature, 'hex'))
+  ) {
+    return res.status(401).json({ error: 'invalid_signature' });
+  }
+
+  if (processedEventIds.has(req.body?.id)) {
+    return res.status(409).json({ error: 'duplicate_event', id: req.body.id });
+  }
+
+  const { id, type, timestamp, data } = req.body ?? {};
+  if (
+    typeof id !== 'string' ||
+    id.length === 0 ||
+    typeof type !== 'string' ||
+    type.length === 0 ||
+    typeof timestamp !== 'number' ||
+    typeof data !== 'object' ||
+    data === null ||
+    Array.isArray(data)
+  ) {
+    return res.status(400).json({ error: 'invalid_body' });
+  }
+
+  processedEventIds.add(id);
+  return res.json({ accepted: true, id });
+});
