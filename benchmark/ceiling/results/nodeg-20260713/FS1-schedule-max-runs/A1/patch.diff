+    def test_max_runs_until_and_scheduler_state(self):
+        mock_job = make_mock_job()
+
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            job = every().seconds.max_runs(2).until(datetime.time(11, 35, 20)).do(
+                mock_job
+            )
+            schedule.run_all()
+            schedule.run_all()
+            assert mock_job.call_count == 2
+            assert job.run_count == 2
+            assert len(schedule.jobs) == 0
+            assert schedule.next_run() is None
+            assert schedule.idle_seconds() is None
+
+        schedule.clear()
+        mock_job.reset_mock()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            job = every().seconds.max_runs(3).until(datetime.time(11, 35, 12)).do(
+                mock_job
+            )
+        with mock_datetime(2020, 1, 1, 11, 35, 11):
+            schedule.run_pending()
+            assert mock_job.call_count == 1
+            assert job.run_count == 1
