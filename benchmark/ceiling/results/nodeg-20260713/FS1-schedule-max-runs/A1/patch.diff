+    def test_max_runs_reconfiguration_and_isolation(self):
+        mock_job = make_mock_job()
+        job = every().second.max_runs(3).do(mock_job)
+        schedule.run_all()
+        job.max_runs(2)
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert job.run_count == 2
+        assert len(schedule.jobs) == 0
+
+        scheduler = schedule.Scheduler()
+        first_job = make_mock_job()
+        second_job = make_mock_job()
+        scheduler.every().second.max_runs(1).do(first_job)
+        scheduler.every().second.max_runs(2).do(second_job)
+        scheduler.run_all()
+        assert first_job.call_count == 1
+        assert second_job.call_count == 1
+        assert len(scheduler.jobs) == 1
+        scheduler.run_all()
+        assert first_job.call_count == 1
+        assert second_job.call_count == 2
+        assert len(scheduler.jobs) == 0
+
+    def test_max_runs_downward_reconfiguration_cancels_before_execution(self):
+        scheduler = schedule.Scheduler()
+        mock_job = make_mock_job()
+        job = scheduler.every().second.max_runs(3).do(mock_job)
+        scheduler.run_all()
+        scheduler.run_all()
+        assert mock_job.call_count == 2
+
+        job.max_runs(1)
+        scheduler.run_all()
+
+        assert mock_job.call_count == 2
+        assert len(scheduler.jobs) == 0
