 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  fulfill-wave --input PATH  Allocate orders from warehouse lots
   --help, -h                 Show this help
 
 Examples:
@@ -35,6 +36,197 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function isObject(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function isNonEmptyString(value) {
+  return typeof value === 'string' && value.length > 0;
+}
+
+function isPositiveInteger(value) {
+  return typeof value === 'number' && Number.isInteger(value) && value > 0;
+}
+
+function isValidExpiry(value) {
+  if (typeof value !== 'string') return false;
+
+  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
+  if (!match) return false;
+
+  const [, year, month, day] = match.map(Number);
+  const date = new Date(0);
+  date.setUTCFullYear(year, month - 1, day);
+  return date.getUTCFullYear() === year
+    && date.getUTCMonth() === month - 1
+    && date.getUTCDate() === day;
+}
+
+function submittedAtMilliseconds(value) {
+  return /^\d+$/.test(value) ? BigInt(value) : Date.parse(value);
+}
+
+function compareStrings(a, b) {
+  if (a === b) return 0;
+  return a < b ? -1 : 1;
+}
+
+function validateFulfillWaveInput(input) {
+  if (!isObject(input) || !Array.isArray(input.warehouses) || !Array.isArray(input.orders)) {
+    throw new Error('input must contain warehouses and orders arrays');
+  }
+
+  for (const warehouse of input.warehouses) {
+    if (!isObject(warehouse)
+      || !isNonEmptyString(warehouse.id)
+      || !Number.isFinite(warehouse.distance)
+      || !Array.isArray(warehouse.lots)) {
+      throw new Error('invalid warehouse');
+    }
+
+    for (const lot of warehouse.lots) {
+      if (!isObject(lot)
+        || !isNonEmptyString(lot.sku)
+        || !isNonEmptyString(lot.lot)
+        || !isPositiveInteger(lot.qty)
+        || !isValidExpiry(lot.expires)) {
+        throw new Error('invalid lot');
+      }
+    }
+  }
+
+  const orderIds = new Set();
+  for (const order of input.orders) {
+    if (!isObject(order)
+      || !isNonEmptyString(order.id)
+      || !Number.isFinite(order.priority)
+      || typeof order.submitted_at !== 'string'
+      || Number.isNaN(submittedAtMilliseconds(order.submitted_at))
+      || !Array.isArray(order.lines)
+      || orderIds.has(order.id)) {
+      throw new Error('invalid order');
+    }
+    orderIds.add(order.id);
+
+    for (const line of order.lines) {
+      if (!isObject(line)
+        || !isNonEmptyString(line.sku)
+        || !isPositiveInteger(line.qty)
+        || typeof line.single_warehouse !== 'boolean') {
+        throw new Error('invalid line');
+      }
+    }
+  }
+}
+
+function sortedWarehouses(warehouses) {
+  return [...warehouses].sort((a, b) => {
+    if (a.distance !== b.distance) return a.distance < b.distance ? -1 : 1;
+    return compareStrings(a.id, b.id);
+  });
+}
+
+function sortedLots(warehouse, sku) {
+  return warehouse.lots
+    .filter((lot) => lot.sku === sku && lot.qty > 0)
+    .sort((a, b) => compareStrings(a.expires, b.expires) || compareStrings(a.lot, b.lot));
+}
+
+function consumeLots(warehouse, sku, quantity, allocations, deductions) {
+  let needed = quantity;
+
+  for (const lot of sortedLots(warehouse, sku)) {
+    if (needed === 0) break;
+    const drawn = Math.min(needed, lot.qty);
+    lot.qty -= drawn;
+    needed -= drawn;
+    deductions.push({ lot, qty: drawn });
+    allocations.push({ sku, warehouse: warehouse.id, lot: lot.lot, qty: drawn });
+  }
+
+  return needed;
+}
+
+function allocateLine(line, warehouses, allocations, deductions) {
+  if (line.single_warehouse) {
+    for (const warehouse of warehouses) {
+      const available = sortedLots(warehouse, line.sku)
+        .reduce((total, lot) => total + lot.qty, 0);
+      if (available >= line.qty) {
+        return consumeLots(warehouse, line.sku, line.qty, allocations, deductions) === 0;
+      }
+    }
+    return false;
+  }
+
+  let needed = line.qty;
+  for (const warehouse of warehouses) {
+    needed = consumeLots(warehouse, line.sku, needed, allocations, deductions);
+    if (needed === 0) return true;
+  }
+  return false;
+}
+
+function fulfillWave(input) {
+  const warehouses = sortedWarehouses(input.warehouses);
+  const orders = [...input.orders].sort((a, b) => {
+    if (a.priority !== b.priority) return a.priority > b.priority ? -1 : 1;
+
+    const aSubmitted = submittedAtMilliseconds(a.submitted_at);
+    const bSubmitted = submittedAtMilliseconds(b.submitted_at);
+    if (aSubmitted < bSubmitted) return -1;
+    if (aSubmitted > bSubmitted) return 1;
+    return compareStrings(a.id, b.id);
+  });
+  const accepted = [];
+  const rejectedIds = new Set();
+
+  for (const order of orders) {
+    const allocations = [];
+    const deductions = [];
+    const acceptedOrder = order.lines.every((line) => allocateLine(line, warehouses, allocations, deductions));
+
+    if (acceptedOrder) {
+      accepted.push({ id: order.id, allocations });
+      continue;
+    }
+
+    for (const deduction of deductions) {
+      deduction.lot.qty += deduction.qty;
+    }
+    rejectedIds.add(order.id);
+  }
+
+  const remaining = input.warehouses
+    .flatMap((warehouse) => warehouse.lots
+      .filter((lot) => lot.qty > 0)
+      .map((lot) => ({ warehouse: warehouse.id, sku: lot.sku, lot: lot.lot, qty: lot.qty, expires: lot.expires })))
+    .sort((a, b) => compareStrings(a.warehouse, b.warehouse)
+      || compareStrings(a.sku, b.sku)
+      || compareStrings(a.expires, b.expires)
+      || compareStrings(a.lot, b.lot));
+
+  return {
+    accepted,
+    rejected: input.orders
+      .filter((order) => rejectedIds.has(order.id))
+      .map((order) => ({ id: order.id, reason: 'insufficient_stock' })),
+    remaining
+  };
+}
+
+function runFulfillWave(argv) {
+  const inputIndex = argv.indexOf('--input');
+  const inputPath = argv[inputIndex + 1];
+  if (inputIndex === -1 || !inputPath) {
+    throw new Error('--input requires a path');
+  }
+
+  const input = JSON.parse(fs.readFileSync(inputPath, 'utf8'));
+  validateFulfillWaveInput(input);
+  console.log(JSON.stringify(fulfillWave(input)));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +245,15 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'fulfill-wave': {
+      try {
+        runFulfillWave(rest);
+      } catch (error) {
+        process.stderr.write(`${JSON.stringify({ error: error.message })}\n`);
+        process.exitCode = 2;
+      }
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
