+
+test('fulfill-wave accepts an allocation using FEFO lots', () => {
+  const result = runFulfillWave({
+    warehouses: [{
+      id: 'west',
+      distance: 1,
+      lots: [
+        { sku: 'widget', lot: 'later', qty: 4, expires: '2025-02-01' },
+        { sku: 'widget', lot: 'early', qty: 3, expires: '2025-01-01' }
+      ]
+    }],
+    orders: [{
+      id: 'order-1',
+      priority: 1,
+      submitted_at: '2024-01-01T00:00:00Z',
+      lines: [{ sku: 'widget', qty: 5, single_warehouse: false }]
+    }]
+  });
+
+  assert.deepStrictEqual(result, {
+    accepted: [{
+      id: 'order-1',
+      allocations: [
+        { sku: 'widget', warehouse: 'west', lot: 'early', qty: 3 },
+        { sku: 'widget', warehouse: 'west', lot: 'later', qty: 2 }
+      ]
+    }],
+    rejected: [],
+    remaining: [{ warehouse: 'west', sku: 'widget', lot: 'later', qty: 2, expires: '2025-02-01' }]
+  });
+});
+
+test('fulfill-wave rolls back a rejected all-or-nothing order', () => {
+  const result = runFulfillWave({
+    warehouses: [{
+      id: 'west',
+      distance: 1,
+      lots: [{ sku: 'widget', lot: 'one', qty: 5, expires: '2025-01-01' }]
+    }],
+    orders: [
+      {
+        id: 'rejected-first',
+        priority: 2,
+        submitted_at: '2024-01-01T00:00:00Z',
+        lines: [
+          { sku: 'widget', qty: 5, single_warehouse: false },
+          { sku: 'missing', qty: 1, single_warehouse: false }
+        ]
+      },
+      {
+        id: 'accepted-after-rollback',
+        priority: 1,
+        submitted_at: '2024-01-02T00:00:00Z',
+        lines: [{ sku: 'widget', qty: 5, single_warehouse: false }]
+      }
+    ]
+  });
+
+  assert.deepStrictEqual(result, {
+    accepted: [{
+      id: 'accepted-after-rollback',
+      allocations: [{ sku: 'widget', warehouse: 'west', lot: 'one', qty: 5 }]
+    }],
+    rejected: [{ id: 'rejected-first', reason: 'insufficient_stock' }],
+    remaining: []
+  });
+});
