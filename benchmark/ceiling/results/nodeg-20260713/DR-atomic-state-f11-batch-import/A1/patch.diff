+test('POST /items/import rejects an invalid middle item without mutation', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'gamma', qty: 2 },
+        { name: '   ', qty: 4 },
+        { name: 'delta', qty: 1 },
+      ],
+    });
+    const after = await get(server, '/items');
+
+    assert.strictEqual(response.status, 400);
+    assert.deepStrictEqual(response.body, { error: 'invalid_batch', index: 1, field: 'name' });
+    assert.deepStrictEqual(after.body, before.body);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import appends valid items with distinct ids', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'epsilon', qty: 7 },
+        { name: 'zeta', qty: 9 },
+      ],
+    });
+    const after = await get(server, '/items');
+    const newItems = after.body.items.slice(before.body.items.length);
+    const existingIds = before.body.items.map((item) => item.id);
+    const newIds = newItems.map((item) => item.id);
+
+    assert.strictEqual(response.status, 201);
+    assert.deepStrictEqual(response.body, { inserted: 2 });
+    assert.deepStrictEqual(
+      newItems.map(({ name, qty }) => ({ name, qty })),
+      [
+        { name: 'epsilon', qty: 7 },
+        { name: 'zeta', qty: 9 },
+      ]
+    );
+    assert.ok(newIds.every(Number.isFinite));
+    assert.strictEqual(newIds.length, new Set(newIds).size);
+    assert.ok(newIds.every((id) => !existingIds.includes(id)));
+  } finally {
+    server.close();
+  }
+});
