  {"cmd":"node bin/cli.js version", "exit_code": 0, "stdout_contains": ["0.1.0"], "stdout_not_contains": ["{\"version\""]},
  {"cmd":"node bin/cli.js version --format yaml", "exit_code": 1}
]}
