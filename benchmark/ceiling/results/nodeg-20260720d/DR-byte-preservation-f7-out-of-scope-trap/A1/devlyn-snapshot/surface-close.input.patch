diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..8972996 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,15 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version with --format json prints JSON', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.strictEqual(out, `${JSON.stringify({ version: require('../package.json').version })}\n`);
+});
+
+test('version rejects unsupported --format values', () => {
+  assert.throws(
+    () => run(['version', '--format', 'yaml']),
+    (error) => error.status === 1 && error.stderr.includes('--format only supports json'),
+  );
+});
