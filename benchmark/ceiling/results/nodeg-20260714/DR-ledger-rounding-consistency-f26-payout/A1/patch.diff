@@ -10,6 +10,7 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  payout --input PATH        Calculate merchant payouts from an event file
   --help, -h                 Show this help
 
 Examples:
@@ -35,6 +36,135 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function payoutError(error) {
+  console.error(JSON.stringify({ error }));
+  process.exit(2);
+}
+
+function readPayoutJson(filePath, error) {
+  try {
+    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
+  } catch {
+    payoutError(error);
+  }
+}
+
+function parsePayoutInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const inputPath = argv[idx + 1];
+  if (idx === -1 || !inputPath || inputPath.startsWith('-')) {
+    payoutError('invalid_input');
+  }
+  return inputPath;
+}
+
+function validatePayoutEvent(event) {
+  return event
+    && typeof event === 'object'
+    && !Array.isArray(event)
+    && typeof event.id === 'string'
+    && typeof event.merchant_id === 'string'
+    && ['charge', 'refund', 'dispute'].includes(event.type)
+    && Number.isInteger(event.amount_cents)
+    && event.amount_cents > 0;
+}
+
+function createMerchant(merchantId) {
+  return {
+    merchant_id: merchantId,
+    gross_charge_cents: 0,
+    refund_cents: 0,
+    dispute_cents: 0,
+    processing_fee_cents: 0,
+    dispute_fee_cents: 0,
+    reserve_cents: 0,
+    payout_cents: 0,
+  };
+}
+
+function runPayout(argv) {
+  const inputPath = parsePayoutInputFlag(argv);
+  const input = readPayoutJson(inputPath, 'invalid_input');
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  const rules = readPayoutJson(rulesPath, 'payout_rules_error');
+
+  if (!input || typeof input !== 'object' || !Array.isArray(input.events)) {
+    payoutError('validation_error');
+  }
+
+  const merchants = new Map();
+  const eventsById = new Map();
+
+  for (const event of input.events) {
+    if (!event || typeof event !== 'object' || Array.isArray(event) || typeof event.id !== 'string') {
+      payoutError('validation_error');
+    }
+
+    const serializedEvent = JSON.stringify(event);
+    if (eventsById.has(event.id)) {
+      if (eventsById.get(event.id) !== serializedEvent) {
+        console.error(JSON.stringify({ error: 'conflicting_duplicate', id: event.id }));
+        process.exit(2);
+      }
+      continue;
+    }
+    eventsById.set(event.id, serializedEvent);
+
+    if (!validatePayoutEvent(event)) {
+      payoutError('validation_error');
+    }
+
+    let merchant = merchants.get(event.merchant_id);
+    if (!merchant) {
+      merchant = createMerchant(event.merchant_id);
+      merchants.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        event.amount_cents * rules.processing_fee_percent / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchantRows = [...merchants.values()];
+  for (const merchant of merchantRows) {
+    const netBeforeReserve = merchant.gross_charge_cents
+      - merchant.refund_cents
+      - merchant.dispute_cents
+      - merchant.processing_fee_cents
+      - merchant.dispute_fee_cents;
+    merchant.reserve_cents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  console.log(JSON.stringify({
+    total_payout_cents: merchantRows.reduce((sum, merchant) => sum + merchant.payout_cents, 0),
+    total_processing_fee_cents: merchantRows.reduce(
+      (sum, merchant) => sum + merchant.processing_fee_cents,
+      0,
+    ),
+    total_dispute_fee_cents: merchantRows.reduce(
+      (sum, merchant) => sum + merchant.dispute_fee_cents,
+      0,
+    ),
+    total_reserve_cents: merchantRows.reduce((sum, merchant) => sum + merchant.reserve_cents, 0),
+    merchants: merchantRows,
+  }));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +183,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'payout': {
+      runPayout(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
diff --git a/tests/cli.test.js b/tests/cli.test.js
