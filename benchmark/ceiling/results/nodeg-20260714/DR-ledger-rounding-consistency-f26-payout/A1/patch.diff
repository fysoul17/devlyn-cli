--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
 const { execFileSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,14 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function writeInput(t, input) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  const inputPath = path.join(directory, 'input.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+  t.after(() => fs.rmSync(directory, { recursive: true, force: true }));
+  return inputPath;
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +33,63 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('payout calculates payouts from unique events', (t) => {
+  const inputPath = writeInput(t, {
+    events: [
+      { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+      { id: 'refund-a', merchant_id: 'merchant-a', type: 'refund', amount_cents: 500 },
+      { id: 'dispute-a', merchant_id: 'merchant-a', type: 'dispute', amount_cents: 200 },
+      { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+      { id: 'charge-b', merchant_id: 'merchant-b', type: 'charge', amount_cents: 1100 },
+    ],
+  });
+
+  const out = run(['payout', '--input', inputPath]);
+  assert.deepStrictEqual(JSON.parse(out), {
+    total_payout_cents: 6732,
+    total_processing_fee_cents: 382,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 1786,
+    merchants: [
+      {
+        merchant_id: 'merchant-a',
+        gross_charge_cents: 10000,
+        refund_cents: 500,
+        dispute_cents: 200,
+        processing_fee_cents: 320,
+        dispute_fee_cents: 1500,
+        reserve_cents: 748,
+        payout_cents: 6732,
+      },
+      {
+        merchant_id: 'merchant-b',
+        gross_charge_cents: 1100,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 62,
+        dispute_fee_cents: 0,
+        reserve_cents: 1038,
+        payout_cents: 0,
+      },
+    ],
+  });
+});
+
+test('payout writes validation errors as JSON to stderr', (t) => {
+  const inputPath = writeInput(t, {
+    events: [
+      { id: 'event-a', merchant_id: 'merchant-a', type: 'transfer', amount_cents: 100 },
+    ],
+  });
+
+  assert.throws(
+    () => run(['payout', '--input', inputPath]),
+    (error) => {
+      assert.strictEqual(error.status, 2);
+      assert.strictEqual(error.stdout, '');
+      assert.deepStrictEqual(JSON.parse(error.stderr), { error: 'validation_error' });
+      return true;
+    },
+  );
+});
