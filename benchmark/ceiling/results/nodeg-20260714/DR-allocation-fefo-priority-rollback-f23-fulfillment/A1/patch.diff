diff --git a/bin/cli.js b/bin/cli.js
index 9cc9b24..c5c131e 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -35,6 +35,202 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const value = argv[idx + 1];
+  if (idx === -1 || !value) {
+    throw new Error('--input requires a path');
+  }
+  return value;
+}
+
+function compareText(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function compareWarehouses(left, right) {
+  return left.distance - right.distance || compareText(left.id, right.id);
+}
+
+function compareLots(left, right) {
+  return compareText(left.expires, right.expires) || compareText(left.lot, right.lot);
+}
+
+function isNonEmptyString(value) {
+  return typeof value === 'string' && value.length > 0;
+}
+
+function isValidDate(value) {
+  if (typeof value !== 'string') return false;
+  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
+  if (!match) return false;
+
+  const year = Number(match[1]);
+  const month = Number(match[2]);
+  const day = Number(match[3]);
+  const date = new Date(Date.UTC(year, month - 1, day));
+  if (year <= 99) date.setUTCFullYear(year);
+  return date.getUTCFullYear() === year
+    && date.getUTCMonth() === month - 1
+    && date.getUTCDate() === day;
+}
+
+function validateInput(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)) {
+    throw new Error('input must be an object');
+  }
+  if (!Array.isArray(input.warehouses) || !Array.isArray(input.orders)) {
+    throw new Error('warehouses and orders must be arrays');
+  }
+
+  for (const warehouse of input.warehouses) {
+    if (!warehouse || typeof warehouse !== 'object' || Array.isArray(warehouse)) {
+      throw new Error('warehouse must be an object');
+    }
+    if (!isNonEmptyString(warehouse.id) || typeof warehouse.distance !== 'number'
+      || !Array.isArray(warehouse.lots)) {
+      throw new Error('warehouse is invalid');
+    }
+
+    for (const lot of warehouse.lots) {
+      if (!lot || typeof lot !== 'object' || Array.isArray(lot)) {
+        throw new Error('lot must be an object');
+      }
+      if (!isNonEmptyString(lot.sku) || !isNonEmptyString(lot.lot)
+        || !Number.isInteger(lot.qty) || lot.qty <= 0 || !isValidDate(lot.expires)) {
+        throw new Error('lot is invalid');
+      }
+    }
+  }
+
+  const orderIds = new Set();
+  for (const order of input.orders) {
+    if (!order || typeof order !== 'object' || Array.isArray(order)) {
+      throw new Error('order must be an object');
+    }
+    if (!isNonEmptyString(order.id) || typeof order.priority !== 'number'
+      || typeof order.submitted_at !== 'string' || Number.isNaN(Date.parse(order.submitted_at))
+      || !Array.isArray(order.lines)) {
+      throw new Error('order is invalid');
+    }
+    if (orderIds.has(order.id)) {
+      throw new Error('order ids must be unique');
+    }
+    orderIds.add(order.id);
+
+    for (const line of order.lines) {
+      if (!line || typeof line !== 'object' || Array.isArray(line)) {
+        throw new Error('line must be an object');
+      }
+      if (!isNonEmptyString(line.sku) || !Number.isInteger(line.qty) || line.qty <= 0
+        || typeof line.single_warehouse !== 'boolean') {
+        throw new Error('line is invalid');
+      }
+    }
+  }
+}
+
+function matchingQuantity(warehouse, sku) {
+  return warehouse.lots.reduce(
+    (total, lot) => total + (lot.sku === sku ? lot.qty : 0),
+    0,
+  );
+}
+
+function drawFromWarehouse(warehouse, sku, qty, allocations, deductions) {
+  let remaining = qty;
+  const lots = warehouse.lots.filter((lot) => lot.sku === sku && lot.qty > 0).sort(compareLots);
+
+  for (const lot of lots) {
+    if (remaining === 0) break;
+    const taken = Math.min(lot.qty, remaining);
+    lot.qty -= taken;
+    remaining -= taken;
+    allocations.push({ sku, warehouse: warehouse.id, lot: lot.lot, qty: taken });
+    deductions.push({ lot, qty: taken });
+  }
+}
+
+function fulfillWave(input) {
+  const warehouses = [...input.warehouses].sort(compareWarehouses);
+  const orders = input.orders
+    .map((order, index) => ({ order, index }))
+    .sort((left, right) => right.order.priority - left.order.priority
+      || Date.parse(left.order.submitted_at) - Date.parse(right.order.submitted_at)
+      || compareText(left.order.id, right.order.id));
+  const accepted = [];
+  const failed = [];
+
+  for (const { order, index } of orders) {
+    const allocations = [];
+    const deductions = [];
+    let rejected = false;
+
+    for (const line of order.lines) {
+      if (line.single_warehouse) {
+        const warehouse = warehouses.find((candidate) => matchingQuantity(candidate, line.sku) >= line.qty);
+        if (!warehouse) {
+          rejected = true;
+          break;
+        }
+        drawFromWarehouse(warehouse, line.sku, line.qty, allocations, deductions);
+        continue;
+      }
+
+      const total = warehouses.reduce(
+        (sum, warehouse) => sum + matchingQuantity(warehouse, line.sku),
+        0,
+      );
+      if (total < line.qty) {
+        rejected = true;
+        break;
+      }
+
+      let remaining = line.qty;
+      for (const warehouse of warehouses) {
+        const available = matchingQuantity(warehouse, line.sku);
+        const taken = Math.min(available, remaining);
+        if (taken > 0) {
+          drawFromWarehouse(warehouse, line.sku, taken, allocations, deductions);
+          remaining -= taken;
+        }
+        if (remaining === 0) break;
+      }
+    }
+
+    if (rejected) {
+      for (const deduction of deductions) {
+        deduction.lot.qty += deduction.qty;
+      }
+      failed.push({ index, id: order.id });
+    } else {
+      accepted.push({ id: order.id, allocations });
+    }
+  }
+
+  const rejected = failed
+    .sort((left, right) => left.index - right.index)
+    .map(({ id }) => ({ id, reason: 'insufficient_stock' }));
+  const remaining = input.warehouses
+    .flatMap((warehouse) => warehouse.lots
+      .filter((lot) => lot.qty > 0)
+      .map((lot) => ({
+        warehouse: warehouse.id,
+        sku: lot.sku,
+        lot: lot.lot,
+        qty: lot.qty,
+        expires: lot.expires,
+      })))
+    .sort((left, right) => compareText(left.warehouse, right.warehouse)
+      || compareText(left.sku, right.sku)
+      || compareText(left.expires, right.expires)
+      || compareText(left.lot, right.lot));
+
+  return { accepted, rejected, remaining };
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +249,18 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'fulfill-wave': {
+      try {
+        const inputPath = parseInputFlag(rest);
+        const input = JSON.parse(fs.readFileSync(inputPath, 'utf8'));
+        validateInput(input);
+        console.log(JSON.stringify(fulfillWave(input)));
+      } catch (error) {
+        process.stderr.write(`${JSON.stringify({ error: error.message })}\n`);
+        process.exit(2);
+      }
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..b8fc805 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
 const { execFileSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,18 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function withInput(input, callback) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'fulfill-wave-'));
+  const inputPath = path.join(directory, 'input.json');
+  const raw = JSON.stringify(input);
+  fs.writeFileSync(inputPath, raw);
+  try {
+    return callback(inputPath, raw);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +37,102 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('fulfill-wave accepts allocations in warehouse and FEFO order', () => {
+  const input = {
+    warehouses: [
+      {
+        id: 'west',
+        distance: 2,
+        lots: [{ sku: 'tea', lot: 'west-lot', qty: 3, expires: '2027-01-01' }],
+      },
+      {
+        id: 'north',
+        distance: 1,
+        lots: [
+          { sku: 'tea', lot: 'late', qty: 2, expires: '2027-03-01' },
+          { sku: 'tea', lot: 'early', qty: 1, expires: '2027-02-01' },
+        ],
+      },
+    ],
+    orders: [
+      {
+        id: 'wave-1',
+        priority: 1,
+        submitted_at: '2027-01-01T00:00:00Z',
+        lines: [{ sku: 'tea', qty: 4, single_warehouse: false }],
+      },
+    ],
+  };
+
+  withInput(input, (inputPath, raw) => {
+    const result = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+    assert.deepStrictEqual(result, {
+      accepted: [{
+        id: 'wave-1',
+        allocations: [
+          { sku: 'tea', warehouse: 'north', lot: 'early', qty: 1 },
+          { sku: 'tea', warehouse: 'north', lot: 'late', qty: 2 },
+          { sku: 'tea', warehouse: 'west', lot: 'west-lot', qty: 1 },
+        ],
+      }],
+      rejected: [],
+      remaining: [{
+        warehouse: 'west',
+        sku: 'tea',
+        lot: 'west-lot',
+        qty: 2,
+        expires: '2027-01-01',
+      }],
+    });
+    assert.strictEqual(fs.readFileSync(inputPath, 'utf8'), raw);
+  });
+});
+
+test('fulfill-wave rolls back a rejected all-or-nothing order', () => {
+  const input = {
+    warehouses: [{
+      id: 'warehouse-1',
+      distance: 1,
+      lots: [
+        { sku: 'apple', lot: 'apple-lot', qty: 2, expires: '2027-01-01' },
+        { sku: 'banana', lot: 'banana-lot', qty: 1, expires: '2027-01-02' },
+      ],
+    }],
+    orders: [
+      {
+        id: 'rejected-first',
+        priority: 2,
+        submitted_at: '2027-01-01T00:00:00Z',
+        lines: [
+          { sku: 'apple', qty: 2, single_warehouse: false },
+          { sku: 'banana', qty: 2, single_warehouse: false },
+        ],
+      },
+      {
+        id: 'accepted-after-rollback',
+        priority: 1,
+        submitted_at: '2027-01-01T00:00:00Z',
+        lines: [{ sku: 'apple', qty: 2, single_warehouse: false }],
+      },
+    ],
+  };
+
+  withInput(input, (inputPath) => {
+    const result = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+    assert.deepStrictEqual(result, {
+      accepted: [{
+        id: 'accepted-after-rollback',
+        allocations: [{ sku: 'apple', warehouse: 'warehouse-1', lot: 'apple-lot', qty: 2 }],
+      }],
+      rejected: [{ id: 'rejected-first', reason: 'insufficient_stock' }],
+      remaining: [{
+        warehouse: 'warehouse-1',
+        sku: 'banana',
+        lot: 'banana-lot',
+        qty: 1,
+        expires: '2027-01-02',
+      }],
+    });
+  });
+});
