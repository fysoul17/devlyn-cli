diff --git a/bin/cli.js b/bin/cli.js
index fcff156..00eacfc 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -41,6 +41,21 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseFormatFlag(argv) {
+  const idx = argv.indexOf('--format');
+  if (idx === -1) return null;
+  const value = argv[idx + 1];
+  if (!value || value.startsWith('-')) {
+    console.error('--format requires a value');
+    process.exit(1);
+  }
+  if (value !== 'json') {
+    console.error(`Unsupported format: ${value}`);
+    process.exit(1);
+  }
+  return value;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -57,7 +72,12 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
+      const format = parseFormatFlag(rest);
+      if (format === 'json') {
+        console.log(JSON.stringify({ version: readPackageVersion() }));
+      } else {
+        console.log(readPackageVersion());
+      }
       return;
     }
     default:
