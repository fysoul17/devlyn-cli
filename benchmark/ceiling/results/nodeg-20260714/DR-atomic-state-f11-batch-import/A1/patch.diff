+test('POST /items/import rejects an invalid middle item without changes', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const imported = await post(server, '/items/import', {
+      items: [
+        { name: 'gamma', qty: 2 },
+        { name: '   ', qty: 4 },
+        { name: 'delta', qty: 6 },
+      ],
+    });
+    assert.strictEqual(imported.status, 400);
+    assert.deepStrictEqual(imported.body, { error: 'invalid_batch', index: 1, field: 'name' });
+
+    const after = await get(server, '/items');
+    assert.deepStrictEqual(after, before);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import appends a valid batch in input order', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const nextId = Math.max(...before.body.items.map((item) => item.id)) + 1;
+    const imported = await post(server, '/items/import', {
+      items: [
+        { id: 999, name: ' gamma ', qty: 2 },
+        { name: 'delta', qty: 6 },
+      ],
+    });
+    assert.strictEqual(imported.status, 201);
+    assert.deepStrictEqual(imported.body, { inserted: 2 });
+
+    const after = await get(server, '/items');
+    assert.deepStrictEqual(after.body.items.slice(0, before.body.items.length), before.body.items);
+    assert.deepStrictEqual(after.body.items.slice(-2), [
+      { id: nextId, name: ' gamma ', qty: 2 },
+      { id: nextId + 1, name: 'delta', qty: 6 },
+    ]);
+  } finally {
+    server.close();
+  }
+});
