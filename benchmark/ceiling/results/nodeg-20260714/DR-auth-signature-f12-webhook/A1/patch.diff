+
+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  const event = { id: 'event-happy-path', type: 'item.created', timestamp: 1720953988, data: { itemId: 1 } };
+  const body = JSON.stringify(event);
+  try {
+    const response = await post(server, '/webhook', body, sign(body));
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects replayed event ids', async () => {
+  const server = await startServer();
+  const event = { id: 'event-replay', type: 'item.updated', timestamp: 1720953989, data: { itemId: 2 } };
+  const body = JSON.stringify(event);
+  const signature = sign(body);
+  try {
+    const firstResponse = await post(server, '/webhook', body, signature);
+    const replayResponse = await post(server, '/webhook', body, signature);
+    assert.strictEqual(firstResponse.status, 200);
+    assert.strictEqual(replayResponse.status, 409);
+    assert.deepStrictEqual(replayResponse.body, { error: 'duplicate_event', id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
