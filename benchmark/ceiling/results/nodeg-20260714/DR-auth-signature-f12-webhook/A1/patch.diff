+const webhookSecret = fs.readFileSync(path.join(__dirname, '../data/webhook-secret.txt'), 'utf8').trim();
+const acceptedEventIds = new Set();
+
+function hasValidWebhookSignature(req) {
+  const signature = req.get('X-Signature');
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(req.rawBody || Buffer.alloc(0))
+    .digest();
+  const receivedSignature = typeof signature === 'string'
+    && signature.length === expectedSignature.length * 2
+    && /^[0-9a-f]+$/.test(signature)
+    ? Buffer.from(signature, 'hex')
+    : null;
+
+  return receivedSignature
+    && receivedSignature.length === expectedSignature.length
+    && crypto.timingSafeEqual(receivedSignature, expectedSignature);
+}
 
