const assert = require('node:assert');
const crypto = require('node:crypto');
const fs = require('node:fs');
const path = require('node:path');
const { app } = require('./server');

const secret = fs.readFileSync(path.join('data', 'webhook-secret.txt'), 'utf8').trim();
const handler = app._router.stack.find((layer) => layer.route && layer.route.path === '/webhook').route.stack[0].handle;
const sign = (rawBody) => crypto.createHmac('sha256', secret).update(rawBody).digest('hex');
const invoke = (body, rawBody, signature) => new Promise((resolve) => {
  const response = {
    statusCode: 200,
    status(code) {
      this.statusCode = code;
      return this;
    },
    json(responseBody) {
      resolve({ status: this.statusCode, body: responseBody });
    },
  };
  handler({ body, rawBody, get: (name) => (name === 'X-Signature' ? signature : undefined) }, response);
});

(async () => {
  const validBody = { id: 'handler_valid', type: 'created', timestamp: 1, data: {} };
  const validRaw = Buffer.from(JSON.stringify(validBody));
  assert.deepStrictEqual(await invoke(validBody, validRaw, sign(validRaw)), { status: 200, body: { accepted: true, id: 'handler_valid' } });

  const duplicateBody = { id: 'handler_duplicate', type: 'created', timestamp: 2, data: {} };
  const duplicateRaw = Buffer.from(JSON.stringify(duplicateBody));
  await invoke(duplicateBody, duplicateRaw, sign(duplicateRaw));
  assert.deepStrictEqual(await invoke(duplicateBody, duplicateRaw, sign(duplicateRaw)), { status: 409, body: { error: 'duplicate_event', id: 'handler_duplicate' } });

  const originalBody = { id: 'handler_tampered', type: 'created', timestamp: 3, data: { value: 1 } };
  const originalRaw = Buffer.from(JSON.stringify(originalBody));
  const tamperedBody = { id: 'handler_tampered', type: 'created', timestamp: 3, data: { value: 2 } };
  const tamperedRaw = Buffer.from(JSON.stringify(tamperedBody));
  assert.deepStrictEqual(await invoke(tamperedBody, tamperedRaw, sign(originalRaw)), { status: 401, body: { error: 'invalid_signature' } });

  const invalidBody = { id: '', type: '', timestamp: '3', data: [] };
  const invalidRaw = Buffer.from(JSON.stringify(invalidBody));
  assert.deepStrictEqual(await invoke(invalidBody, invalidRaw, sign(invalidRaw)), { status: 400, body: { error: 'invalid_body' } });
  assert.deepStrictEqual(await invoke(invalidBody, invalidRaw, ''), { status: 401, body: { error: 'invalid_signature' } });
  console.log('Registered webhook handler: PASS');
})().catch((error) => {
  console.error(error);
  process.exitCode = 1;
});
