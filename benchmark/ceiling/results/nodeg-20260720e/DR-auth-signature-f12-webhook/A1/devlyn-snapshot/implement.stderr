const directory = process.argv[2];
const socketPath = path.join(directory, 'server.sock');
const secret = fs.readFileSync(path.join('data', 'webhook-secret.txt'), 'utf8').trim();
const sign = (body) => crypto.createHmac('sha256', secret).update(body).digest('hex');
const request = (body, signature) => new Promise((resolve, reject) => {
  const req = http.request({
    socketPath,
    path: '/webhook',
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Content-Length': Buffer.byteLength(body),
      'X-Signature': signature,
    },
  }, (res) => {
    let response = '';
    res.on('data', (chunk) => (response += chunk));
    res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(response) }));
  });
  req.on('error', reject);
  req.end(body);
});

const server = http.createServer(app);
server.listen(socketPath, async () => {
  try {
    const valid = JSON.stringify({ id: 'validation_valid', type: 'created', timestamp: 1, data: {} });
    assert.deepStrictEqual(await request(valid, sign(valid)), { status: 200, body: { accepted: true, id: 'validation_valid' } });

    const duplicate = JSON.stringify({ id: 'validation_duplicate', type: 'created', timestamp: 2, data: {} });
    await request(duplicate, sign(duplicate));
    assert.deepStrictEqual(await request(duplicate, sign(duplicate)), { status: 409, body: { error: 'duplicate_event', id: 'validation_duplicate' } });

    const signed = JSON.stringify({ id: 'validation_tampered', type: 'created', timestamp: 3, data: { value: 1 } });
    const tampered = JSON.stringify({ id: 'validation_tampered', type: 'created', timestamp: 3, data: { value: 2 } });
    assert.deepStrictEqual(await request(tampered, sign(signed)), { status: 401, body: { error: 'invalid_signature' } });
    console.log('Unix-socket webhook integration: PASS');
  } finally {
    server.close(() => fs.rmdirSync(directory));
  }
});
