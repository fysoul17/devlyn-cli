 #!/usr/bin/env node
 // harbor-tools — small command-line utilities for local workflows.
 // Keep the core commands minimal and easy to understand.
 
 const fs = require('fs');
 const path = require('path');
 
 const USAGE = `Usage: bench-cli <command> [options]
 
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  cart --input PATH          Calculate a cart total from a JSON input file
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli cart --input cart.json
 `;
 
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
   return JSON.parse(raw).version;
 }
 
 function parseNameFlag(argv) {
   const idx = argv.indexOf('--name');
   if (idx === -1) return 'world';
   const value = argv[idx + 1];
   if (!value || value.startsWith('-')) {
     console.error('--name requires a value');
     process.exit(1);
   }
   return value;
 }
 
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const value = argv[idx + 1];
+  if (idx === -1 || !value || value.startsWith('-')) {
+    console.error('--input requires a value');
+    process.exit(1);
+  }
+  return value;
+}
+
+function cartError(error) {
+  process.stderr.write(`${JSON.stringify(error)}\n`);
+  process.exit(2);
+}
+
+function readCartInput(inputPath) {
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch {
+    cartError({ error: 'invalid_json' });
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch {
+    cartError({ error: 'invalid_json' });
+  }
+}
+
+function calculateCart(input, catalog) {
+  if (!input || typeof input !== 'object' || !Array.isArray(input.items)) {
+    cartError({ error: 'missing_items' });
+  }
+
+  for (const item of input.items) {
+    if (!item || !Object.hasOwn(catalog.products, item.sku)) {
+      cartError({ error: 'unknown_sku' });
+    }
+  }
+
+  for (const item of input.items) {
+    if (!Number.isInteger(item.qty) || item.qty <= 0) {
+      cartError({ error: 'invalid_quantity' });
+    }
+  }
+
+  if (input.coupon != null && !Object.hasOwn(catalog.coupons, input.coupon)) {
+    cartError({ error: 'unknown_coupon' });
+  }
+
+  if (!Object.hasOwn(catalog.tax_rates, input.state)) {
+    cartError({ error: 'unknown_state' });
+  }
+
+  const quantities = new Map();
+  for (const item of input.items) {
+    quantities.set(item.sku, (quantities.get(item.sku) || 0) + item.qty);
+  }
+
+  for (const [sku, qty] of quantities) {
+    if (qty > catalog.products[sku].stock) {
+      cartError({
+        error: 'invalid_stock',
+        sku,
+        available: catalog.products[sku].stock,
+        requested: qty,
+      });
+    }
+  }
+
+  let subtotalCents = 0;
+  let lineDiscountCents = 0;
+  let taxablePostLineDiscountCents = 0;
+  const items = [];
+
+  for (const [sku, qty] of quantities) {
+    const product = catalog.products[sku];
+    const promotion = catalog.line_promotions.find((entry) => entry.sku === sku);
+    const lineSubtotalCents = qty * product.unit_cents;
+    let lineDiscountCentsForItem = 0;
+
+    if (promotion?.type === 'buy_x_get_y_free') {
+      lineDiscountCentsForItem = Math.floor(qty / (promotion.buy_qty + promotion.free_qty))
+        * promotion.free_qty * product.unit_cents;
+    }
+    if (promotion?.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
+      lineDiscountCentsForItem = promotion.per_unit_discount_cents * qty;
+    }
+
+    const lineTotalCents = lineSubtotalCents - lineDiscountCentsForItem;
+    subtotalCents += lineSubtotalCents;
+    lineDiscountCents += lineDiscountCentsForItem;
+    if (catalog.taxable_codes[product.tax_code] === true) {
+      taxablePostLineDiscountCents += lineTotalCents;
+    }
+    items.push({
+      sku,
+      qty,
+      line_subtotal_cents: lineSubtotalCents,
+      line_discount_cents: lineDiscountCentsForItem,
+      line_total_cents: lineTotalCents,
+    });
+  }
+
+  const postLineDiscountCents = subtotalCents - lineDiscountCents;
+  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[input.state]);
+  const coupon = input.coupon == null ? null : catalog.coupons[input.coupon];
+  const couponDiscountCents = coupon && postLineDiscountCents >= coupon.min_subtotal_cents
+    ? Math.round(postLineDiscountCents * coupon.percent / 100)
+    : 0;
+  const shippingCents = postLineDiscountCents - couponDiscountCents >= catalog.free_shipping_min_cents
+    ? 0
+    : catalog.shipping_cents;
+
+  return {
+    subtotal_cents: subtotalCents,
+    line_discount_cents: lineDiscountCents,
+    coupon_discount_cents: couponDiscountCents,
+    tax_cents: taxCents,
+    shipping_cents: shippingCents,
+    total_cents: postLineDiscountCents - couponDiscountCents + taxCents + shippingCents,
+    items,
+  };
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
   if (!command || command === '--help' || command === '-h') {
     process.stdout.write(USAGE);
     return;
   }
 
   switch (command) {
     case 'hello': {
       const name = parseNameFlag(rest);
       console.log(`Hello, ${name}!`);
       return;
     }
     case 'version': {
       console.log(readPackageVersion());
       return;
     }
+    case 'cart': {
+      const inputPath = parseInputFlag(rest);
+      const input = readCartInput(inputPath);
+      const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
+      const catalog = JSON.parse(fs.readFileSync(catalogPath, 'utf8'));
+      const cart = calculateCart(input, catalog);
+      process.stdout.write(`${JSON.stringify(cart)}\n`);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
       process.exit(1);
   }
 }
 
 main(process.argv.slice(2));
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..f597d3c 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,25 +1,109 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
 const { execFileSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
 
 function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function withCartInput(input, callback) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-cart-'));
+  const inputPath = path.join(directory, 'input.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+  try {
+    callback(inputPath);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
 });
 
 test('hello with --name', () => {
   const out = run(['hello', '--name', 'alice']);
   assert.match(out, /Hello, alice!/);
 });
 
 test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('cart calculates promotions, tax, coupon, and shipping', () => {
+  withCartInput({
+    state: 'CA',
+    coupon: 'ORDER10',
+    items: [
+      { sku: 'TEE', qty: 3 },
+      { sku: 'BAG', qty: 2 },
+      { sku: 'MUG', qty: 1 },
+    ],
+  }, (inputPath) => {
+    const out = run(['cart', '--input', inputPath]);
+    assert.deepStrictEqual(JSON.parse(out), {
+      subtotal_cents: 15100,
+      line_discount_cents: 3500,
+      coupon_discount_cents: 1160,
+      tax_cents: 858,
+      shipping_cents: 0,
+      total_cents: 11298,
+      items: [
+        {
+          sku: 'TEE',
+          qty: 3,
+          line_subtotal_cents: 7500,
+          line_discount_cents: 2500,
+          line_total_cents: 5000,
+        },
+        {
+          sku: 'BAG',
+          qty: 2,
+          line_subtotal_cents: 6400,
+          line_discount_cents: 1000,
+          line_total_cents: 5400,
+        },
+        {
+          sku: 'MUG',
+          qty: 1,
+          line_subtotal_cents: 1200,
+          line_discount_cents: 0,
+          line_total_cents: 1200,
+        },
+      ],
+    });
+  });
+});
+
+test('cart reports combined quantities above stock', () => {
+  withCartInput({
+    state: 'OR',
+    coupon: null,
+    items: [
+      { sku: 'BAG', qty: 3 },
+      { sku: 'BAG', qty: 2 },
+    ],
+  }, (inputPath) => {
+    assert.throws(
+      () => run(['cart', '--input', inputPath]),
+      (error) => {
+        assert.strictEqual(error.status, 2);
+        assert.strictEqual(error.stdout, '');
+        assert.deepStrictEqual(JSON.parse(error.stderr), {
+          error: 'invalid_stock',
+          sku: 'BAG',
+          available: 4,
+          requested: 5,
+        });
+        return true;
+      },
+    );
+  });
+});
# Generated criteria — bench-cli cart command

Source: free-form goal (`.devlyn/goal.raw.txt`, medium complexity).

## Requirements

- Add a `bench-cli cart --input <path>` command to `bin/cli.js`. Input JSON shape: `{ "state": string, "coupon": string | null, "items": [{ "sku": string, "qty": number }] }`. Read products, stock, tax codes, promotions, coupons, tax rates, shipping cost, and free-shipping threshold from `data/catalog.json`; changing catalog values must change the result without a code change.
- Combine duplicate SKU quantities before stock validation and promotion math. On success, print exactly one JSON object to stdout (no stderr) whose only top-level keys are `subtotal_cents`, `line_discount_cents`, `coupon_discount_cents`, `tax_cents`, `shipping_cents`, `total_cents`, `items`. `items` has one row per SKU in first-seen order, each row having exactly `sku`, `qty`, `line_subtotal_cents`, `line_discount_cents`, `line_total_cents`. All public amounts are integer cents.
- Line promotion math: `buy_x_get_y_free` discount = `Math.floor(qty / (buy_qty + free_qty)) * free_qty * unit_cents`; `per_unit_discount_cents` applies only when combined qty >= `min_qty`, discount = `per_unit_discount_cents * qty`. Apply line promotions before the order coupon. Top-level `line_discount_cents` is the sum of item line discounts; each line total = line subtotal − line discount.
- Coupon + tax + shipping math, in this order: (1) line promotions; (2) tax on `taxable_post_line_discount_cents` per `catalog.taxable_codes[tax_code]` and `catalog.tax_rates[state]`, `tax_cents = Math.round(taxable_post_line_discount_cents * rate)`; (3) coupon discount, applied only when the post-line-discount subtotal meets `coupon.min_subtotal_cents`: `Math.round((subtotal_cents - line_discount_cents) * coupon.percent / 100)`, else `0`; (4) shipping is `0` when `subtotal_cents - line_discount_cents - coupon_discount_cents >= catalog.free_shipping_min_cents`, else `catalog.shipping_cents`. `total_cents = subtotal_cents - line_discount_cents - coupon_discount_cents + tax_cents + shipping_cents`.
- Error contract: invalid JSON, missing `items`, unknown SKU, non-positive/non-integer quantity, unknown coupon, unknown state, or combined quantity over stock must exit `2`, print exactly one JSON error object to stderr, and print nothing to stdout. Stock failure shape is exactly `{ "error": "invalid_stock", "sku": string, "available": number, "requested": number }` where `requested` is the combined quantity. Parsing/file-read failures must surface as JSON errors, not silent catches.
- Update `tests/cli.test.js`: existing tests must still pass; add at least two new tests covering the cart command, including one successful cart and one validation failure.

## Constraints

- Only touch `bin/cli.js` and `tests/cli.test.js`. Do not touch `server/` or `web/` files.
- Do not add dependencies (no new `package.json` deps/devDeps).
- Follow the existing `bin/cli.js` pattern: a `main(argv)` switch over commands, `USAGE` text, `process.exit` for errors.
- Follow the existing `tests/cli.test.js` pattern: `node:test` + `node:assert` + `execFileSync`.

## Out of Scope

- Anything not in `bin/cli.js` / `tests/cli.test.js` (e.g. `server/`, `web/`, `data/catalog.json` shape changes, README updates).

