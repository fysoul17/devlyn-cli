+
+test('POST /items/import appends a valid batch in order', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'gamma', qty: 2 },
+        { name: 'delta', qty: 7 },
+      ],
+    });
+    assert.strictEqual(response.status, 201);
+    assert.deepStrictEqual(response.body, { inserted: 2 });
+
+    const after = await get(server, '/items');
+    const inserted = after.body.items.slice(before.body.items.length);
+    assert.deepStrictEqual(
+      inserted.map(({ name, qty }) => ({ name, qty })),
+      [
+        { name: 'gamma', qty: 2 },
+        { name: 'delta', qty: 7 },
+      ]
+    );
+    const ids = inserted.map((item) => item.id);
+    assert.ok(ids.every(Number.isInteger));
+    assert.strictEqual(new Set(ids).size, ids.length);
+    assert.ok(ids.every((id) => !before.body.items.some((item) => item.id === id)));
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import rejects an invalid middle item without changes', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'epsilon', qty: 1 },
+        { name: '   ', qty: 4 },
+        { name: 'zeta', qty: 9 },
+      ],
+    });
+    assert.strictEqual(response.status, 400);
+    assert.deepStrictEqual(response.body, { error: 'invalid_batch', index: 1, field: 'name' });
+    const after = await get(server, '/items');
+    assert.deepStrictEqual(after.body, before.body);
+  } finally {
+    server.close();
+  }
+});
