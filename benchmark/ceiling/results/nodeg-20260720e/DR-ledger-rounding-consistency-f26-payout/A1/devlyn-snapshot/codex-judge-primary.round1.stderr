    75	function isValidPayoutEvent(event) {
    76	  return event
    77	    && typeof event === 'object'
    78	    && !Array.isArray(event)
    79	    && typeof event.id === 'string'
    80	    && typeof event.merchant_id === 'string'
    81	    && ['charge', 'refund', 'dispute'].includes(event.type)
    82	    && Number.isInteger(event.amount_cents)
    83	    && event.amount_cents > 0;
    84	}
    85	
    86	function payout(argv) {
    87	  const ledger = readPayoutInput(argv);
    88	  if (!ledger || typeof ledger !== 'object' || Array.isArray(ledger) || !Array.isArray(ledger.events)) {
    89	    writePayoutError({ error: 'invalid_events' });
    90	  }
    91	
    92	  const rules = readPayoutRules();
    93	  const seen = new Map();
    94	  const merchantOrder = [];
    95	  const rows = new Map();
    96	
    97	  for (const event of ledger.events) {
    98	    if (event && typeof event === 'object' && typeof event.id === 'string' && seen.has(event.id)) {
    99	      if (!isDeepStrictEqual(seen.get(event.id), event)) {
   100	        writePayoutError({ error: 'conflicting_duplicate', id: event.id });
   101	      }
   102	      continue;
   103	    }
   104	
   105	    if (!isValidPayoutEvent(event)) writePayoutError({ error: 'invalid_event' });
   106	
   107	    seen.set(event.id, event);
   108	
   109	    if (!rows.has(event.merchant_id)) {
   110	      rows.set(event.merchant_id, {
   111	        merchant_id: event.merchant_id,
   112	        gross_charge_cents: 0,
   113	        refund_cents: 0,
   114	        dispute_cents: 0,
   115	        processing_fee_cents: 0,
   116	        dispute_fee_cents: 0,
   117	      });
   118	      merchantOrder.push(event.merchant_id);
   119	    }
   120	
   121	    const row = rows.get(event.merchant_id);
   122	    if (event.type === 'charge') {
   123	      row.gross_charge_cents += event.amount_cents;
   124	      row.processing_fee_cents += Math.round(event.amount_cents * rules.processing_fee_percent / 100)
   125	        + rules.fixed_fee_cents;
   126	    } else if (event.type === 'refund') {
   127	      row.refund_cents += event.amount_cents;
   128	    } else {
   129	      row.dispute_cents += event.amount_cents;
   130	      row.dispute_fee_cents += rules.dispute_fee_cents;
   131	    }
   132	  }
   133	
   134	  const merchants = merchantOrder.map((merchantId) => {
   135	    const row = rows.get(merchantId);
   136	    const netBeforeReserve = row.gross_charge_cents
   137	      - row.refund_cents
   138	      - row.dispute_cents
   139	      - row.processing_fee_cents
   140	      - row.dispute_fee_cents;
   141	    let reserveCents = netBeforeReserve > 0
   142	      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
   143	      : 0;
   144	    let payoutCents = netBeforeReserve - reserveCents;
   145	    if (payoutCents > 0 && payoutCents < rules.minimum_payout_cents) {
   146	      reserveCents += payoutCents;
   147	      payoutCents = 0;
   148	    }
   149	    return {
   150	      ...row,
   151	      reserve_cents: reserveCents,
   152	      payout_cents: payoutCents,
   153	    };
   154	  });
   155	
   156	  process.stdout.write(`${JSON.stringify({
   157	    total_payout_cents: merchants.reduce((sum, merchant) => sum + merchant.payout_cents, 0),
   158	    total_processing_fee_cents: merchants.reduce((sum, merchant) => sum + merchant.processing_fee_cents, 0),
   159	    total_dispute_fee_cents: merchants.reduce((sum, merchant) => sum + merchant.dispute_fee_cents, 0),
   160	    total_reserve_cents: merchants.reduce((sum, merchant) => sum + merchant.reserve_cents, 0),
   161	    merchants,
   162	  })}\n`);
   163	}
   164	
   165	function main(argv) {
   166	  const [command, ...rest] = argv;
   167	
   168	  if (!command || command === '--help' || command === '-h') {
   169	    process.stdout.write(USAGE);
   170	    return;
   171	  }
   172	
   173	  switch (command) {
   174	    case 'hello': {
   175	      const name = parseNameFlag(rest);
   176	      console.log(`Hello, ${name}!`);
   177	      return;
   178	    }
   179	    case 'payout': {
   180	      payout(rest);
   181	      return;
   182	    }
   183	    case 'version': {
   184	      console.log(readPackageVersion());
   185	      return;
   186	    }
   187	    default:
   188	      console.error(`Unknown command: ${command}`);
   189	      process.stderr.write(USAGE);
   190	      process.exit(1);
   191	  }
   192	}
   193	
   194	main(process.argv.slice(2));
     1	const { test } = require('node:test');
     2	const assert = require('node:assert');
     3	const { execFileSync } = require('node:child_process');
     4	const fs = require('node:fs');
     5	const os = require('node:os');
     6	const path = require('node:path');
     7	
     8	const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
     9	
    10	function run(args) {
    11	  return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
    12	}
    13	
    14	test('hello default', () => {
    15	  const out = run(['hello']);
    16	  assert.match(out, /Hello, world!/);
    17	});
    18	
    19	test('hello with --name', () => {
    20	  const out = run(['hello', '--name', 'alice']);
    21	  assert.match(out, /Hello, alice!/);
    22	});
    23	
    24	test('version prints package version', () => {
    25	  const out = run(['version']);
    26	  assert.match(out, /\d+\.\d+\.\d+/);
    27	});
    28	
    29	test('payout calculates merchant balances and ignores identical duplicates', (t) => {
    30	  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
    31	  const inputPath = path.join(dir, 'ledger.json');
    32	  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
    33	  fs.writeFileSync(inputPath, JSON.stringify({
    34	    events: [
    35	      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
    36	      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
    37	      { id: 'r1', merchant_id: 'm1', type: 'refund', amount_cents: 1000 },
    38	      { id: 'd1', merchant_id: 'm1', type: 'dispute', amount_cents: 2000 },
    39	      { id: 'c2', merchant_id: 'm2', type: 'charge', amount_cents: 500 },
    40	    ],
    41	  }));
    42	
    43	  assert.deepStrictEqual(JSON.parse(run(['payout', '--input', inputPath])), {
    44	    total_payout_cents: 4662,
    45	    total_processing_fee_cents: 365,
    46	    total_dispute_fee_cents: 1500,
    47	    total_reserve_cents: 973,
    48	    merchants: [
    49	      {
    50	        merchant_id: 'm1',
    51	        gross_charge_cents: 10000,
    52	        refund_cents: 1000,
    53	        dispute_cents: 2000,
    54	        processing_fee_cents: 320,
    55	        dispute_fee_cents: 1500,
    56	        reserve_cents: 518,
    57	        payout_cents: 4662,
    58	      },
    59	      {
    60	        merchant_id: 'm2',
    61	        gross_charge_cents: 500,
    62	        refund_cents: 0,
    63	        dispute_cents: 0,
    64	        processing_fee_cents: 45,
    65	        dispute_fee_cents: 0,
    66	        reserve_cents: 455,
    67	        payout_cents: 0,
    68	      },
    69	    ],
    70	  });
    71	});
    72	
    73	test('payout emits a JSON error for invalid events', (t) => {
    74	  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
    75	  const inputPath = path.join(dir, 'ledger.json');
    76	  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
    77	  fs.writeFileSync(inputPath, JSON.stringify({
    78	    events: [{ id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 1.5 }],
    79	  }));
    80	
    81	  assert.throws(() => run(['payout', '--input', inputPath]), (error) => {
    82	    assert.strictEqual(error.status, 2);
    83	    assert.strictEqual(error.stdout, '');
    84	    assert.deepStrictEqual(JSON.parse(error.stderr), { error: 'invalid_event' });
    85	    return true;
    86	  });
    87	});
    88	
    89	test('payout rejects conflicting duplicates before validating the duplicate event', (t) => {
    90	  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
    91	  const inputPath = path.join(dir, 'ledger.json');
    92	  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
    93	  fs.writeFileSync(inputPath, JSON.stringify({
    94	    events: [
    95	      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 100 },
    96	      { id: 'c1', merchant_id: 'm1', type: 'bogus', amount_cents: 100 },
    97	    ],
    98	  }));
    99	
   100	  assert.throws(() => run(['payout', '--input', inputPath]), (error) => {
   101	    assert.strictEqual(error.status, 2);
