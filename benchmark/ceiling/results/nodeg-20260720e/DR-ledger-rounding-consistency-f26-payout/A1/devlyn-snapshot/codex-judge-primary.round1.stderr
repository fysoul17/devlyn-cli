     7	const { isDeepStrictEqual } = require('node:util');
     8	
     9	const USAGE = `Usage: bench-cli <command> [options]
    10	
    11	Commands:
    12	  hello [--name NAME]        Print a greeting (default name: "world")
    13	  payout --input PATH        Calculate payouts from a ledger JSON file
    14	  version                    Print the CLI version from package.json
    15	  --help, -h                 Show this help
    16	
    17	Examples:
    18	  bench-cli hello
    19	  bench-cli hello --name alice
    20	  bench-cli version
    21	`;
    22	
    23	function readPackageVersion() {
    24	  const pkgPath = path.join(__dirname, '..', 'package.json');
    25	  const raw = fs.readFileSync(pkgPath, 'utf8');
    26	  return JSON.parse(raw).version;
    27	}
    28	
    29	function parseNameFlag(argv) {
    30	  const idx = argv.indexOf('--name');
    31	  if (idx === -1) return 'world';
    32	  const value = argv[idx + 1];
    33	  if (!value || value.startsWith('-')) {
    34	    console.error('--name requires a value');
    35	    process.exit(1);
    36	  }
    37	  return value;
    38	}
    39	
    40	function parseInputFlag(argv) {
    41	  const idx = argv.indexOf('--input');
    42	  if (idx === -1) return null;
    43	  const value = argv[idx + 1];
    44	  return value && !value.startsWith('-') ? value : null;
    45	}
    46	
    47	function writePayoutError(error) {
    48	  process.stderr.write(`${JSON.stringify(error)}\n`);
    49	  process.exit(2);
    50	}
    51	
    52	function readPayoutInput(argv) {
    53	  const inputPath = parseInputFlag(argv);
    54	  if (!inputPath) writePayoutError({ error: 'unreadable_input' });
    55	
    56	  let raw;
    57	  try {
    58	    raw = fs.readFileSync(inputPath, 'utf8');
    59	  } catch {
    60	    writePayoutError({ error: 'unreadable_input' });
    61	  }
    62	
    63	  try {
    64	    return JSON.parse(raw);
    65	  } catch {
    66	    writePayoutError({ error: 'invalid_json' });
    67	  }
    68	}
