const { test } = require('node:test');
const assert = require('node:assert');
const { execFileSync } = require('node:child_process');
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');

const CLI = path.join(__dirname, '..', 'bin', 'cli.js');

function run(args) {
  return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
}

test('hello default', () => {
  const out = run(['hello']);
  assert.match(out, /Hello, world!/);
});

test('hello with --name', () => {
  const out = run(['hello', '--name', 'alice']);
  assert.match(out, /Hello, alice!/);
});

test('version prints package version', () => {
  const out = run(['version']);
  assert.match(out, /\d+\.\d+\.\d+/);
});

test('payout calculates merchant balances and ignores identical duplicates', (t) => {
  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
  const inputPath = path.join(dir, 'ledger.json');
  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
  fs.writeFileSync(inputPath, JSON.stringify({
    events: [
      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
      { id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 10000 },
      { id: 'r1', merchant_id: 'm1', type: 'refund', amount_cents: 1000 },
      { id: 'd1', merchant_id: 'm1', type: 'dispute', amount_cents: 2000 },
      { id: 'c2', merchant_id: 'm2', type: 'charge', amount_cents: 500 },
    ],
  }));

  assert.deepStrictEqual(JSON.parse(run(['payout', '--input', inputPath])), {
    total_payout_cents: 4662,
    total_processing_fee_cents: 365,
    total_dispute_fee_cents: 1500,
    total_reserve_cents: 973,
    merchants: [
      {
        merchant_id: 'm1',
        gross_charge_cents: 10000,
        refund_cents: 1000,
        dispute_cents: 2000,
        processing_fee_cents: 320,
        dispute_fee_cents: 1500,
        reserve_cents: 518,
        payout_cents: 4662,
      },
      {
        merchant_id: 'm2',
        gross_charge_cents: 500,
        refund_cents: 0,
        dispute_cents: 0,
        processing_fee_cents: 45,
        dispute_fee_cents: 0,
        reserve_cents: 455,
        payout_cents: 0,
      },
    ],
  });
});

test('payout emits a JSON error for invalid events', (t) => {
  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
  const inputPath = path.join(dir, 'ledger.json');
  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
  fs.writeFileSync(inputPath, JSON.stringify({
    events: [{ id: 'c1', merchant_id: 'm1', type: 'charge', amount_cents: 1.5 }],
  }));

  assert.throws(() => run(['payout', '--input', inputPath]), (error) => {
    assert.strictEqual(error.status, 2);
    assert.strictEqual(error.stdout, '');
    assert.deepStrictEqual(JSON.parse(error.stderr), { error: 'invalid_event' });
    return true;
  });
});
