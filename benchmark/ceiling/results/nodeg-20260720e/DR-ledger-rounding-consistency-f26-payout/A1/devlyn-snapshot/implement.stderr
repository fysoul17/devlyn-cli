@@ -4,11 +4,13 @@
 
 const fs = require('fs');
 const path = require('path');
+const { isDeepStrictEqual } = require('node:util');
 
 const USAGE = `Usage: bench-cli <command> [options]
 
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
+  payout --input PATH        Calculate payouts from a ledger JSON file
   version                    Print the CLI version from package.json
   --help, -h                 Show this help
 
@@ -35,6 +37,130 @@
   return value;
 }
 
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  if (idx === -1) return null;
+  const value = argv[idx + 1];
+  return value && !value.startsWith('-') ? value : null;
+}
+
+function writePayoutError(error) {
+  process.stderr.write(`${JSON.stringify(error)}\n`);
+  process.exit(2);
+}
+
+function readPayoutInput(argv) {
+  const inputPath = parseInputFlag(argv);
+  if (!inputPath) writePayoutError({ error: 'unreadable_input' });
+
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch {
+    writePayoutError({ error: 'unreadable_input' });
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch {
+    writePayoutError({ error: 'invalid_json' });
+  }
+}
+
+function readPayoutRules() {
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  return JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
+}
+
+function isValidPayoutEvent(event) {
+  return event
+    && typeof event === 'object'
+    && !Array.isArray(event)
+    && typeof event.id === 'string'
+    && typeof event.merchant_id === 'string'
+    && ['charge', 'refund', 'dispute'].includes(event.type)
+    && Number.isInteger(event.amount_cents)
+    && event.amount_cents > 0;
+}
+
+function payout(argv) {
+  const ledger = readPayoutInput(argv);
+  if (!ledger || typeof ledger !== 'object' || Array.isArray(ledger) || !Array.isArray(ledger.events)) {
+    writePayoutError({ error: 'invalid_events' });
+  }
+
+  const rules = readPayoutRules();
+  const seen = new Map();
+  const merchantOrder = [];
+  const rows = new Map();
+
+  for (const event of ledger.events) {
+    if (!isValidPayoutEvent(event)) writePayoutError({ error: 'invalid_event' });
+
+    if (seen.has(event.id)) {
+      if (!isDeepStrictEqual(seen.get(event.id), event)) {
+        writePayoutError({ error: 'conflicting_duplicate', id: event.id });
+      }
+      continue;
+    }
+    seen.set(event.id, event);
+
+    if (!rows.has(event.merchant_id)) {
+      rows.set(event.merchant_id, {
+        merchant_id: event.merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+      });
+      merchantOrder.push(event.merchant_id);
+    }
+
+    const row = rows.get(event.merchant_id);
+    if (event.type === 'charge') {
+      row.gross_charge_cents += event.amount_cents;
+      row.processing_fee_cents += Math.round(event.amount_cents * rules.processing_fee_percent / 100)
+        + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      row.refund_cents += event.amount_cents;
+    } else {
+      row.dispute_cents += event.amount_cents;
+      row.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchants = merchantOrder.map((merchantId) => {
+    const row = rows.get(merchantId);
+    const netBeforeReserve = row.gross_charge_cents
+      - row.refund_cents
+      - row.dispute_cents
+      - row.processing_fee_cents
+      - row.dispute_fee_cents;
+    let reserveCents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    let payoutCents = netBeforeReserve - reserveCents;
+    if (payoutCents > 0 && payoutCents < rules.minimum_payout_cents) {
+      reserveCents += payoutCents;
+      payoutCents = 0;
+    }
+    return {
+      ...row,
+      reserve_cents: reserveCents,
+      payout_cents: payoutCents,
+    };
+  });
+
+  process.stdout.write(`${JSON.stringify({
+    total_payout_cents: merchants.reduce((sum, merchant) => sum + merchant.payout_cents, 0),
+    total_processing_fee_cents: merchants.reduce((sum, merchant) => sum + merchant.processing_fee_cents, 0),
+    total_dispute_fee_cents: merchants.reduce((sum, merchant) => sum + merchant.dispute_fee_cents, 0),
+    total_reserve_cents: merchants.reduce((sum, merchant) => sum + merchant.reserve_cents, 0),
+    merchants,
+  })}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
