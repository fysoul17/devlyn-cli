const assert = require('node:assert');
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const { spawnSync } = require('node:child_process');
const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-audit-'));
try {
  const cases = [
    ['missing-events', {}],
    ['unknown-type', { events: [{ id: '1', merchant_id: 'm', type: 'other', amount_cents: 1 }] }],
    ['missing-merchant', { events: [{ id: '1', type: 'charge', amount_cents: 1 }] }],
    ['missing-id', { events: [{ merchant_id: 'm', type: 'charge', amount_cents: 1 }] }],
    ['zero-amount', { events: [{ id: '1', merchant_id: 'm', type: 'charge', amount_cents: 0 }] }],
    ['fractional-amount', { events: [{ id: '1', merchant_id: 'm', type: 'charge', amount_cents: 1.5 }] }],
  ];
  for (const [name, ledger] of cases) {
    const input = path.join(dir, name + '.json');
    fs.writeFileSync(input, JSON.stringify(ledger));
    const result = spawnSync('node', ['bin/cli.js', 'payout', '--input', input], { encoding: 'utf8' });
    assert.strictEqual(result.status, 2, name);
    assert.strictEqual(result.stdout, '', name);
    assert.strictEqual(typeof JSON.parse(result.stderr).error, 'string', name);
  }
  const unreadable = spawnSync('node', ['bin/cli.js', 'payout', '--input', path.join(dir, 'absent.json')], { encoding: 'utf8' });
  assert.strictEqual(unreadable.status, 2);
  assert.strictEqual(unreadable.stdout, '');
  assert.strictEqual(typeof JSON.parse(unreadable.stderr).error, 'string');
  const ordered = path.join(dir, 'key-order.json');
  fs.writeFileSync(ordered, '{\\\"events\\\":[{\\\"id\\\":\\\"d\\\",\\\"merchant_id\\\":\\\"m\\\",\\\"type\\\":\\\"charge\\\",\\\"amount_cents\\\":1000},{\\\"amount_cents\\\":1000,\\\"type\\\":\\\"charge\\\",\\\"merchant_id\\\":\\\"m\\\",\\\"id\\\":\\\"d\\\"}]}');
  const duplicate = spawnSync('node', ['bin/cli.js', 'payout', '--input', ordered], { encoding: 'utf8' });
  assert.strictEqual(duplicate.status, 0);
  assert.strictEqual(JSON.parse(duplicate.stdout).merchants[0].gross_charge_cents, 1000);
  console.log('PAYOUT_EDGE_CHECK_OK');
} finally {
  fs.rmSync(dir, { recursive: true, force: true });
}
