test_schedule.py:658:            assert job.next_run.minute == 30
test_schedule.py-659-        with mock_datetime(2023, 3, 27, 1, 30):
test_schedule.py-660-            # the next day the job shall again run at 02:30
test_schedule.py-661-            job.run()
test_schedule.py:662:            assert job.next_run.day == 27
test_schedule.py:663:            assert job.next_run.hour == 2
test_schedule.py:664:            assert job.next_run.minute == 30
