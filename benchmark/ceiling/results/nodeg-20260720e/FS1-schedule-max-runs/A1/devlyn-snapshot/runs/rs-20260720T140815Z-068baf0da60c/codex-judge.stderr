   699	                 deadline is reached.
   700	
   701	        """
   702	        if self._is_overdue(datetime.datetime.now()):
   703	            logger.debug("Cancelling job %s", self)
   704	            return CancelJob
   705	
   706	        logger.debug("Running job %s", self)
   707	        ret = self.job_func()
   708	        self._run_count += 1
   709	        self.last_run = datetime.datetime.now()
   710	        self._schedule_next_run()
   711	
   712	        if self._is_overdue(self.next_run):
   713	            logger.debug("Cancelling job %s", self)
   714	            return CancelJob
   715	        if self._max_runs is not None and self._run_count >= self._max_runs:
   716	            logger.debug("Cancelling job %s", self)
   717	            return CancelJob
   718	        return ret
