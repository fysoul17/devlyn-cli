   690	    def run(self):
   691	        """
   692	        Run the job and immediately reschedule it.
   693	        If the job's deadline is reached (configured using .until()), the job is not
   694	        run and CancelJob is returned immediately. If the next scheduled run exceeds
   695	        the job's deadline, CancelJob is returned after the execution. In this latter
   696	        case CancelJob takes priority over any other returned value.
