/bin/zsh -lc "python3 -c '
import datetime
import json
import schedule

results = {}

scheduler = schedule.Scheduler()
calls = []
first = scheduler.every().second.max_runs(1).do(lambda: calls.append(\"first\"))
second = scheduler.every().second.max_runs(2).do(lambda: calls.append(\"second\"))
scheduler.run_all()
scheduler.run_all()
scheduler.run_all()
results[\"two_jobs_run_all\"] = {\"calls\": calls, \"jobs_remaining\": len(scheduler.jobs), \"counts\": [first._run_count, second._run_count]}

scheduler = schedule.Scheduler()
calls = []
job = scheduler.every().second.max_runs(3).do(lambda: calls.append(\"lowered\"))
scheduler.run_all()
job.max_runs(1)
scheduler.run_all()
results[\"lowered_budget\"] = {\"calls\": len(calls), \"jobs_remaining\": len(scheduler.jobs), \"run_count\": job._run_count, \"max_runs\": job._max_runs}

scheduler = schedule.Scheduler()
calls = []
def raising_job():
    calls.append(\"raised\")
    raise RuntimeError(\"boom\")
job = scheduler.every().second.max_runs(1).do(raising_job)
for _ in range(2):
    try:
        scheduler.run_all()
    except RuntimeError:
        pass
results[\"raising_job\"] = {\"calls\": len(calls), \"jobs_remaining\": len(scheduler.jobs), \"run_count\": job._run_count}

print(json.dumps(results, sort_keys=True))
