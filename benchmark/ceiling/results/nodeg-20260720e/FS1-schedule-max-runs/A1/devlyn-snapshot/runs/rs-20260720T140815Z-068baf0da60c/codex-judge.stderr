   720	    def _schedule_next_run(self) -> None:
   721	        """
   722	        Compute the instant when this job should run next.
   723	        """
   724	        if self.unit not in ("seconds", "minutes", "hours", "days", "weeks"):
   725	            raise ScheduleValueError(
   726	                "Invalid unit (valid units are `seconds`, `minutes`, `hours`, "
   727	                "`days`, and `weeks`)"
   728	            )
