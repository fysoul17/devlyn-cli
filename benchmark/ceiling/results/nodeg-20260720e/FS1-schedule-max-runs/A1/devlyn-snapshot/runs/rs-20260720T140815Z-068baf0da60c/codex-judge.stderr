   730	            if not (self.latest >= self.interval):
   731	                raise ScheduleError("`latest` is greater than `interval`")
   732	            interval = random.randint(self.interval, self.latest)
   733	        else:
   734	            interval = self.interval
   735	
   736	        # Do all computation in the context of the requested timezone
   737	        now = datetime.datetime.now(self.at_time_zone)
   738	
   739	        next_run = now
   740	
   741	        if self.start_day is not None:
   742	            if self.unit != "weeks":
   743	                raise ScheduleValueError("`unit` should be 'weeks'")
   744	            next_run = _move_to_next_weekday(next_run, self.start_day)
   745	
   746	        if self.at_time is not None:
   747	            next_run = self._move_to_at_time(next_run)
   748	
   749	        period = datetime.timedelta(**{self.unit: interval})
   750	        if interval != 1:
   751	            next_run += period
   752	
   753	        while next_run <= now:
   754	            next_run += period
   755	
   756	        next_run = self._correct_utc_offset(
   757	            next_run, fixate_time=(self.at_time is not None)
   758	        )
   759	
   760	        # To keep the api consistent with older versions, we have to set the 'next_run' to a naive timestamp in the local timezone.
   761	        # Because we want to stay backwards compatible with older versions.
   762	        if self.at_time_zone is not None:
   763	            # Convert back to the local timezone
   764	            next_run = next_run.astimezone()
   765	
   766	            next_run = next_run.replace(tzinfo=None)
   767	
   768	        self.next_run = next_run
