   842	    def _decode_datetimestr(
   843	        self, datetime_str: str, formats: List[str]
   844	    ) -> Optional[datetime.datetime]:
   845	        for f in formats:
   846	            try:
   847	                return datetime.datetime.strptime(datetime_str, f)
   848	            except ValueError:
   849	                pass
   850	        return None
