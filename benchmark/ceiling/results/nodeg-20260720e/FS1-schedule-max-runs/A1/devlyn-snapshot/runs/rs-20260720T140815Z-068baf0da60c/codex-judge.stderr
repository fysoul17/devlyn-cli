   770	    def _move_to_at_time(self, moment: datetime.datetime) -> datetime.datetime:
   771	        """
   772	        Takes a datetime and moves the time-component to the job's at_time.
   773	        """
   774	        if self.at_time is None:
   775	            return moment
   776	
   777	        kwargs = {"second": self.at_time.second, "microsecond": 0}
   778	
   779	        if self.unit == "days" or self.start_day is not None:
   780	            kwargs["hour"] = self.at_time.hour
   781	
   782	        if self.unit in ["days", "hours"] or self.start_day is not None:
   783	            kwargs["minute"] = self.at_time.minute
   784	
   785	        moment = moment.replace(**kwargs)  # type: ignore
   786	
   787	        # When we set the time elements, we might end up in a different UTC-offset than the current offset.
   788	        # This happens when we cross into or out of daylight saving time.
   789	        moment = self._correct_utc_offset(moment, fixate_time=True)
   790	
   791	        return moment
   792	
   793	    def _correct_utc_offset(
   794	        self, moment: datetime.datetime, fixate_time: bool
   795	    ) -> datetime.datetime:
   796	        """
   797	        Given a datetime, corrects any mistakes in the utc offset.
   798	        This is similar to pytz' normalize, but adds the ability to attempt
   799	        keeping the time-component at the same hour/minute/second.
   800	        """
   801	        if self.at_time_zone is None:
   802	            return moment
   803	        # Normalize corrects the utc-offset to match the timezone
   804	        # For example: When a date&time&offset does not exist within a timezone,
   805	        # the normalization will change the utc-offset to where it is valid.
   806	        # It does this while keeping the moment in time the same, by moving the
   807	        # time component opposite of the utc-change.
   808	        offset_before_normalize = moment.utcoffset()
   809	        moment = self.at_time_zone.normalize(moment)
   810	        offset_after_normalize = moment.utcoffset()
   811	
   812	        if offset_before_normalize == offset_after_normalize:
   813	            # There was no change in the utc-offset, datetime didn't change.
   814	            return moment
   815	
   816	        # The utc-offset and time-component has changed
   817	
   818	        if not fixate_time:
   819	            # No need to fixate the time.
   820	            return moment
   821	
   822	        offset_diff = offset_after_normalize - offset_before_normalize
   823	
   824	        # Adjust the time to reset the date-time to have the same HH:mm components
   825	        moment -= offset_diff
   826	
   827	        # Check if moving the timestamp back by the utc-offset-difference made it end up
   828	        # in a moment that does not exist within the current timezone/utc-offset
   829	        re_normalized_offset = self.at_time_zone.normalize(moment).utcoffset()
   830	        if re_normalized_offset != offset_after_normalize:
   831	            # We ended up in a DST Gap. The requested 'at' time does not exist
   832	            # within the current timezone/utc-offset. As a best effort, we will
   833	            # schedule the job 1 offset later than possible.
   834	            # For example, if 02:23 does not exist (because DST moves from 02:00
   835	            # to 03:00), this will schedule the job at 03:23.
   836	            moment += offset_diff
   837	        return moment
