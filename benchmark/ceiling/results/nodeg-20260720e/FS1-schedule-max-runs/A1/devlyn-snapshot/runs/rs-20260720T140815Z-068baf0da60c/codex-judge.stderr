import datetime
import json
import schedule
from test_schedule import mock_datetime

results = {}
for name, budget, deadline_seconds, run_second in ((\"budget_first\", 1, 10, 1), (\"deadline_first\", 3, 1, 2), (\"equal_boundary\", 1, 1, 1)):
    scheduler = schedule.Scheduler()
    calls = []
    with mock_datetime(2020, 1, 1, 10, 0, 0):
        job = scheduler.every().second.max_runs(budget).until(datetime.timedelta(seconds=deadline_seconds)).do(lambda: calls.append(name))
        with mock_datetime(2020, 1, 1, 10, 0, run_second):
            scheduler.run_pending()
    results[name] = {\"calls\": len(calls), \"jobs_remaining\": len(scheduler.jobs), \"run_count\": job._run_count}
print(json.dumps(results, sort_keys=True))
