+    def test_limit_choices_to_preserves_custom_queryset(self):
+        def formfield_callback(db_field, **kwargs):
+            formfield = db_field.formfield(**kwargs)
+            if db_field.name == 'most_recently_fooled':
+                formfield.queryset = formfield.queryset.annotate(
