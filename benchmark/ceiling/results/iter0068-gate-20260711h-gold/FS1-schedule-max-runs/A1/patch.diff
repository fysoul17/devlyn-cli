+    def max_runs(self, n: int):
+        """
+        Limit the total number of times this job will be executed.
+
+        After the job has run `n` times it is automatically removed from
+        its scheduler, exactly as a job returning CancelJob would be. When
+        combined with :meth:`Job.until`, whichever limit is reached first
+        cancels the job.
+
+        :param n: Maximum number of executions; must be an int >= 1.
+        :return: The invoked job instance
+        """
+        if isinstance(n, bool) or not isinstance(n, int) or n < 1:
+            raise ValueError("max_runs(n) requires an integer n >= 1")
+        self.max_runs_limit = n
+        return self
+
