+test('POST /webhook accepts a correctly signed first delivery', async () => {
+  const server = await startServer();
+  try {
+    const bytes = Buffer.from('{"id":"evt_test_happy","type":"order.created","timestamp":1,"data":{}}');
+    const response = await postWebhook(server, bytes);
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: 'evt_test_happy' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects every later delivery of an accepted id', async () => {
+  const server = await startServer();
+  try {
+    const firstBytes = Buffer.from('{"id":"evt_test_replay","type":"order.created","timestamp":1,"data":{}}');
+    const malformedBytes = Buffer.from('{"id":"evt_test_replay","type":"order.created","timestamp":"bad","data":{}}');
+    const first = await postWebhook(server, firstBytes);
+    const repeated = await postWebhook(server, firstBytes);
+    const malformed = await postWebhook(server, malformedBytes);
+    assert.strictEqual(first.status, 200);
+    assert.deepStrictEqual(repeated.body, { error: 'duplicate_event', id: 'evt_test_replay' });
+    assert.strictEqual(repeated.status, 409);
+    assert.deepStrictEqual(malformed.body, { error: 'duplicate_event', id: 'evt_test_replay' });
+    assert.strictEqual(malformed.status, 409);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects bytes changed after signing', async () => {
+  const server = await startServer();
