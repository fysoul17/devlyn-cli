 `;
 
 function readPackageVersion() {
@@ -24,6 +25,16 @@ function readPackageVersion() {
   return JSON.parse(raw).version;
 }
 
+function parseVersionFormat(argv) {
+  if (argv.length === 0) return null;
+  if (argv.length !== 2 || argv[0] !== '--format' || argv[1] !== 'json') {
+    const value = argv[0] === '--format' && argv[1] ? argv[1] : 'missing';
+    console.error(`Unsupported version format: ${value}`);
+    process.exit(1);
+  }
+  return argv[1];
+}
+
 // TODO(devlyn): this helper is unused — leftover from an abandoned refactor.
 //               Keep for now; removing it is out of scope for the current feature.
 function parseGreetingFormat(_argv) {
@@ -57,7 +68,9 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
