+app.post('/items/import', (req, res) => {
+  const importedItems = req.body && req.body.items;
+  if (!Array.isArray(importedItems)) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  // Validate the entire batch before allocating IDs or changing the store so a
+  // rejected import cannot leave behind partially-created items.
+  for (const [index, item] of importedItems.entries()) {
+    if (!item || typeof item.name !== 'string' || item.name.trim() === '') {
+      res.status(400).json({ error: 'invalid_batch', index, field: 'name' });
+      return;
+    }
+    if (!Number.isInteger(item.qty) || item.qty <= 0) {
+      res.status(400).json({ error: 'invalid_batch', index, field: 'qty' });
+      return;
+    }
+  }
+
+  const usedIds = new Set(
+    items
+      .map((item) => item.id)
+      .filter((id) => typeof id === 'number' && Number.isFinite(id)),
+  );
+  let nextId = 1;
+  const createdItems = importedItems.map((item) => {
+    while (usedIds.has(nextId)) nextId += 1;
+    const createdItem = { id: nextId, name: item.name, qty: item.qty };
+    usedIds.add(nextId);
+    nextId += 1;
+    return createdItem;
+  });
+
+  items.push(...createdItems);
+  res.status(201).json({ inserted: createdItems.length });
+});
