+test('POST /items/import rejects an invalid middle item without changing state', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const { status, body } = await request(server, 'POST', '/items/import', {
+      items: [
+        { name: 'gamma', qty: 2 },
+        { name: 'invalid', qty: 0 },
+        { name: 'delta', qty: 4 },
+      ],
+    });
+    const after = await get(server, '/items');
+
+    assert.strictEqual(status, 400);
+    assert.deepStrictEqual(body, { error: 'invalid_batch', index: 1, field: 'qty' });
+    assert.deepStrictEqual(after.body.items, before.body.items);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import adds every valid item in input order', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const { status, body } = await request(server, 'POST', '/items/import', {
+      items: [
+        { name: 'gamma', qty: 2 },
+        { name: 'delta', qty: 4 },
+      ],
+    });
+    const after = await get(server, '/items');
+    const expectedItems = [
+      { id: before.body.items.length + 1, name: 'gamma', qty: 2 },
+      { id: before.body.items.length + 2, name: 'delta', qty: 4 },
+    ];
+
+    assert.strictEqual(status, 201);
+    assert.deepStrictEqual(body, { inserted: 2 });
+    assert.deepStrictEqual(after.body.items.slice(-2), expectedItems);
+  } finally {
+    server.close();
+  }
+});
