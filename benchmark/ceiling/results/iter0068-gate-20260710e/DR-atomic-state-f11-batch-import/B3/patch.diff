--- a/server/index.js
+++ b/server/index.js
@@ -17,6 +17,46 @@ app.get('/items', (_req, res) => {
   res.json({ items });
 });
 
+app.post('/items/import', (req, res) => {
+  if (!req.body || !Array.isArray(req.body.items)) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  const { items: batch } = req.body;
+  for (let index = 0; index < batch.length; index += 1) {
+    const item = batch[index];
+    if (!item || typeof item.name !== 'string' || item.name.trim() === '') {
+      res.status(400).json({ error: 'invalid_batch', index, field: 'name' });
+      return;
+    }
+    if (!Number.isInteger(item.qty) || item.qty <= 0) {
+      res.status(400).json({ error: 'invalid_batch', index, field: 'qty' });
+      return;
+    }
+  }
+
+  const existingIds = new Set(items.map((item) => item.id));
+  let nextId = Math.max(
+    0,
+    ...items
+      .map((item) => item.id)
+      .filter((id) => typeof id === 'number' && Number.isFinite(id)),
+  ) + 1;
+  const importedItems = batch.map((item) => {
+    while (existingIds.has(nextId)) {
+      nextId += 1;
+    }
+    const importedItem = { id: nextId, name: item.name, qty: item.qty };
+    existingIds.add(nextId);
+    nextId += 1;
+    return importedItem;
+  });
+
+  items.push(...importedItems);
+  res.status(201).json({ inserted: importedItems.length });
+});
+
