+test('POST /items/import rejects an invalid middle item without changing items', async () => {
+  const server = await startServer();
+  try {
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', {
+      items: [
+        { name: 'gamma', qty: 2 },
+        { name: '   ', qty: 4 },
+        { name: 'delta', qty: 6 },
+      ],
+    });
+    const after = await get(server, '/items');
+
+    assert.strictEqual(response.status, 400);
+    assert.deepStrictEqual(response.body, {
+      error: 'invalid_batch',
+      index: 1,
+      field: 'name',
+    });
+    assert.deepStrictEqual(after.body.items, before.body.items);
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /items/import appends a valid batch in order with unique ids', async () => {
+  const server = await startServer();
+  try {
+    const batch = [
+      { name: 'gamma', qty: 2 },
+      { name: 'delta', qty: 6 },
+    ];
+    const before = await get(server, '/items');
+    const response = await post(server, '/items/import', { items: batch });
+    const after = await get(server, '/items');
+    const importedItems = after.body.items.slice(before.body.items.length);
+
+    assert.strictEqual(response.status, 201);
+    assert.deepStrictEqual(response.body, { inserted: batch.length });
+    assert.deepStrictEqual(
+      importedItems.map(({ name, qty }) => ({ name, qty })),
+      batch,
+    );
+    assert.ok(importedItems.every((item) => typeof item.id === 'number'));
+    assert.strictEqual(
+      new Set(after.body.items.map((item) => item.id)).size,
+      after.body.items.length,
+    );
+  } finally {
+    server.close();
+  }
+});
