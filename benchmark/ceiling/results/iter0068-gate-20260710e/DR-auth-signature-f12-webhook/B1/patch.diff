+    assert.strictEqual(unsignedResponse.status, 401);
+    assert.deepStrictEqual(unsignedResponse.body, { error: 'invalid_signature' });
+
+    const signedResponse = await postWebhook(server, malformedBody, signWebhookBody(malformedBody));
+    assert.strictEqual(signedResponse.status, 400);
