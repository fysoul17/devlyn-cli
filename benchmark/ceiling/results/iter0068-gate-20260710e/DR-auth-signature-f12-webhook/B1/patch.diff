+function hasValidWebhookSignature(signature, rawBody) {
+  if (typeof signature !== 'string' || !/^[0-9a-f]{64}$/.test(signature)) {
+    return false;
+  }
+
+  const provided = Buffer.from(signature, 'hex');
+  const expected = crypto.createHmac('sha256', webhookSecret).update(rawBody).digest();
+  return crypto.timingSafeEqual(provided, expected);
+}
+
+app.post('/webhook', express.raw({ type: () => true }), (req, res) => {
+  const rawBody = Buffer.isBuffer(req.body) ? req.body : Buffer.alloc(0);
+
+  if (!hasValidWebhookSignature(req.get('X-Signature'), rawBody)) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  let event;
+  try {
+    event = JSON.parse(rawBody.toString('utf8'));
+  } catch {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  if (
+    event !== null &&
+    typeof event === 'object' &&
+    !Array.isArray(event) &&
+    typeof event.id === 'string' &&
+    acceptedWebhookIds.has(event.id)
+  ) {
+    res.status(409).json({ error: 'duplicate_event', id: event.id });
+    return;
+  }
+
+  if (
+    event === null ||
+    typeof event !== 'object' ||
+    Array.isArray(event) ||
+    typeof event.id !== 'string' ||
+    event.id.length === 0 ||
+    typeof event.type !== 'string' ||
+    event.type.length === 0 ||
+    !Number.isFinite(event.timestamp) ||
+    event.data === null ||
+    typeof event.data !== 'object' ||
+    Array.isArray(event.data)
+  ) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedWebhookIds.add(event.id);
+  res.json({ accepted: true, id: event.id });
+});
