+
+test('POST /webhook rejects a validly signed replay before validating its other fields', async () => {
+  const server = await startServer();
+  try {
+    const event = validWebhookEvent();
+    const firstBody = JSON.stringify(event);
+    const firstResponse = await postWebhook(server, firstBody, signWebhookBody(firstBody));
+    assert.strictEqual(firstResponse.status, 200);
+
+    const replayBody = JSON.stringify({ id: event.id });
+    const replayResponse = await postWebhook(server, replayBody, signWebhookBody(replayBody));
+
+    assert.strictEqual(replayResponse.status, 409);
+    assert.deepStrictEqual(replayResponse.body, { error: 'duplicate_event', id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a tampered body signed for the original bytes', async () => {
+  const server = await startServer();
+  try {
+    const body = JSON.stringify(validWebhookEvent());
+    const tamperedBody = body.replace('item.updated', 'item.deleted');
+    const response = await postWebhook(server, tamperedBody, signWebhookBody(body));
+
+    assert.strictEqual(response.status, 401);
+    assert.deepStrictEqual(response.body, { error: 'invalid_signature' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook checks the signature before parsing and reports signed malformed JSON as invalid body', async () => {
+  const server = await startServer();
