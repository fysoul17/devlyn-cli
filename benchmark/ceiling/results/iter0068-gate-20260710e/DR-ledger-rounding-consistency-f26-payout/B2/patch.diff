   assert.match(out, /Hello, world!/);
@@ -23,3 +41,88 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('payout calculates exact fees, reserves, totals, and idempotent events', () => {
+  const result = runPayout([
+    { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+    { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+    { id: 'refund-a', merchant_id: 'merchant-a', type: 'refund', amount_cents: 500 },
+    { id: 'dispute-a', merchant_id: 'merchant-a', type: 'dispute', amount_cents: 2000 },
+    { id: 'charge-b', merchant_id: 'merchant-b', type: 'charge', amount_cents: 1000 },
+  ]);
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    total_payout_cents: 5112,
+    total_processing_fee_cents: 379,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 1509,
+    merchants: [
+      {
+        merchant_id: 'merchant-a',
+        gross_charge_cents: 10000,
+        refund_cents: 500,
+        dispute_cents: 2000,
+        processing_fee_cents: 320,
+        dispute_fee_cents: 1500,
+        reserve_cents: 568,
+        payout_cents: 5112,
+      },
+      {
+        merchant_id: 'merchant-b',
+        gross_charge_cents: 1000,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 59,
+        dispute_fee_cents: 0,
+        reserve_cents: 941,
+        payout_cents: 0,
+      },
+    ],
+  });
+});
+
+test('payout rejects invalid event types with JSON-only stderr', () => {
+  const result = runPayout([
+    { id: 'event-1', merchant_id: 'merchant-1', type: 'capture', amount_cents: 1000 },
+  ]);
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.deepStrictEqual(JSON.parse(result.stderr), { error: 'unknown_event_type' });
+});
+
+test('payout emits JSON errors for malformed and unreadable input files', () => {
+  const malformedResult = runPayoutInput('{');
+  assert.strictEqual(malformedResult.status, 2);
+  assert.strictEqual(malformedResult.stdout, '');
+  assert.deepStrictEqual(JSON.parse(malformedResult.stderr), { error: 'invalid_json' });
+
+  const missingDir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-missing-'));
+  let unreadableResult;
+  try {
+    unreadableResult = spawnSync('node', [CLI, 'payout', '--input', path.join(missingDir, 'input.json')], {
+      encoding: 'utf8',
+    });
+  } finally {
+    fs.rmSync(missingDir, { recursive: true, force: true });
+  }
+  assert.strictEqual(unreadableResult.status, 2);
+  assert.strictEqual(unreadableResult.stdout, '');
+  assert.deepStrictEqual(JSON.parse(unreadableResult.stderr), { error: 'unreadable_input' });
+});
+
+test('payout rejects conflicting duplicate events before producing totals', () => {
+  const result = runPayout([
+    { id: 'event-1', merchant_id: 'merchant-1', type: 'charge', amount_cents: 1000 },
+    { id: 'event-1', merchant_id: 'merchant-1', type: 'charge', amount_cents: 1001 },
+  ]);
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.deepStrictEqual(JSON.parse(result.stderr), {
+    error: 'conflicting_duplicate',
+    id: 'event-1',
+  });
+});
