@@ -35,6 +37,213 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writePayoutError(error, details = {}) {
+  process.stderr.write(JSON.stringify({ error, ...details }));
+  process.exitCode = 2;
+}
+
+function readJsonFile(filePath, unreadableError, invalidJsonError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch {
+    return { error: unreadableError };
+  }
+
+  try {
+    return { value: JSON.parse(raw) };
+  } catch {
+    return { error: invalidJsonError };
+  }
+}
+
+function canonicalJson(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(canonicalJson).join(',')}]`;
+  }
+
+  if (value && typeof value === 'object') {
+    return `{${Object.keys(value)
+      .sort()
+      .map((key) => `${JSON.stringify(key)}:${canonicalJson(value[key])}`)
+      .join(',')}}`;
+  }
+
+  return JSON.stringify(value);
+}
+
+function validPayoutRules(rules) {
+  return (
+    rules &&
+    typeof rules === 'object' &&
+    !Array.isArray(rules) &&
+    typeof rules.processing_fee_percent === 'number' &&
+    Number.isFinite(rules.processing_fee_percent) &&
+    rules.processing_fee_percent >= 0 &&
+    Number.isSafeInteger(rules.fixed_fee_cents) &&
+    rules.fixed_fee_cents >= 0 &&
+    Number.isSafeInteger(rules.dispute_fee_cents) &&
+    rules.dispute_fee_cents >= 0 &&
+    typeof rules.reserve_percent === 'number' &&
+    Number.isFinite(rules.reserve_percent) &&
+    rules.reserve_percent >= 0 &&
+    Number.isSafeInteger(rules.minimum_payout_cents) &&
+    rules.minimum_payout_cents >= 0
+  );
+}
+
+function validEventIdentity(event) {
+  if (!event || typeof event !== 'object' || Array.isArray(event)) {
+    return 'invalid_event';
+  }
+  if (typeof event.id !== 'string' || event.id.length === 0) {
+    return 'missing_id';
+  }
+  return null;
+}
+
+function validEvent(event) {
+  const identityError = validEventIdentity(event);
+  if (identityError) {
+    return identityError;
+  }
+  if (typeof event.merchant_id !== 'string' || event.merchant_id.length === 0) {
+    return 'missing_merchant_id';
+  }
+  if (!['charge', 'refund', 'dispute'].includes(event.type)) {
+    return 'unknown_event_type';
+  }
+  if (!Number.isSafeInteger(event.amount_cents) || event.amount_cents <= 0) {
+    return 'invalid_amount_cents';
+  }
+  return null;
+}
+
+function createMerchant(merchantId) {
+  return {
+    merchant_id: merchantId,
+    gross_charge_cents: 0,
+    refund_cents: 0,
+    dispute_cents: 0,
+    processing_fee_cents: 0,
+    dispute_fee_cents: 0,
+    reserve_cents: 0,
+    payout_cents: 0,
+  };
+}
+
+function sumMerchantField(merchants, field) {
+  return merchants.reduce((total, merchant) => total + merchant[field], 0);
+}
+
+function runPayout(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    writePayoutError('invalid_arguments');
+    return;
+  }
+
+  const inputResult = readJsonFile(argv[1], 'unreadable_input', 'invalid_json');
+  if (inputResult.error) {
+    writePayoutError(inputResult.error);
+    return;
+  }
+
+  const input = inputResult.value;
+  if (!input || typeof input !== 'object' || Array.isArray(input) || !Object.hasOwn(input, 'events')) {
+    writePayoutError('missing_events');
+    return;
+  }
+  if (!Array.isArray(input.events)) {
+    writePayoutError('invalid_events');
+    return;
+  }
+
+  const rulesResult = readJsonFile(
+    path.join(__dirname, '..', 'data', 'payout-rules.json'),
+    'unreadable_payout_rules',
+    'invalid_payout_rules',
+  );
+  if (rulesResult.error || !validPayoutRules(rulesResult.value)) {
+    writePayoutError(rulesResult.error || 'invalid_payout_rules');
+    return;
+  }
+
+  const rules = rulesResult.value;
+  const eventsById = new Map();
+  const merchantsById = new Map();
+  const merchants = [];
+
+  for (const event of input.events) {
+    const identityError = validEventIdentity(event);
+    if (identityError) {
+      writePayoutError(identityError);
+      return;
+    }
+
+    const fingerprint = canonicalJson(event);
+    const previousFingerprint = eventsById.get(event.id);
+    if (previousFingerprint !== undefined) {
+      if (previousFingerprint !== fingerprint) {
+        writePayoutError('conflicting_duplicate', { id: event.id });
+        return;
+      }
+      continue;
+    }
+    eventsById.set(event.id, fingerprint);
+
+    const eventError = validEvent(event);
+    if (eventError) {
+      writePayoutError(eventError);
+      return;
+    }
+
+    let merchant = merchantsById.get(event.merchant_id);
+    if (!merchant) {
+      merchant = createMerchant(event.merchant_id);
+      merchantsById.set(event.merchant_id, merchant);
+      merchants.push(merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents +=
+        Math.round((event.amount_cents * rules.processing_fee_percent) / 100) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  for (const merchant of merchants) {
+    const netBeforeReserve =
+      merchant.gross_charge_cents -
+      merchant.refund_cents -
+      merchant.dispute_cents -
+      merchant.processing_fee_cents -
+      merchant.dispute_fee_cents;
+    merchant.reserve_cents =
+      netBeforeReserve > 0 ? Math.round((netBeforeReserve * rules.reserve_percent) / 100) : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  process.stdout.write(
+    JSON.stringify({
+      total_payout_cents: sumMerchantField(merchants, 'payout_cents'),
+      total_processing_fee_cents: sumMerchantField(merchants, 'processing_fee_cents'),
+      total_dispute_fee_cents: sumMerchantField(merchants, 'dispute_fee_cents'),
+      total_reserve_cents: sumMerchantField(merchants, 'reserve_cents'),
+      merchants,
+    }),
+  );
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
