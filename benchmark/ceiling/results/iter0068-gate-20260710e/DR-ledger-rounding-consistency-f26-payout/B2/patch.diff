+function runPayoutInput(input) {
+  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-payout-'));
+  const inputPath = path.join(tempDir, 'events.json');
+  fs.writeFileSync(inputPath, input);
+
+  try {
+    return spawnSync('node', [CLI, 'payout', '--input', inputPath], { encoding: 'utf8' });
+  } finally {
+    fs.rmSync(tempDir, { recursive: true, force: true });
+  }
+}
+
+function runPayout(events) {
+  return runPayoutInput(JSON.stringify({ events }));
+}
+
 test('hello default', () => {
