+      { id: 'dispute-1', merchant_id: 'merchant-a', type: 'dispute', amount_cents: 2000 },
+      { id: 'charge-2', merchant_id: 'merchant-b', type: 'charge', amount_cents: 1200 },
+      { id: 'charge-3', merchant_id: 'merchant-c', type: 'charge', amount_cents: 1000 },
