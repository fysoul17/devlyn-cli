   return value;
 }
 
+function writeJsonError(error) {
+  process.stderr.write(`${JSON.stringify(error)}\n`);
+  return 2;
+}
+
+function canonicalJson(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(canonicalJson).join(',')}]`;
+  }
+
+  if (value && typeof value === 'object') {
+    return `{${Object.keys(value)
+      .sort()
+      .map((key) => `${JSON.stringify(key)}:${canonicalJson(value[key])}`)
+      .join(',')}}`;
+  }
+
+  return JSON.stringify(value);
+}
+
+function readPayoutRules() {
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  let rules;
+
+  try {
+    rules = JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
+  } catch {
+    return { error: 'payout_rules_error' };
+  }
+
+  if (!rules || typeof rules !== 'object' || Array.isArray(rules)) {
+    return { error: 'invalid_payout_rules' };
+  }
+
+  const percentFields = ['processing_fee_percent', 'reserve_percent'];
+  const centFields = ['fixed_fee_cents', 'dispute_fee_cents', 'minimum_payout_cents'];
+  const hasValidPercent = percentFields.every(
+    (field) => Number.isFinite(rules[field]) && rules[field] >= 0,
+  );
+  const hasValidCents = centFields.every(
+    (field) => Number.isInteger(rules[field]) && rules[field] >= 0,
+  );
+
+  if (!hasValidPercent || !hasValidCents) return { error: 'invalid_payout_rules' };
+
+  return { rules };
+}
+
+function readPayoutEvents(inputPath) {
+  let input;
+
+  try {
+    input = fs.readFileSync(inputPath, 'utf8');
+  } catch {
+    return { error: 'input_read_error' };
+  }
+
+  try {
+    return { value: JSON.parse(input) };
+  } catch {
+    return { error: 'invalid_json' };
+  }
+}
+
+function validateEvent(event) {
+  if (!event || typeof event !== 'object' || Array.isArray(event)) {
+    return { error: 'invalid_event' };
+  }
+  if (typeof event.id !== 'string') {
+    return { error: 'missing_id' };
+  }
+  if (typeof event.merchant_id !== 'string') {
+    return { error: 'missing_merchant_id' };
+  }
+  if (!['charge', 'refund', 'dispute'].includes(event.type)) {
+    return { error: 'unknown_event_type' };
+  }
+  if (!Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
+    return { error: 'invalid_amount_cents' };
+  }
+
+  return null;
+}
+
+function calculatePayouts(events, rules) {
+  const eventsById = new Map();
+  const uniqueEvents = [];
+
+  for (const event of events) {
+    if (!event || typeof event !== 'object' || Array.isArray(event)) {
+      return { error: 'invalid_event' };
+    }
+    if (typeof event.id !== 'string') return { error: 'missing_id' };
+
+    const serializedEvent = canonicalJson(event);
+    const existingEvent = eventsById.get(event.id);
+    if (existingEvent) {
+      if (existingEvent !== serializedEvent) {
+        return { error: 'conflicting_duplicate', id: event.id };
+      }
+      continue;
+    }
+
+    eventsById.set(event.id, serializedEvent);
+    uniqueEvents.push(event);
+  }
+
+  for (const event of uniqueEvents) {
+    const validationError = validateEvent(event);
+    if (validationError) return validationError;
+  }
+
+  const merchants = new Map();
+  for (const event of uniqueEvents) {
+    let merchant = merchants.get(event.merchant_id);
+    if (!merchant) {
+      merchant = {
+        merchant_id: event.merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+        reserve_cents: 0,
+        payout_cents: 0,
+      };
+      merchants.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents +=
+        Math.round((event.amount_cents * rules.processing_fee_percent) / 100) +
+        rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchantRows = [...merchants.values()];
+  for (const merchant of merchantRows) {
+    const netBeforeReserve =
+      merchant.gross_charge_cents -
+      merchant.refund_cents -
+      merchant.dispute_cents -
+      merchant.processing_fee_cents -
+      merchant.dispute_fee_cents;
+
+    merchant.reserve_cents =
+      netBeforeReserve > 0
+        ? Math.round((netBeforeReserve * rules.reserve_percent) / 100)
+        : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (
+      merchant.payout_cents > 0 &&
+      merchant.payout_cents < rules.minimum_payout_cents
+    ) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  return {
+    total_payout_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.payout_cents,
+      0,
+    ),
+    total_processing_fee_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.processing_fee_cents,
+      0,
+    ),
+    total_dispute_fee_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.dispute_fee_cents,
+      0,
+    ),
+    total_reserve_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.reserve_cents,
+      0,
+    ),
+    merchants: merchantRows,
+  };
+}
+
+function payout(argv) {
+  const inputFlagIndex = argv.indexOf('--input');
+  const inputPath = argv[inputFlagIndex + 1];
+  if (
+    inputFlagIndex === -1 ||
+    !inputPath ||
+    inputPath.startsWith('-') ||
+    argv.length !== 2
+  ) {
+    return writeJsonError({ error: 'input_required' });
+  }
+
+  const rulesResult = readPayoutRules();
+  if (rulesResult.error) return writeJsonError({ error: rulesResult.error });
+
+  const inputResult = readPayoutEvents(inputPath);
+  if (inputResult.error) return writeJsonError({ error: inputResult.error });
+
+  if (
+    !inputResult.value ||
+    typeof inputResult.value !== 'object' ||
+    !Array.isArray(inputResult.value.events)
+  ) {
+    return writeJsonError({ error: 'missing_events' });
+  }
+
+  const payoutResult = calculatePayouts(inputResult.value.events, rulesResult.rules);
+  if (payoutResult.error) return writeJsonError(payoutResult);
+
+  process.stdout.write(`${JSON.stringify(payoutResult)}\n`);
+  return 0;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
