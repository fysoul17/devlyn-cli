diff --git a/bin/cli.js b/bin/cli.js
index 78fdd98..38fdc75 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -10,14 +10,18 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  payout --input PATH        Calculate merchant payouts from ledger events
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli payout --input ledger.json
 `;
 
+const PAYOUT_RULES_PATH = path.join(__dirname, '..', 'data', 'payout-rules.json');
+
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
@@ -35,6 +39,199 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writePayoutError(error, extra = {}) {
+  process.stderr.write(`${JSON.stringify({ error, ...extra })}\n`);
+  process.exitCode = 2;
+}
+
+function parseInputFlag(argv) {
+  const inputIndexes = argv
+    .map((argument, index) => (argument === '--input' ? index : -1))
+    .filter((index) => index !== -1);
+
+  if (inputIndexes.length !== 1) return null;
+
+  const value = argv[inputIndexes[0] + 1];
+  return value && !value.startsWith('-') ? value : null;
+}
+
+function loadJsonFile(filePath, unreadableError) {
+  let source;
+  try {
+    source = fs.readFileSync(filePath, 'utf8');
+  } catch {
+    return { error: unreadableError };
+  }
+
+  try {
+    return { value: JSON.parse(source) };
+  } catch {
+    return { error: 'invalid_json' };
+  }
+}
+
+function loadPayoutRules() {
+  const result = loadJsonFile(PAYOUT_RULES_PATH, 'payout_rules_unreadable');
+  if (result.error) return result;
+
+  const rules = result.value;
+  const valid = rules && typeof rules === 'object' && !Array.isArray(rules)
+    && Number.isFinite(rules.processing_fee_percent)
+    && Number.isSafeInteger(rules.fixed_fee_cents)
+    && Number.isSafeInteger(rules.dispute_fee_cents)
+    && Number.isFinite(rules.reserve_percent)
+    && Number.isSafeInteger(rules.minimum_payout_cents);
+
+  return valid ? { value: rules } : { error: 'invalid_payout_rules' };
+}
+
+function canonicalJson(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(canonicalJson).join(',')}]`;
+  }
+
+  if (value && typeof value === 'object') {
+    return `{${Object.keys(value).sort().map((key) => (
+      `${JSON.stringify(key)}:${canonicalJson(value[key])}`
+    )).join(',')}}`;
+  }
+
+  return JSON.stringify(value);
+}
+
+function validateEvent(event) {
+  if (!event || typeof event !== 'object' || Array.isArray(event)) {
+    return 'invalid_event';
+  }
+  if (typeof event.id !== 'string' || event.id.length === 0) return 'missing_id';
+  if (typeof event.merchant_id !== 'string' || event.merchant_id.length === 0) {
+    return 'missing_merchant_id';
+  }
+  if (!['charge', 'refund', 'dispute'].includes(event.type)) return 'unknown_event_type';
+  if (!Number.isSafeInteger(event.amount_cents) || event.amount_cents <= 0) {
+    return 'invalid_amount_cents';
+  }
+  return null;
+}
+
+function createMerchant(merchantId) {
+  return {
+    merchant_id: merchantId,
+    gross_charge_cents: 0,
+    refund_cents: 0,
+    dispute_cents: 0,
+    processing_fee_cents: 0,
+    dispute_fee_cents: 0,
+    reserve_cents: 0,
+    payout_cents: 0,
+  };
+}
+
+function calculatePayout(events, rules) {
+  const eventById = new Map();
+  const merchants = new Map();
+
+  for (const event of events) {
+    const validationError = validateEvent(event);
+    if (validationError) return { error: validationError };
+
+    const serializedEvent = canonicalJson(event);
+    const previousEvent = eventById.get(event.id);
+    if (previousEvent !== undefined) {
+      if (previousEvent !== serializedEvent) {
+        return { error: 'conflicting_duplicate', id: event.id };
+      }
+      continue;
+    }
+    eventById.set(event.id, serializedEvent);
+
+    let merchant = merchants.get(event.merchant_id);
+    if (!merchant) {
+      merchant = createMerchant(event.merchant_id);
+      merchants.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        event.amount_cents * rules.processing_fee_percent / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchantRows = [...merchants.values()];
+  for (const merchant of merchantRows) {
+    const netBeforeReserve = merchant.gross_charge_cents
+      - merchant.refund_cents
+      - merchant.dispute_cents
+      - merchant.processing_fee_cents
+      - merchant.dispute_fee_cents;
+    merchant.reserve_cents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  return {
+    value: {
+      total_payout_cents: merchantRows.reduce((total, merchant) => total + merchant.payout_cents, 0),
+      total_processing_fee_cents: merchantRows.reduce(
+        (total, merchant) => total + merchant.processing_fee_cents,
+        0,
+      ),
+      total_dispute_fee_cents: merchantRows.reduce(
+        (total, merchant) => total + merchant.dispute_fee_cents,
+        0,
+      ),
+      total_reserve_cents: merchantRows.reduce((total, merchant) => total + merchant.reserve_cents, 0),
+      merchants: merchantRows,
+    },
+  };
+}
+
+function runPayout(argv) {
+  const inputPath = parseInputFlag(argv);
+  if (!inputPath) {
+    writePayoutError('missing_input');
+    return;
+  }
+
+  const input = loadJsonFile(inputPath, 'input_unreadable');
+  if (input.error) {
+    writePayoutError(input.error);
+    return;
+  }
+  if (!input.value || typeof input.value !== 'object' || !Array.isArray(input.value.events)) {
+    writePayoutError('missing_events');
+    return;
+  }
+
+  const rules = loadPayoutRules();
+  if (rules.error) {
+    writePayoutError(rules.error);
+    return;
+  }
+
+  const payout = calculatePayout(input.value.events, rules.value);
+  if (payout.error) {
+    const { error, ...extra } = payout;
+    writePayoutError(error, extra);
+    return;
+  }
+
+  process.stdout.write(`${JSON.stringify(payout.value)}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +250,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'payout': {
+      runPayout(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
diff --git a/tests/cli.test.js b/tests/cli.test.js
