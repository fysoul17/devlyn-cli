@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
-const { execFileSync } = require('node:child_process');
+const { execFileSync, spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,17 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function runResult(args) {
+  return spawnSync('node', [CLI, ...args], { encoding: 'utf8' });
+}
+
+function writeInput(contents) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  const inputPath = path.join(directory, 'ledger.json');
+  fs.writeFileSync(inputPath, JSON.stringify(contents));
+  return inputPath;
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +36,77 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('payout calculates fees, reserves, threshold holds, and idempotent events', () => {
+  const inputPath = writeInput({
+    events: [
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+      { id: 'refund-1', merchant_id: 'merchant-a', type: 'refund', amount_cents: 500 },
+      { id: 'dispute-1', merchant_id: 'merchant-a', type: 'dispute', amount_cents: 1000 },
+      { id: 'charge-2', merchant_id: 'merchant-b', type: 'charge', amount_cents: 1000 },
+    ],
+  });
+
+  const result = runResult(['payout', '--input', inputPath]);
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    total_payout_cents: 6012,
+    total_processing_fee_cents: 379,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 1609,
+    merchants: [
+      {
+        merchant_id: 'merchant-a',
+        gross_charge_cents: 10000,
+        refund_cents: 500,
+        dispute_cents: 1000,
+        processing_fee_cents: 320,
+        dispute_fee_cents: 1500,
+        reserve_cents: 668,
+        payout_cents: 6012,
+      },
+      {
+        merchant_id: 'merchant-b',
+        gross_charge_cents: 1000,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 59,
+        dispute_fee_cents: 0,
+        reserve_cents: 941,
+        payout_cents: 0,
+      },
+    ],
+  });
+});
+
+test('payout rejects conflicting duplicate ids without stdout', () => {
+  const inputPath = writeInput({
+    events: [
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 1000 },
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 2000 },
+    ],
+  });
+
+  const result = runResult(['payout', '--input', inputPath]);
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.strictEqual(result.stderr, '{"error":"conflicting_duplicate","id":"charge-1"}\n');
+});
+
+test('payout rejects invalid event amounts without stdout', () => {
+  const inputPath = writeInput({
+    events: [
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 12.5 },
+    ],
+  });
+
+  const result = runResult(['payout', '--input', inputPath]);
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.deepStrictEqual(JSON.parse(result.stderr), { error: 'invalid_amount_cents' });
+});
