+function withCartFile(input, testCart) {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-cart-'));
+  const inputPath = path.join(dir, 'cart.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+  try {
+    testCart(inputPath);
+  } finally {
+    fs.rmSync(dir, { recursive: true, force: true });
+  }
+}
+
+function runCart(inputPath) {
+  return spawnSync(process.execPath, [CLI, 'cart', '--input', inputPath], { encoding: 'utf8' });
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +40,75 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('cart combines duplicate SKUs and applies promotions, coupon, tax, and shipping', () => {
+  withCartFile({
+    state: 'CA',
+    coupon: 'ORDER10',
+    items: [
+      { sku: 'TEE', qty: 2 },
+      { sku: 'BAG', qty: 2 },
+      { sku: 'TEE', qty: 1 },
+      { sku: 'MUG', qty: 2 },
+    ],
+  }, (inputPath) => {
+    const result = runCart(inputPath);
+
+    assert.equal(result.status, 0);
+    assert.equal(result.stderr, '');
+    assert.deepStrictEqual(JSON.parse(result.stdout), {
+      subtotal_cents: 16300,
+      line_discount_cents: 3500,
+      coupon_discount_cents: 1280,
+      tax_cents: 858,
+      shipping_cents: 0,
+      total_cents: 12378,
+      items: [
+        {
+          sku: 'TEE',
+          qty: 3,
+          line_subtotal_cents: 7500,
+          line_discount_cents: 2500,
+          line_total_cents: 5000,
+        },
+        {
+          sku: 'BAG',
+          qty: 2,
+          line_subtotal_cents: 6400,
+          line_discount_cents: 1000,
+          line_total_cents: 5400,
+        },
+        {
+          sku: 'MUG',
+          qty: 2,
+          line_subtotal_cents: 2400,
+          line_discount_cents: 0,
+          line_total_cents: 2400,
+        },
+      ],
+    });
+  });
+});
+
+test('cart reports combined stock failures as JSON on stderr', () => {
