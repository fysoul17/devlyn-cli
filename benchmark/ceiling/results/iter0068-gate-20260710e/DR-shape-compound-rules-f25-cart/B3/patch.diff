 `;
 
 function readPackageVersion() {
@@ -35,6 +37,168 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writeCartError(error) {
+  process.stderr.write(JSON.stringify(error));
+  process.exitCode = 2;
+}
+
+function readJsonFile(filePath, readError, parseError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch {
+    return { error: { error: readError } };
+  }
+
+  try {
+    return { value: JSON.parse(raw) };
+  } catch {
+    return { error: { error: parseError } };
+  }
+}
+
+function cartInputPath(argv) {
+  const index = argv.indexOf('--input');
+  const value = argv[index + 1];
+  return index === -1 || !value || value.startsWith('-') ? null : value;
+}
+
+function lineDiscountCents(sku, qty, unitCents, promotions) {
+  return promotions
+    .filter((promotion) => promotion.sku === sku)
+    .reduce((discount, promotion) => {
+      if (promotion.type === 'buy_x_get_y_free') {
+        return discount + Math.floor(qty / (promotion.buy_qty + promotion.free_qty))
+          * promotion.free_qty * unitCents;
+      }
+
+      if (promotion.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
+        return discount + promotion.per_unit_discount_cents * qty;
+      }
+
+      return discount;
+    }, 0);
+}
+
+function priceCart(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)) {
+    return { error: { error: 'invalid_input' } };
+  }
+  if (!Array.isArray(input.items)) {
+    return { error: { error: 'invalid_items' } };
+  }
+
+  const quantities = new Map();
+  for (const item of input.items) {
+    if (!item || typeof item !== 'object' || typeof item.sku !== 'string'
+      || !Number.isInteger(item.qty) || item.qty <= 0) {
+      return { error: { error: 'invalid_quantity' } };
+    }
+    quantities.set(item.sku, (quantities.get(item.sku) || 0) + item.qty);
+  }
+
+  const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
+  const catalogResult = readJsonFile(catalogPath, 'catalog_read_failed', 'invalid_catalog_json');
+  if (catalogResult.error) return catalogResult;
+  const catalog = catalogResult.value;
+  const products = catalog.products;
+
+  for (const [sku, qty] of quantities) {
+    const product = products[sku];
+    if (!product) return { error: { error: 'unknown_sku', sku } };
+    if (qty > product.stock) {
+      return {
+        error: { error: 'invalid_stock', sku, available: product.stock, requested: qty },
+      };
+    }
+  }
+
+  if (!Object.hasOwn(catalog.tax_rates, input.state)) {
+    return { error: { error: 'unknown_state', state: input.state } };
+  }
+  if (input.coupon !== null && typeof input.coupon !== 'string') {
+    return { error: { error: 'unknown_coupon', coupon: input.coupon } };
+  }
+
+  const coupon = input.coupon === null ? null : catalog.coupons[input.coupon];
+  if (input.coupon !== null && !coupon) {
+    return { error: { error: 'unknown_coupon', coupon: input.coupon } };
+  }
+
+  let subtotalCents = 0;
+  let lineDiscountCentsTotal = 0;
+  let taxablePostLineDiscountCents = 0;
+  const items = [];
+
+  for (const [sku, qty] of quantities) {
+    const product = products[sku];
+    const lineSubtotalCents = qty * product.unit_cents;
+    const lineDiscount = lineDiscountCents(
+      sku,
+      qty,
+      product.unit_cents,
+      catalog.line_promotions,
+    );
+    const lineTotalCents = lineSubtotalCents - lineDiscount;
+
+    subtotalCents += lineSubtotalCents;
+    lineDiscountCentsTotal += lineDiscount;
+    if (catalog.taxable_codes[product.tax_code] === true) {
+      taxablePostLineDiscountCents += lineTotalCents;
+    }
+    items.push({
+      sku,
+      qty,
+      line_subtotal_cents: lineSubtotalCents,
+      line_discount_cents: lineDiscount,
+      line_total_cents: lineTotalCents,
+    });
+  }
+
+  const postLineDiscountCents = subtotalCents - lineDiscountCentsTotal;
+  const couponDiscountCents = coupon && postLineDiscountCents >= coupon.min_subtotal_cents
+    ? Math.round(postLineDiscountCents * coupon.percent / 100)
+    : 0;
+  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[input.state]);
+  const shippingCents = postLineDiscountCents - couponDiscountCents >= catalog.free_shipping_min_cents
+    ? 0
+    : catalog.shipping_cents;
+
+  return {
+    value: {
+      subtotal_cents: subtotalCents,
+      line_discount_cents: lineDiscountCentsTotal,
+      coupon_discount_cents: couponDiscountCents,
+      tax_cents: taxCents,
+      shipping_cents: shippingCents,
+      total_cents: postLineDiscountCents - couponDiscountCents + taxCents + shippingCents,
+      items,
+    },
+  };
+}
+
+function cart(argv) {
+  const inputPath = cartInputPath(argv);
+  if (!inputPath) {
+    writeCartError({ error: 'input_required' });
+    return;
+  }
+
+  const input = readJsonFile(inputPath, 'input_read_failed', 'invalid_json');
+  if (input.error) {
+    writeCartError(input.error);
+    return;
+  }
+
+  const priced = priceCart(input.value);
+  if (priced.error) {
+    writeCartError(priced.error);
+    return;
+  }
+
+  process.stdout.write(JSON.stringify(priced.value));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +217,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'cart': {
+      cart(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
