+
+test('cart combines duplicate SKUs and prices promotions, coupon, tax, and shipping', () => {
+  const result = runCart({
+    state: 'CA',
+    coupon: 'SMALL5',
+    items: [
+      { sku: 'TEE', qty: 1 },
+      { sku: 'BAG', qty: 2 },
+      { sku: 'TEE', qty: 2 },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    subtotal_cents: 13900,
+    line_discount_cents: 3500,
+    coupon_discount_cents: 520,
+    tax_cents: 858,
+    shipping_cents: 0,
+    total_cents: 10738,
+    items: [
+      {
+        sku: 'TEE',
+        qty: 3,
+        line_subtotal_cents: 7500,
+        line_discount_cents: 2500,
+        line_total_cents: 5000,
+      },
+      {
+        sku: 'BAG',
+        qty: 2,
+        line_subtotal_cents: 6400,
+        line_discount_cents: 1000,
+        line_total_cents: 5400,
+      },
