+function runCartFile(contents) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-cart-'));
+  const inputPath = path.join(directory, 'cart.json');
+  fs.writeFileSync(inputPath, contents);
+
+  try {
+    return spawnSync('node', [CLI, 'cart', '--input', inputPath], { encoding: 'utf8' });
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
+function runCart(input) {
+  return runCartFile(JSON.stringify(input));
+}
