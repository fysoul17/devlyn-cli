+    assert.equal(result.stdout, `${JSON.stringify(expected)}\n`);
+    assert.deepStrictEqual(JSON.parse(result.stdout), expected);
+  });
+});
+
+test('schedule preserves rejected request input order', () => {
+  withJsonFixture({
+    resources: [{
+      id: 'alpha',
+      windows: [{ start: '09:00', end: '09:30' }],
+      blocked: [{ start: '09:00', end: '09:30' }],
+    }],
