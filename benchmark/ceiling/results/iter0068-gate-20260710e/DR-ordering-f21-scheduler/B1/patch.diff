@@ -35,6 +36,242 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function isPlainObject(value) {
+  if (value === null || typeof value !== 'object' || Array.isArray(value)) {
+    return false;
+  }
+
+  const prototype = Object.getPrototypeOf(value);
+  return prototype === Object.prototype || prototype === null;
+}
+
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^([01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    return null;
+  }
+
+  const [hours, minutes] = value.split(':').map(Number);
+  return (hours * 60) + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function compareStrings(first, second) {
+  if (first < second) return -1;
+  if (first > second) return 1;
+  return 0;
+}
+
+function parseInterval(value) {
+  if (!isPlainObject(value)) return null;
+
+  const start = parseTime(value.start);
+  const end = parseTime(value.end);
+  if (start === null || end === null || end <= start) return null;
+
+  return { start, end };
+}
+
+function parseResource(value) {
+  if (!isPlainObject(value) || typeof value.id !== 'string' || value.id.length === 0) {
+    return null;
+  }
+  if (!Array.isArray(value.windows) || !Array.isArray(value.blocked)) return null;
+
+  const windows = value.windows.map(parseInterval);
+  const blocked = value.blocked.map(parseInterval);
+  if (windows.some((interval) => interval === null)
+    || blocked.some((interval) => interval === null)) {
+    return null;
+  }
+
+  return { id: value.id, windows, blocked, reservations: [] };
+}
+
+function parseRequest(value, inputIndex) {
+  if (!isPlainObject(value)
+    || typeof value.id !== 'string'
+    || value.id.length === 0
+    || typeof value.resource !== 'string'
+    || value.resource.length === 0
+    || !Number.isInteger(value.duration_min)
+    || value.duration_min <= 0
+    || !Number.isFinite(value.priority)
+    || typeof value.submitted_at !== 'string'
+    || value.submitted_at.length === 0) {
+    return null;
+  }
+
+  const start = parseTime(value.start);
+  const submittedAt = parseTime(value.submitted_at);
+  if (start === null || submittedAt === null) return null;
+
+  return {
+    id: value.id,
+    resource: value.resource,
+    start,
+    duration: value.duration_min,
+    priority: value.priority,
+    submittedAt,
+    inputIndex,
+  };
+}
+
+function parseScheduleInput(value) {
+  if (!isPlainObject(value) || !Array.isArray(value.resources) || !Array.isArray(value.requests)) {
+    return null;
+  }
+
+  const resourceIds = new Set();
+  const resources = [];
+  for (const resourceValue of value.resources) {
+    const resource = parseResource(resourceValue);
+    if (resource === null || resourceIds.has(resource.id)) return null;
+    resourceIds.add(resource.id);
+    resources.push(resource);
+  }
+
+  const requestIds = new Set();
+  const requests = [];
+  for (const [inputIndex, requestValue] of value.requests.entries()) {
+    const request = parseRequest(requestValue, inputIndex);
+    if (request === null || requestIds.has(request.id)) return null;
+    requestIds.add(request.id);
+    requests.push(request);
+  }
+
+  return { resources, requests };
+}
+
+function intervalsOverlap(start, end, interval) {
+  return start < interval.end && interval.start < end;
+}
+
+function findEarliestPlacement(resource, request) {
+  let earliest = null;
+
+  for (const window of resource.windows) {
+    let start = Math.max(request.start, window.start);
+
+    while (start + request.duration <= window.end) {
+      let conflictEnd = null;
+      for (const interval of [...resource.blocked, ...resource.reservations]) {
+        if (intervalsOverlap(start, start + request.duration, interval)
+          && (conflictEnd === null || interval.end > conflictEnd)) {
+          conflictEnd = interval.end;
+        }
+      }
+
+      if (conflictEnd === null) {
+        if (earliest === null || start < earliest) earliest = start;
+        break;
+      }
+
+      start = conflictEnd;
+    }
+  }
+
+  return earliest;
+}
+
+function runSchedule(input) {
+  const resourcesById = new Map(input.resources.map((resource) => [resource.id, resource]));
+  const orderedRequests = [...input.requests].sort((first, second) => {
+    if (first.priority !== second.priority) return second.priority - first.priority;
+    if (first.submittedAt !== second.submittedAt) return first.submittedAt - second.submittedAt;
+    return compareStrings(first.id, second.id);
+  });
+  const accepted = [];
+  const rejected = [];
+
+  for (const request of orderedRequests) {
+    const resource = resourcesById.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const start = findEarliestPlacement(resource, request);
+    if (start === null) {
+      rejected.push({ id: request.id, reason: 'no_slot', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.reservations.push({ start, end });
+    accepted.push({ id: request.id, resource: request.resource, start, end });
+  }
+
+  accepted.sort((first, second) => {
+    if (first.start !== second.start) return first.start - second.start;
+    const resourceComparison = compareStrings(first.resource, second.resource);
+    if (resourceComparison !== 0) return resourceComparison;
+    return compareStrings(first.id, second.id);
+  });
+  rejected.sort((first, second) => first.inputIndex - second.inputIndex);
+
+  return {
+    scheduled: accepted.map(({ id, resource, start, end }) => ({
+      id,
+      resource,
+      start: formatTime(start),
+      end: formatTime(end),
+    })),
+    rejected: rejected.map(({ id, reason }) => ({ id, reason })),
+  };
+}
+
+function scheduleInputPath(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input') return null;
+
+  const inputPath = argv[1];
+  if (typeof inputPath !== 'string' || inputPath.length === 0 || inputPath.startsWith('-')) {
+    return null;
+  }
+  return inputPath;
+}
+
+function writeScheduleError() {
+  process.stderr.write(`${JSON.stringify({ error: 'invalid_input' })}\n`);
+  process.exitCode = 2;
+}
+
+function runScheduleCommand(argv) {
+  const inputPath = scheduleInputPath(argv);
+  if (inputPath === null) {
+    writeScheduleError();
+    return;
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    writeScheduleError();
+    return;
+  }
+
+  let value;
+  try {
+    value = JSON.parse(raw);
+  } catch (error) {
+    writeScheduleError();
+    return;
+  }
+
+  const input = parseScheduleInput(value);
+  if (input === null) {
+    writeScheduleError();
+    return;
+  }
+
+  process.stdout.write(`${JSON.stringify(runSchedule(input))}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +290,10 @@ function main(argv) {
       console.log(readPackageVersion());
