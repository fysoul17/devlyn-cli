+
+test('schedule prioritizes requests and emits sorted earliest placements', () => {
+  withJsonFixture({
+    resources: [
+      {
+        id: 'alpha',
+        windows: [{ start: '09:00', end: '10:00' }],
+        blocked: [{ start: '09:20', end: '09:30' }],
+      },
+      {
+        id: 'beta',
+        windows: [{ start: '09:00', end: '09:15' }],
+        blocked: [],
+      },
+      {
+        id: 'gamma',
+        windows: [{ start: '10:00', end: '10:30' }],
+        blocked: [],
+      },
+      {
+        id: 'delta',
+        windows: [{ start: '09:00', end: '10:00' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'low-alpha', resource: 'alpha', start: '09:00', duration_min: 20, priority: 1, submitted_at: '10:00',
+      },
+      {
+        id: 'end-gamma', resource: 'gamma', start: '10:15', duration_min: 15, priority: 0, submitted_at: '10:00',
+      },
+      {
+        id: 'early-beta', resource: 'beta', start: '09:00', duration_min: 10, priority: 2, submitted_at: '10:00',
+      },
+      {
+        id: 'tie-z', resource: 'delta', start: '09:00', duration_min: 10, priority: 4, submitted_at: '09:10',
+      },
+      {
+        id: 'tie-a', resource: 'delta', start: '09:00', duration_min: 10, priority: 4, submitted_at: '09:10',
+      },
+      {
+        id: 'high-alpha', resource: 'alpha', start: '09:00', duration_min: 20, priority: 3, submitted_at: '10:00',
+      },
+    ],
+  }, (inputPath) => {
+    const result = runCaptured(['schedule', '--input', inputPath]);
+    const expected = {
+      scheduled: [
+        { id: 'high-alpha', resource: 'alpha', start: '09:00', end: '09:20' },
+        { id: 'early-beta', resource: 'beta', start: '09:00', end: '09:10' },
+        { id: 'tie-a', resource: 'delta', start: '09:00', end: '09:10' },
+        { id: 'tie-z', resource: 'delta', start: '09:10', end: '09:20' },
+        { id: 'low-alpha', resource: 'alpha', start: '09:30', end: '09:50' },
+        { id: 'end-gamma', resource: 'gamma', start: '10:15', end: '10:30' },
