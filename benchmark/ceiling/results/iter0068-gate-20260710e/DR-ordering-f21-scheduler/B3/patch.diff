 }
 
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^([01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    return null;
+  }
+  const [hours, minutes] = value.split(':').map(Number);
+  return hours * 60 + minutes;
+}
+
+function formatTime(minutes) {
+  return `${String(Math.floor(minutes / 60)).padStart(2, '0')}:${String(minutes % 60).padStart(2, '0')}`;
+}
+
+function isObject(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function parseRange(value) {
+  if (!isObject(value)) return null;
+  const start = parseTime(value.start);
+  const end = parseTime(value.end);
+  if (start === null || end === null || start >= end) return null;
+  return { start, end };
+}
+
+function parseScheduleInput(input) {
+  if (!isObject(input) || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    return null;
+  }
+
+  const resourceIds = new Set();
+  const resources = [];
+  for (const resource of input.resources) {
+    if (
+      !isObject(resource)
+      || typeof resource.id !== 'string'
+      || resource.id.length === 0
+      || !Array.isArray(resource.windows)
+      || !Array.isArray(resource.blocked)
+      || resourceIds.has(resource.id)
+    ) {
+      return null;
+    }
+
+    const windows = resource.windows.map(parseRange);
+    const blocked = resource.blocked.map(parseRange);
+    if (windows.includes(null) || blocked.includes(null)) return null;
+
+    resourceIds.add(resource.id);
+    resources.push({
+      id: resource.id,
+      windows: windows.sort((a, b) => a.start - b.start || a.end - b.end),
+      blocked,
+      accepted: [],
+    });
+  }
+
+  const requestIds = new Set();
+  const requests = [];
+  for (const [index, request] of input.requests.entries()) {
+    if (
+      !isObject(request)
+      || typeof request.id !== 'string'
+      || request.id.length === 0
+      || typeof request.resource !== 'string'
+      || request.resource.length === 0
+      || !Number.isInteger(request.duration_min)
+      || request.duration_min <= 0
+      || !Number.isFinite(request.priority)
+      || requestIds.has(request.id)
+    ) {
+      return null;
+    }
+
+    const start = parseTime(request.start);
+    const submittedAt = parseTime(request.submitted_at);
+    if (start === null || submittedAt === null) return null;
+
+    requestIds.add(request.id);
+    requests.push({
+      id: request.id,
+      resource: request.resource,
+      start,
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt,
+      index,
+    });
+  }
+
+  return { resources, requests };
+}
+
+function rangesOverlap(start, end, range) {
+  return start < range.end && range.start < end;
+}
+
+function findEarliestSlot(resource, request) {
+  const unavailable = resource.blocked.concat(resource.accepted);
+
+  for (const window of resource.windows) {
+    let start = Math.max(request.start, window.start);
+    while (start + request.duration <= window.end) {
+      const conflict = unavailable.find((range) => rangesOverlap(start, start + request.duration, range));
+      if (!conflict) return start;
+      start = conflict.end;
+    }
+  }
+
+  return null;
+}
+
+function compareStrings(first, second) {
+  if (first < second) return -1;
+  if (first > second) return 1;
+  return 0;
+}
+
+function buildSchedule(input) {
+  const resources = new Map(input.resources.map((resource) => [resource.id, resource]));
+  const rejectedReasons = new Map();
+  const scheduled = [];
+  const requests = [...input.requests].sort((first, second) => (
+    second.priority - first.priority
+    || first.submittedAt - second.submittedAt
+    || compareStrings(first.id, second.id)
+  ));
+
+  for (const request of requests) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejectedReasons.set(request.index, 'unknown_resource');
+      continue;
+    }
+
+    const start = findEarliestSlot(resource, request);
+    if (start === null) {
+      rejectedReasons.set(request.index, 'no_slot');
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.accepted.push({ start, end });
+    scheduled.push({ id: request.id, resource: request.resource, start, end });
+  }
+
+  scheduled.sort((first, second) => (
+    first.start - second.start
+    || compareStrings(first.resource, second.resource)
+    || compareStrings(first.id, second.id)
+  ));
+
+  return {
+    scheduled: scheduled.map((entry) => ({
+      id: entry.id,
+      resource: entry.resource,
+      start: formatTime(entry.start),
+      end: formatTime(entry.end),
+    })),
+    rejected: input.requests
+      .filter((request) => rejectedReasons.has(request.index))
+      .map((request) => ({ id: request.id, reason: rejectedReasons.get(request.index) })),
+  };
+}
+
+function writeScheduleError(error) {
+  process.stderr.write(`${JSON.stringify({ error })}\n`);
+  process.exitCode = 2;
+}
+
+function schedule(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    writeScheduleError('invalid_input');
+    return;
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(argv[1], 'utf8');
+  } catch (error) {
+    writeScheduleError('file_read_failed');
+    return;
+  }
+
+  let input;
+  try {
+    input = JSON.parse(raw);
+  } catch (error) {
+    writeScheduleError('invalid_input');
+    return;
+  }
+
+  const parsedInput = parseScheduleInput(input);
+  if (!parsedInput) {
+    writeScheduleError('invalid_input');
+    return;
+  }
+
+  process.stdout.write(JSON.stringify(buildSchedule(parsedInput)));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
