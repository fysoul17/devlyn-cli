 });
+
+test('schedule uses priority and earliest valid placement', (t) => {
+  const inputPath = scheduleInput(t, {
+    resources: [{
+      id: 'room-a',
+      windows: [{ start: '09:00', end: '10:00' }],
+      blocked: [{ start: '09:20', end: '09:30' }],
+    }],
+    requests: [
+      {
+        id: 'low-priority', resource: 'room-a', start: '09:00', duration_min: 15, priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'high-priority', resource: 'room-a', start: '09:00', duration_min: 20, priority: 2, submitted_at: '09:02',
+      },
+      {
+        id: 'window-edge', resource: 'room-a', start: '09:45', duration_min: 15, priority: 0, submitted_at: '09:03',
+      },
+    ],
+  });
+
+  const result = runProcess(['schedule', '--input', inputPath]);
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'high-priority', resource: 'room-a', start: '09:00', end: '09:20' },
+      { id: 'low-priority', resource: 'room-a', start: '09:30', end: '09:45' },
+      { id: 'window-edge', resource: 'room-a', start: '09:45', end: '10:00' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports no-slot and unknown-resource rejections in input order', (t) => {
+  const inputPath = scheduleInput(t, {
+    resources: [{
+      id: 'room-a',
+      windows: [{ start: '09:00', end: '09:30' }],
+      blocked: [{ start: '09:00', end: '09:30' }],
+    }],
+    requests: [
+      {
+        id: 'no-slot', resource: 'room-a', start: '09:00', duration_min: 15, priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'missing-resource', resource: 'room-b', start: '09:00', duration_min: 15, priority: 2, submitted_at: '09:00',
+      },
+    ],
+  });
+
+  const result = runProcess(['schedule', '--input', inputPath]);
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [],
