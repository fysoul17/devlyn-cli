+
+test('schedule honors global priority and finds the earliest available slots', () => {
+  const result = runSchedule({
+    resources: [
+      {
+        id: 'amber',
+        windows: [{ start: '09:00', end: '12:00' }],
+        blocked: [{ start: '10:00', end: '10:30' }],
+      },
+      {
+        id: 'blue',
+        windows: [{ start: '09:00', end: '11:00' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'later', resource: 'amber', start: '09:00', duration_min: 60, priority: 1, submitted_at: '09:01',
+      },
+      {
+        id: 'urgent', resource: 'amber', start: '09:00', duration_min: 60, priority: 2, submitted_at: '09:02',
+      },
+      {
+        id: 'blue-request', resource: 'blue', start: '09:10', duration_min: 20, priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'ends-at-window-boundary', resource: 'blue', start: '09:30', duration_min: 90, priority: 1, submitted_at: '09:05',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'urgent', resource: 'amber', start: '09:00', end: '10:00' },
+      { id: 'blue-request', resource: 'blue', start: '09:10', end: '09:30' },
+      { id: 'ends-at-window-boundary', resource: 'blue', start: '09:30', end: '11:00' },
+      { id: 'later', resource: 'amber', start: '10:30', end: '11:30' },
+    ],
+    rejected: [],
+  });
+});
+
