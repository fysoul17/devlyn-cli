+function parseTime(value) {
+  if (typeof value !== 'string' || !/^(?:[01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    throw new ScheduleInputError('Invalid time');
+  }
+
+  const [hours, minutes] = value.split(':').map(Number);
+  return (hours * 60) + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function parseRange(value) {
+  if (!value || typeof value !== 'object' || Array.isArray(value)) {
+    throw new ScheduleInputError('Invalid time range');
+  }
+
+  const start = parseTime(value.start);
+  const end = parseTime(value.end);
+  if (end <= start) {
+    throw new ScheduleInputError('Invalid time range');
+  }
+
+  return { start, end };
+}
+
+function parseResource(value, resourceIds) {
+  if (!value || typeof value !== 'object' || Array.isArray(value)
+    || typeof value.id !== 'string' || value.id.length === 0
+    || !Array.isArray(value.windows) || !Array.isArray(value.blocked)) {
+    throw new ScheduleInputError('Invalid resource');
+  }
+
+  if (resourceIds.has(value.id)) {
+    throw new ScheduleInputError('Duplicate resource id');
+  }
+  resourceIds.add(value.id);
+
+  return {
+    id: value.id,
+    windows: value.windows.map(parseRange),
+    blocked: value.blocked.map(parseRange),
+  };
+}
+
+function parseRequest(value, requestIds) {
+  if (!value || typeof value !== 'object' || Array.isArray(value)
+    || typeof value.id !== 'string' || value.id.length === 0
+    || typeof value.resource !== 'string' || value.resource.length === 0
+    || !Number.isInteger(value.duration_min) || value.duration_min <= 0
+    || !Number.isFinite(value.priority)
+    || typeof value.submitted_at !== 'string') {
+    throw new ScheduleInputError('Invalid request');
+  }
+
+  if (requestIds.has(value.id)) {
+    throw new ScheduleInputError('Duplicate request id');
+  }
+  requestIds.add(value.id);
+
+  return {
+    id: value.id,
+    resource: value.resource,
+    start: parseTime(value.start),
+    duration: value.duration_min,
+    priority: value.priority,
+    submittedAt: parseTime(value.submitted_at),
+  };
+}
+
+function validateScheduleInput(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)
+    || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    throw new ScheduleInputError('Invalid schedule input');
+  }
+
+  const resourceIds = new Set();
+  const requestIds = new Set();
+  return {
+    resources: input.resources.map((resource) => parseResource(resource, resourceIds)),
+    requests: input.requests.map((request) => parseRequest(request, requestIds)),
+  };
+}
+
+function parseInputFlag(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    throw new ScheduleInputError('schedule requires --input <path>');
+  }
+  return argv[1];
+}
+
+function readScheduleInput(inputPath) {
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    throw new ScheduleInputError(`Unable to read input file: ${error.code || error.message}`);
+  }
+
+  let parsed;
+  try {
+    parsed = JSON.parse(raw);
+  } catch (error) {
+    throw new ScheduleInputError(`Invalid JSON input: ${error.message}`);
+  }
+
+  return validateScheduleInput(parsed);
+}
+
+function overlaps(start, end, interval) {
+  return start < interval.end && interval.start < end;
+}
+
+function findEarliestSlot(request, resource, accepted) {
+  const unavailable = resource.blocked.concat(accepted).sort((left, right) => left.start - right.start);
+  let earliest = null;
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(request.start, window.start);
+
+    while (candidate + request.duration <= window.end) {
+      const conflict = unavailable.find((interval) => overlaps(candidate, candidate + request.duration, interval));
+      if (!conflict) {
+        if (earliest === null || candidate < earliest) earliest = candidate;
+        break;
+      }
+      candidate = Math.max(candidate, conflict.end);
+    }
+  }
+
+  return earliest;
+}
+
+function compareStrings(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function scheduleAppointments(input) {
+  const resources = new Map(input.resources.map((resource) => [resource.id, resource]));
+  const acceptedByResource = new Map(input.resources.map((resource) => [resource.id, []]));
+  const scheduled = [];
+  const rejections = new Map();
+  const requests = [...input.requests].sort((left, right) => (
+    right.priority - left.priority
+    || left.submittedAt - right.submittedAt
+    || compareStrings(left.id, right.id)
+  ));
+
+  for (const request of requests) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejections.set(request.id, 'unknown_resource');
+      continue;
+    }
+
+    const accepted = acceptedByResource.get(resource.id);
+    const start = findEarliestSlot(request, resource, accepted);
+    if (start === null) {
+      rejections.set(request.id, 'no_slot');
+      continue;
+    }
+
+    const end = start + request.duration;
+    accepted.push({ start, end });
+    scheduled.push({ id: request.id, resource: resource.id, start, end });
+  }
+
+  return {
+    scheduled: scheduled
+      .sort((left, right) => left.start - right.start || compareStrings(left.resource, right.resource) || compareStrings(left.id, right.id))
+      .map(({ id, resource, start, end }) => ({ id, resource, start: formatTime(start), end: formatTime(end) })),
+    rejected: input.requests
+      .filter((request) => rejections.has(request.id))
+      .map((request) => ({ id: request.id, reason: rejections.get(request.id) })),
+  };
+}
+
+function runSchedule(argv) {
+  try {
+    const inputPath = parseInputFlag(argv);
+    const input = readScheduleInput(inputPath);
+    process.stdout.write(`${JSON.stringify(scheduleAppointments(input))}\n`);
+  } catch (error) {
+    const message = error instanceof Error ? error.message : 'Invalid schedule input';
+    process.stderr.write(`${JSON.stringify({ error: message })}\n`);
+    process.exitCode = 2;
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
