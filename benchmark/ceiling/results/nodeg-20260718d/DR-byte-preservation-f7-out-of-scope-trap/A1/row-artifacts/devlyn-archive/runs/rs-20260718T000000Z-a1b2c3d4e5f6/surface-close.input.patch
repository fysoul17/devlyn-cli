diff --git a/bin/cli.js b/bin/cli.js
index fcff156..b35478d 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -41,6 +41,17 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseFormatFlag(argv) {
+  const idx = argv.indexOf('--format');
+  if (idx === -1) return undefined;
+  const value = argv[idx + 1];
+  if (value !== 'json') {
+    console.error('--format must be json');
+    process.exit(1);
+  }
+  return value;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -57,7 +68,12 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
+      const format = parseFormatFlag(rest);
+      if (format === 'json') {
+        console.log(JSON.stringify({ version: readPackageVersion() }));
+      } else {
+        console.log(readPackageVersion());
+      }
       return;
     }
     default:
diff --git a/tests/cli.test.js b/tests/cli.test.js
