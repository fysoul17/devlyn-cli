diff --git a/bin/cli.js b/bin/cli.js
index fcff156..07db5b3 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -57,7 +57,17 @@ function main(argv) {
       return;
     }
     case 'version': {
-      console.log(readPackageVersion());
+      const formatIndex = rest.lastIndexOf('--format');
+      if (formatIndex === -1) {
+        console.log(readPackageVersion());
+        return;
+      }
+      const format = rest[formatIndex + 1];
+      if (!format || format.startsWith('-') || format !== 'json') {
+        console.error(`Unsupported format: ${format || ''}`);
+        process.exit(1);
+      }
+      console.log(JSON.stringify({ version: readPackageVersion() }));
       return;
     }
     default:
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..b5332d5 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,27 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  const parsed = JSON.parse(out);
+  assert.deepEqual(parsed, { version: parsed.version });
+  assert.match(parsed.version, /\d+\.\d+\.\d+/);
+  assert.equal(out, `${JSON.stringify(parsed)}\n`);
+});
+
+test('version rejects unsupported --format value', () => {
+  assert.throws(() => run(['version', '--format', 'yaml']), /Command failed/);
+});
+
+test('version rejects a final unsupported repeated --format value', () => {
+  assert.throws(
+    () => run(['version', '--format', 'json', '--format', 'yaml']),
+    /Command failed/,
+  );
+});
+
+test('help retains the original version usage line', () => {
+  const out = run(['--help']);
+  assert.match(out, /^  version                    Print the CLI version from package\.json$/m);
+});
