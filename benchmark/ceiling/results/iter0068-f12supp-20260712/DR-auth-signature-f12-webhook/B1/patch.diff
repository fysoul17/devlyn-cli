 // Tiny Express server with a deliberately small API surface.
+const crypto = require('crypto');
 const express = require('express');
+const fs = require('fs');
+const path = require('path');
 
 const app = express();
+const webhookSecret = fs
+  .readFileSync(path.join(__dirname, '../data/webhook-secret.txt'), 'utf8')
+  .trim();
+const acceptedEventIds = new Set();
+
+app.post('/webhook', express.raw({ type: '*/*' }), (req, res) => {
+  const signature = req.get('X-Signature');
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(req.body || Buffer.alloc(0))
+    .digest('hex');
+  const expectedSignatureBuffer = Buffer.from(expectedSignature, 'utf8');
+  const receivedSignatureBuffer = Buffer.alloc(expectedSignatureBuffer.length);
+
+  if (typeof signature === 'string') {
+    Buffer.from(signature, 'utf8').copy(receivedSignatureBuffer);
+  }
+
+  const signaturesMatch = crypto.timingSafeEqual(
+    expectedSignatureBuffer,
+    receivedSignatureBuffer
+  );
+  const signatureIsValid =
+    typeof signature === 'string' &&
+    signature.length === expectedSignature.length &&
+    /^[0-9a-f]{64}$/.test(signature) &&
+    signaturesMatch;
+
+  if (!signatureIsValid) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  let event;
+  try {
+    event = JSON.parse(req.body.toString('utf8'));
+  } catch {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  const { id, type, timestamp, data } = event || {};
+
+  if (typeof id === 'string' && acceptedEventIds.has(id)) {
+    res.status(409).json({ error: 'duplicate_event', id });
+    return;
+  }
+
+  const bodyIsValid =
+    typeof id === 'string' &&
+    id.length > 0 &&
+    typeof type === 'string' &&
+    type.length > 0 &&
+    Number.isFinite(timestamp) &&
+    typeof data === 'object' &&
+    data !== null &&
+    !Array.isArray(data);
+
+  if (!bodyIsValid) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedEventIds.add(id);
+  res.json({ accepted: true, id });
+});
+
 app.use(express.json());
 
