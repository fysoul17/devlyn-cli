+test('POST /webhook accepts a signed valid event', async () => {
+  const server = await startServer();
+  const body = JSON.stringify({
+    id: 'evt_webhook_happy',
+    type: 'order.created',
+    timestamp: 1735689600,
+    data: { order_id: 'o_42' },
+  });
+
+  try {
+    const response = await post(server, '/webhook', body, { 'X-Signature': sign(body) });
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: 'evt_webhook_happy' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  const body = JSON.stringify({
+    id: 'evt_webhook_replay',
+    type: 'order.created',
+    timestamp: 1735689600,
+    data: { order_id: 'o_43' },
+  });
+  const replayedBody = JSON.stringify({ id: 'evt_webhook_replay' });
+
+  try {
+    const firstResponse = await post(server, '/webhook', body, { 'X-Signature': sign(body) });
+    const secondResponse = await post(server, '/webhook', replayedBody, {
