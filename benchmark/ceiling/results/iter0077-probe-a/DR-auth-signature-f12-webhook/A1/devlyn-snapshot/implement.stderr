+    .createHmac('sha256', webhookSecret)
+    .update(req.rawBody)
+    .digest('hex');
+  const expectedSignatureBuffer = Buffer.from(expectedSignature, 'hex');
+  const providedSignatureBuffer = Buffer.from(providedSignature || '', 'hex');
