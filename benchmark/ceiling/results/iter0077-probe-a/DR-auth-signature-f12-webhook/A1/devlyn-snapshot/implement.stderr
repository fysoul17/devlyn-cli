The final mandated `npm test` still exits nonzero solely because the sandbox disallows every TCP listener; syntax and diff checks pass. I’m running a non-network dispatch check of the three webhook contracts to validate the route logic without altering the committed HTTP tests.
exec
/bin/zsh -lc "node <<'NODE'
const assert = require('node:assert');
const crypto = require('node:crypto');
const { EventEmitter } = require('node:events');
const { Readable } = require('node:stream');
const { app } = require('./server');
const secret = require('node:fs').readFileSync('./data/webhook-secret.txt', 'utf8').replace(/\\r?\\n"'$/, '"'');

function sign(payload) {
  return crypto.createHmac('sha256', secret).update(payload).digest('hex');
}

function dispatch(payload, signature) {
  return new Promise((resolve, reject) => {
    const req = new Readable({ read() { this.push(payload); this.push(null); } });
    Object.assign(req, {
      method: 'POST',
      url: '/webhook',
      headers: {
        'content-type': 'application/json',
        'content-length': String(Buffer.byteLength(payload)),
        'x-signature': signature,
      },
    });
    const res = new EventEmitter();
    const headers = {};
    Object.assign(res, {
      statusCode: 200,
      setHeader(name, value) { headers[name.toLowerCase()] = value; },
      getHeader(name) { return headers[name.toLowerCase()]; },
      removeHeader(name) { delete headers[name.toLowerCase()]; },
      end(body) {
        resolve({ status: this.statusCode, body: JSON.parse(body) });
        this.emit('finish');
      },
    });
    app.handle(req, res, reject);
  });
}

(async () => {
  const accepted = JSON.stringify({ id: 'dispatch-check', type: 'item.updated', timestamp: 1, data: {} });
  assert.deepStrictEqual(await dispatch(accepted, sign(accepted)), { status: 200, body: { accepted: true, id: 'dispatch-check' } });
  const replay = JSON.stringify({ id: 'dispatch-check' });
  assert.deepStrictEqual(await dispatch(replay, sign(replay)), { status: 409, body: { error: 'duplicate_event', id: 'dispatch-check' } });
  const original = JSON.stringify({ id: 'dispatch-tamper', type: 'item.updated', timestamp: 1, data: { value: 1 } });
  const tampered = JSON.stringify({ id: 'dispatch-tamper', type: 'item.updated', timestamp: 1, data: { value: 2 } });
  assert.deepStrictEqual(await dispatch(tampered, sign(original)), { status: 401, body: { error: 'invalid_signature' } });
  console.log('webhook dispatch checks passed');
})().catch((error) => { console.error(error); process.exitCode = 1; });
