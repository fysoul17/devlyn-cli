+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  const payload = JSON.stringify({
+    id: 'event-happy-path',
+    type: 'item.updated',
+    timestamp: 1721563200,
+    data: { id: 1 },
+  });
+  try {
+    const { status, body } = await postWebhook(server, payload, sign(payload));
+    assert.strictEqual(status, 200);
+    assert.deepStrictEqual(body, { accepted: true, id: 'event-happy-path' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  const payload = JSON.stringify({
+    id: 'event-replay',
+    type: 'item.updated',
+    timestamp: 1721563201,
+    data: { id: 1 },
+  });
+  try {
+    await postWebhook(server, payload, sign(payload));
+    const replayPayload = JSON.stringify({ id: 'event-replay' });
+    const { status, body } = await postWebhook(server, replayPayload, sign(replayPayload));
+    assert.strictEqual(status, 409);
+    assert.deepStrictEqual(body, { error: 'duplicate_event', id: 'event-replay' });
+  } finally {
+    server.close();
+  }
+});
+
