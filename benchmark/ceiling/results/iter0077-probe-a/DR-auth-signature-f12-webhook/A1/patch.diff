+app.post('/webhook', (req, res) => {
+  const providedSignature = req.get('X-Signature');
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(req.rawBody)
+    .digest('hex');
+  const expectedSignatureBuffer = Buffer.from(expectedSignature, 'hex');
+  const providedSignatureBuffer = Buffer.from(providedSignature || '', 'hex');
+
+  if (
+    !/^[0-9a-f]+$/.test(providedSignature || '') ||
+    providedSignatureBuffer.length !== expectedSignatureBuffer.length ||
+    !crypto.timingSafeEqual(providedSignatureBuffer, expectedSignatureBuffer)
+  ) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  const { id, type, timestamp, data } = req.body;
+  if (acceptedEventIds.has(id)) {
+    res.status(409).json({ error: 'duplicate_event', id });
+    return;
+  }
+
+  if (
+    typeof id !== 'string' ||
+    id.length === 0 ||
+    typeof type !== 'string' ||
+    type.length === 0 ||
+    typeof timestamp !== 'number' ||
+    typeof data !== 'object' ||
+    data === null ||
+    Array.isArray(data)
+  ) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedEventIds.add(id);
+  res.json({ accepted: true, id });
+});
