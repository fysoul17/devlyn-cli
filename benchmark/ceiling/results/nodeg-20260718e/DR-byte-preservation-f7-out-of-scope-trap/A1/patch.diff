diff --git a/bin/cli.js b/bin/cli.js
index fcff156..e5d4317 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -57,6 +57,16 @@ function main(argv) {
       return;
     }
     case 'version': {
+      const idx = rest.indexOf('--format');
+      if (idx !== -1) {
+        const format = rest[idx + 1];
+        if (format !== 'json') {
+          console.error(`Unsupported format: ${format || '(missing)'}`);
+          process.exit(1);
+        }
+        console.log(JSON.stringify({ version: readPackageVersion() }));
+        return;
+      }
       console.log(readPackageVersion());
       return;
     }
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..ee58dc1 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,15 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.strictEqual(out, `${JSON.stringify({ version: require('../package.json').version })}\n`);
+});
+
+test('version rejects unsupported --format', () => {
+  assert.throws(
+    () => execFileSync('node', [CLI, 'version', '--format', 'yaml'], { encoding: 'utf8', stdio: 'pipe' }),
+    (error) => error.status === 1 && /Unsupported format: yaml/.test(error.stderr),
+  );
+});
