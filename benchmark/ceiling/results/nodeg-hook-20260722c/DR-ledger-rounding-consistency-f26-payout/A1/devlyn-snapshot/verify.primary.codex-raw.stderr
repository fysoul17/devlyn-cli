diff --git a/bin/cli.js b/bin/cli.js
index 9cc9b24..a55115d 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -1,63 +1,237 @@
 #!/usr/bin/env node
 // harbor-tools — small command-line utilities for local workflows.
 // Keep the core commands minimal and easy to understand.
 
 const fs = require('fs');
 const path = require('path');
 
 const USAGE = `Usage: bench-cli <command> [options]
 
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  payout --input PATH        Print payout totals for ledger events
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli payout --input ledger-events.json
 `;
 
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
   return JSON.parse(raw).version;
 }
 
 function parseNameFlag(argv) {
   const idx = argv.indexOf('--name');
   if (idx === -1) return 'world';
   const value = argv[idx + 1];
   if (!value || value.startsWith('-')) {
     console.error('--name requires a value');
     process.exit(1);
   }
   return value;
 }
 
+function writePayoutError(error) {
+  process.stderr.write(`${JSON.stringify(error)}\n`);
+  process.exit(2);
+}
+
+function readPayoutInput(argv) {
+  const inputIndex = argv.indexOf('--input');
+  const inputPath = argv[inputIndex + 1];
+
+  if (inputIndex === -1 || !inputPath || inputPath.startsWith('-')) {
+    writePayoutError({ error: 'unreadable_input' });
+  }
+
+  let rawInput;
+  try {
+    rawInput = fs.readFileSync(inputPath, 'utf8');
+  } catch {
+    writePayoutError({ error: 'unreadable_input' });
+  }
+
+  try {
+    return JSON.parse(rawInput);
+  } catch {
+    writePayoutError({ error: 'invalid_json' });
+  }
+}
+
+function validateEvent(event, index) {
+  if (!event || typeof event !== 'object' || Array.isArray(event)) {
+    writePayoutError({ error: 'invalid_event', index });
+  }
+  if (typeof event.id !== 'string') {
+    writePayoutError({ error: 'missing_id', index });
+  }
+  if (typeof event.merchant_id !== 'string') {
+    writePayoutError({ error: 'missing_merchant_id', index });
+  }
+  if (!['charge', 'refund', 'dispute'].includes(event.type)) {
+    writePayoutError({ error: 'unknown_type', index });
+  }
+  if (!Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
+    writePayoutError({ error: 'invalid_amount_cents', index });
+  }
+}
+
+function hasSameEventContent(first, second) {
+  if (first === second) return true;
+  if (!first || !second || typeof first !== 'object' || typeof second !== 'object') {
+    return false;
+  }
+
+  const firstKeys = Object.keys(first).sort();
+  const secondKeys = Object.keys(second).sort();
+  if (firstKeys.length !== secondKeys.length) return false;
+
+  return firstKeys.every((key, index) => (
+    key === secondKeys[index] && hasSameEventContent(first[key], second[key])
+  ));
+}
+
+function uniqueEvents(events) {
+  const eventsById = new Map();
+  const unique = [];
+
+  events.forEach((event, index) => {
+    validateEvent(event, index);
+    const priorEvent = eventsById.get(event.id);
+    if (priorEvent) {
+      if (!hasSameEventContent(priorEvent, event)) {
+        writePayoutError({ error: 'conflicting_duplicate', id: event.id });
+      }
+      return;
+    }
+    eventsById.set(event.id, event);
+    unique.push(event);
+  });
+
+  return unique;
+}
+
+function loadPayoutRules() {
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  return JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
+}
+
+function createMerchant(merchantId) {
+  return {
+    merchant_id: merchantId,
+    gross_charge_cents: 0,
+    refund_cents: 0,
+    dispute_cents: 0,
+    processing_fee_cents: 0,
+    dispute_fee_cents: 0,
+  };
+}
+
+function calculatePayout(events, rules) {
+  const merchantsById = new Map();
+
+  for (const event of events) {
+    let merchant = merchantsById.get(event.merchant_id);
+    if (!merchant) {
+      merchant = createMerchant(event.merchant_id);
+      merchantsById.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        event.amount_cents * rules.processing_fee_percent / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchants = Array.from(merchantsById.values(), (merchant) => {
+    const netBeforeReserve = merchant.gross_charge_cents
+      - merchant.refund_cents
+      - merchant.dispute_cents
+      - merchant.processing_fee_cents
+      - merchant.dispute_fee_cents;
+    let reserveCents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    let payoutCents = netBeforeReserve - reserveCents;
+
+    if (payoutCents > 0 && payoutCents < rules.minimum_payout_cents) {
+      reserveCents += payoutCents;
+      payoutCents = 0;
+    }
+
+    return {
+      ...merchant,
+      reserve_cents: reserveCents,
+      payout_cents: payoutCents,
+    };
+  });
+
+  return {
+    total_payout_cents: merchants.reduce((total, merchant) => total + merchant.payout_cents, 0),
+    total_processing_fee_cents: merchants.reduce(
+      (total, merchant) => total + merchant.processing_fee_cents,
+      0,
+    ),
+    total_dispute_fee_cents: merchants.reduce(
+      (total, merchant) => total + merchant.dispute_fee_cents,
+      0,
+    ),
+    total_reserve_cents: merchants.reduce((total, merchant) => total + merchant.reserve_cents, 0),
+    merchants,
+  };
+}
+
+function payout(argv) {
+  const input = readPayoutInput(argv);
+  if (!input || !Array.isArray(input.events)) {
+    writePayoutError({ error: 'missing_events' });
+  }
+
+  const rules = loadPayoutRules();
+  const result = calculatePayout(uniqueEvents(input.events), rules);
+  process.stdout.write(`${JSON.stringify(result)}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
   if (!command || command === '--help' || command === '-h') {
     process.stdout.write(USAGE);
     return;
   }
 
   switch (command) {
     case 'hello': {
       const name = parseNameFlag(rest);
       console.log(`Hello, ${name}!`);
       return;
     }
     case 'version': {
       console.log(readPackageVersion());
       return;
     }
+    case 'payout': {
+      payout(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
       process.exit(1);
   }
 }
 
 main(process.argv.slice(2));
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..7cb326b 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,25 +1,141 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
 const { execFileSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
 
 function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function runFailure(args) {
+  let failure;
+  try {
+    run(args);
+  } catch (error) {
+    failure = error;
+  }
+  assert.ok(failure, 'expected the CLI command to fail');
+  return failure;
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
 });
 
 test('hello with --name', () => {
   const out = run(['hello', '--name', 'alice']);
   assert.match(out, /Hello, alice!/);
 });
 
 test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('payout prints per-merchant totals after deduplicating events', (t) => {
+  const fixtureDirectory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  t.after(() => fs.rmSync(fixtureDirectory, { recursive: true, force: true }));
+  const inputPath = path.join(fixtureDirectory, 'ledger-events.json');
+  fs.writeFileSync(inputPath, JSON.stringify({
+    events: [
+      { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 10000 },
+      { id: 'refund-a', merchant_id: 'merchant-a', type: 'refund', amount_cents: 1000 },
+      { id: 'dispute-a', merchant_id: 'merchant-a', type: 'dispute', amount_cents: 500 },
+      { id: 'charge-b', merchant_id: 'merchant-b', type: 'charge', amount_cents: 500 },
+      { id: 'charge-b', merchant_id: 'merchant-b', type: 'charge', amount_cents: 500 },
+    ],
+  }));
+
+  const output = JSON.parse(run(['payout', '--input', inputPath]));
+  assert.deepEqual(output, {
+    total_payout_cents: 6012,
+    total_processing_fee_cents: 365,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 1123,
+    merchants: [
+      {
+        merchant_id: 'merchant-a',
+        gross_charge_cents: 10000,
+        refund_cents: 1000,
+        dispute_cents: 500,
+        processing_fee_cents: 320,
+        dispute_fee_cents: 1500,
+        reserve_cents: 668,
+        payout_cents: 6012,
+      },
+      {
+        merchant_id: 'merchant-b',
+        gross_charge_cents: 500,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 45,
+        dispute_fee_cents: 0,
+        reserve_cents: 455,
+        payout_cents: 0,
+      },
+    ],
+  });
+});
+
+test('payout reports validation failures as a single JSON error', (t) => {
+  const fixtureDirectory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  t.after(() => fs.rmSync(fixtureDirectory, { recursive: true, force: true }));
+  const inputPath = path.join(fixtureDirectory, 'ledger-events.json');
+  fs.writeFileSync(inputPath, JSON.stringify({
+    events: [{ id: 'unknown-type', merchant_id: 'merchant-a', type: 'transfer', amount_cents: 100 }],
+  }));
+
+  const failure = runFailure(['payout', '--input', inputPath]);
+  const stderr = String(failure.stderr);
+  const error = JSON.parse(stderr);
+
+  assert.equal(failure.status, 2);
+  assert.equal(String(failure.stdout), '');
+  assert.ok(error.error);
+  assert.equal(stderr, `${JSON.stringify(error)}\n`);
+});
+
+test('payout exits with conflicting_duplicate before printing totals when an id repeats with different content', (t) => {
+  const fixtureDirectory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  t.after(() => fs.rmSync(fixtureDirectory, { recursive: true, force: true }));
+  const inputPath = path.join(fixtureDirectory, 'ledger-events.json');
+  fs.writeFileSync(inputPath, JSON.stringify({
+    events: [
+      { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 100 },
+      { id: 'charge-a', merchant_id: 'merchant-a', type: 'charge', amount_cents: 200 },
+    ],
+  }));
+
+  const failure = runFailure(['payout', '--input', inputPath]);
+
+  assert.equal(failure.status, 2);
+  assert.equal(String(failure.stdout), '');
+  assert.deepEqual(JSON.parse(String(failure.stderr)), { error: 'conflicting_duplicate', id: 'charge-a' });
+});
+
+test('payout rejects duplicate ids with different extra JSON properties', (t) => {
+  const fixtureDirectory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  t.after(() => fs.rmSync(fixtureDirectory, { recursive: true, force: true }));
+  const inputPath = path.join(fixtureDirectory, 'ledger-events.json');
+  fs.writeFileSync(inputPath, JSON.stringify({
+    events: [
+      {
+        id: 'same', merchant_id: 'merchant-a', type: 'charge', amount_cents: 100, source: 'card-a',
+      },
+      {
+        id: 'same', merchant_id: 'merchant-a', type: 'charge', amount_cents: 100, source: 'card-b',
+      },
+    ],
+  }));
+
+  const failure = runFailure(['payout', '--input', inputPath]);
+
+  assert.equal(failure.status, 2);
+  assert.equal(String(failure.stdout), '');
+  assert.equal(String(failure.stderr), '{"error":"conflicting_duplicate","id":"same"}\n');
+});

