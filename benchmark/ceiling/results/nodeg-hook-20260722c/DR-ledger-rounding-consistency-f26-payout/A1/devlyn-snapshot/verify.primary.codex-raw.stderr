node -e '
const { spawnSync } = require(\"node:child_process\");
const path = require(\"node:path\");
const cli = path.join(process.cwd(), \"bin\", \"cli.js\");
const input = JSON.stringify({events:[
  {id:\"a\",merchant_id:\"first\",type:\"charge\",amount_cents:10000},
  {id:\"a\",merchant_id:\"first\",type:\"charge\",amount_cents:10000},
  {id:\"b\",merchant_id:\"first\",type:\"refund\",amount_cents:1000},
  {id:\"c\",merchant_id:\"first\",type:\"dispute\",amount_cents:500},
  {id:\"d\",merchant_id:\"second\",type:\"charge\",amount_cents:500}
]});
const result = spawnSync(process.execPath,[cli,\"payout\",\"--input\",\"/dev/stdin\"],{input,encoding:\"utf8\"});
const output = JSON.parse(result.stdout);
const top = [\"total_payout_cents\",\"total_processing_fee_cents\",\"total_dispute_fee_cents\",\"total_reserve_cents\",\"merchants\"];
const row = [\"merchant_id\",\"gross_charge_cents\",\"refund_cents\",\"dispute_cents\",\"processing_fee_cents\",\"dispute_fee_cents\",\"reserve_cents\",\"payout_cents\"];
const expected = {total_payout_cents:6012,total_processing_fee_cents:365,total_dispute_fee_cents:1500,total_reserve_cents:1123,merchants:[
  {merchant_id:\"first\",gross_charge_cents:10000,refund_cents:1000,dispute_cents:500,processing_fee_cents:320,dispute_fee_cents:1500,reserve_cents:668,payout_cents:6012},
  {merchant_id:\"second\",gross_charge_cents:500,refund_cents:0,dispute_cents:0,processing_fee_cents:45,dispute_fee_cents:0,reserve_cents:455,payout_cents:0}
]};
const exactTop = JSON.stringify(Object.keys(output)) === JSON.stringify(top);
const exactRows = output.merchants.every((merchant) => JSON.stringify(Object.keys(merchant)) === JSON.stringify(row));
const exactValues = JSON.stringify(output) === JSON.stringify(expected);
process.stdout.write(JSON.stringify({status:result.status,stderr:result.stderr,objects:(result.stdout.trim().match(/"'^'"\\{.*\\}"'$/s)||[]).length,exactTop,exactRows,exactValues,output})+"'"\\n\");
