/bin/zsh -lc "node -e '
const { spawnSync } = require(\"node:child_process\");
const path = require(\"node:path\");
const cli = path.join(process.cwd(), \"bin\", \"cli.js\");
function run(name, input, args = [\"payout\", \"--input\", \"/dev/stdin\"]) {
  const result = spawnSync(process.execPath, [cli, ...args], {
    input: typeof input === \"string\" ? input : JSON.stringify(input),
    encoding: \"utf8\",
  });
  const observed = { name, status: result.status, signal: result.signal, stdout: result.stdout, stderr: result.stderr };
  process.stdout.write(JSON.stringify(observed) + \"\\n\");
}
const events = [
  { id: \"charge-a\", merchant_id: \"merchant-a\", type: \"charge\", amount_cents: 10000 },
  { id: \"charge-a\", merchant_id: \"merchant-a\", type: \"charge\", amount_cents: 10000 },
  { id: \"refund-a\", merchant_id: \"merchant-a\", type: \"refund\", amount_cents: 1000 },
  { id: \"dispute-a\", merchant_id: \"merchant-a\", type: \"dispute\", amount_cents: 500 },
  { id: \"charge-b\", merchant_id: \"merchant-b\", type: \"charge\", amount_cents: 500 },
  { id: \"charge-b\", merchant_id: \"merchant-b\", type: \"charge\", amount_cents: 500 },
];
run(\"combined-success-identical-duplicates\", { events });
run(\"combined-conflict-after-valid-ledger\", { events: [...events, { id: \"charge-a\", merchant_id: \"merchant-a\", type: \"charge\", amount_cents: 9999 }] });
run(\"conflicting-duplicate-with-invalid-second-event\", { events: [
  { id: \"same\", merchant_id: \"merchant-a\", type: \"charge\", amount_cents: 1000 },
  { id: \"same\", type: \"charge\", amount_cents: 1000 },
] });
run(\"unknown-type\", { events: [{ id: \"e\", merchant_id: \"m\", type: \"transfer\", amount_cents: 1 }] });
run(\"missing-merchant-id\", { events: [{ id: \"e\", type: \"charge\", amount_cents: 1 }] });
run(\"missing-id\", { events: [{ merchant_id: \"m\", type: \"charge\", amount_cents: 1 }] });
run(\"zero-amount\", { events: [{ id: \"e\", merchant_id: \"m\", type: \"charge\", amount_cents: 0 }] });
run(\"negative-amount\", { events: [{ id: \"e\", merchant_id: \"m\", type: \"charge\", amount_cents: -1 }] });
run(\"fractional-amount\", { events: [{ id: \"e\", merchant_id: \"m\", type: \"charge\", amount_cents: 1.5 }] });
run(\"missing-events\", {});
run(\"invalid-json\", \"{\\\"events\\\":[\");
run(\"unreadable-input\", \"\", [\"payout\", \"--input\", \"/definitely/not/a/real/ledger.json\"]);
run(\"missing-input-flag\", \"\", [\"payout\"]);
run(\"max-number-amount\", { events: [{ id: \"huge\", merchant_id: \"m\", type: \"charge\", amount_cents: Number.MAX_VALUE }] });
