    40	function writePayoutError(error) {
    41	  process.stderr.write(`${JSON.stringify(error)}\n`);
    42	  process.exit(2);
    43	}
    44	
    45	function readPayoutInput(argv) {
    46	  const inputIndex = argv.indexOf('--input');
    47	  const inputPath = argv[inputIndex + 1];
    48	
    49	  if (inputIndex === -1 || !inputPath || inputPath.startsWith('-')) {
    50	    writePayoutError({ error: 'unreadable_input' });
    51	  }
    52	
    53	  let rawInput;
    54	  try {
    55	    rawInput = fs.readFileSync(inputPath, 'utf8');
    56	  } catch {
    57	    writePayoutError({ error: 'unreadable_input' });
    58	  }
    59	
    60	  try {
    61	    return JSON.parse(rawInput);
    62	  } catch {
    63	    writePayoutError({ error: 'invalid_json' });
    64	  }
    65	}
    66	
    67	function validateEvent(event, index) {
    68	  if (!event || typeof event !== 'object' || Array.isArray(event)) {
    69	    writePayoutError({ error: 'invalid_event', index });
    70	  }
    71	  if (typeof event.id !== 'string') {
    72	    writePayoutError({ error: 'missing_id', index });
    73	  }
    74	  if (typeof event.merchant_id !== 'string') {
    75	    writePayoutError({ error: 'missing_merchant_id', index });
    76	  }
    77	  if (!['charge', 'refund', 'dispute'].includes(event.type)) {
    78	    writePayoutError({ error: 'unknown_type', index });
    79	  }
    80	  if (!Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
    81	    writePayoutError({ error: 'invalid_amount_cents', index });
    82	  }
    83	}
    84	
    85	function hasSameEventContent(first, second) {
    86	  return first.id === second.id
    87	    && first.merchant_id === second.merchant_id
    88	    && first.type === second.type
    89	    && first.amount_cents === second.amount_cents;
    90	}
    91	
    92	function uniqueEvents(events) {
    93	  const eventsById = new Map();
    94	  const unique = [];
    95	
    96	  events.forEach((event, index) => {
    97	    validateEvent(event, index);
    98	    const priorEvent = eventsById.get(event.id);
    99	    if (priorEvent) {
   100	      if (!hasSameEventContent(priorEvent, event)) {
   101	        writePayoutError({ error: 'conflicting_duplicate', id: event.id });
   102	      }
   103	      return;
   104	    }
   105	    eventsById.set(event.id, event);
   106	    unique.push(event);
   107	  });
   108	
   109	  return unique;
   110	}
   111	
   112	function loadPayoutRules() {
   113	  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
   114	  return JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
   115	}
   116	
   117	function createMerchant(merchantId) {
   118	  return {
   119	    merchant_id: merchantId,
   120	    gross_charge_cents: 0,
   121	    refund_cents: 0,
   122	    dispute_cents: 0,
   123	    processing_fee_cents: 0,
   124	    dispute_fee_cents: 0,
   125	  };
   126	}
   127	
   128	function calculatePayout(events, rules) {
   129	  const merchantsById = new Map();
   130	
   131	  for (const event of events) {
   132	    let merchant = merchantsById.get(event.merchant_id);
   133	    if (!merchant) {
   134	      merchant = createMerchant(event.merchant_id);
   135	      merchantsById.set(event.merchant_id, merchant);
   136	    }
   137	
   138	    if (event.type === 'charge') {
   139	      merchant.gross_charge_cents += event.amount_cents;
   140	      merchant.processing_fee_cents += Math.round(
   141	        event.amount_cents * rules.processing_fee_percent / 100,
   142	      ) + rules.fixed_fee_cents;
   143	    } else if (event.type === 'refund') {
   144	      merchant.refund_cents += event.amount_cents;
   145	    } else {
   146	      merchant.dispute_cents += event.amount_cents;
   147	      merchant.dispute_fee_cents += rules.dispute_fee_cents;
   148	    }
   149	  }
   150	
   151	  const merchants = Array.from(merchantsById.values(), (merchant) => {
   152	    const netBeforeReserve = merchant.gross_charge_cents
   153	      - merchant.refund_cents
   154	      - merchant.dispute_cents
   155	      - merchant.processing_fee_cents
   156	      - merchant.dispute_fee_cents;
   157	    let reserveCents = netBeforeReserve > 0
   158	      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
   159	      : 0;
   160	    let payoutCents = netBeforeReserve - reserveCents;
   161	
   162	    if (payoutCents > 0 && payoutCents < rules.minimum_payout_cents) {
   163	      reserveCents += payoutCents;
   164	      payoutCents = 0;
   165	    }
   166	
   167	    return {
   168	      ...merchant,
   169	      reserve_cents: reserveCents,
   170	      payout_cents: payoutCents,
   171	    };
   172	  });
   173	
   174	  return {
   175	    total_payout_cents: merchants.reduce((total, merchant) => total + merchant.payout_cents, 0),
   176	    total_processing_fee_cents: merchants.reduce(
   177	      (total, merchant) => total + merchant.processing_fee_cents,
   178	      0,
   179	    ),
   180	    total_dispute_fee_cents: merchants.reduce(
   181	      (total, merchant) => total + merchant.dispute_fee_cents,
   182	      0,
   183	    ),
   184	    total_reserve_cents: merchants.reduce((total, merchant) => total + merchant.reserve_cents, 0),
   185	    merchants,
   186	  };
   187	}
   188	
   189	function payout(argv) {
   190	  const input = readPayoutInput(argv);
   191	  if (!input || !Array.isArray(input.events)) {
   192	    writePayoutError({ error: 'missing_events' });
   193	  }
   194	
   195	  const rules = loadPayoutRules();
   196	  const result = calculatePayout(uniqueEvents(input.events), rules);
   197	  process.stdout.write(`${JSON.stringify(result)}\n`);
   198	}
   199	
   200	function main(argv) {
   201	  const [command, ...rest] = argv;
   202	
   203	  if (!command || command === '--help' || command === '-h') {
   204	    process.stdout.write(USAGE);
   205	    return;
   206	  }
   207	
   208	  switch (command) {
   209	    case 'hello': {
   210	      const name = parseNameFlag(rest);
   211	      console.log(`Hello, ${name}!`);
   212	      return;
   213	    }
   214	    case 'version': {
   215	      console.log(readPackageVersion());
   216	      return;
   217	    }
   218	    case 'payout': {
   219	      payout(rest);
   220	      return;
   221	    }
   222	    default:
   223	      console.error(`Unknown command: ${command}`);
   224	      process.stderr.write(USAGE);
   225	      process.exit(1);
   226	  }
   227	}
