    79	function lineDiscountCents(promotion, qty, unitCents) {
    80	  if (!promotion) return 0;
    81	
    82	  if (promotion.type === 'buy_x_get_y_free') {
    83	    return Math.floor(qty / (promotion.buy_qty + promotion.free_qty))
    84	      * promotion.free_qty * unitCents;
    85	  }
    86	
    87	  if (promotion.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
