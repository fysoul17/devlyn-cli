    94	function runCart(argv) {
    95	  const inputPath = parseInputFlag(argv);
    96	  if (!inputPath) {
    97	    writeCartError(cartError('invalid_input'));
    98	    return;
    99	  }
   100	
   101	  const cartResult = readJsonFile(inputPath, 'input_read_failed');
   102	  if (cartResult.error) {
   103	    writeCartError(cartResult.error);
   104	    return;
   105	  }
   106	
   107	  const cart = cartResult.value;
   108	  if (!cart || !Array.isArray(cart.items)) {
   109	    writeCartError(cartError('missing_items'));
   110	    return;
   111	  }
   112	
   113	  const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
   114	  const catalogResult = readJsonFile(catalogPath, 'catalog_read_failed');
   115	  if (catalogResult.error) {
   116	    writeCartError(catalogResult.error);
   117	    return;
   118	  }
   119	
   120	  const catalog = catalogResult.value;
   121	  for (const item of cart.items) {
   122	    if (!item || typeof item.sku !== 'string' || !Object.hasOwn(catalog.products, item.sku)) {
   123	      writeCartError(cartError('unknown_sku', typeof item?.sku === 'string' ? { sku: item.sku } : {}));
   124	      return;
   125	    }
   126	
   127	    if (!Number.isInteger(item.qty) || item.qty <= 0) {
   128	      writeCartError(cartError('invalid_quantity', { sku: item.sku }));
   129	      return;
   130	    }
   131	  }
   132	
   133	  if (typeof cart.state !== 'string' || !Object.hasOwn(catalog.tax_rates, cart.state)) {
   134	    writeCartError(cartError('unknown_state'));
   135	    return;
   136	  }
   137	
   138	  if (cart.coupon !== null && (typeof cart.coupon !== 'string' || !Object.hasOwn(catalog.coupons, cart.coupon))) {
   139	    writeCartError(cartError('unknown_coupon'));
   140	    return;
   141	  }
   142	
   143	  const quantities = new Map();
   144	  for (const item of cart.items) {
   145	    quantities.set(item.sku, (quantities.get(item.sku) || 0) + item.qty);
   146	  }
   147	
   148	  for (const [sku, qty] of quantities) {
   149	    const product = catalog.products[sku];
   150	    if (qty > product.stock) {
   151	      writeCartError(cartError('invalid_stock', {
   152	        sku,
   153	        available: product.stock,
   154	        requested: qty,
   155	      }));
   156	      return;
   157	    }
   158	  }
   159	
   160	  let subtotalCents = 0;
   161	  let totalLineDiscountCents = 0;
   162	  let taxablePostLineDiscountCents = 0;
   163	  const items = [];
   164	
   165	  for (const [sku, qty] of quantities) {
   166	    const product = catalog.products[sku];
   167	    const promotion = catalog.line_promotions.find((entry) => entry.sku === sku);
   168	    const lineSubtotalCents = qty * product.unit_cents;
   169	    const discountCents = lineDiscountCents(promotion, qty, product.unit_cents);
   170	    const lineTotalCents = lineSubtotalCents - discountCents;
   171	
   172	    subtotalCents += lineSubtotalCents;
   173	    totalLineDiscountCents += discountCents;
   174	    if (catalog.taxable_codes[product.tax_code] === true) {
   175	      taxablePostLineDiscountCents += lineTotalCents;
   176	    }
   177	
   178	    items.push({
   179	      sku,
   180	      qty,
   181	      line_subtotal_cents: lineSubtotalCents,
   182	      line_discount_cents: discountCents,
   183	      line_total_cents: lineTotalCents,
   184	    });
   185	  }
   186	
   187	  const postLineDiscountSubtotalCents = subtotalCents - totalLineDiscountCents;
   188	  const coupon = cart.coupon === null ? null : catalog.coupons[cart.coupon];
   189	  const couponDiscountCents = coupon && postLineDiscountSubtotalCents >= coupon.min_subtotal_cents
   190	    ? Math.round(postLineDiscountSubtotalCents * coupon.percent / 100)
   191	    : 0;
   192	  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[cart.state]);
   193	  const shippingCents = postLineDiscountSubtotalCents - couponDiscountCents >= catalog.free_shipping_min_cents
   194	    ? 0
   195	    : catalog.shipping_cents;
   196	  const totalCents = postLineDiscountSubtotalCents - couponDiscountCents + taxCents + shippingCents;
   197	
   198	  process.stdout.write(`${JSON.stringify({
   199	    subtotal_cents: subtotalCents,
   200	    line_discount_cents: totalLineDiscountCents,
   201	    coupon_discount_cents: couponDiscountCents,
   202	    tax_cents: taxCents,
   203	    shipping_cents: shippingCents,
   204	    total_cents: totalCents,
   205	    items,
   206	  })}\n`);
   207	}
