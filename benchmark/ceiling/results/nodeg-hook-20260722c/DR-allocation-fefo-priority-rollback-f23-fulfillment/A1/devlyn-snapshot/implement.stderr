   162	function drawFromWarehouse(warehouse, sku, qty, allocations, deductions) {
   163	  let remaining = qty;
   164	
   165	  for (const lot of warehouse.lots) {
   166	    if (lot.sku !== sku || lot.qty === 0 || remaining === 0) continue;
   167	
   168	    const drawn = Math.min(lot.qty, remaining);
   169	    lot.qty -= drawn;
   170	    remaining -= drawn;
   171	    allocations.push({ sku, warehouse: warehouse.id, lot: lot.lot, qty: drawn });
   172	    deductions.push({ lot, qty: drawn });
   173	  }
   174	
   175	  return remaining;
   176	}
