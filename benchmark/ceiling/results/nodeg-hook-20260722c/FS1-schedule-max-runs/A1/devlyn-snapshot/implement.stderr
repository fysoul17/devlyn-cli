   660	    def do(self, job_func: Callable, *args, **kwargs):
   661	        """
   662	        Specifies the job_func that should be called every time the
   663	        job runs.
   664	
   665	        Any additional arguments are passed on to job_func when
   666	        the job runs.
   667	
   668	        :param job_func: The function to be scheduled
   669	        :return: The invoked job instance
   670	        """
   671	        self.job_func = functools.partial(job_func, *args, **kwargs)
   672	        functools.update_wrapper(self.job_func, job_func)
   673	        self._schedule_next_run()
   674	        if self.scheduler is None:
   675	            raise ScheduleError(
   676	                "Unable to a add job to schedule. "
   677	                "Job is not associated with an scheduler"
   678	            )
   679	        self.scheduler.jobs.append(self)
