   689	
   690	    def run(self):
   691	        """
   692	        Run the job and immediately reschedule it.
   693	        If the job's deadline is reached (configured using .until()), the job is not
   694	        run and CancelJob is returned immediately. If the next scheduled run exceeds
   695	        the job's deadline, CancelJob is returned after the execution. In this latter
   696	        case CancelJob takes priority over any other returned value.
   697	
   698	        :return: The return value returned by the `job_func`, or CancelJob if the job's
   699	                 deadline is reached.
   700	
   701	        """
   702	        if self._is_overdue(datetime.datetime.now()):
   703	            logger.debug("Cancelling job %s", self)
   704	            return CancelJob
   705	
   706	        logger.debug("Running job %s", self)
   707	        ret = self.job_func()
   708	        self.last_run = datetime.datetime.now()
   709	        self._schedule_next_run()
   710	
   711	        if self.max_runs_remaining is not None:
   712	            self.max_runs_remaining -= 1
   713	            if self.max_runs_remaining == 0:
   714	                logger.debug("Cancelling job %s", self)
   715	                return CancelJob
   716	
   717	        if self._is_overdue(self.next_run):
   718	            logger.debug("Cancelling job %s", self)
   719	            return CancelJob
   720	        return ret
