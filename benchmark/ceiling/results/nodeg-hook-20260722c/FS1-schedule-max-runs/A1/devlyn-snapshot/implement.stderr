+    def max_runs(self, n: int):
+        """
+        Schedule the job to run at most ``n`` times.
+
+        :param n: Positive number of times the job may run
+        :return: The invoked job instance
+        """
+        if type(n) is not int or n < 1:
+            raise ValueError("max_runs() requires a positive integer")
+        self.max_runs_remaining = n
+        return self
