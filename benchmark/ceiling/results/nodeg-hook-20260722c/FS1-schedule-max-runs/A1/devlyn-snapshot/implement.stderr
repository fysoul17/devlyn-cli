+    def test_max_runs_cancels_after_nth_run_pending_execution(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 12, 0, 0):
+            job = every().seconds.max_runs(2).do(mock_job)
+            with mock_datetime(2020, 1, 1, 12, 0, 1):
+                schedule.run_pending()
+                assert mock_job.call_count == 1
+                assert job.max_runs_remaining == 1
+                assert schedule.jobs == [job]
+            with mock_datetime(2020, 1, 1, 12, 0, 2):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+                assert job.max_runs_remaining == 0
+                assert schedule.jobs == []
+            with mock_datetime(2020, 1, 1, 12, 0, 3):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+
+    def test_max_runs_cancels_after_nth_run_all_execution(self):
+        mock_job = make_mock_job()
+        job = every().seconds.max_runs(2).do(mock_job)
+
+        schedule.run_all()
+        assert mock_job.call_count == 1
+        assert schedule.jobs == [job]
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert schedule.jobs == []
+        schedule.run_all()
+        assert mock_job.call_count == 2
