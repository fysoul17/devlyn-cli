   648	    def max_runs(self, n: int):
   649	        """
   650	        Schedule the job to run at most ``n`` times.
   651	
   652	        :param n: Positive number of times the job may run
   653	        :return: The invoked job instance
   654	        """
   655	        if type(n) is not int or n < 1:
