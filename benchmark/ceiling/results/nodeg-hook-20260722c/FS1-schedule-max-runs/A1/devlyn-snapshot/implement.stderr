         self._schedule_next_run()
 
+        if self.max_runs_remaining is not None:
+            self.max_runs_remaining -= 1
+            if self.max_runs_remaining == 0:
+                logger.debug("Cancelling job %s", self)
+                return CancelJob
+
         if self._is_overdue(self.next_run):
             logger.debug("Cancelling job %s", self)
             return CancelJob
