diff --git a/test_schedule.py b/test_schedule.py
index f497826d1dca3c209ec55d205553ff4660268ab5..5ce28ebb5d6c934c9604258773ccdf27aa3ca578
--- a/test_schedule.py
+++ b/test_schedule.py
@@ -387,6 +387,116 @@
                 assert mock_job.call_count == 0
                 assert len(schedule.jobs) == 0
 
+    def test_max_runs_is_chainable_and_validates_input(self):
+        mock_job = make_mock_job()
+
+        job_after_unit = every(5).seconds.max_runs(3)
+        assert job_after_unit is job_after_unit.max_runs(3)
+        assert job_after_unit.do(mock_job) is job_after_unit
+
+        job_before_unit = every().max_runs(3).seconds
+        assert job_before_unit.do(mock_job) is job_before_unit
+
+        for value in (0, -1, 1.0, 2.5, "3", None, True, False):
+            with self.subTest(value=value):
+                with self.assertRaises(ValueError):
+                    every().seconds.max_runs(value)
+
+    def test_max_runs_cancels_after_nth_run_pending_execution(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 12, 0, 0):
+            job = every().seconds.max_runs(2).do(mock_job)
+            with mock_datetime(2020, 1, 1, 12, 0, 1):
+                schedule.run_pending()
+                assert mock_job.call_count == 1
+                assert job.max_runs_remaining == 1
+                assert schedule.jobs == [job]
+            with mock_datetime(2020, 1, 1, 12, 0, 2):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+                assert job.max_runs_remaining == 0
+                assert schedule.jobs == []
+            with mock_datetime(2020, 1, 1, 12, 0, 3):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+
+    def test_max_runs_cancels_after_nth_run_all_execution(self):
+        mock_job = make_mock_job()
+        job = every().seconds.max_runs(2).do(mock_job)
+
+        schedule.run_all()
+        assert mock_job.call_count == 1
+        assert schedule.jobs == [job]
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert schedule.jobs == []
+        schedule.run_all()
+        assert mock_job.call_count == 2
+
+    def test_max_runs_and_until_cancel_when_each_limit_is_first(self):
+        budget_job = make_mock_job("budget_job")
+        deadline_job = make_mock_job("deadline_job")
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            budget = every(5).seconds.max_runs(1).until(
+                datetime.datetime(2020, 1, 1, 11, 36)
+            ).do(budget_job)
+            deadline = every(5).seconds.max_runs(5).until(
+                datetime.datetime(2020, 1, 1, 11, 35, 20)
+            ).do(deadline_job)
+            with mock_datetime(2020, 1, 1, 11, 35, 15):
+                schedule.run_pending()
+                assert budget_job.call_count == 1
+                assert budget.max_runs_remaining == 0
+                assert deadline_job.call_count == 1
+                assert deadline.max_runs_remaining == 4
+                assert schedule.jobs == [deadline]
+            with mock_datetime(2020, 1, 1, 11, 35, 20):
+                schedule.run_all()
+                assert deadline_job.call_count == 2
+                assert deadline.max_runs_remaining == 3
+                assert schedule.jobs == []
+
+    def test_max_runs_last_call_wins_and_budgets_are_independent(self):
+        first_job = make_mock_job("first_job")
+        second_job = make_mock_job("second_job")
+        first = every().seconds.max_runs(5).do(first_job)
+        second = every().seconds.max_runs(2).do(second_job)
+
+        schedule.run_all()
+        assert first.max_runs_remaining == 4
+        first.max_runs(1)
+        assert first.max_runs_remaining == 1
+        assert second.max_runs_remaining == 1
+
+        schedule.run_all()
+        assert first_job.call_count == 2
+        assert second_job.call_count == 2
+        assert first.max_runs_remaining == 0
+        assert second.max_runs_remaining == 0
+        assert schedule.jobs == []
+
+    def test_max_runs_removal_updates_next_run_and_idle_seconds(self):
+        first_job = make_mock_job("first_job")
+        second_job = make_mock_job("second_job")
+        with mock_datetime(2020, 1, 1, 12, 0, 0):
+            first = every(5).seconds.max_runs(1).do(first_job)
+            second = every().hours.max_runs(2).do(second_job)
+            assert schedule.next_run() == first.next_run
+
+            schedule.run_all()
+            assert schedule.jobs == [second]
+            assert schedule.next_run() == second.next_run
+            assert schedule.idle_seconds() is not None
+            assert schedule.default_scheduler.next_run == second.next_run
+            assert schedule.default_scheduler.idle_seconds is not None
+
+            schedule.run_all()
+            assert schedule.jobs == []
+            assert schedule.next_run() is None
+            assert schedule.idle_seconds() is None
+            assert schedule.default_scheduler.next_run is None
+            assert schedule.default_scheduler.idle_seconds is None
+
     def test_weekday_at_todady(self):
         mock_job = make_mock_job()
 

[codex-monitored] heartbeat: elapsed=150s
codex
Probe P2 exposed a concrete compatibility fault in the existing `.until()` type check: its frozen clock replaces `datetime.datetime`, so a real `datetime` deadline is rejected before the new budget logic runs. I’ll preserve `.until()` behavior while checking against the original datetime class, which lets both real and frozen datetimes remain valid.
[codex-monitored] heartbeat: elapsed=180s
apply patch
