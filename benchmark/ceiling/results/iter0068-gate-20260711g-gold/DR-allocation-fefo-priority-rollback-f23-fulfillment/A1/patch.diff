+test('fulfill-wave: priority preemption + FEFO + remaining sort', () => {
+  // Lower-priority order appears first in input but must lose to higher-priority.
+  // Higher-priority must consume W1/A (FEFO earliest expiry across warehouses
+  // when walking W1 first by distance) before the lower-priority order runs.
+  const file = writeTmpInput({
+    warehouses: [
+      {
+        id: 'W1',
+        distance: 5,
+        lots: [
+          { sku: 'X', lot: 'A', qty: 2, expires: '2026-01-01' },
+          { sku: 'X', lot: 'B', qty: 3, expires: '2026-06-01' },
+        ],
+      },
+      {
+        id: 'W2',
+        distance: 10,
+        lots: [
+          { sku: 'X', lot: 'C', qty: 4, expires: '2026-03-01' },
+        ],
+      },
+    ],
+    orders: [
+      {
+        id: 'low_first',
+        priority: 1,
+        submitted_at: '2026-05-01T00:00:00Z',
+        lines: [{ sku: 'X', qty: 2, single_warehouse: false }],
+      },
+      {
+        id: 'high_later',
+        priority: 10,
+        submitted_at: '2026-05-01T00:01:00Z',
+        lines: [{ sku: 'X', qty: 2, single_warehouse: false }],
+      },
+    ],
+  });
+  const out = JSON.parse(run(['fulfill-wave', '--input', file]));
+  assert.deepStrictEqual(out, {
+    accepted: [
+      { id: 'high_later', allocations: [{ sku: 'X', warehouse: 'W1', lot: 'A', qty: 2 }] },
+      { id: 'low_first', allocations: [{ sku: 'X', warehouse: 'W1', lot: 'B', qty: 2 }] },
+    ],
+    rejected: [],
+    remaining: [
+      { warehouse: 'W1', sku: 'X', lot: 'B', qty: 1, expires: '2026-06-01' },
+      { warehouse: 'W2', sku: 'X', lot: 'C', qty: 4, expires: '2026-03-01' },
+    ],
+  });
+});
+
+test('fulfill-wave: rejects non-ISO submitted_at with exit 2 and JSON error to stderr', () => {
+  const file = writeTmpInput({
+    warehouses: [
+      {
+        id: 'W1',
+        distance: 1,
+        lots: [{ sku: 'X', lot: 'A', qty: 1, expires: '2026-01-01' }],
+      },
+    ],
+    orders: [
+      {
+        id: 'bad_date',
+        priority: 1,
+        submitted_at: 'not-a-date',
+        lines: [{ sku: 'X', qty: 1, single_warehouse: false }],
+      },
+    ],
+  });
+  const result = spawnSync('node', [CLI, 'fulfill-wave', '--input', file], { encoding: 'utf8' });
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  const parsed = JSON.parse(result.stderr);
+  assert.ok(typeof parsed.error === 'string' && parsed.error.length > 0);
+});
+
+test('fulfill-wave: all-or-nothing rollback frees stock for later order', () => {
+  // mid_fail (priority 5) tentatively allocates X then fails on Y → must roll back
+  // so low_after (priority 1) can still consume the X stock that was tentatively held.
+  const file = writeTmpInput({
+    warehouses: [
+      {
+        id: 'W1',
+        distance: 1,
+        lots: [
+          { sku: 'X', lot: 'A', qty: 1, expires: '2026-01-01' },
+          { sku: 'Y', lot: 'B', qty: 1, expires: '2026-01-01' },
+        ],
+      },
+    ],
+    orders: [
+      {
+        id: 'mid_fail',
+        priority: 5,
+        submitted_at: '2026-05-01T00:00:00Z',
+        lines: [
+          { sku: 'X', qty: 1, single_warehouse: false },
+          { sku: 'Y', qty: 5, single_warehouse: false },
+        ],
+      },
+      {
+        id: 'low_after',
+        priority: 1,
+        submitted_at: '2026-05-01T00:01:00Z',
+        lines: [{ sku: 'X', qty: 1, single_warehouse: false }],
+      },
+    ],
+  });
+  const out = JSON.parse(run(['fulfill-wave', '--input', file]));
+  assert.deepStrictEqual(out, {
+    accepted: [
+      { id: 'low_after', allocations: [{ sku: 'X', warehouse: 'W1', lot: 'A', qty: 1 }] },
+    ],
+    rejected: [{ id: 'mid_fail', reason: 'insufficient_stock' }],
+    remaining: [
+      { warehouse: 'W1', sku: 'Y', lot: 'B', qty: 1, expires: '2026-01-01' },
+    ],
+  });
+});
