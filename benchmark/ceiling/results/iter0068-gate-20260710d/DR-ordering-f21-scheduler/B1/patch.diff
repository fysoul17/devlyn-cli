 const { test } = require('node:test');
 const assert = require('node:assert');
-const { execFileSync } = require('node:child_process');
+const { execFileSync, spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,32 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function runResult(args) {
+  return spawnSync(process.execPath, [CLI, ...args], { encoding: 'utf8' });
+}
+
+function inputPath(t, input) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-schedule-'));
+  t.after(() => fs.rmSync(directory, { recursive: true, force: true }));
+  const file = path.join(directory, 'input.json');
+  if (input !== undefined) {
+    fs.writeFileSync(file, typeof input === 'string' ? input : JSON.stringify(input));
+  }
+  return file;
+}
+
+function assertInputError(result, label) {
+  assert.equal(result.status, 2, label);
+  assert.equal(result.signal, null, label);
+  assert.equal(result.stdout, '', label);
+  const lines = result.stderr.split('\n');
+  assert.equal(lines.length, 2, label);
+  assert.equal(lines[1], '', label);
+  const error = JSON.parse(lines[0]);
+  assert.deepEqual(Object.keys(error), ['error'], label);
+  assert.equal(typeof error.error, 'string', label);
+}
+
