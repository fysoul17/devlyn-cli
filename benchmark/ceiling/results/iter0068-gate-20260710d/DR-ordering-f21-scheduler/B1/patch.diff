+
+test('schedule uses earliest fits around blocks and allocations', (t) => {
+  const file = inputPath(t, {
+    resources: [{
+      id: 'room',
+      windows: [{ start: '09:00', end: '10:00' }],
+      blocked: [{ start: '09:10', end: '09:20' }],
+    }],
+    requests: [
+      { id: 'first', resource: 'room', start: '09:00', duration_min: 10, priority: 2, submitted_at: '08:00' },
+      { id: 'second', resource: 'room', start: '09:05', duration_min: 10, priority: 1, submitted_at: '08:00' },
+    ],
+  });
+
+  const result = runResult(['schedule', '--input', file]);
+  assert.equal(result.status, 0);
+  assert.equal(result.stderr, '');
+  assert.deepEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'first', resource: 'room', start: '09:00', end: '09:10' },
+      { id: 'second', resource: 'room', start: '09:20', end: '09:30' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule globally prioritizes and emits exact ordered result shapes', (t) => {
+  const file = inputPath(t, {
+    resources: [
+      {
+        id: 'alpha',
+        windows: [{ start: '09:00', end: '09:20' }],
+        blocked: [{ start: '09:05', end: '09:15' }],
+      },
+      {
+        id: 'beta',
+        windows: [{ start: '10:00', end: '10:10' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      { id: 'low', resource: 'beta', start: '10:00', duration_min: 10, priority: 1, submitted_at: '08:00' },
+      { id: 'blocked', resource: 'alpha', start: '09:00', duration_min: 11, priority: 9, submitted_at: '08:00' },
+      { id: 'high', resource: 'beta', start: '10:00', duration_min: 10, priority: 5, submitted_at: '08:00' },
+      { id: 'later', resource: 'alpha', start: '09:00', duration_min: 5, priority: 0, submitted_at: '08:00' },
+      { id: 'unknown', resource: 'missing', start: '09:00', duration_min: 5, priority: 10, submitted_at: '08:00' },
+    ],
+  });
+
+  const result = runResult(['schedule', '--input', file]);
+  assert.equal(result.status, 0);
+  assert.equal(result.stderr, '');
+  const output = JSON.parse(result.stdout);
+  assert.deepEqual(Object.keys(output), ['scheduled', 'rejected']);
+  output.scheduled.forEach((row) => assert.deepEqual(Object.keys(row), ['id', 'resource', 'start', 'end']));
+  output.rejected.forEach((row) => assert.deepEqual(Object.keys(row), ['id', 'reason']));
+  assert.deepEqual(output, {
+    scheduled: [
+      { id: 'later', resource: 'alpha', start: '09:00', end: '09:05' },
+      { id: 'high', resource: 'beta', start: '10:00', end: '10:10' },
+    ],
+    rejected: [
+      { id: 'low', reason: 'no_slot' },
+      { id: 'blocked', reason: 'no_slot' },
+      { id: 'unknown', reason: 'unknown_resource' },
+    ],
+  });
+});
+
+test('schedule breaks equal priority by submission time and id', (t) => {
+  const file = inputPath(t, {
+    resources: [{ id: 'room', windows: [{ start: '09:00', end: '09:15' }], blocked: [] }],
+    requests: [
+      { id: 'late', resource: 'room', start: '09:00', duration_min: 5, priority: 4, submitted_at: '08:01' },
+      { id: 'b', resource: 'room', start: '09:00', duration_min: 5, priority: 4, submitted_at: '08:00' },
+      { id: 'a', resource: 'room', start: '09:00', duration_min: 5, priority: 4, submitted_at: '08:00' },
+    ],
+  });
+
+  const result = runResult(['schedule', '--input', file]);
+  assert.equal(result.status, 0);
+  assert.equal(result.stderr, '');
+  assert.deepEqual(JSON.parse(result.stdout).scheduled, [
+    { id: 'a', resource: 'room', start: '09:00', end: '09:05' },
+    { id: 'b', resource: 'room', start: '09:05', end: '09:10' },
+    { id: 'late', resource: 'room', start: '09:10', end: '09:15' },
+  ]);
+});
+
+test('schedule treats ranges as half-open at blocked boundaries', (t) => {
+  const file = inputPath(t, {
+    resources: [
+      {
+        id: 'end-edge',
+        windows: [{ start: '09:00', end: '09:10' }],
+        blocked: [{ start: '09:05', end: '09:10' }],
+      },
+      {
+        id: 'start-edge',
+        windows: [{ start: '09:00', end: '09:10' }],
+        blocked: [{ start: '09:00', end: '09:05' }],
+      },
+      {
+        id: 'overlap',
+        windows: [{ start: '09:00', end: '09:05' }],
+        blocked: [{ start: '09:04', end: '09:05' }],
+      },
+    ],
+    requests: [
+      { id: 'ends-at-block', resource: 'end-edge', start: '09:00', duration_min: 5, priority: 1, submitted_at: '08:00' },
+      { id: 'starts-after-block', resource: 'start-edge', start: '09:05', duration_min: 5, priority: 1, submitted_at: '08:00' },
+      { id: 'one-minute-overlap', resource: 'overlap', start: '09:00', duration_min: 5, priority: 1, submitted_at: '08:00' },
+    ],
+  });
+
+  const result = runResult(['schedule', '--input', file]);
+  assert.equal(result.status, 0);
+  assert.equal(result.stderr, '');
+  assert.deepEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'ends-at-block', resource: 'end-edge', start: '09:00', end: '09:05' },
+      { id: 'starts-after-block', resource: 'start-edge', start: '09:05', end: '09:10' },
+    ],
+    rejected: [{ id: 'one-minute-overlap', reason: 'no_slot' }],
+  });
+});
+
+test('schedule reports file-read and missing-flag errors on stderr only', (t) => {
+  const missing = inputPath(t);
+  assertInputError(runResult(['schedule', '--input', missing]), 'missing file');
+  assertInputError(runResult(['schedule']), 'missing --input');
+});
+
+test('schedule rejects malformed JSON, shapes, ids, times, ranges, and durations', (t) => {
+  const resource = {
+    id: 'room',
+    windows: [{ start: '09:00', end: '10:00' }],
+    blocked: [],
+  };
+  const request = {
+    id: 'request',
+    resource: 'room',
+    start: '09:00',
+    duration_min: 5,
+    priority: 1,
+    submitted_at: '08:00',
+  };
+  const cases = [
+    ['malformed JSON', '{'],
+    ['top-level array', []],
+    ['missing requests array', { resources: [] }],
+    ['invalid resource shape', { resources: [{ id: 'room', windows: [] }], requests: [] }],
+    ['duplicate resource ids', { resources: [resource, resource], requests: [] }],
+    ['duplicate request ids', { resources: [resource], requests: [request, { ...request }] }],
+    ['invalid request time', { resources: [resource], requests: [{ ...request, start: '9:00' }] }],
+    ['invalid submitted time', { resources: [resource], requests: [{ ...request, submitted_at: '24:00' }] }],
+    ['invalid range time', {
+      resources: [{ ...resource, windows: [{ start: '09:00', end: '25:00' }] }],
+      requests: [],
+    }],
+    ['empty range', {
+      resources: [{ ...resource, windows: [{ start: '09:00', end: '09:00' }] }],
+      requests: [],
+    }],
+    ['reversed blocked range', {
+      resources: [{ ...resource, blocked: [{ start: '09:05', end: '09:04' }] }],
+      requests: [],
+    }],
+    ['zero duration', { resources: [resource], requests: [{ ...request, duration_min: 0 }] }],
+    ['fractional duration', { resources: [resource], requests: [{ ...request, duration_min: 1.5 }] }],
+    ['invalid priority', { resources: [resource], requests: [{ ...request, priority: '1' }] }],
+  ];
+
+  for (const [label, input] of cases) {
+    const result = runResult(['schedule', '--input', inputPath(t, input)]);
+    assertInputError(result, label);
+  }
+});
