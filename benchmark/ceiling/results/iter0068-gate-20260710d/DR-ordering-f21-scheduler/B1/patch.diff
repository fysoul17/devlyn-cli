@@ -35,6 +36,161 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function inputError(message) {
+  process.stderr.write(`${JSON.stringify({ error: message })}\n`);
+  process.exit(2);
+}
+
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^(?:[01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    inputError('invalid time');
+  }
+  const [hours, minutes] = value.split(':').map(Number);
+  return hours * 60 + minutes;
+}
+
+function parseRange(value) {
+  if (!value || typeof value !== 'object' || Array.isArray(value)) {
+    inputError('invalid range');
+  }
+  const start = parseTime(value.start);
+  const end = parseTime(value.end);
+  if (start >= end) inputError('invalid range');
+  return { start, end };
+}
+
+function nonEmptyString(value) {
+  return typeof value === 'string' && value.length > 0;
+}
+
+function readScheduleInput(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    inputError('schedule requires --input <path>');
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(argv[1], 'utf8');
+  } catch (error) {
+    inputError('unable to read input');
+  }
+
+  let input;
+  try {
+    input = JSON.parse(raw);
+  } catch (error) {
+    inputError('invalid JSON');
+  }
+
+  if (!input || typeof input !== 'object' || Array.isArray(input) ||
+      !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    inputError('invalid input shape');
+  }
+
+  const resourceIds = new Set();
+  const resources = input.resources.map((resource) => {
+    if (!resource || typeof resource !== 'object' || Array.isArray(resource) ||
+        !nonEmptyString(resource.id) || !Array.isArray(resource.windows) ||
+        !Array.isArray(resource.blocked) || resourceIds.has(resource.id)) {
+      inputError('invalid resource');
+    }
+    resourceIds.add(resource.id);
+    return {
+      id: resource.id,
+      windows: resource.windows.map(parseRange),
+      occupied: resource.blocked.map(parseRange),
+    };
+  });
+
+  const requestIds = new Set();
+  const requests = input.requests.map((request, index) => {
+    if (!request || typeof request !== 'object' || Array.isArray(request) ||
+        !nonEmptyString(request.id) || !nonEmptyString(request.resource) ||
+        !Number.isInteger(request.duration_min) || request.duration_min <= 0 ||
+        typeof request.priority !== 'number' || !Number.isFinite(request.priority) ||
+        requestIds.has(request.id)) {
+      inputError('invalid request');
+    }
+    requestIds.add(request.id);
+    return {
+      id: request.id,
+      resource: request.resource,
+      start: parseTime(request.start),
+      duration: request.duration_min,
+      priority: request.priority,
+      submitted: parseTime(request.submitted_at),
+      index,
+    };
+  });
+
+  return { resources, requests };
+}
+
+function compareIds(left, right) {
+  return left < right ? -1 : left > right ? 1 : 0;
+}
+
+function firstFit(window, occupied, requestedStart, duration) {
+  let candidate = Math.max(window.start, requestedStart);
+  const conflicts = occupied
+    .filter((range) => range.end > window.start && range.start < window.end)
+    .sort((left, right) => left.start - right.start || left.end - right.end);
+
+  for (const conflict of conflicts) {
+    if (candidate + duration <= conflict.start) break;
+    if (candidate < conflict.end && candidate + duration > conflict.start) {
+      candidate = conflict.end;
+    }
+  }
+  return candidate + duration <= window.end ? candidate : null;
+}
+
+function schedule(argv) {
+  const { resources, requests } = readScheduleInput(argv);
+  const resourcesById = new Map(resources.map((resource) => [resource.id, resource]));
+  const scheduled = [];
+  const rejected = [];
+  const processingOrder = [...requests].sort((left, right) =>
+    right.priority - left.priority ||
+    left.submitted - right.submitted ||
+    compareIds(left.id, right.id));
+
+  for (const request of processingOrder) {
+    const resource = resourcesById.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', index: request.index });
+      continue;
+    }
+
+    let start = null;
+    for (const window of resource.windows) {
+      const candidate = firstFit(window, resource.occupied, request.start, request.duration);
+      if (candidate !== null && (start === null || candidate < start)) start = candidate;
+    }
+    if (start === null) {
+      rejected.push({ id: request.id, reason: 'no_slot', index: request.index });
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.occupied.push({ start, end });
+    scheduled.push({ id: request.id, resource: request.resource, start, end });
+  }
+
+  const formatTime = (minutes) =>
+    `${String(Math.floor(minutes / 60)).padStart(2, '0')}:${String(minutes % 60).padStart(2, '0')}`;
+  const output = {
+    scheduled: scheduled
+      .sort((left, right) => left.start - right.start ||
+        compareIds(left.resource, right.resource) || compareIds(left.id, right.id))
+      .map((row) => ({ ...row, start: formatTime(row.start), end: formatTime(row.end) })),
+    rejected: rejected
+      .sort((left, right) => left.index - right.index)
+      .map(({ id, reason }) => ({ id, reason })),
+  };
+  process.stdout.write(`${JSON.stringify(output)}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +209,10 @@ function main(argv) {
       console.log(readPackageVersion());
