 const { test } = require('node:test');
 const assert = require('node:assert');
 const { execFileSync } = require('node:child_process');
+const { spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +12,13 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function writeCart(input) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-cart-'));
+  const inputPath = path.join(directory, 'cart.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+  return inputPath;
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +33,74 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('cart prices combined quantities, promotions, coupon, tax, and shipping', () => {
+  const inputPath = writeCart({
+    state: 'CA',
+    coupon: 'ORDER10',
+    items: [
+      { sku: 'TEE', qty: 2 },
+      { sku: 'BAG', qty: 2 },
+      { sku: 'TEE', qty: 1 },
+      { sku: 'MUG', qty: 1 },
+    ],
+  });
+
+  const result = spawnSync('node', [CLI, 'cart', '--input', inputPath], { encoding: 'utf8' });
+
+  assert.equal(result.status, 0);
+  assert.equal(result.stderr, '');
+  assert.deepEqual(JSON.parse(result.stdout), {
+    subtotal_cents: 15100,
+    line_discount_cents: 3500,
+    coupon_discount_cents: 1160,
+    tax_cents: 858,
+    shipping_cents: 0,
+    total_cents: 11298,
+    items: [
+      {
+        sku: 'TEE',
+        qty: 3,
+        line_subtotal_cents: 7500,
+        line_discount_cents: 2500,
+        line_total_cents: 5000,
+      },
+      {
+        sku: 'BAG',
+        qty: 2,
+        line_subtotal_cents: 6400,
+        line_discount_cents: 1000,
+        line_total_cents: 5400,
+      },
+      {
+        sku: 'MUG',
+        qty: 1,
+        line_subtotal_cents: 1200,
+        line_discount_cents: 0,
+        line_total_cents: 1200,
+      },
+    ],
+  });
+});
+
+test('cart reports combined stock validation failures as JSON', () => {
+  const inputPath = writeCart({
+    state: 'OR',
+    coupon: null,
+    items: [
+      { sku: 'BAG', qty: 3 },
+      { sku: 'BAG', qty: 2 },
+    ],
+  });
+
+  const result = spawnSync('node', [CLI, 'cart', '--input', inputPath], { encoding: 'utf8' });
+
+  assert.equal(result.status, 2);
+  assert.equal(result.stdout, '');
+  assert.deepEqual(JSON.parse(result.stderr), {
+    error: 'invalid_stock',
+    sku: 'BAG',
+    available: 4,
+    requested: 5,
+  });
+});
