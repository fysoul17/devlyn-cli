diff --git a/bin/cli.js b/bin/cli.js
index 78fdd98..2289789 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -10,6 +10,7 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  cart --input PATH          Price a cart JSON file
   --help, -h                 Show this help
 
 Examples:
@@ -35,6 +36,146 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function cartError(error, details = {}) {
+  return { error, ...details };
+}
+
+function writeCartError(error) {
+  process.stderr.write(JSON.stringify(error));
+}
+
+function readJsonFile(filePath, readError, parseError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch (error) {
+    throw cartError(readError);
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch (error) {
+    throw cartError(parseError);
+  }
+}
+
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const value = argv[idx + 1];
+  if (idx === -1 || !value || value.startsWith('-')) {
+    throw cartError('invalid_input');
+  }
+  return value;
+}
+
+function priceCart(input, catalog) {
+  if (!input || !Array.isArray(input.items)) {
+    throw cartError('missing_items');
+  }
+
+  if (typeof input.state !== 'string' ||
+      !Object.prototype.hasOwnProperty.call(catalog.tax_rates, input.state)) {
+    throw cartError('unknown_state', { state: input && input.state });
+  }
+
+  if (input.coupon !== null && (typeof input.coupon !== 'string' ||
+      !Object.prototype.hasOwnProperty.call(catalog.coupons, input.coupon))) {
+    throw cartError('unknown_coupon', { coupon: input.coupon });
+  }
+
+  const quantities = new Map();
+  for (const item of input.items) {
+    if (!item || typeof item.sku !== 'string' ||
+        !Object.prototype.hasOwnProperty.call(catalog.products, item.sku)) {
+      throw cartError('unknown_sku', { sku: item && item.sku });
+    }
+    if (!Number.isInteger(item.qty) || item.qty <= 0) {
+      throw cartError('invalid_quantity', { sku: item.sku, qty: item.qty });
+    }
+    quantities.set(item.sku, (quantities.get(item.sku) || 0) + item.qty);
+  }
+
+  for (const [sku, qty] of quantities) {
+    const product = catalog.products[sku];
+    if (qty > product.stock) {
+      throw cartError('invalid_stock', {
+        sku,
+        available: product.stock,
+        requested: qty,
+      });
+    }
+  }
+
+  const items = [];
+  let subtotalCents = 0;
+  let lineDiscountCents = 0;
+  let taxablePostLineDiscountCents = 0;
+
+  for (const [sku, qty] of quantities) {
+    const product = catalog.products[sku];
+    const lineSubtotalCents = qty * product.unit_cents;
+    let discountCents = 0;
+
+    for (const promotion of catalog.line_promotions) {
+      if (promotion.sku !== sku) continue;
+      if (promotion.type === 'buy_x_get_y_free') {
+        discountCents += Math.floor(qty / (promotion.buy_qty + promotion.free_qty)) *
+          promotion.free_qty * product.unit_cents;
+      }
+      if (promotion.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
+        discountCents += promotion.per_unit_discount_cents * qty;
+      }
+    }
+
+    const lineTotalCents = lineSubtotalCents - discountCents;
+    subtotalCents += lineSubtotalCents;
+    lineDiscountCents += discountCents;
+    if (catalog.taxable_codes[product.tax_code] === true) {
+      taxablePostLineDiscountCents += lineTotalCents;
+    }
+    items.push({
+      sku,
+      qty,
+      line_subtotal_cents: lineSubtotalCents,
+      line_discount_cents: discountCents,
+      line_total_cents: lineTotalCents,
+    });
+  }
+
+  const postLineDiscountCents = subtotalCents - lineDiscountCents;
+  const coupon = input.coupon === null ? null : catalog.coupons[input.coupon];
+  const couponDiscountCents = coupon && postLineDiscountCents >= coupon.min_subtotal_cents
+    ? Math.round(postLineDiscountCents * coupon.percent / 100)
+    : 0;
+  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[input.state]);
+  const shippingCents = postLineDiscountCents - couponDiscountCents >= catalog.free_shipping_min_cents
+    ? 0
+    : catalog.shipping_cents;
+
+  return {
+    subtotal_cents: subtotalCents,
+    line_discount_cents: lineDiscountCents,
+    coupon_discount_cents: couponDiscountCents,
+    tax_cents: taxCents,
+    shipping_cents: shippingCents,
+    total_cents: postLineDiscountCents - couponDiscountCents + taxCents + shippingCents,
+    items,
+  };
+}
+
+function runCart(argv) {
+  try {
+    const inputPath = parseInputFlag(argv);
+    const input = readJsonFile(inputPath, 'input_read_error', 'invalid_json');
+    const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
+    const catalog = readJsonFile(catalogPath, 'catalog_read_error', 'invalid_catalog_json');
+    process.stdout.write(JSON.stringify(priceCart(input, catalog)));
+  } catch (error) {
+    writeCartError(error && error.error ? error : cartError('cart_error'));
+    process.exitCode = 2;
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +194,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'cart': {
+      runCart(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
