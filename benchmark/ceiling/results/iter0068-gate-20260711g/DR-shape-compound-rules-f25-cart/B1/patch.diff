+function cartError(error) {
+  const err = new Error(error);
+  err.cartError = { error };
+  return err;
+}
+
+function readJsonFile(filePath, error) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch {
+    throw cartError(error);
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch {
+    throw cartError(error);
+  }
+}
+
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const inputPath = argv[idx + 1];
+  if (idx === -1 || !inputPath || inputPath.startsWith('-')) {
+    throw cartError('invalid_input');
+  }
+  return inputPath;
+}
+
+function combineCartItems(items) {
+  if (!Array.isArray(items)) throw cartError('invalid_items');
+
+  const lines = [];
+  const linesBySku = new Map();
+  for (const item of items) {
+    if (!item || typeof item.sku !== 'string') throw cartError('invalid_item');
+    if (!Number.isInteger(item.qty) || item.qty <= 0) {
+      const err = cartError('invalid_quantity');
+      err.cartError.sku = item.sku;
+      throw err;
+    }
+
+    const line = linesBySku.get(item.sku);
+    if (line) {
+      line.qty += item.qty;
+    } else {
+      const newLine = { sku: item.sku, qty: item.qty };
+      linesBySku.set(item.sku, newLine);
+      lines.push(newLine);
+    }
+  }
+  return lines;
+}
+
+function lineDiscountFor(product, sku, qty, promotions) {
+  let discount = 0;
+  for (const promotion of promotions) {
+    if (promotion.sku !== sku) continue;
+
+    if (promotion.type === 'buy_x_get_y_free') {
+      discount += Math.floor(qty / (promotion.buy_qty + promotion.free_qty))
+        * promotion.free_qty * product.unit_cents;
+    } else if (promotion.type === 'per_unit_discount_cents' && qty >= promotion.min_qty) {
+      discount += promotion.per_unit_discount_cents * qty;
+    }
+  }
+  return discount;
+}
+
+function priceCart(inputPath) {
+  const cart = readJsonFile(inputPath, 'invalid_cart_json');
+  const catalog = readJsonFile(path.join(__dirname, '..', 'data', 'catalog.json'), 'invalid_catalog_json');
+
+  if (!cart || typeof cart !== 'object' || !Object.prototype.hasOwnProperty.call(cart, 'items')) {
+    throw cartError('invalid_items');
+  }
+  if (typeof cart.state !== 'string' || !Object.prototype.hasOwnProperty.call(catalog.tax_rates, cart.state)) {
+    throw cartError('unknown_state');
+  }
+  if (cart.coupon !== null && typeof cart.coupon !== 'string') throw cartError('invalid_coupon');
+
+  const lines = combineCartItems(cart.items);
+  const products = catalog.products;
+  const promotions = catalog.line_promotions;
+  const items = [];
+  let subtotalCents = 0;
+  let lineDiscountCents = 0;
+  let taxablePostLineDiscountCents = 0;
+
+  for (const line of lines) {
+    if (!Object.prototype.hasOwnProperty.call(products, line.sku)) {
+      const err = cartError('unknown_sku');
+      err.cartError.sku = line.sku;
+      throw err;
+    }
+    const product = products[line.sku];
+    if (line.qty > product.stock) {
+      const err = cartError('invalid_stock');
+      err.cartError.sku = line.sku;
+      err.cartError.available = product.stock;
+      err.cartError.requested = line.qty;
+      throw err;
+    }
+
+    const lineSubtotalCents = line.qty * product.unit_cents;
+    const lineDiscountCentsForSku = lineDiscountFor(product, line.sku, line.qty, promotions);
+    const lineTotalCents = lineSubtotalCents - lineDiscountCentsForSku;
+    subtotalCents += lineSubtotalCents;
+    lineDiscountCents += lineDiscountCentsForSku;
+    if (catalog.taxable_codes[product.tax_code] === true) {
+      taxablePostLineDiscountCents += lineTotalCents;
+    }
+    items.push({
+      sku: line.sku,
+      qty: line.qty,
+      line_subtotal_cents: lineSubtotalCents,
+      line_discount_cents: lineDiscountCentsForSku,
+      line_total_cents: lineTotalCents,
+    });
+  }
+
+  let couponDiscountCents = 0;
+  if (cart.coupon !== null) {
+    if (!Object.prototype.hasOwnProperty.call(catalog.coupons, cart.coupon)) {
+      const err = cartError('unknown_coupon');
+      err.cartError.coupon = cart.coupon;
+      throw err;
+    }
+    const coupon = catalog.coupons[cart.coupon];
+    const postLineDiscountSubtotal = subtotalCents - lineDiscountCents;
+    if (postLineDiscountSubtotal >= coupon.min_subtotal_cents) {
+      couponDiscountCents = Math.round(postLineDiscountSubtotal * coupon.percent / 100);
+    }
+  }
+
+  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[cart.state]);
+  const postDiscountSubtotal = subtotalCents - lineDiscountCents - couponDiscountCents;
+  const shippingCents = postDiscountSubtotal >= catalog.free_shipping_min_cents
+    ? 0
+    : catalog.shipping_cents;
+
+  return {
+    subtotal_cents: subtotalCents,
+    line_discount_cents: lineDiscountCents,
+    coupon_discount_cents: couponDiscountCents,
+    tax_cents: taxCents,
+    shipping_cents: shippingCents,
+    total_cents: postDiscountSubtotal + taxCents + shippingCents,
+    items,
+  };
+}
+
+function runCart(argv) {
+  try {
+    const result = priceCart(parseInputFlag(argv));
+    process.stdout.write(JSON.stringify(result));
+  } catch (err) {
+    const output = err && err.cartError ? err.cartError : { error: 'cart_error' };
+    process.stderr.write(JSON.stringify(output));
+    process.exitCode = 2;
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +219,10 @@ function main(argv) {
