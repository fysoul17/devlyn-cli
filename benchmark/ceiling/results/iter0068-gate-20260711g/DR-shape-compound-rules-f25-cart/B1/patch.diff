+function withCart(contents, fn) {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-cart-'));
+  const input = path.join(dir, 'cart.json');
+  fs.writeFileSync(input, typeof contents === 'string' ? contents : JSON.stringify(contents));
+  try {
+    fn(input);
+  } finally {
+    fs.rmSync(dir, { recursive: true, force: true });
+  }
+}
+
+test('cart prices combined items with promotions, coupon, tax, and shipping', () => {
+  withCart({
+    state: 'CA',
+    coupon: 'ORDER10',
+    items: [
+      { sku: 'TEE', qty: 2 },
+      { sku: 'MUG', qty: 1 },
+      { sku: 'TEE', qty: 1 },
+      { sku: 'BAG', qty: 2 },
+    ],
+  }, (input) => {
+    const result = spawnSync('node', [CLI, 'cart', '--input', input], { encoding: 'utf8' });
+
+    assert.strictEqual(result.status, 0);
+    assert.strictEqual(result.stderr, '');
+    assert.deepStrictEqual(JSON.parse(result.stdout), {
+      subtotal_cents: 15100,
+      line_discount_cents: 3500,
+      coupon_discount_cents: 1160,
+      tax_cents: 858,
+      shipping_cents: 0,
+      total_cents: 11298,
+      items: [
+        {
+          sku: 'TEE',
+          qty: 3,
+          line_subtotal_cents: 7500,
+          line_discount_cents: 2500,
+          line_total_cents: 5000,
+        },
+        {
+          sku: 'MUG',
+          qty: 1,
+          line_subtotal_cents: 1200,
+          line_discount_cents: 0,
+          line_total_cents: 1200,
+        },
+        {
+          sku: 'BAG',
+          qty: 2,
+          line_subtotal_cents: 6400,
+          line_discount_cents: 1000,
+          line_total_cents: 5400,
+        },
+      ],
+    });
+  });
+});
+
+test('cart reports combined quantities that exceed stock', () => {
+  withCart({
+    state: 'OR',
+    coupon: null,
+    items: [
+      { sku: 'BAG', qty: 3 },
+      { sku: 'BAG', qty: 2 },
