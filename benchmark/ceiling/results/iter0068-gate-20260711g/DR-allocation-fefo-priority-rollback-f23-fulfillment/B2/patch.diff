 });
+
+test('fulfill-wave accepts an order using warehouse distance and FEFO order', () => {
+  const output = JSON.parse(runWithInput({
+    warehouses: [
+      {
+        id: 'far', distance: 20, lots: [
+          { sku: 'book', lot: 'far-lot', qty: 4, expires: '2027-01-01' },
+        ],
+      },
+      {
+        id: 'near', distance: 5, lots: [
+          { sku: 'book', lot: 'later', qty: 3, expires: '2027-02-01' },
+          { sku: 'book', lot: 'first', qty: 2, expires: '2027-01-01' },
+        ],
+      },
+    ],
+    orders: [
+      {
+        id: 'order-1', priority: 1, submitted_at: '2026-01-01T10:00:00Z',
+        lines: [{ sku: 'book', qty: 4, single_warehouse: false }],
+      },
+    ],
+  }));
+
+  assert.deepStrictEqual(output, {
+    accepted: [{
+      id: 'order-1',
+      allocations: [
+        { sku: 'book', warehouse: 'near', lot: 'first', qty: 2 },
+        { sku: 'book', warehouse: 'near', lot: 'later', qty: 2 },
+      ],
+    }],
+    rejected: [],
+    remaining: [
+      { warehouse: 'far', sku: 'book', lot: 'far-lot', qty: 4, expires: '2027-01-01' },
+      { warehouse: 'near', sku: 'book', lot: 'later', qty: 1, expires: '2027-02-01' },
+    ],
+  });
+});
+
+test('fulfill-wave rolls back a rejected all-or-nothing order', () => {
+  const output = JSON.parse(runWithInput({
+    warehouses: [{
+      id: 'warehouse-1', distance: 1, lots: [
+        { sku: 'book', lot: 'book-lot', qty: 3, expires: '2027-01-01' },
+        { sku: 'pen', lot: 'pen-lot', qty: 1, expires: '2027-01-01' },
+      ],
+    }],
+    orders: [
+      {
+        id: 'rejected-order', priority: 2, submitted_at: '2026-01-01', lines: [
+          { sku: 'book', qty: 2, single_warehouse: false },
+          { sku: 'pen', qty: 2, single_warehouse: false },
+        ],
+      },
+      {
+        id: 'later-order', priority: 1, submitted_at: '2026-01-01',
+        lines: [{ sku: 'book', qty: 3, single_warehouse: false }],
+      },
+    ],
+  }));
+
+  assert.deepStrictEqual(output, {
+    accepted: [{
+      id: 'later-order',
+      allocations: [{ sku: 'book', warehouse: 'warehouse-1', lot: 'book-lot', qty: 3 }],
+    }],
+    rejected: [{ id: 'rejected-order', reason: 'insufficient_stock' }],
+    remaining: [
+      { warehouse: 'warehouse-1', sku: 'pen', lot: 'pen-lot', qty: 1, expires: '2027-01-01' },
+    ],
+  });
+});
+
+test('fulfill-wave reports file errors as one JSON object on stderr', () => {
+  const missingPath = path.join(os.tmpdir(), `missing-wave-${process.pid}-${Date.now()}.json`);
+  const result = spawnSync('node', [CLI, 'fulfill-wave', '--input', missingPath], {
+    encoding: 'utf8',
+  });
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  const error = JSON.parse(result.stderr);
+  assert.ok(error && typeof error === 'object' && !Array.isArray(error));
+  assert.ok(Object.keys(error).length > 0);
+});
