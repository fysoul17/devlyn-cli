+test('fulfill-wave accepts an order using warehouse preference and FEFO lots', (t) => {
+  const inputPath = writeInput(t, {
+    warehouses: [
+      {
+        id: 'far', distance: 20, lots: [
+          { sku: 'tea', lot: 'far-lot', qty: 5, expires: '2026-06-01' },
+        ],
+      },
+      {
+        id: 'near', distance: 5, lots: [
+          { sku: 'tea', lot: 'late', qty: 4, expires: '2026-05-01' },
+          { sku: 'tea', lot: 'early', qty: 2, expires: '2026-04-01' },
+        ],
+      },
+    ],
+    orders: [
+      {
+        id: 'order-1', priority: 1, submitted_at: '2026-01-01T09:00:00Z',
+        lines: [{ sku: 'tea', qty: 5, single_warehouse: false }],
+      },
+    ],
+  });
+
+  const result = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+  assert.deepStrictEqual(result, {
+    accepted: [{
+      id: 'order-1',
+      allocations: [
+        { sku: 'tea', warehouse: 'near', lot: 'early', qty: 2 },
+        { sku: 'tea', warehouse: 'near', lot: 'late', qty: 3 },
+      ],
+    }],
+    rejected: [],
+    remaining: [
+      { warehouse: 'far', sku: 'tea', lot: 'far-lot', qty: 5, expires: '2026-06-01' },
+      { warehouse: 'near', sku: 'tea', lot: 'late', qty: 1, expires: '2026-05-01' },
+    ],
+  });
+});
+
+test('fulfill-wave rejects an all-or-nothing order and restores its tentative deductions', (t) => {
+  const inputPath = writeInput(t, {
+    warehouses: [{
+      id: 'warehouse-1', distance: 1, lots: [
+        { sku: 'a', lot: 'a-1', qty: 1, expires: '2026-04-01' },
+        { sku: 'b', lot: 'b-1', qty: 1, expires: '2026-04-01' },
+      ],
+    }],
+    orders: [
+      {
+        id: 'rejected-first', priority: 2, submitted_at: '2026-01-01', lines: [
+          { sku: 'a', qty: 1, single_warehouse: false },
+          { sku: 'b', qty: 2, single_warehouse: false },
+        ],
+      },
+      {
+        id: 'accepted-after-rollback', priority: 1, submitted_at: '2026-01-02',
+        lines: [{ sku: 'a', qty: 1, single_warehouse: false }],
+      },
+    ],
+  });
+
+  const result = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+  assert.deepStrictEqual(result, {
+    accepted: [{
+      id: 'accepted-after-rollback',
+      allocations: [{ sku: 'a', warehouse: 'warehouse-1', lot: 'a-1', qty: 1 }],
+    }],
+    rejected: [{ id: 'rejected-first', reason: 'insufficient_stock' }],
+    remaining: [{ warehouse: 'warehouse-1', sku: 'b', lot: 'b-1', qty: 1, expires: '2026-04-01' }],
+  });
+});
