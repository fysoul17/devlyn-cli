+++ b/bin/cli.js
@@ -10,14 +10,18 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  schedule --input PATH      Schedule appointment requests from a JSON file
   --help, -h                 Show this help
 
 Examples:
