   bench-cli version
+  bench-cli schedule --input appointments.json
 `;
 
+class InputError extends Error {}
+
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
@@ -35,6 +39,246 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function isPlainObject(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^(?:[01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    throw new InputError('invalid time');
+  }
+
+  const [hours, minutes] = value.split(':').map(Number);
+  return hours * 60 + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function parseInterval(value) {
+  let start;
+  let end;
+
+  if (isPlainObject(value)) {
+    ({ start, end } = value);
+  } else if (Array.isArray(value) && value.length === 2) {
+    [start, end] = value;
+  } else {
+    throw new InputError('invalid interval');
+  }
+
+  const startMinute = parseTime(start);
+  const endMinute = parseTime(end);
+  if (endMinute <= startMinute) {
+    throw new InputError('invalid time range');
+  }
+
+  return { start: startMinute, end: endMinute };
+}
+
+function requireId(value, field) {
+  if (typeof value !== 'string' || value.length === 0) {
+    throw new InputError(`invalid ${field}`);
+  }
+  return value;
+}
+
+function compareStrings(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function parseScheduleInput(value) {
+  if (!isPlainObject(value) || !Array.isArray(value.resources) || !Array.isArray(value.requests)) {
+    throw new InputError('invalid input');
+  }
+
+  const resources = new Map();
+  for (const resource of value.resources) {
+    if (!isPlainObject(resource) || !Array.isArray(resource.windows) || !Array.isArray(resource.blocked)) {
+      throw new InputError('invalid resource');
+    }
+
+    const id = requireId(resource.id, 'resource id');
+    if (resources.has(id)) {
+      throw new InputError('duplicate resource id');
+    }
+
+    resources.set(id, {
+      id,
+      windows: resource.windows.map(parseInterval),
+      blocked: resource.blocked.map(parseInterval),
+    });
+  }
+
+  const requestIds = new Set();
+  const requests = value.requests.map((request, index) => {
+    if (!isPlainObject(request)) {
+      throw new InputError('invalid request');
+    }
+
+    const id = requireId(request.id, 'request id');
+    if (requestIds.has(id)) {
+      throw new InputError('duplicate request id');
+    }
+    requestIds.add(id);
+
+    const resource = requireId(request.resource, 'request resource');
+    const start = parseTime(request.start);
+    const submittedAt = parseTime(request.submitted_at);
+    if (!Number.isInteger(request.duration_min) || request.duration_min <= 0) {
+      throw new InputError('invalid duration');
+    }
+    if (typeof request.priority !== 'number' || !Number.isFinite(request.priority)) {
+      throw new InputError('invalid priority');
+    }
+
+    return {
+      id,
+      resource,
+      start,
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt,
+      index,
+    };
+  });
+
+  return { resources, requests };
+}
+
+function findEarliestStart(resource, request, accepted) {
+  const conflicts = resource.blocked.concat(accepted).sort((left, right) => (
+    left.start - right.start || left.end - right.end
+  ));
+  let earliest = null;
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(request.start, window.start);
+    if (candidate + request.duration > window.end) continue;
+
+    for (const conflict of conflicts) {
+      if (conflict.end <= candidate) continue;
+      if (conflict.start >= candidate + request.duration) break;
+
+      candidate = conflict.end;
+      if (candidate + request.duration > window.end) break;
+    }
+
+    if (candidate + request.duration <= window.end && (earliest === null || candidate < earliest)) {
+      earliest = candidate;
+    }
+  }
+
+  return earliest;
+}
+
+function createSchedule(input) {
+  const { resources, requests } = parseScheduleInput(input);
+  const acceptedByResource = new Map();
+  for (const resourceId of resources.keys()) {
+    acceptedByResource.set(resourceId, []);
+  }
+
+  const scheduled = [];
+  const rejectedByIndex = new Map();
+  const orderedRequests = [...requests].sort((left, right) => (
+    right.priority - left.priority ||
+    left.submittedAt - right.submittedAt ||
+    compareStrings(left.id, right.id)
+  ));
+
+  for (const request of orderedRequests) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejectedByIndex.set(request.index, { id: request.id, reason: 'unknown_resource' });
+      continue;
+    }
+
+    const accepted = acceptedByResource.get(resource.id);
+    const start = findEarliestStart(resource, request, accepted);
+    if (start === null) {
+      rejectedByIndex.set(request.index, { id: request.id, reason: 'no_slot' });
+      continue;
+    }
+
+    const end = start + request.duration;
+    accepted.push({ start, end });
+    scheduled.push({ id: request.id, resource: resource.id, start, end });
+  }
+
+  scheduled.sort((left, right) => (
+    left.start - right.start ||
+    compareStrings(left.resource, right.resource) ||
+    compareStrings(left.id, right.id)
+  ));
+
+  return {
+    scheduled: scheduled.map((item) => ({
+      id: item.id,
+      resource: item.resource,
+      start: formatTime(item.start),
+      end: formatTime(item.end),
+    })),
+    rejected: requests
+      .sort((left, right) => left.index - right.index)
+      .filter((request) => rejectedByIndex.has(request.index))
+      .map((request) => rejectedByIndex.get(request.index)),
+  };
+}
+
+function parseInputFlag(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1] || argv[1].startsWith('-')) {
+    throw new InputError('schedule requires --input PATH');
+  }
+  return argv[1];
+}
+
+function writeScheduleError(error) {
+  process.stderr.write(`${JSON.stringify({ error: error.message })}\n`);
+}
+
+function runSchedule(argv) {
+  let inputPath;
+  try {
+    inputPath = parseInputFlag(argv);
+  } catch (error) {
+    writeScheduleError(error);
+    return 2;
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    writeScheduleError(new InputError('unable to read input file'));
+    return 2;
+  }
+
+  let input;
+  try {
+    input = JSON.parse(raw);
+  } catch (error) {
+    writeScheduleError(new InputError('invalid input'));
+    return 2;
+  }
+
+  try {
+    process.stdout.write(`${JSON.stringify(createSchedule(input))}\n`);
+    return 0;
+  } catch (error) {
+    if (error instanceof InputError) {
+      writeScheduleError(error);
+      return 2;
+    }
+    throw error;
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +297,11 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'schedule': {
+      const exitCode = runSchedule(rest);
+      if (exitCode !== 0) process.exitCode = exitCode;
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
