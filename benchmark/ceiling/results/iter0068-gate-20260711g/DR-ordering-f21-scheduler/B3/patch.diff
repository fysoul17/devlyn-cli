 });
+
+test('schedule uses global priority and earliest-fit placement', () => {
+  const result = runSchedule({
+    resources: [
+      {
+        id: 'room-a',
+        windows: [{ start: '09:00', end: '12:00' }],
+        blocked: [{ start: '09:30', end: '10:00' }],
+      },
+      {
+        id: 'room-b',
+        windows: [{ start: '09:00', end: '10:00' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'later-priority', resource: 'room-a', start: '09:00', duration_min: 30, priority: 1, submitted_at: '09:05',
+      },
+      {
+        id: 'higher-priority', resource: 'room-a', start: '09:00', duration_min: 30, priority: 2, submitted_at: '09:10',
+      },
+      {
+        id: 'other-resource', resource: 'room-b', start: '09:15', duration_min: 20, priority: 1, submitted_at: '09:00',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'higher-priority', resource: 'room-a', start: '09:00', end: '09:30' },
+      { id: 'other-resource', resource: 'room-b', start: '09:15', end: '09:35' },
+      { id: 'later-priority', resource: 'room-a', start: '10:00', end: '10:30' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports unknown resources and unavailable requests in input order', () => {
+  const result = runSchedule({
+    resources: [
+      {
+        id: 'room-a',
+        windows: [{ start: '09:00', end: '09:30' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'missing-room', resource: 'room-b', start: '09:00', duration_min: 10, priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'takes-window', resource: 'room-a', start: '09:00', duration_min: 30, priority: 2, submitted_at: '09:00',
+      },
+      {
+        id: 'no-space-left', resource: 'room-a', start: '09:00', duration_min: 10, priority: 1, submitted_at: '09:01',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'takes-window', resource: 'room-a', start: '09:00', end: '09:30' },
+    ],
+    rejected: [
+      { id: 'missing-room', reason: 'unknown_resource' },
+      { id: 'no-space-left', reason: 'no_slot' },
+    ],
+  });
+});
