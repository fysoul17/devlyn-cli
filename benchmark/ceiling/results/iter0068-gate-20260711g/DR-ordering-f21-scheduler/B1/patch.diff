@@ -35,6 +39,266 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writeScheduleError(message) {
+  process.stderr.write(`${JSON.stringify({ error: message })}\n`);
+  process.exitCode = 2;
+}
+
+function compareStrings(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function parseTime(value, fieldName) {
+  if (typeof value !== 'string') {
+    throw new ScheduleInputError(`${fieldName} must be an HH:MM time`);
+  }
+
+  const match = /^(\d{2}):(\d{2})$/.exec(value);
+  if (!match) {
+    throw new ScheduleInputError(`${fieldName} must be an HH:MM time`);
+  }
+
+  const hours = Number(match[1]);
+  const minutes = Number(match[2]);
+  if (hours > 23 || minutes > 59) {
+    throw new ScheduleInputError(`${fieldName} must be an HH:MM time`);
+  }
+
+  return (hours * 60) + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainingMinutes = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainingMinutes).padStart(2, '0')}`;
+}
+
+function isObject(value) {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function requireId(value, fieldName) {
+  if (typeof value !== 'string' || value.length === 0) {
+    throw new ScheduleInputError(`${fieldName} must be a non-empty string`);
+  }
+  return value;
+}
+
+function normalizeIntervals(intervals, fieldName) {
+  if (!Array.isArray(intervals)) {
+    throw new ScheduleInputError(`${fieldName} must be an array`);
+  }
+
+  return intervals.map((interval, index) => {
+    if (!isObject(interval)) {
+      throw new ScheduleInputError(`${fieldName}[${index}] must be an object`);
+    }
+
+    const start = parseTime(interval.start, `${fieldName}[${index}].start`);
+    const end = parseTime(interval.end, `${fieldName}[${index}].end`);
+    if (end <= start) {
+      throw new ScheduleInputError(`${fieldName}[${index}] must have an end after its start`);
+    }
+    return { start, end };
+  });
+}
+
+function normalizeScheduleInput(input) {
+  if (!isObject(input) || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    throw new ScheduleInputError('input must be an object with resources and requests arrays');
+  }
+
+  const resources = new Map();
+  input.resources.forEach((resource, index) => {
+    if (!isObject(resource)) {
+      throw new ScheduleInputError(`resources[${index}] must be an object`);
+    }
+
+    const id = requireId(resource.id, `resources[${index}].id`);
+    if (resources.has(id)) {
+      throw new ScheduleInputError(`duplicate resource id: ${id}`);
+    }
+
+    resources.set(id, {
+      id,
+      windows: normalizeIntervals(resource.windows, `resources[${index}].windows`),
+      blocked: normalizeIntervals(resource.blocked, `resources[${index}].blocked`),
+      accepted: [],
+    });
+  });
+
+  const requestIds = new Set();
+  const requests = input.requests.map((request, index) => {
+    if (!isObject(request)) {
+      throw new ScheduleInputError(`requests[${index}] must be an object`);
+    }
+
+    const id = requireId(request.id, `requests[${index}].id`);
+    if (requestIds.has(id)) {
+      throw new ScheduleInputError(`duplicate request id: ${id}`);
+    }
+    requestIds.add(id);
+
+    const resource = requireId(request.resource, `requests[${index}].resource`);
+    const start = parseTime(request.start, `requests[${index}].start`);
+    if (!Number.isInteger(request.duration_min) || request.duration_min <= 0) {
+      throw new ScheduleInputError(`requests[${index}].duration_min must be a positive integer`);
+    }
+    if (typeof request.priority !== 'number' || !Number.isFinite(request.priority)) {
+      throw new ScheduleInputError(`requests[${index}].priority must be a finite number`);
+    }
+    if (typeof request.submitted_at !== 'string') {
+      throw new ScheduleInputError(`requests[${index}].submitted_at must be a string`);
+    }
+
+    return {
+      id,
+      resource,
+      start,
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt: request.submitted_at,
+      inputIndex: index,
+    };
+  });
+
+  return { resources, requests };
+}
+
+function findEarliestPlacement(resource, request) {
+  let earliest = null;
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(window.start, request.start);
+    const unavailable = resource.blocked.concat(resource.accepted)
+      .filter((interval) => interval.end > candidate && interval.start < window.end)
+      .sort((left, right) => (left.start - right.start) || (left.end - right.end));
+
+    for (const interval of unavailable) {
+      if (candidate + request.duration <= interval.start) {
+        break;
+      }
+      if (candidate < interval.end) {
+        candidate = interval.end;
+      }
+    }
+
+    if (candidate + request.duration <= window.end
+      && (earliest === null || candidate < earliest)) {
+      earliest = candidate;
+    }
+  }
+
+  return earliest;
+}
+
+function buildSchedule(input) {
+  const { resources, requests } = normalizeScheduleInput(input);
+  const scheduled = [];
+  const rejections = new Map();
+  const processingOrder = [...requests].sort((left, right) => (
+    (right.priority - left.priority)
+    || compareStrings(left.submittedAt, right.submittedAt)
+    || compareStrings(left.id, right.id)
+  ));
+
+  for (const request of processingOrder) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejections.set(request.inputIndex, { id: request.id, reason: 'unknown_resource' });
+      continue;
+    }
+
+    const start = findEarliestPlacement(resource, request);
+    if (start === null) {
+      rejections.set(request.inputIndex, { id: request.id, reason: 'no_slot' });
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.accepted.push({ start, end });
+    scheduled.push({
+      id: request.id,
+      resource: request.resource,
+      start,
+      end,
+    });
+  }
+
+  scheduled.sort((left, right) => (
+    (left.start - right.start)
+    || compareStrings(left.resource, right.resource)
+    || compareStrings(left.id, right.id)
+  ));
+
+  return {
+    scheduled: scheduled.map((appointment) => ({
+      id: appointment.id,
+      resource: appointment.resource,
+      start: formatTime(appointment.start),
+      end: formatTime(appointment.end),
+    })),
+    rejected: requests
+      .filter((request) => rejections.has(request.inputIndex))
+      .map((request) => rejections.get(request.inputIndex)),
+  };
+}
+
+function parseScheduleInputPath(argv) {
+  let inputPath;
+
+  for (let index = 0; index < argv.length; index += 1) {
+    if (argv[index] !== '--input' || inputPath !== undefined || index + 1 >= argv.length) {
+      throw new ScheduleInputError('schedule requires exactly one --input path');
+    }
+    inputPath = argv[index + 1];
+    index += 1;
+  }
+
+  if (typeof inputPath !== 'string' || inputPath.length === 0) {
+    throw new ScheduleInputError('schedule requires exactly one --input path');
+  }
+
+  return inputPath;
+}
+
+function runSchedule(argv) {
+  let inputPath;
+  let rawInput;
+  let input;
+
+  try {
+    inputPath = parseScheduleInputPath(argv);
+    rawInput = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    if (error instanceof ScheduleInputError) {
+      writeScheduleError(error.message);
+    } else {
+      writeScheduleError('unable to read input file');
+    }
+    return;
+  }
+
+  try {
+    input = JSON.parse(rawInput);
+  } catch (error) {
+    writeScheduleError('input file must contain valid JSON');
+    return;
+  }
+
+  try {
+    process.stdout.write(`${JSON.stringify(buildSchedule(input))}\n`);
+  } catch (error) {
+    if (error instanceof ScheduleInputError) {
+      writeScheduleError(error.message);
+      return;
+    }
+    throw error;
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +317,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'schedule': {
+      runSchedule(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
