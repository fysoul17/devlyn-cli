+
+test('schedule assigns requests by priority and earliest available fit', (t) => {
+  const inputPath = writeScheduleInput(t, {
+    resources: [
+      {
+        id: 'a',
+        windows: [{ start: '09:00', end: '12:00' }],
+        blocked: [{ start: '10:00', end: '10:30' }],
+      },
+      {
+        id: 'b',
+        windows: [{ start: '09:00', end: '09:20' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'later-priority',
+        resource: 'a',
+        start: '09:00',
+        duration_min: 60,
+        priority: 1,
+        submitted_at: '2026-01-01T09:01:00Z',
+      },
+      {
+        id: 'first-priority',
+        resource: 'a',
+        start: '09:00',
+        duration_min: 30,
+        priority: 2,
+        submitted_at: '2026-01-01T09:02:00Z',
+      },
+      {
+        id: 'other-resource',
+        resource: 'b',
+        start: '09:00',
+        duration_min: 20,
+        priority: 1,
+        submitted_at: '2026-01-01T09:00:00Z',
+      },
+    ],
+  });
+
+  const result = runWithOutput(['schedule', '--input', inputPath]);
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'first-priority', resource: 'a', start: '09:00', end: '09:30' },
+      { id: 'other-resource', resource: 'b', start: '09:00', end: '09:20' },
+      { id: 'later-priority', resource: 'a', start: '10:30', end: '11:30' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports unknown resources and unavailable requests in input order', (t) => {
+  const inputPath = writeScheduleInput(t, {
+    resources: [{
+      id: 'room-1',
+      windows: [{ start: '09:00', end: '10:00' }],
+      blocked: [{ start: '09:30', end: '10:00' }],
+    }],
+    requests: [
+      {
+        id: 'missing-resource',
+        resource: 'room-2',
+        start: '09:00',
+        duration_min: 15,
+        priority: 3,
+        submitted_at: '2026-01-01T09:00:00Z',
+      },
+      {
+        id: 'does-not-fit',
+        resource: 'room-1',
+        start: '09:00',
+        duration_min: 31,
+        priority: 2,
+        submitted_at: '2026-01-01T09:00:00Z',
+      },
+      {
+        id: 'fits',
+        resource: 'room-1',
+        start: '09:00',
+        duration_min: 30,
+        priority: 1,
+        submitted_at: '2026-01-01T09:00:00Z',
+      },
+    ],
+  });
+
+  const result = runWithOutput(['schedule', '--input', inputPath]);
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [{ id: 'fits', resource: 'room-1', start: '09:00', end: '09:30' }],
+    rejected: [
+      { id: 'missing-resource', reason: 'unknown_resource' },
+      { id: 'does-not-fit', reason: 'no_slot' },
+    ],
+  });
+});
+
+test('schedule emits a JSON error and no stdout for invalid input', (t) => {
+  const inputPath = writeScheduleInput(t, {
+    resources: [],
+    requests: [
+      {
+        id: 'duplicate',
+        resource: 'room-1',
+        start: '09:00',
+        duration_min: 30,
+        priority: 1,
+        submitted_at: '2026-01-01T09:00:00Z',
+      },
+      {
+        id: 'duplicate',
+        resource: 'room-1',
+        start: '09:00',
+        duration_min: 30,
+        priority: 1,
+        submitted_at: '2026-01-01T09:01:00Z',
+      },
+    ],
+  });
+
+  const result = runWithOutput(['schedule', '--input', inputPath]);
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.deepStrictEqual(JSON.parse(result.stderr), { error: 'duplicate request id: duplicate' });
+});
