+test('schedule assigns requests by priority and earliest valid placement', () => {
+  withScheduleInput({
+    resources: [{
+      id: 'desk',
+      windows: [{ start: '09:00', end: '12:00' }],
+      blocked: [{ start: '10:00', end: '10:15' }],
+    }, {
+      id: 'alpha',
+      windows: [{ start: '09:00', end: '12:00' }],
+      blocked: [],
+    }],
+    requests: [
+      {
+        id: 'low-first', resource: 'desk', start: '09:00', duration_min: 45, priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'urgent-first', resource: 'desk', start: '09:00', duration_min: 30, priority: 5, submitted_at: '09:00',
+      },
+      {
+        id: 'urgent-second', resource: 'desk', start: '09:00', duration_min: 30, priority: 5, submitted_at: '09:01',
+      },
+      {
+        id: 'after-block', resource: 'desk', start: '09:00', duration_min: 30, priority: 2, submitted_at: '09:00',
+      },
+      {
+        id: 'alpha-request', resource: 'alpha', start: '09:00', duration_min: 30, priority: 0, submitted_at: '09:00',
+      },
+    ],
+  }, (inputPath) => {
+    const result = runDetailed(['schedule', '--input', inputPath]);
+    assert.strictEqual(result.status, 0);
+    assert.strictEqual(result.stderr, '');
+    assert.deepStrictEqual(JSON.parse(result.stdout), {
+      scheduled: [
+        { id: 'alpha-request', resource: 'alpha', start: '09:00', end: '09:30' },
+        { id: 'urgent-first', resource: 'desk', start: '09:00', end: '09:30' },
+        { id: 'urgent-second', resource: 'desk', start: '09:30', end: '10:00' },
+        { id: 'after-block', resource: 'desk', start: '10:15', end: '10:45' },
+        { id: 'low-first', resource: 'desk', start: '10:45', end: '11:30' },
+      ],
+      rejected: [],
+    });
+  });
+});
