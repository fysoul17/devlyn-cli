@@ -35,6 +37,224 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function isPlainObject(value) {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^(?:[01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    return null;
+  }
+
+  return Number(value.slice(0, 2)) * 60 + Number(value.slice(3, 5));
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function parseRange(value) {
+  if (!isPlainObject(value)) return null;
+
+  const start = parseTime(value.start);
+  const end = parseTime(value.end);
+  if (start === null || end === null || start >= end) return null;
+
+  return { start, end };
+}
+
+function compareStrings(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function validateScheduleInput(input) {
+  if (!isPlainObject(input) || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    return null;
+  }
+
+  const resources = new Map();
+  for (const resource of input.resources) {
+    if (
+      !isPlainObject(resource)
+      || typeof resource.id !== 'string'
+      || resource.id.length === 0
+      || !Array.isArray(resource.windows)
+      || !Array.isArray(resource.blocked)
+      || resources.has(resource.id)
+    ) {
+      return null;
+    }
+
+    const windows = resource.windows.map(parseRange);
+    const blocked = resource.blocked.map(parseRange);
+    if (windows.some((range) => range === null) || blocked.some((range) => range === null)) {
+      return null;
+    }
+
+    resources.set(resource.id, { windows, blocked });
+  }
+
+  const requests = [];
+  const requestIds = new Set();
+  for (let index = 0; index < input.requests.length; index += 1) {
+    const request = input.requests[index];
+    if (
+      !isPlainObject(request)
+      || typeof request.id !== 'string'
+      || request.id.length === 0
+      || typeof request.resource !== 'string'
+      || request.resource.length === 0
+      || requestIds.has(request.id)
+      || !Number.isInteger(request.duration_min)
+      || request.duration_min <= 0
+      || typeof request.priority !== 'number'
+      || !Number.isFinite(request.priority)
+    ) {
+      return null;
+    }
+
+    const start = parseTime(request.start);
+    const submittedAt = parseTime(request.submitted_at);
+    if (start === null || submittedAt === null) return null;
+
+    requestIds.add(request.id);
+    requests.push({
+      id: request.id,
+      resource: request.resource,
+      start,
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt,
+      index,
+    });
+  }
+
+  return { resources, requests };
+}
+
+function intervalsOverlap(start, end, interval) {
+  return start < interval.end && interval.start < end;
+}
+
+function findEarliestPlacement(request, resource, accepted) {
+  const constraints = resource.blocked.concat(accepted);
+  let earliest = null;
+
+  for (const window of resource.windows) {
+    let start = Math.max(request.start, window.start);
+
+    while (start + request.duration <= window.end) {
+      const end = start + request.duration;
+      const conflict = constraints.find((interval) => intervalsOverlap(start, end, interval));
+      if (!conflict) {
+        if (!earliest || start < earliest.start) {
+          earliest = { start, end };
+        }
+        break;
+      }
+
+      start = conflict.end;
+    }
+  }
+
+  return earliest;
+}
+
+function readScheduleFile(inputPath) {
+  let contents;
+  try {
+    contents = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    return { error: 'file_read_error' };
+  }
+
+  try {
+    return { input: JSON.parse(contents) };
+  } catch (error) {
+    return { error: 'invalid_input' };
+  }
+}
+
+function getScheduleInputPath(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) return null;
+  return argv[1];
+}
+
+function schedule(input) {
+  const { resources, requests } = input;
+  const acceptedByResource = new Map();
+  for (const resourceId of resources.keys()) acceptedByResource.set(resourceId, []);
+
+  const scheduled = [];
+  const rejected = [];
+  const processingOrder = [...requests].sort((left, right) => (
+    right.priority - left.priority
+    || left.submittedAt - right.submittedAt
+    || compareStrings(left.id, right.id)
+  ));
+
+  for (const request of processingOrder) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', index: request.index });
+      continue;
+    }
+
+    const placement = findEarliestPlacement(request, resource, acceptedByResource.get(request.resource));
+    if (!placement) {
+      rejected.push({ id: request.id, reason: 'no_slot', index: request.index });
+      continue;
+    }
+
+    acceptedByResource.get(request.resource).push(placement);
+    scheduled.push({
+      id: request.id,
+      resource: request.resource,
+      start: placement.start,
+      end: placement.end,
+    });
+  }
+
+  scheduled.sort((left, right) => (
+    left.start - right.start
+    || compareStrings(left.resource, right.resource)
+    || compareStrings(left.id, right.id)
+  ));
+  rejected.sort((left, right) => left.index - right.index);
+
+  return {
+    scheduled: scheduled.map((entry) => ({
+      id: entry.id,
+      resource: entry.resource,
+      start: formatTime(entry.start),
+      end: formatTime(entry.end),
+    })),
+    rejected: rejected.map((entry) => ({ id: entry.id, reason: entry.reason })),
+  };
+}
+
+function runSchedule(argv) {
+  const inputPath = getScheduleInputPath(argv);
+  if (!inputPath) return { error: 'invalid_input' };
+
+  const loaded = readScheduleFile(inputPath);
+  if (loaded.error) return loaded;
+
+  const input = validateScheduleInput(loaded.input);
+  if (!input) return { error: 'invalid_input' };
+
+  return { result: schedule(input) };
+}
+
+function writeScheduleError(error) {
+  process.stderr.write(`${JSON.stringify({ error })}\n`);
+  process.exitCode = 2;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +273,15 @@ function main(argv) {
