diff --git a/bin/cli.js b/bin/cli.js
index 78fdd98..bc1a179 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -10,14 +10,28 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  payout --input PATH        Calculate merchant payouts from ledger events
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli payout --input ledger-events.json
 `;
 
+class PayoutError extends Error {
+  constructor(error, id) {
+    super(error);
+    this.error = error;
+    this.id = id;
+  }
+
+  toJSON() {
+    return this.id === undefined ? { error: this.error } : { error: this.error, id: this.id };
+  }
+}
+
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
@@ -35,6 +49,176 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function stableStringify(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(stableStringify).join(',')}]`;
+  }
+  if (value && typeof value === 'object') {
+    return `{${Object.keys(value).sort().map((key) => `${JSON.stringify(key)}:${stableStringify(value[key])}`).join(',')}}`;
+  }
+  return JSON.stringify(value);
+}
+
+function readJsonFile(filePath, unreadableError, invalidError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch (error) {
+    throw new PayoutError(unreadableError);
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch (error) {
+    throw new PayoutError(invalidError);
+  }
+}
+
+function readPayoutRules() {
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  const rules = readJsonFile(rulesPath, 'unreadable_rules', 'invalid_rules');
+  const percentFields = ['processing_fee_percent', 'reserve_percent'];
+  const centsFields = ['fixed_fee_cents', 'dispute_fee_cents', 'minimum_payout_cents'];
+
+  if (!rules || typeof rules !== 'object' || Array.isArray(rules)
+    || percentFields.some((field) => !Number.isFinite(rules[field]) || rules[field] < 0)
+    || centsFields.some((field) => !Number.isInteger(rules[field]) || rules[field] < 0)) {
+    throw new PayoutError('invalid_rules');
+  }
+
+  return rules;
+}
+
+function parsePayoutInputPath(argv) {
+  const inputIndex = argv.indexOf('--input');
+  const inputPath = argv[inputIndex + 1];
+  if (inputIndex === -1 || !inputPath || inputPath.startsWith('-')) {
+    throw new PayoutError('missing_input');
+  }
+  if (argv.length !== 2 || inputIndex !== 0) {
+    throw new PayoutError('invalid_arguments');
+  }
+  return inputPath;
+}
+
+function uniqueEvents(events) {
+  if (!Array.isArray(events)) {
+    throw new PayoutError('missing_events');
+  }
+
+  const eventsById = new Map();
+  const result = [];
+  for (const event of events) {
+    const id = event && typeof event === 'object' && !Array.isArray(event) ? event.id : undefined;
+    if (typeof id !== 'string' || id.length === 0) {
+      throw new PayoutError('invalid_event');
+    }
+
+    const serialized = stableStringify(event);
+    if (eventsById.has(id)) {
+      if (eventsById.get(id) !== serialized) {
+        throw new PayoutError('conflicting_duplicate', id);
+      }
+      continue;
+    }
+
+    eventsById.set(id, serialized);
+    result.push(event);
+  }
+  return result;
+}
+
+function validateEvent(event) {
+  if (!event || typeof event !== 'object' || Array.isArray(event)
+    || typeof event.id !== 'string' || event.id.length === 0
+    || typeof event.merchant_id !== 'string' || event.merchant_id.length === 0
+    || !['charge', 'refund', 'dispute'].includes(event.type)
+    || !Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
+    throw new PayoutError('invalid_event');
+  }
+}
+
+function newMerchant(merchantId) {
+  return {
+    merchant_id: merchantId,
+    gross_charge_cents: 0,
+    refund_cents: 0,
+    dispute_cents: 0,
+    processing_fee_cents: 0,
+    dispute_fee_cents: 0,
+    reserve_cents: 0,
+    payout_cents: 0,
+  };
+}
+
+function calculatePayout(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)) {
+    throw new PayoutError('missing_events');
+  }
+
+  const rules = readPayoutRules();
+  const events = uniqueEvents(input.events);
+  const merchantsById = new Map();
+
+  for (const event of events) {
+    validateEvent(event);
+    let merchant = merchantsById.get(event.merchant_id);
+    if (!merchant) {
+      merchant = newMerchant(event.merchant_id);
+      merchantsById.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        (event.amount_cents * rules.processing_fee_percent) / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchants = Array.from(merchantsById.values());
+  for (const merchant of merchants) {
+    const netBeforeReserve = merchant.gross_charge_cents
+      - merchant.refund_cents
+      - merchant.dispute_cents
+      - merchant.processing_fee_cents
+      - merchant.dispute_fee_cents;
+    merchant.reserve_cents = netBeforeReserve > 0
+      ? Math.round((netBeforeReserve * rules.reserve_percent) / 100)
+      : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  return {
+    total_payout_cents: merchants.reduce((total, merchant) => total + merchant.payout_cents, 0),
+    total_processing_fee_cents: merchants.reduce((total, merchant) => total + merchant.processing_fee_cents, 0),
+    total_dispute_fee_cents: merchants.reduce((total, merchant) => total + merchant.dispute_fee_cents, 0),
+    total_reserve_cents: merchants.reduce((total, merchant) => total + merchant.reserve_cents, 0),
+    merchants,
+  };
+}
+
+function runPayout(argv) {
+  try {
+    const inputPath = parsePayoutInputPath(argv);
+    const input = readJsonFile(inputPath, 'unreadable_input', 'invalid_json');
+    process.stdout.write(`${JSON.stringify(calculatePayout(input))}\n`);
+  } catch (error) {
+    const payoutError = error instanceof PayoutError ? error : new PayoutError('payout_error');
+    process.stderr.write(`${JSON.stringify(payoutError.toJSON())}\n`);
+    process.exitCode = 2;
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +237,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'payout': {
+      runPayout(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
