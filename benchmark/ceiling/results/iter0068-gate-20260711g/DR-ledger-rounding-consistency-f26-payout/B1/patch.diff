 function readPackageVersion() {
@@ -35,6 +37,193 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writeJsonError(error) {
+  process.stderr.write(JSON.stringify(error));
+  return 2;
+}
+
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const value = idx === -1 ? undefined : argv[idx + 1];
+
+  if (!value || value.startsWith('-')) {
+    return undefined;
+  }
+
+  return value;
+}
+
+function stableJson(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(stableJson).join(',')}]`;
+  }
+
+  if (value && typeof value === 'object') {
+    return `{${Object.keys(value)
+      .sort()
+      .map((key) => `${JSON.stringify(key)}:${stableJson(value[key])}`)
+      .join(',')}}`;
+  }
+
+  return JSON.stringify(value);
+}
+
+function isValidEvent(event) {
+  return (
+    event &&
+    typeof event === 'object' &&
+    !Array.isArray(event) &&
+    typeof event.id === 'string' &&
+    typeof event.merchant_id === 'string' &&
+    ['charge', 'refund', 'dispute'].includes(event.type) &&
+    Number.isInteger(event.amount_cents) &&
+    event.amount_cents > 0
+  );
+}
+
+function readPayoutRules() {
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  const rules = JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
+  if (
+    !Number.isFinite(rules.processing_fee_percent) ||
+    !Number.isFinite(rules.reserve_percent) ||
+    !Number.isInteger(rules.fixed_fee_cents) ||
+    !Number.isInteger(rules.dispute_fee_cents) ||
+    !Number.isInteger(rules.minimum_payout_cents)
+  ) {
+    throw new Error('Invalid payout rules');
+  }
+
+  return rules;
+}
+
+function calculatePayout(input, rules) {
+  if (!input || typeof input !== 'object' || !Array.isArray(input.events)) {
+    throw new Error('Invalid input');
+  }
+
+  const eventById = new Map();
+  const merchants = new Map();
+
+  for (const event of input.events) {
+    if (!isValidEvent(event)) {
+      throw new Error('Invalid event');
+    }
+
+    const eventJson = stableJson(event);
+    if (eventById.has(event.id)) {
+      if (eventById.get(event.id) !== eventJson) {
+        const error = new Error('Conflicting duplicate');
+        error.code = 'conflicting_duplicate';
+        error.id = event.id;
+        throw error;
+      }
+      continue;
+    }
+    eventById.set(event.id, eventJson);
+
+    if (!merchants.has(event.merchant_id)) {
+      merchants.set(event.merchant_id, {
+        merchant_id: event.merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+        reserve_cents: 0,
+        payout_cents: 0,
+      });
+    }
+
+    const merchant = merchants.get(event.merchant_id);
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents +=
+        Math.round((event.amount_cents * rules.processing_fee_percent) / 100) +
+        rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  for (const merchant of merchants.values()) {
+    const netBeforeReserve =
+      merchant.gross_charge_cents -
+      merchant.refund_cents -
+      merchant.dispute_cents -
+      merchant.processing_fee_cents -
+      merchant.dispute_fee_cents;
+    merchant.reserve_cents =
+      netBeforeReserve > 0
+        ? Math.round((netBeforeReserve * rules.reserve_percent) / 100)
+        : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (
+      merchant.payout_cents > 0 &&
+      merchant.payout_cents < rules.minimum_payout_cents
+    ) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  const merchantRows = [...merchants.values()];
+  return {
+    total_payout_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.payout_cents,
+      0,
+    ),
+    total_processing_fee_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.processing_fee_cents,
+      0,
+    ),
+    total_dispute_fee_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.dispute_fee_cents,
+      0,
+    ),
+    total_reserve_cents: merchantRows.reduce(
+      (total, merchant) => total + merchant.reserve_cents,
+      0,
+    ),
+    merchants: merchantRows,
+  };
+}
+
+function runPayout(argv) {
+  const inputPath = parseInputFlag(argv);
+  if (!inputPath) {
+    return writeJsonError({ error: 'invalid_input' });
+  }
+
+  let input;
+  try {
+    input = JSON.parse(fs.readFileSync(inputPath, 'utf8'));
+  } catch (error) {
+    if (error instanceof SyntaxError) {
+      return writeJsonError({ error: 'invalid_json' });
+    }
+    return writeJsonError({ error: 'input_read_error' });
+  }
+
+  try {
+    const result = calculatePayout(input, readPayoutRules());
+    process.stdout.write(JSON.stringify(result));
+    return 0;
+  } catch (error) {
+    if (error.code === 'conflicting_duplicate') {
+      return writeJsonError({ error: 'conflicting_duplicate', id: error.id });
+    }
+    if (error.message === 'Invalid payout rules') {
+      return writeJsonError({ error: 'invalid_payout_rules' });
+    }
+    return writeJsonError({ error: 'invalid_input' });
+  }
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +242,9 @@ function main(argv) {
       console.log(readPackageVersion());
