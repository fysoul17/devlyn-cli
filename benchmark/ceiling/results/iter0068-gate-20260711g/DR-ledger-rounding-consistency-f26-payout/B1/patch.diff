+
+test('payout calculates fees, reserves, thresholds, and idempotent events', () => {
+  const input = {
+    events: [
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 20000 },
+      { id: 'charge-1', merchant_id: 'merchant-a', type: 'charge', amount_cents: 20000 },
+      { id: 'refund-1', merchant_id: 'merchant-a', type: 'refund', amount_cents: 2000 },
+      { id: 'dispute-1', merchant_id: 'merchant-a', type: 'dispute', amount_cents: 4000 },
+      { id: 'charge-2', merchant_id: 'merchant-b', type: 'charge', amount_cents: 1000 },
+    ],
+  };
+
+  withInputFile(JSON.stringify(input), (inputPath) => {
+    const result = runProcess(['payout', '--input', inputPath]);
+
+    assert.strictEqual(result.status, 0);
+    assert.strictEqual(result.stderr, '');
+    assert.deepStrictEqual(JSON.parse(result.stdout), {
+      total_payout_cents: 10701,
+      total_processing_fee_cents: 669,
+      total_dispute_fee_cents: 1500,
+      total_reserve_cents: 2130,
+      merchants: [
+        {
+          merchant_id: 'merchant-a',
+          gross_charge_cents: 20000,
+          refund_cents: 2000,
+          dispute_cents: 4000,
+          processing_fee_cents: 610,
+          dispute_fee_cents: 1500,
+          reserve_cents: 1189,
+          payout_cents: 10701,
+        },
+        {
+          merchant_id: 'merchant-b',
