+function runProcess(args) {
+  return spawnSync(process.execPath, [CLI, ...args], { encoding: 'utf8' });
+}
+
+function withInputFile(contents, callback) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  const inputPath = path.join(directory, 'events.json');
+  fs.writeFileSync(inputPath, contents);
+
+  try {
+    return callback(inputPath);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
