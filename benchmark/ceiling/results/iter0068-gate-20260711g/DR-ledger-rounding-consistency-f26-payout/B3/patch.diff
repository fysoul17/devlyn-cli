 function readPackageVersion() {
@@ -35,6 +37,186 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writeJson(stream, value) {
+  stream.write(JSON.stringify(value));
+}
+
+function payoutError(error, id) {
+  const value = id === undefined ? { error } : { error, id };
+  writeJson(process.stderr, value);
+  return 2;
+}
+
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  if (idx === -1 || idx !== argv.length - 2 || !argv[idx + 1]) {
+    return null;
+  }
+  return argv[idx + 1];
+}
+
+function readJsonFile(filePath, unreadableError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch {
+    return { error: unreadableError };
+  }
+
+  try {
+    return { value: JSON.parse(raw) };
+  } catch {
+    return { error: 'invalid_json' };
+  }
+}
+
+function stableJson(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(stableJson).join(',')}]`;
+  }
+  if (value !== null && typeof value === 'object') {
+    return `{${Object.keys(value).sort().map((key) => (
+      `${JSON.stringify(key)}:${stableJson(value[key])}`
+    )).join(',')}}`;
+  }
+  return JSON.stringify(value);
+}
+
+function isValidEvent(event) {
+  return event !== null
+    && typeof event === 'object'
+    && !Array.isArray(event)
+    && typeof event.id === 'string'
+    && typeof event.merchant_id === 'string'
+    && ['charge', 'refund', 'dispute'].includes(event.type)
+    && Number.isSafeInteger(event.amount_cents)
+    && event.amount_cents > 0;
+}
+
+function isValidRules(rules) {
+  return rules !== null
+    && typeof rules === 'object'
+    && Number.isFinite(rules.processing_fee_percent)
+    && Number.isSafeInteger(rules.fixed_fee_cents)
+    && Number.isSafeInteger(rules.dispute_fee_cents)
+    && Number.isFinite(rules.reserve_percent)
+    && Number.isSafeInteger(rules.minimum_payout_cents);
+}
+
+function calculatePayout(events, rules) {
+  const seenEvents = new Map();
+  const uniqueEvents = [];
+
+  for (const event of events) {
+    if (!isValidEvent(event)) {
+      return { error: 'invalid_event' };
+    }
+
+    const serialized = stableJson(event);
+    const previous = seenEvents.get(event.id);
+    if (previous !== undefined) {
+      if (previous !== serialized) {
+        return { error: 'conflicting_duplicate', id: event.id };
+      }
+      continue;
+    }
+
+    seenEvents.set(event.id, serialized);
+    uniqueEvents.push(event);
+  }
+
+  const merchants = new Map();
+  for (const event of uniqueEvents) {
+    let merchant = merchants.get(event.merchant_id);
+    if (!merchant) {
+      merchant = {
+        merchant_id: event.merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+        reserve_cents: 0,
+        payout_cents: 0,
+      };
+      merchants.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        event.amount_cents * rules.processing_fee_percent / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  let totalPayout = 0;
+  let totalProcessingFee = 0;
+  let totalDisputeFee = 0;
+  let totalReserve = 0;
+  const merchantRows = [];
+
+  for (const merchant of merchants.values()) {
+    const netBeforeReserve = merchant.gross_charge_cents
+      - merchant.refund_cents
+      - merchant.dispute_cents
+      - merchant.processing_fee_cents
+      - merchant.dispute_fee_cents;
+    merchant.reserve_cents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+
+    totalPayout += merchant.payout_cents;
+    totalProcessingFee += merchant.processing_fee_cents;
+    totalDisputeFee += merchant.dispute_fee_cents;
+    totalReserve += merchant.reserve_cents;
+    merchantRows.push(merchant);
+  }
+
+  return {
+    value: {
+      total_payout_cents: totalPayout,
+      total_processing_fee_cents: totalProcessingFee,
+      total_dispute_fee_cents: totalDisputeFee,
+      total_reserve_cents: totalReserve,
+      merchants: merchantRows,
+    },
+  };
+}
+
+function runPayout(argv) {
+  const inputPath = parseInputFlag(argv);
+  if (!inputPath) return payoutError('input_required');
+
+  const inputResult = readJsonFile(inputPath, 'unreadable_input');
+  if (inputResult.error) return payoutError(inputResult.error);
+  if (!inputResult.value || !Array.isArray(inputResult.value.events)) {
+    return payoutError('invalid_events');
+  }
+
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  const rulesResult = readJsonFile(rulesPath, 'unreadable_payout_rules');
+  if (rulesResult.error) return payoutError(rulesResult.error);
+  if (!isValidRules(rulesResult.value)) return payoutError('invalid_payout_rules');
+
+  const result = calculatePayout(inputResult.value.events, rulesResult.value);
+  if (result.error) return payoutError(result.error, result.id);
+
+  writeJson(process.stdout, result.value);
+  return 0;
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
