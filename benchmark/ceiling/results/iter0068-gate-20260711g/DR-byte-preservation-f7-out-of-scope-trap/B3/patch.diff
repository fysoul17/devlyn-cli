diff --git a/bin/cli.js b/bin/cli.js
index 07ac960..fd78940 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -9,13 +9,13 @@ const USAGE = `Usage: bench-cli <command> [options]
 
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
-  version                    Print the CLI version from package.json
+  version [--format json]    Print the CLI version from package.json
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
-  bench-cli version
