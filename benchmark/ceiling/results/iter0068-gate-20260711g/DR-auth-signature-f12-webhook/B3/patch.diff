+function hasValidSignature(req) {
+  const signature = req.get('X-Signature');
+  if (typeof signature !== 'string' || !/^[a-f0-9]{64}$/.test(signature)) {
+    return false;
+  }
+
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(req.rawBody || Buffer.alloc(0))
+    .digest();
+
+  return crypto.timingSafeEqual(Buffer.from(signature, 'hex'), expectedSignature);
+}
+
+function isValidWebhookBody(body) {
+  return (
+    body !== null &&
+    typeof body === 'object' &&
+    typeof body.id === 'string' &&
+    body.id.length > 0 &&
+    typeof body.type === 'string' &&
+    body.type.length > 0 &&
+    typeof body.timestamp === 'number' &&
+    body.data !== null &&
+    typeof body.data === 'object' &&
+    !Array.isArray(body.data)
+  );
+}
+
+app.post('/webhook', (req, res) => {
+  if (!hasValidSignature(req)) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  if (req.body && typeof req.body.id === 'string' && acceptedEventIds.has(req.body.id)) {
+    res.status(409).json({ error: 'duplicate_event', id: req.body.id });
+    return;
+  }
+
+  if (!isValidWebhookBody(req.body)) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedEventIds.add(req.body.id);
+  res.json({ accepted: true, id: req.body.id });
+});
+
