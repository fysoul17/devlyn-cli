+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  const event = {
+    id: 'evt-happy-path',
+    type: 'order.created',
+    timestamp: 1720000000,
+    data: { orderId: 'ord-123' },
+  };
+  const body = JSON.stringify(event);
+
+  try {
+    const response = await post(server, '/webhook', body, {
+      'X-Signature': signWebhookBody(body),
+    });
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  const event = {
+    id: 'evt-replay',
+    type: 'order.updated',
+    timestamp: 1720000001,
+    data: { orderId: 'ord-456' },
+  };
+  const body = JSON.stringify(event);
+  const headers = { 'X-Signature': signWebhookBody(body) };
+
+  try {
+    const firstResponse = await post(server, '/webhook', body, headers);
+    assert.strictEqual(firstResponse.status, 200);
+
+    const replayResponse = await post(server, '/webhook', body, headers);
+    assert.strictEqual(replayResponse.status, 409);
+    assert.deepStrictEqual(replayResponse.body, { error: 'duplicate_event', id: event.id });
+  } finally {
+    server.close();
+  }
+});
