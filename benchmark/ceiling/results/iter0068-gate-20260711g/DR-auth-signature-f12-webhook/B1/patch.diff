+function hasValidWebhookSignature(rawBody, signature) {
+  if (typeof signature !== 'string' || !/^[a-f0-9]{64}$/.test(signature)) {
+    return false;
+  }
+
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(rawBody)
+    .digest();
+  const receivedSignature = Buffer.from(signature, 'hex');
+
+  return (
+    receivedSignature.length === expectedSignature.length &&
+    crypto.timingSafeEqual(receivedSignature, expectedSignature)
+  );
+}
+
+function isValidWebhookEvent(event) {
+  return (
+    event !== null &&
+    typeof event === 'object' &&
+    !Array.isArray(event) &&
+    typeof event.id === 'string' &&
+    event.id.length > 0 &&
+    typeof event.type === 'string' &&
+    event.type.length > 0 &&
+    typeof event.timestamp === 'number' &&
+    event.data !== null &&
+    typeof event.data === 'object' &&
+    !Array.isArray(event.data)
+  );
+}
+
+app.post('/webhook', express.raw({ type: '*/*' }), (req, res) => {
+  const rawBody = req.body;
+
+  if (!hasValidWebhookSignature(rawBody, req.get('X-Signature'))) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  let event;
+  try {
+    event = JSON.parse(rawBody.toString('utf8'));
+  } catch (_error) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  if (!isValidWebhookEvent(event)) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  if (acceptedWebhookEventIds.has(event.id)) {
+    res.status(409).json({ error: 'duplicate_event', id: event.id });
+    return;
+  }
+
+  acceptedWebhookEventIds.add(event.id);
+  res.json({ accepted: true, id: event.id });
+});
+
+app.use(express.json());
