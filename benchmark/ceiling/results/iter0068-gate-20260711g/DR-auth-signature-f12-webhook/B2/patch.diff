 // Tiny Express server used by backend-contract fixtures. Intentionally small.
+const crypto = require('crypto');
 const express = require('express');
+const fs = require('fs');
+const path = require('path');
 
 const app = express();
+const webhookSecret = fs
+  .readFileSync(path.join(__dirname, '..', 'data', 'webhook-secret.txt'), 'utf8')
+  .trim();
+const acceptedWebhookIds = new Set();
+
+function hasValidWebhookSignature(body, signature) {
+  if (typeof signature !== 'string') {
+    return false;
+  }
+
+  const expectedSignature = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(body)
+    .digest('hex');
+  const actualSignature = Buffer.from(signature, 'utf8');
+  const expectedSignatureBuffer = Buffer.from(expectedSignature, 'utf8');
+
+  return (
+    actualSignature.length === expectedSignatureBuffer.length &&
+    crypto.timingSafeEqual(actualSignature, expectedSignatureBuffer)
+  );
+}
+
+function isNonEmptyString(value) {
+  return typeof value === 'string' && value.length > 0;
+}
+
+function isObject(value) {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+app.post('/webhook', express.raw({ type: '*/*' }), (req, res) => {
+  const body = req.body;
+  if (!hasValidWebhookSignature(body, req.get('X-Signature'))) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  let event;
+  try {
+    event = JSON.parse(body.toString('utf8'));
+  } catch {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  if (isNonEmptyString(event?.id) && acceptedWebhookIds.has(event.id)) {
+    res.status(409).json({ error: 'duplicate_event', id: event.id });
+    return;
+  }
+
+  if (
+    !isObject(event) ||
+    !isNonEmptyString(event.id) ||
+    !isNonEmptyString(event.type) ||
+    typeof event.timestamp !== 'number' ||
+    !Number.isFinite(event.timestamp) ||
+    !isObject(event.data)
+  ) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedWebhookIds.add(event.id);
+  res.json({ accepted: true, id: event.id });
+});
+
 app.use(express.json());
 
