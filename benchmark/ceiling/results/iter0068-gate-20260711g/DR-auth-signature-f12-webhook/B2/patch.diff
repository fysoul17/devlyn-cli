+
+test('POST /webhook accepts a correctly signed event', async () => {
+  const server = await startServer();
+  const event = {
+    id: 'evt-happy-path',
+    type: 'invoice.paid',
+    timestamp: 1720000000,
+    data: { invoiceId: 'inv_123' },
+  };
+  const body = JSON.stringify(event);
+
+  try {
+    const response = await postWebhook(server, body);
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  const event = {
+    id: 'evt-replay',
+    type: 'invoice.paid',
+    timestamp: 1720000001,
+    data: { invoiceId: 'inv_456' },
+  };
+  const body = JSON.stringify(event);
+
+  try {
+    const firstResponse = await postWebhook(server, body);
+    const secondResponse = await postWebhook(server, body);
+
+    assert.strictEqual(firstResponse.status, 200);
+    assert.strictEqual(secondResponse.status, 409);
+    assert.deepStrictEqual(secondResponse.body, {
+      error: 'duplicate_event',
+      id: event.id,
+    });
+  } finally {
+    server.close();
+  }
+});
+
