@@ -573,6 +579,25 @@ class Job:
         self.latest = latest
         return self
 
+    def max_runs(self, n: int):
+        """
+        Limit the number of times the job may run.
+
+        Once the job has run ``n`` times, it is canceled. Calling this method
+        more than once replaces the previous limit.
+
+        :param n: Maximum number of times the job may run
+        :return: The invoked job instance
+        """
+        if not isinstance(n, int) or isinstance(n, bool) or n < 1:
+            raise ValueError(
+                "max_runs() requires an integer greater than or equal to 1"
+            )
+        self._max_runs = n
+        if self._run_count >= n and self.scheduler is not None:
+            self.scheduler.cancel_job(self)
+        return self
+
