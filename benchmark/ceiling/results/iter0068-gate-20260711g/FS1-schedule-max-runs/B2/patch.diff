+    def test_max_runs_removes_job_after_final_pending_run(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 10, 0, 0):
+            job = every().max_runs(2).seconds.do(mock_job)
+
+            with mock_datetime(2020, 1, 1, 10, 0, 1):
+                schedule.run_pending()
+                assert mock_job.call_count == 1
+                assert job in schedule.jobs
+
+            with mock_datetime(2020, 1, 1, 10, 0, 2):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+                assert job not in schedule.jobs
+                assert schedule.default_scheduler.next_run is None
+                assert schedule.idle_seconds() is None
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+
+    def test_max_runs_applies_to_run_all_and_is_per_job(self):
+        first_job = make_mock_job("first_job")
+        second_job = make_mock_job("second_job")
+        first = every().seconds.max_runs(1).do(first_job)
+        second = every().max_runs(1).max_runs(2).seconds.do(second_job)
+
+        schedule.run_all()
+        first_job.assert_called_once_with()
+        second_job.assert_called_once_with()
