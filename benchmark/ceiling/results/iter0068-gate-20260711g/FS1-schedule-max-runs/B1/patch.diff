+    def test_max_runs_is_chainable_and_validated(self):
+        mock_job = make_mock_job()
+
+        job = every(5).seconds.max_runs(3).do(mock_job)
+        assert job.max_runs(2) is job
+        assert every().max_runs(3).seconds.do(mock_job) in schedule.jobs
+
+        for value in (0, -1, 1.0, 1.5, "1", None, True, False):
+            with self.assertRaises(ValueError):
+                every().max_runs(value)
+
+    def test_max_runs_last_call_wins(self):
+        mock_job = make_mock_job()
+        every().second.max_runs(1).max_runs(2).do(mock_job)
+
+        schedule.run_all()
+        assert mock_job.call_count == 1
+        assert len(schedule.jobs) == 1
+
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert len(schedule.jobs) == 0
+
+        schedule.run_all()
+        assert mock_job.call_count == 2
+
+    def test_max_runs_removes_job_after_run_pending(self):
+        mock_job = make_mock_job()
+
+        with mock_datetime(2020, 1, 1, 10, 0, 0):
+            every().second.max_runs(2).do(mock_job)
+
+        with mock_datetime(2020, 1, 1, 10, 0, 1):
+            schedule.run_pending()
+            assert mock_job.call_count == 1
+            assert len(schedule.jobs) == 1
+
+        with mock_datetime(2020, 1, 1, 10, 0, 2):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+            assert schedule.next_run() is None
+            assert schedule.idle_seconds() is None
+
+        with mock_datetime(2020, 1, 1, 10, 0, 3):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+
+    def test_max_runs_applies_per_job_to_run_all(self):
+        first_job = make_mock_job("first")
+        second_job = make_mock_job("second")
+        every().second.max_runs(1).do(first_job)
+        every().second.max_runs(2).do(second_job)
+
+        schedule.run_all()
+        assert first_job.call_count == 1
+        assert second_job.call_count == 1
+        assert len(schedule.jobs) == 1
+
+        schedule.run_all()
+        assert first_job.call_count == 1
+        assert second_job.call_count == 2
+        assert len(schedule.jobs) == 0
+
+        schedule.run_all()
+        assert first_job.call_count == 1
+        assert second_job.call_count == 2
+
+    def test_max_runs_and_until_cancel_when_the_first_limit_is_reached(self):
