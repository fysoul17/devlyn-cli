+    def max_runs(self, n: int):
+        """
+        Limit the number of times the job can run.
+
+        After the job has run ``n`` times, it is canceled. Calling this method
+        more than once replaces the previously configured limit.
+
+        :param n: The maximum number of times the job may run
+        :return: The invoked job instance
+        :raises ValueError: If ``n`` is not an integer greater than or equal to 1
+        """
+        if not isinstance(n, int) or isinstance(n, bool) or n < 1:
+            raise ValueError(
+                "max_runs() requires an integer greater than or equal to 1"
+            )
+        self._max_runs = n
+        return self
