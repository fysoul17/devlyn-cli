+    def test_max_runs_validation_and_chaining(self):
+        for n in (0, -1, 1.0, True, False, "1", None):
+            with self.assertRaises(ValueError):
+                every().max_runs(n)
+
+        first_job = every(5).seconds.max_runs(3).do(make_mock_job())
+        second_job = every().max_runs(3).seconds.do(make_mock_job())
+        assert first_job._max_runs == 3
+        assert second_job._max_runs == 3
+
+    def test_max_runs_last_call_wins_and_run_all(self):
+        first_job_func = make_mock_job("first")
+        second_job_func = make_mock_job("second")
+        first_job = every().max_runs(3).second.max_runs(1).do(first_job_func)
+        second_job = every().max_runs(2).second.do(second_job_func)
+
+        schedule.run_all()
+        first_job_func.assert_called_once_with()
+        second_job_func.assert_called_once_with()
+        assert first_job not in schedule.jobs
+        assert second_job in schedule.jobs
+
+        schedule.run_all()
+        first_job_func.assert_called_once_with()
+        assert second_job_func.call_count == 2
+        assert schedule.jobs == []
+
+        schedule.run_all()
+        assert second_job_func.call_count == 2
+
+    def test_max_runs_run_pending_updates_scheduler_state(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            every().max_runs(2).second.do(mock_job)
+
+        with mock_datetime(2020, 1, 1, 11, 35, 11):
+            schedule.run_pending()
+            assert mock_job.call_count == 1
+            assert schedule.next_run() == datetime.datetime(2020, 1, 1, 11, 35, 12)
+            assert schedule.idle_seconds() == 1
+
+        with mock_datetime(2020, 1, 1, 11, 35, 12):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+            assert schedule.next_run() is None
+            assert schedule.idle_seconds() is None
+
+        with mock_datetime(2020, 1, 1, 11, 35, 13):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+
+    def test_max_runs_and_until_cancel_at_the_first_limit(self):
