+    def max_runs(self, n: int):
+        """
+        Limit the job to a maximum number of executions.
+
+        Once the job function has been run ``n`` times, the job is canceled.
+        Calling this method again replaces the previous limit.
+
+        :param n: The maximum number of times the job function may run.
+        :return: The invoked job instance
+        """
+        if not isinstance(n, int) or isinstance(n, bool) or n < 1:
+            raise ValueError(
+                "max_runs() requires an integer greater than or equal to 1"
+            )
+        self._max_runs = n
+        return self
