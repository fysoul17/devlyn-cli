@@ -23,6 +28,34 @@ function get(server, path) {
   });
 }

+function signatureFor(body) {
+  return crypto.createHmac('sha256', webhookSecret).update(body).digest('hex');
+}
+
+function post(server, path, body, signature = signatureFor(body)) {
+  return new Promise((resolve, reject) => {
+    const { port } = server.address();
+    const req = http.request(
+      `http://127.0.0.1:${port}${path}`,
+      {
+        method: 'POST',
+        headers: {
+          'Content-Type': 'application/json',
+          'Content-Length': Buffer.byteLength(body),
+          'X-Signature': signature,
+        },
+      },
+      (res) => {
+        let responseBody = '';
+        res.on('data', (chunk) => (responseBody += chunk));
+        res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(responseBody) }));
+      },
+    );
+    req.on('error', reject);
+    req.end(body);
+  });
+}
+
 test('GET /health returns ok', async () => {
   const server = await startServer();
   try {
@@ -56,3 +89,72 @@ test('GET /items/:id returns 404 for missing', async () => {
     server.close();
   }
 });
+
+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  try {
+    const body = JSON.stringify({
+      id: 'event-happy-path',
+      type: 'item.created',
+      timestamp: 1721644140,
+      data: { itemId: 1 },
+    });
+    const { status, body: responseBody } = await post(server, '/webhook', body);
+    assert.strictEqual(status, 200);
+    assert.deepStrictEqual(responseBody, { accepted: true, id: 'event-happy-path' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  try {
+    const firstBody = JSON.stringify({
+      id: 'event-replay',
+      type: 'item.created',
+      timestamp: 1721644141,
+      data: { itemId: 1 },
+    });
+    const replayedBody = JSON.stringify({
+      id: 'event-replay',
+      type: 'item.updated',
+      timestamp: 1721644142,
+      data: { itemId: 2 },
+    });
+    await post(server, '/webhook', firstBody);
+    const { status, body: responseBody } = await post(server, '/webhook', replayedBody);
+    assert.strictEqual(status, 409);
+    assert.deepStrictEqual(responseBody, { error: 'duplicate_event', id: 'event-replay' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a tampered body with its original signature', async () => {
+  const server = await startServer();
+  try {
+    const originalBody = JSON.stringify({
+      id: 'event-tampered',
+      type: 'item.created',
+      timestamp: 1721644143,
+      data: { itemId: 1 },
