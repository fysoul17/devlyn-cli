+      timestamp: 1721644143,
+      data: { itemId: 2 },
+    });
+    const { status, body: responseBody } = await post(
+      server,
+      '/webhook',
+      tamperedBody,
+      signatureFor(originalBody),
+    );
+    assert.strictEqual(status, 401);
