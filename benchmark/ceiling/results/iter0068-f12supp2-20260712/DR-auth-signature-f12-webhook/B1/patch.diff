+function hasValidWebhookSignature(req) {
+  const signature = req.get('X-Signature');
+  if (!signature || !/^[0-9a-f]{64}$/.test(signature)) {
+    return false;
+  }
+
+  const expected = crypto
+    .createHmac('sha256', webhookSecret)
+    .update(req.rawBody || Buffer.alloc(0))
+    .digest();
+  const received = Buffer.from(signature, 'hex');
+
+  return crypto.timingSafeEqual(expected, received);
+}
+
+function isValidWebhookBody(body) {
+  return body
+    && typeof body === 'object'
+    && typeof body.id === 'string'
+    && body.id.length > 0
+    && typeof body.type === 'string'
+    && body.type.length > 0
+    && typeof body.timestamp === 'number'
+    && Number.isFinite(body.timestamp)
+    && body.data
+    && typeof body.data === 'object'
+    && !Array.isArray(body.data);
+}
+
+app.post('/webhook', webhookBodyParser, (req, res) => {
+  if (!hasValidWebhookSignature(req)) {
+    res.status(401).json({ error: 'invalid_signature' });
+    return;
+  }
+
+  let body;
+  try {
+    body = JSON.parse(req.rawBody.toString('utf8'));
+  } catch {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  if (typeof body.id === 'string' && acceptedEventIds.has(body.id)) {
+    res.status(409).json({ error: 'duplicate_event', id: body.id });
+    return;
+  }
+
+  if (!isValidWebhookBody(body)) {
+    res.status(400).json({ error: 'invalid_body' });
+    return;
+  }
+
+  acceptedEventIds.add(body.id);
+  res.json({ accepted: true, id: body.id });
+});
+
+app.use(express.json());
+
