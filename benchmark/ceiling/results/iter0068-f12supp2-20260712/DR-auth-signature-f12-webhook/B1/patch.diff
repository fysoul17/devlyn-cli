+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  const event = {
+    id: 'event-happy-path',
+    type: 'order.created',
+    timestamp: 1720000000,
+    data: { orderId: 'order-123' },
+  };
+  const body = JSON.stringify(event);
+
+  try {
+    const response = await post(server, '/webhook', body, {
+      'X-Signature': signWebhookBody(body),
+    });
+    assert.strictEqual(response.status, 200);
+    assert.deepStrictEqual(response.body, { accepted: true, id: event.id });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  const event = {
+    id: 'event-replayed-id',
+    type: 'order.created',
+    timestamp: 1720000001,
+    data: { orderId: 'order-456' },
+  };
+  const body = JSON.stringify(event);
+  const headers = { 'X-Signature': signWebhookBody(body) };
+
+  try {
+    const first = await post(server, '/webhook', body, headers);
+    const second = await post(server, '/webhook', body, headers);
+    assert.strictEqual(first.status, 200);
+    assert.deepStrictEqual(second, {
+      status: 409,
+      body: { error: 'duplicate_event', id: event.id },
+    });
+  } finally {
+    server.close();
+  }
+});
