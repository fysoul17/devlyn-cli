diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..0cb33c5 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,15 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.deepStrictEqual(JSON.parse(out), { version: require('../package.json').version });
+});
+
+test('version with unsupported --format exits with error', () => {
+  assert.throws(
+    () => run(['version', '--format', 'yaml']),
+    (err) => err.status === 1
+  );
+});
