diff --git a/bin/cli.js b/bin/cli.js
index fcff156..b02d339 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -57,6 +57,15 @@ function main(argv) {
       return;
     }
     case 'version': {
+      const formatIdx = rest.indexOf('--format');
+      if (formatIdx !== -1) {
+        if (rest[formatIdx + 1] !== 'json') {
+          console.error('Unsupported version format');
+          process.exit(1);
+        }
+        console.log(JSON.stringify({ version: readPackageVersion() }));
+        return;
+      }
       console.log(readPackageVersion());
       return;
     }
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..233e255 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,16 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.deepStrictEqual(JSON.parse(out), { version: require('../package.json').version });
+  assert.strictEqual(out, `${JSON.stringify({ version: require('../package.json').version })}\n`);
+});
+
+test('version rejects an unsupported --format', () => {
+  assert.throws(
+    () => run(['version', '--format', 'yaml']),
+    (error) => error.status === 1 && /Unsupported version format/.test(error.stderr),
+  );
+});
