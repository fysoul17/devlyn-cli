diff --git a/bin/cli.js b/bin/cli.js
index fcff156..4bafa24 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -9,7 +9,7 @@ const USAGE = `Usage: bench-cli <command> [options]
 
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
