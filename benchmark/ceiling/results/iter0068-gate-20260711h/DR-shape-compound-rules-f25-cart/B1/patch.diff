--- a/bin/cli.js
+++ b/bin/cli.js
@@ -10,12 +10,14 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  cart --input PATH          Price a cart JSON file
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli cart --input cart.json
 `;
 
 function readPackageVersion() {
@@ -35,6 +37,176 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function writeJson(stream, value) {
+  stream.write(JSON.stringify(value));
+}
+
+function cartError(error) {
+  writeJson(process.stderr, error);
+  process.exitCode = 2;
+}
+
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const value = argv[idx + 1];
+  if (idx === -1 || !value || value.startsWith('-')) {
+    return null;
+  }
+  return value;
+}
+
+function readJson(filePath, readErrorCode, parseErrorCode) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch (error) {
+    return { error: { error: readErrorCode } };
+  }
+  try {
+    return { value: JSON.parse(raw) };
+  } catch (error) {
+    return { error: { error: parseErrorCode } };
+  }
+}
+
+function hasOwn(object, key) {
+  return Object.prototype.hasOwnProperty.call(object, key);
+}
+
+function priceCart(input, catalog) {
+  if (!input || typeof input !== 'object' || !hasOwn(input, 'items')) {
+    return { error: { error: 'missing_items' } };
+  }
+  if (!Array.isArray(input.items)) {
+    return { error: { error: 'invalid_items' } };
+  }
+
+  if (!catalog.tax_rates || !hasOwn(catalog.tax_rates, input.state)) {
+    return { error: { error: 'unknown_state', state: input.state } };
+  }
+  if (input.coupon !== null && (!catalog.coupons || !hasOwn(catalog.coupons, input.coupon))) {
+    return { error: { error: 'unknown_coupon', coupon: input.coupon } };
+  }
+
+  const combinedItems = [];
+  const itemBySku = new Map();
+  for (const item of input.items) {
+    if (!item || typeof item !== 'object' || typeof item.sku !== 'string' || !catalog.products || !hasOwn(catalog.products, item.sku)) {
+      return { error: { error: 'unknown_sku', sku: item && item.sku } };
+    }
+    if (!Number.isInteger(item.qty) || item.qty <= 0) {
+      return { error: { error: 'invalid_quantity', sku: item.sku, qty: item.qty } };
+    }
+
+    const existing = itemBySku.get(item.sku);
+    if (existing) {
+      existing.qty += item.qty;
+    } else {
+      const combined = { sku: item.sku, qty: item.qty };
+      itemBySku.set(item.sku, combined);
+      combinedItems.push(combined);
+    }
+  }
+
+  for (const item of combinedItems) {
+    const product = catalog.products[item.sku];
+    if (item.qty > product.stock) {
+      return {
+        error: {
+          error: 'invalid_stock',
+          sku: item.sku,
+          available: product.stock,
+          requested: item.qty,
+        },
+      };
+    }
+  }
+
+  let subtotalCents = 0;
+  let lineDiscountCents = 0;
+  let taxablePostLineDiscountCents = 0;
+  const rows = combinedItems.map((item) => {
+    const product = catalog.products[item.sku];
+    const lineSubtotalCents = item.qty * product.unit_cents;
+    let itemLineDiscountCents = 0;
+
+    for (const promotion of catalog.line_promotions || []) {
+      if (promotion.sku !== item.sku) continue;
+      if (promotion.type === 'buy_x_get_y_free') {
+        itemLineDiscountCents += Math.floor(item.qty / (promotion.buy_qty + promotion.free_qty))
+          * promotion.free_qty * product.unit_cents;
+      } else if (promotion.type === 'per_unit_discount_cents' && item.qty >= promotion.min_qty) {
+        itemLineDiscountCents += promotion.per_unit_discount_cents * item.qty;
+      }
+    }
+
+    const lineTotalCents = lineSubtotalCents - itemLineDiscountCents;
+    subtotalCents += lineSubtotalCents;
+    lineDiscountCents += itemLineDiscountCents;
+    if (catalog.taxable_codes && catalog.taxable_codes[product.tax_code] === true) {
+      taxablePostLineDiscountCents += lineTotalCents;
+    }
+
+    return {
+      sku: item.sku,
+      qty: item.qty,
+      line_subtotal_cents: lineSubtotalCents,
+      line_discount_cents: itemLineDiscountCents,
+      line_total_cents: lineTotalCents,
+    };
+  });
+
+  const postLineDiscountCents = subtotalCents - lineDiscountCents;
+  const coupon = input.coupon === null ? null : catalog.coupons[input.coupon];
+  const couponDiscountCents = coupon && postLineDiscountCents >= coupon.min_subtotal_cents
+    ? Math.round(postLineDiscountCents * coupon.percent / 100)
+    : 0;
+  const taxCents = Math.round(taxablePostLineDiscountCents * catalog.tax_rates[input.state]);
+  const shippingCents = postLineDiscountCents - couponDiscountCents >= catalog.free_shipping_min_cents
+    ? 0
+    : catalog.shipping_cents;
+
+  return {
+    value: {
+      subtotal_cents: subtotalCents,
+      line_discount_cents: lineDiscountCents,
+      coupon_discount_cents: couponDiscountCents,
+      tax_cents: taxCents,
+      shipping_cents: shippingCents,
+      total_cents: postLineDiscountCents - couponDiscountCents + taxCents + shippingCents,
+      items: rows,
+    },
+  };
+}
+
+function runCart(argv) {
+  const inputPath = parseInputFlag(argv);
+  if (!inputPath) {
+    cartError({ error: 'missing_input' });
+    return;
+  }
+
+  const inputResult = readJson(inputPath, 'input_read_error', 'invalid_json');
+  if (inputResult.error) {
+    cartError(inputResult.error);
+    return;
+  }
+
+  const catalogPath = path.join(__dirname, '..', 'data', 'catalog.json');
+  const catalogResult = readJson(catalogPath, 'catalog_read_error', 'catalog_invalid_json');
+  if (catalogResult.error) {
+    cartError(catalogResult.error);
+    return;
+  }
+
+  const result = priceCart(inputResult.value, catalogResult.value);
+  if (result.error) {
+    cartError(result.error);
+    return;
+  }
+  writeJson(process.stdout, result.value);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +225,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'cart': {
+      runCart(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
