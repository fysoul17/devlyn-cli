+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +32,73 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('cart prices combined SKUs, promotions, coupon, tax, and shipping', () => {
+  const input = writeCart({
+    state: 'CA',
+    coupon: 'ORDER10',
+    items: [
+      { sku: 'TEE', qty: 2 },
+      { sku: 'TEE', qty: 1 },
+      { sku: 'BAG', qty: 2 },
+      { sku: 'MUG', qty: 1 },
+    ],
+  });
+
+  const command = spawnSync('node', [CLI, 'cart', '--input', input], { encoding: 'utf8' });
+  assert.strictEqual(command.status, 0);
+  assert.strictEqual(command.stderr, '');
+  const result = JSON.parse(command.stdout);
+  assert.deepStrictEqual(result, {
+    subtotal_cents: 15100,
+    line_discount_cents: 3500,
+    coupon_discount_cents: 1160,
+    tax_cents: 858,
+    shipping_cents: 0,
+    total_cents: 11298,
+    items: [
+      {
+        sku: 'TEE',
+        qty: 3,
+        line_subtotal_cents: 7500,
+        line_discount_cents: 2500,
+        line_total_cents: 5000,
+      },
+      {
+        sku: 'BAG',
+        qty: 2,
+        line_subtotal_cents: 6400,
+        line_discount_cents: 1000,
+        line_total_cents: 5400,
+      },
+      {
+        sku: 'MUG',
+        qty: 1,
+        line_subtotal_cents: 1200,
+        line_discount_cents: 0,
+        line_total_cents: 1200,
+      },
+    ],
+  });
+});
+
+test('cart rejects combined quantities above stock', () => {
+  const input = writeCart({
+    state: 'OR',
+    coupon: null,
+    items: [
+      { sku: 'TEE', qty: 6 },
+      { sku: 'TEE', qty: 5 },
+    ],
+  });
+
+  const result = spawnSync('node', [CLI, 'cart', '--input', input], { encoding: 'utf8' });
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.deepStrictEqual(JSON.parse(result.stderr), {
+    error: 'invalid_stock',
+    sku: 'TEE',
+    available: 10,
+    requested: 11,
+  });
+});
