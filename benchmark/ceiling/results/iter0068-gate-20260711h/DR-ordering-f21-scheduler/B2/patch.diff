+
+test('schedule assigns requests by priority and earliest available slot', (t) => {
+  const inputPath = writeScheduleInput(t, {
+    resources: [{
+      id: 'room-a',
+      windows: [{ start: '09:00', end: '10:00' }],
+      blocked: [{ start: '09:20', end: '09:30' }],
+    }],
+    requests: [
+      {
+        id: 'lower-priority', resource: 'room-a', start: '09:00', duration_min: 30,
+        priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'higher-priority', resource: 'room-a', start: '09:00', duration_min: 20,
+        priority: 2, submitted_at: '09:05',
+      },
+    ],
+  });
+
+  const out = run(['schedule', '--input', inputPath]);
+  assert.deepStrictEqual(JSON.parse(out), {
+    scheduled: [
+      { id: 'higher-priority', resource: 'room-a', start: '09:00', end: '09:20' },
+      { id: 'lower-priority', resource: 'room-a', start: '09:30', end: '10:00' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports unknown resources and requests without a slot', (t) => {
+  const inputPath = writeScheduleInput(t, {
+    resources: [{
+      id: 'room-a',
+      windows: [{ start: '09:00', end: '09:30' }],
+      blocked: [{ start: '09:00', end: '09:30' }],
+    }],
+    requests: [
+      {
+        id: 'missing-room', resource: 'room-b', start: '09:00', duration_min: 15,
+        priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'blocked-request', resource: 'room-a', start: '09:00', duration_min: 15,
+        priority: 2, submitted_at: '09:00',
+      },
+    ],
+  });
+
+  const out = run(['schedule', '--input', inputPath]);
+  assert.deepStrictEqual(JSON.parse(out), {
+    scheduled: [],
+    rejected: [
+      { id: 'missing-room', reason: 'unknown_resource' },
+      { id: 'blocked-request', reason: 'no_slot' },
+    ],
+  });
+});
+
+test('schedule rejects invalid inputs without writing stdout', (t) => {
+  const inputPath = writeScheduleInput(t, {
+    resources: [],
+    requests: [
+      {
+        id: 'duplicate', resource: 'room-a', start: '09:00', duration_min: 15,
+        priority: 1, submitted_at: '09:00',
+      },
+      {
