 }
 
+function isRecord(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function timeToMinutes(value) {
+  if (typeof value !== 'string' || !/^(?:[01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    return null;
+  }
+
+  const [hours, minutes] = value.split(':').map(Number);
+  return hours * 60 + minutes;
+}
+
+function minutesToTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function normalizeRange(value) {
+  if (!isRecord(value)) return null;
+
+  const start = timeToMinutes(value.start);
+  const end = timeToMinutes(value.end);
+  if (start === null || end === null || start >= end) return null;
+
+  return { start, end };
+}
+
+function normalizeScheduleInput(input) {
+  if (!isRecord(input) || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    return null;
+  }
+
+  const resources = new Map();
+  for (const resource of input.resources) {
+    if (!isRecord(resource)
+      || typeof resource.id !== 'string'
+      || resource.id.length === 0
+      || !Array.isArray(resource.windows)
+      || !Array.isArray(resource.blocked)
+      || resources.has(resource.id)) {
+      return null;
+    }
+
+    const windows = resource.windows.map(normalizeRange);
+    const blocked = resource.blocked.map(normalizeRange);
+    if (windows.includes(null) || blocked.includes(null)) return null;
+
+    resources.set(resource.id, {
+      id: resource.id,
+      windows: windows.sort(compareRanges),
+      blocked,
+      scheduled: [],
+    });
+  }
+
+  const requests = [];
+  const requestIds = new Set();
+  for (let index = 0; index < input.requests.length; index += 1) {
+    const request = input.requests[index];
+    if (!isRecord(request)
+      || typeof request.id !== 'string'
+      || request.id.length === 0
+      || typeof request.resource !== 'string'
+      || request.resource.length === 0
+      || requestIds.has(request.id)
+      || !Number.isInteger(request.duration_min)
+      || request.duration_min <= 0
+      || typeof request.priority !== 'number'
+      || !Number.isFinite(request.priority)) {
+      return null;
+    }
+
+    const start = timeToMinutes(request.start);
+    const submittedAt = timeToMinutes(request.submitted_at);
+    if (start === null || submittedAt === null) return null;
+
+    requestIds.add(request.id);
+    requests.push({
+      id: request.id,
+      resource: request.resource,
+      start,
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt,
+      index,
+    });
+  }
+
+  return { resources, requests };
+}
+
+function compareRanges(left, right) {
+  return left.start - right.start || left.end - right.end;
+}
+
+function compareText(left, right) {
+  if (left < right) return -1;
+  if (left > right) return 1;
+  return 0;
+}
+
+function findEarliestSlot(resource, request) {
+  const unavailable = resource.blocked.concat(resource.scheduled).sort(compareRanges);
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(request.start, window.start);
+    if (candidate + request.duration > window.end) continue;
+
+    for (const interval of unavailable) {
+      if (interval.end <= candidate) continue;
+      if (interval.start >= candidate + request.duration) break;
+
+      candidate = interval.end;
+      if (candidate + request.duration > window.end) break;
+    }
+
+    if (candidate + request.duration <= window.end) return candidate;
+  }
+
+  return null;
+}
+
+function printScheduleError(error) {
+  process.stderr.write(`${JSON.stringify({ error })}\n`);
+  process.exitCode = 2;
+}
+
+function runSchedule(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    printScheduleError('invalid_input');
+    return;
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(argv[1], 'utf8');
+  } catch (readError) {
+    printScheduleError('file_read_failed');
+    return;
+  }
+
+  let input;
+  try {
+    input = JSON.parse(raw);
+  } catch (parseError) {
+    printScheduleError('invalid_input');
+    return;
+  }
+
+  const normalized = normalizeScheduleInput(input);
+  if (!normalized) {
+    printScheduleError('invalid_input');
+    return;
+  }
+
+  const orderedRequests = [...normalized.requests].sort((left, right) => (
+    right.priority - left.priority
+    || left.submittedAt - right.submittedAt
+    || compareText(left.id, right.id)
+  ));
+  const rejected = [];
+
+  for (const request of orderedRequests) {
+    const resource = normalized.resources.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', index: request.index });
+      continue;
+    }
+
+    const start = findEarliestSlot(resource, request);
+    if (start === null) {
+      rejected.push({ id: request.id, reason: 'no_slot', index: request.index });
+      continue;
+    }
+
+    resource.scheduled.push({ id: request.id, start, end: start + request.duration });
+  }
+
+  const scheduled = [];
+  for (const resource of normalized.resources.values()) {
+    for (const interval of resource.scheduled) {
+      scheduled.push({
+        id: interval.id,
+        resource: resource.id,
+        start: minutesToTime(interval.start),
+        end: minutesToTime(interval.end),
+      });
+    }
+  }
+
+  scheduled.sort((left, right) => (
+    timeToMinutes(left.start) - timeToMinutes(right.start)
+    || compareText(left.resource, right.resource)
+    || compareText(left.id, right.id)
+  ));
+  rejected.sort((left, right) => left.index - right.index);
+
+  process.stdout.write(`${JSON.stringify({
+    scheduled,
+    rejected: rejected.map(({ id, reason }) => ({ id, reason })),
+  })}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
