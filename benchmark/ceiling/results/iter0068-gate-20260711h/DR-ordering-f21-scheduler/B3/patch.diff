diff --git a/bin/cli.js b/bin/cli.js
index 9cc9b24..bc02e60 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -10,14 +10,229 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  schedule --input PATH      Schedule requests from a JSON input file
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli schedule --input schedule.json
 `;
 
+class ScheduleInputError extends Error {}
+
+function compareIds(left, right) {
+  const leftValue = String(left);
+  const rightValue = String(right);
+  if (leftValue < rightValue) return -1;
+  if (leftValue > rightValue) return 1;
+  return 0;
+}
+
+function parseTime(value) {
+  if (typeof value !== 'string' || !/^\d{2}:\d{2}$/.test(value)) {
+    throw new ScheduleInputError('Invalid time');
+  }
+
+  const hours = Number(value.slice(0, 2));
+  const minutes = Number(value.slice(3, 5));
+  if (hours > 23 || minutes > 59) {
+    throw new ScheduleInputError('Invalid time');
+  }
+
+  return (hours * 60) + minutes;
+}
+
+function formatTime(minutes) {
+  return `${String(Math.floor(minutes / 60)).padStart(2, '0')}:${String(minutes % 60).padStart(2, '0')}`;
+}
+
+function parseInterval(value) {
+  let start;
+  let end;
+
+  if (Array.isArray(value) && value.length === 2) {
+    [start, end] = value;
+  } else if (value && typeof value === 'object' && !Array.isArray(value)) {
+    ({ start, end } = value);
+  } else {
+    throw new ScheduleInputError('Invalid interval');
+  }
+
+  const startMinute = parseTime(start);
+  const endMinute = parseTime(end);
+  if (startMinute >= endMinute) {
+    throw new ScheduleInputError('Invalid interval');
+  }
+
+  return { start: startMinute, end: endMinute };
+}
+
+function validateScheduleInput(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)
+    || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    throw new ScheduleInputError('Invalid top-level input');
+  }
+
+  const resources = new Map();
+  for (const resource of input.resources) {
+    if (!resource || typeof resource !== 'object' || Array.isArray(resource)
+      || (typeof resource.id !== 'string' && typeof resource.id !== 'number')
+      || !Array.isArray(resource.windows) || !Array.isArray(resource.blocked)
+      || resources.has(resource.id)) {
+      throw new ScheduleInputError('Invalid resource');
+    }
+
+    resources.set(resource.id, {
+      id: resource.id,
+      windows: resource.windows.map(parseInterval),
+      blocked: resource.blocked.map(parseInterval),
+      scheduled: [],
+    });
+  }
+
+  const requestIds = new Set();
+  const requests = input.requests.map((request, index) => {
+    if (!request || typeof request !== 'object' || Array.isArray(request)
+      || (typeof request.id !== 'string' && typeof request.id !== 'number')
+      || (typeof request.resource !== 'string' && typeof request.resource !== 'number')
+      || !Number.isInteger(request.duration_min) || request.duration_min <= 0
+      || typeof request.priority !== 'number' || !Number.isFinite(request.priority)) {
+      throw new ScheduleInputError('Invalid request');
+    }
+
+    if (requestIds.has(request.id)) {
+      throw new ScheduleInputError('Duplicate request id');
+    }
+    requestIds.add(request.id);
+
+    return {
+      id: request.id,
+      resource: request.resource,
+      start: parseTime(request.start),
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt: parseTime(request.submitted_at),
+      inputIndex: index,
+    };
+  });
+
+  return { resources, requests };
+}
+
+function intervalsOverlap(start, end, interval) {
+  return start < interval.end && end > interval.start;
+}
+
+function findEarliestPlacement(resource, request) {
+  const unavailable = resource.blocked.concat(resource.scheduled)
+    .sort((left, right) => left.start - right.start || left.end - right.end);
+  let earliest;
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(request.start, window.start);
+
+    for (const interval of unavailable) {
+      if (interval.end <= candidate) continue;
+      if (interval.start >= candidate + request.duration) break;
+      if (intervalsOverlap(candidate, candidate + request.duration, interval)) {
+        candidate = interval.end;
+      }
+    }
+
+    if (candidate + request.duration <= window.end
+      && (earliest === undefined || candidate < earliest)) {
+      earliest = candidate;
+    }
+  }
+
+  return earliest;
+}
+
+function scheduleRequests(input) {
+  const { resources, requests } = validateScheduleInput(input);
+  const orderedRequests = [...requests].sort((left, right) => (
+    right.priority - left.priority
+    || left.submittedAt - right.submittedAt
+    || compareIds(left.id, right.id)
+  ));
+  const scheduled = [];
+  const rejected = [];
+
+  for (const request of orderedRequests) {
+    const resource = resources.get(request.resource);
+    if (!resource) {
+      rejected.push({ id: request.id, reason: 'unknown_resource', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const start = findEarliestPlacement(resource, request);
+    if (start === undefined) {
+      rejected.push({ id: request.id, reason: 'no_slot', inputIndex: request.inputIndex });
+      continue;
+    }
+
+    const end = start + request.duration;
+    resource.scheduled.push({ start, end });
+    scheduled.push({ id: request.id, resource: request.resource, start, end });
+  }
+
+  scheduled.sort((left, right) => (
+    left.start - right.start
+    || compareIds(left.resource, right.resource)
+    || compareIds(left.id, right.id)
+  ));
+  rejected.sort((left, right) => left.inputIndex - right.inputIndex);
+
+  return {
+    scheduled: scheduled.map(({ id, resource, start, end }) => ({
+      id,
+      resource,
+      start: formatTime(start),
+      end: formatTime(end),
+    })),
+    rejected: rejected.map(({ id, reason }) => ({ id, reason })),
+  };
+}
+
+function writeScheduleError(error) {
+  process.stderr.write(`${JSON.stringify({ error })}\n`);
+  process.exitCode = 2;
+}
+
+function parseScheduleArguments(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    throw new ScheduleInputError('Missing input path');
+  }
+  return argv[1];
+}
+
+function runSchedule(argv) {
+  let inputPath;
+  try {
+    inputPath = parseScheduleArguments(argv);
+  } catch (error) {
+    writeScheduleError('invalid_input');
+    return;
+  }
+
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    writeScheduleError('file_read_error');
+    return;
+  }
+
+  try {
+    const output = scheduleRequests(JSON.parse(raw));
+    process.stdout.write(`${JSON.stringify(output)}\n`);
+  } catch (error) {
+    writeScheduleError('invalid_input');
+  }
+}
+
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
@@ -53,6 +268,10 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'schedule': {
+      runSchedule(rest);
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..6956ec7 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
-const { execFileSync } = require('node:child_process');
+const { execFileSync, spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -9,6 +11,24 @@ function run(args) {
   return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
 }
 
+function withScheduleInput(input, callback) {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-schedule-'));
+  const inputPath = path.join(directory, 'input.json');
+  fs.writeFileSync(inputPath, JSON.stringify(input));
+
+  try {
+    return callback(inputPath);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+}
+
+function runSchedule(input) {
+  return withScheduleInput(input, (inputPath) => (
+    spawnSync('node', [CLI, 'schedule', '--input', inputPath], { encoding: 'utf8' })
+  ));
+}
+
 test('hello default', () => {
   const out = run(['hello']);
   assert.match(out, /Hello, world!/);
@@ -23,3 +43,84 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('schedule assigns requests by priority, submission time, and earliest open interval', () => {
+  const result = runSchedule({
+    resources: [
+      {
+        id: 'a-room',
+        windows: [{ start: '09:00', end: '10:00' }],
+        blocked: [{ start: '09:10', end: '09:20' }],
+      },
+      {
+        id: 'b-room',
+        windows: [{ start: '09:00', end: '10:00' }],
+        blocked: [],
+      },
+    ],
+    requests: [
+      {
+        id: 'later-submission', resource: 'a-room', start: '09:00', duration_min: 10,
+        priority: 1, submitted_at: '09:10',
+      },
+      {
+        id: 'b-request', resource: 'b-room', start: '09:00', duration_min: 5,
+        priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'high-priority', resource: 'a-room', start: '09:00', duration_min: 10,
+        priority: 2, submitted_at: '09:30',
+      },
+      {
+        id: 'earlier-submission', resource: 'a-room', start: '09:00', duration_min: 10,
+        priority: 1, submitted_at: '09:00',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [
+      { id: 'high-priority', resource: 'a-room', start: '09:00', end: '09:10' },
+      { id: 'b-request', resource: 'b-room', start: '09:00', end: '09:05' },
+      { id: 'earlier-submission', resource: 'a-room', start: '09:20', end: '09:30' },
+      { id: 'later-submission', resource: 'a-room', start: '09:30', end: '09:40' },
+    ],
+    rejected: [],
+  });
+});
+
+test('schedule reports unknown resources and unavailable requests in input order', () => {
+  const result = runSchedule({
+    resources: [{
+      id: 'room-a',
+      windows: [{ start: '09:00', end: '09:30' }],
+      blocked: [{ start: '09:10', end: '09:30' }],
+    }],
+    requests: [
+      {
+        id: 'no-slot', resource: 'room-a', start: '09:00', duration_min: 15,
+        priority: 1, submitted_at: '09:00',
+      },
+      {
+        id: 'unknown', resource: 'missing-room', start: '09:00', duration_min: 5,
+        priority: 10, submitted_at: '09:00',
+      },
+      {
+        id: 'accepted', resource: 'room-a', start: '09:00', duration_min: 10,
+        priority: 5, submitted_at: '09:00',
+      },
+    ],
+  });
+
+  assert.strictEqual(result.status, 0);
+  assert.strictEqual(result.stderr, '');
+  assert.deepStrictEqual(JSON.parse(result.stdout), {
+    scheduled: [{ id: 'accepted', resource: 'room-a', start: '09:00', end: '09:10' }],
+    rejected: [
+      { id: 'no-slot', reason: 'no_slot' },
+      { id: 'unknown', reason: 'unknown_resource' },
+    ],
+  });
+});
