+function inputError(message) {
+  const error = new Error(message);
+  error.isInputError = true;
+  return error;
+}
+
+function parseTime(value, field) {
+  if (typeof value !== 'string' || !/^([01]\d|2[0-3]):[0-5]\d$/.test(value)) {
+    throw inputError(`${field} must be an HH:MM time`);
+  }
+
+  const [hours, minutes] = value.split(':').map(Number);
+  return hours * 60 + minutes;
+}
+
+function formatTime(minutes) {
+  const hours = Math.floor(minutes / 60);
+  const remainder = minutes % 60;
+  return `${String(hours).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
+}
+
+function parseRanges(ranges, field) {
+  if (!Array.isArray(ranges)) {
+    throw inputError(`${field} must be an array`);
+  }
+
+  return ranges.map((range, index) => {
+    if (!range || typeof range !== 'object' || Array.isArray(range)) {
+      throw inputError(`${field}[${index}] must be an object`);
+    }
+
+    const start = parseTime(range.start, `${field}[${index}].start`);
+    const end = parseTime(range.end, `${field}[${index}].end`);
+    if (end <= start) {
+      throw inputError(`${field}[${index}] must end after it starts`);
+    }
+    return { start, end };
+  });
+}
+
+function parseScheduleInput(input) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)
+      || !Array.isArray(input.resources) || !Array.isArray(input.requests)) {
+    throw inputError('input must contain resources and requests arrays');
+  }
+
+  const resourceIds = new Set();
+  const resources = input.resources.map((resource, index) => {
+    if (!resource || typeof resource !== 'object' || Array.isArray(resource)
+        || typeof resource.id !== 'string' || resource.id.length === 0) {
+      throw inputError(`resources[${index}] must have a non-empty string id`);
+    }
+    if (resourceIds.has(resource.id)) {
+      throw inputError(`duplicate resource id: ${resource.id}`);
+    }
+    resourceIds.add(resource.id);
+
+    return {
+      id: resource.id,
+      windows: parseRanges(resource.windows, `resources[${index}].windows`),
+      blocked: parseRanges(resource.blocked, `resources[${index}].blocked`),
+    };
+  });
+
+  const requestIds = new Set();
+  const requests = input.requests.map((request, index) => {
+    if (!request || typeof request !== 'object' || Array.isArray(request)
+        || typeof request.id !== 'string' || request.id.length === 0
+        || typeof request.resource !== 'string' || request.resource.length === 0) {
+      throw inputError(`requests[${index}] must have non-empty string id and resource`);
+    }
+    if (requestIds.has(request.id)) {
+      throw inputError(`duplicate request id: ${request.id}`);
+    }
+    requestIds.add(request.id);
+
+    if (!Number.isFinite(request.priority)) {
+      throw inputError(`requests[${index}].priority must be a number`);
+    }
+    if (!Number.isInteger(request.duration_min) || request.duration_min <= 0) {
+      throw inputError(`requests[${index}].duration_min must be a positive integer`);
+    }
+
+    return {
+      id: request.id,
+      resource: request.resource,
+      start: parseTime(request.start, `requests[${index}].start`),
+      duration: request.duration_min,
+      priority: request.priority,
+      submittedAt: parseTime(request.submitted_at, `requests[${index}].submitted_at`),
+      index,
+    };
+  });
+
+  return { resources, requests };
+}
+
+function findEarliestPlacement(request, resource, accepted) {
+  let earliest = null;
+
+  for (const window of resource.windows) {
+    let candidate = Math.max(request.start, window.start);
+    const blockers = resource.blocked.concat(accepted)
+      .filter((interval) => interval.start < window.end && interval.end > window.start)
+      .sort((left, right) => left.start - right.start || left.end - right.end);
+
+    for (const blocker of blockers) {
+      if (blocker.end <= candidate) {
+        continue;
+      }
+      if (candidate + request.duration <= blocker.start) {
+        break;
+      }
+      candidate = Math.max(candidate, blocker.end);
+    }
+
+    if (candidate + request.duration <= window.end
+        && (earliest === null || candidate < earliest)) {
+      earliest = candidate;
+    }
+  }
+
+  return earliest;
+}
+
+function compareStrings(left, right) {
+  return left < right ? -1 : left > right ? 1 : 0;
+}
+
+function createSchedule(input) {
+  const { resources, requests } = parseScheduleInput(input);
+  const resourcesById = new Map(resources.map((resource) => [resource.id, resource]));
+  const acceptedByResource = new Map(resources.map((resource) => [resource.id, []]));
+  const scheduled = [];
+  const rejectedByIndex = new Map();
+
+  const orderedRequests = [...requests].sort((left, right) => (
+    right.priority - left.priority
+    || left.submittedAt - right.submittedAt
+    || compareStrings(left.id, right.id)
+  ));
+
+  for (const request of orderedRequests) {
+    const resource = resourcesById.get(request.resource);
+    if (!resource) {
+      rejectedByIndex.set(request.index, { id: request.id, reason: 'unknown_resource' });
+      continue;
+    }
+
+    const accepted = acceptedByResource.get(resource.id);
+    const placement = findEarliestPlacement(request, resource, accepted);
+    if (placement === null) {
+      rejectedByIndex.set(request.index, { id: request.id, reason: 'no_slot' });
+      continue;
+    }
+
+    const interval = { start: placement, end: placement + request.duration };
+    accepted.push(interval);
+    scheduled.push({
+      id: request.id,
+      resource: resource.id,
+      start: formatTime(interval.start),
+      end: formatTime(interval.end),
+      sortStart: interval.start,
+    });
+  }
+
+  scheduled.sort((left, right) => (
+    left.sortStart - right.sortStart
+    || compareStrings(left.resource, right.resource)
+    || compareStrings(left.id, right.id)
+  ));
+
+  return {
+    scheduled: scheduled.map(({ id, resource, start, end }) => ({ id, resource, start, end })),
+    rejected: requests
+      .filter((request) => rejectedByIndex.has(request.index))
+      .map((request) => rejectedByIndex.get(request.index)),
+  };
+}
+
+function parseSchedulePath(argv) {
+  if (argv.length !== 2 || argv[0] !== '--input' || !argv[1]) {
+    throw inputError('schedule requires --input PATH');
+  }
+  return argv[1];
+}
+
+function runSchedule(argv) {
+  const inputPath = parseSchedulePath(argv);
+  let raw;
+  try {
+    raw = fs.readFileSync(inputPath, 'utf8');
+  } catch (error) {
+    throw inputError(`unable to read input file: ${error.message}`);
+  }
+
+  let input;
+  try {
+    input = JSON.parse(raw);
+  } catch (error) {
+    throw inputError(`input is not valid JSON: ${error.message}`);
+  }
+
+  process.stdout.write(JSON.stringify(createSchedule(input)));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +262,16 @@ function main(argv) {
