diff --git a/bin/cli.js b/bin/cli.js
index 9cc9b24..d6a8cab 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -10,14 +10,28 @@ const USAGE = `Usage: bench-cli <command> [options]
 Commands:
   hello [--name NAME]        Print a greeting (default name: "world")
   version                    Print the CLI version from package.json
+  payout --input PATH        Calculate merchant payouts from ledger events
   --help, -h                 Show this help
 
 Examples:
   bench-cli hello
   bench-cli hello --name alice
   bench-cli version
+  bench-cli payout --input ledger.json
 `;
 
+class PayoutError extends Error {
+  constructor(error, details = {}) {
+    super(error);
+    this.error = error;
+    this.details = details;
+  }
+}
+
+function payoutError(error, details) {
+  throw new PayoutError(error, details);
+}
+
 function readPackageVersion() {
   const pkgPath = path.join(__dirname, '..', 'package.json');
   const raw = fs.readFileSync(pkgPath, 'utf8');
@@ -35,6 +49,196 @@ function parseNameFlag(argv) {
   return value;
 }
 
+function parseInputFlag(argv) {
+  const idx = argv.indexOf('--input');
+  const value = idx === -1 ? undefined : argv[idx + 1];
+  if (!value || value.startsWith('-') || argv.length !== 2 || idx !== 0) {
+    payoutError('invalid_input_argument');
+  }
+  return value;
+}
+
+function readJsonFile(filePath, readError, parseError) {
+  let raw;
+  try {
+    raw = fs.readFileSync(filePath, 'utf8');
+  } catch {
+    payoutError(readError);
+  }
+
+  try {
+    return JSON.parse(raw);
+  } catch {
+    payoutError(parseError);
+  }
+}
+
+function readPayoutRules() {
+  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
+  const rules = readJsonFile(rulesPath, 'unreadable_payout_rules', 'invalid_payout_rules');
+  const integerFields = ['fixed_fee_cents', 'dispute_fee_cents', 'minimum_payout_cents'];
+  const percentFields = ['processing_fee_percent', 'reserve_percent'];
+
+  if (!rules || typeof rules !== 'object' || Array.isArray(rules)) {
+    payoutError('invalid_payout_rules');
+  }
+  for (const field of integerFields) {
+    if (!Number.isSafeInteger(rules[field]) || rules[field] < 0) {
+      payoutError('invalid_payout_rules');
+    }
+  }
+  for (const field of percentFields) {
+    if (typeof rules[field] !== 'number' || !Number.isFinite(rules[field]) || rules[field] < 0) {
+      payoutError('invalid_payout_rules');
+    }
+  }
+
+  return rules;
+}
+
+function canonicalJson(value) {
+  if (Array.isArray(value)) {
+    return `[${value.map(canonicalJson).join(',')}]`;
+  }
+  if (value && typeof value === 'object') {
+    return `{${Object.keys(value).sort().map((key) => `${JSON.stringify(key)}:${canonicalJson(value[key])}`).join(',')}}`;
+  }
+  return JSON.stringify(value);
+}
+
+function validateEvent(event) {
+  if (!event || typeof event !== 'object' || Array.isArray(event)) {
+    payoutError('invalid_event');
+  }
+  if (!Object.hasOwn(event, 'id')) {
+    payoutError('missing_id');
+  }
+  if (typeof event.id !== 'string') {
+    payoutError('invalid_id');
+  }
+  if (!Object.hasOwn(event, 'merchant_id')) {
+    payoutError('missing_merchant_id');
+  }
+  if (typeof event.merchant_id !== 'string') {
+    payoutError('invalid_merchant_id');
+  }
+  if (!['charge', 'refund', 'dispute'].includes(event.type)) {
+    payoutError('unknown_event_type');
+  }
+  if (!Number.isSafeInteger(event.amount_cents) || event.amount_cents <= 0) {
+    payoutError('invalid_amount_cents');
+  }
+}
+
+function readLedgerEvents(inputPath) {
+  const input = readJsonFile(inputPath, 'unreadable_input', 'invalid_json');
+  if (!input || typeof input !== 'object' || Array.isArray(input)) {
+    payoutError('invalid_input');
+  }
+  if (!Object.hasOwn(input, 'events')) {
+    payoutError('missing_events');
+  }
+  if (!Array.isArray(input.events)) {
+    payoutError('invalid_events');
+  }
+
+  const eventsById = new Map();
+  const uniqueEvents = [];
+  for (const event of input.events) {
+    if (!event || typeof event !== 'object' || Array.isArray(event)
+      || !Object.hasOwn(event, 'id') || typeof event.id !== 'string') {
+      validateEvent(event);
+    }
+    const fingerprint = canonicalJson(event);
+    if (eventsById.has(event.id)) {
+      const existing = eventsById.get(event.id);
+      if (existing !== fingerprint) {
+        payoutError('conflicting_duplicate', { id: event.id });
+      }
+      continue;
+    }
+    eventsById.set(event.id, fingerprint);
+    uniqueEvents.push(event);
+  }
+  for (const event of uniqueEvents) {
+    validateEvent(event);
+  }
+  return uniqueEvents;
+}
+
+function emptyMerchant(merchantId) {
+  return {
+    merchant_id: merchantId,
+    gross_charge_cents: 0,
+    refund_cents: 0,
+    dispute_cents: 0,
+    processing_fee_cents: 0,
+    dispute_fee_cents: 0,
+    reserve_cents: 0,
+    payout_cents: 0,
+  };
+}
+
+function calculatePayout(events, rules) {
+  const merchants = new Map();
+  for (const event of events) {
+    let merchant = merchants.get(event.merchant_id);
+    if (!merchant) {
+      merchant = emptyMerchant(event.merchant_id);
+      merchants.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        event.amount_cents * rules.processing_fee_percent / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  for (const merchant of merchants.values()) {
+    const netBeforeReserve = merchant.gross_charge_cents
+      - merchant.refund_cents
+      - merchant.dispute_cents
+      - merchant.processing_fee_cents
+      - merchant.dispute_fee_cents;
+    merchant.reserve_cents = netBeforeReserve > 0
+      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
+      : 0;
+    merchant.payout_cents = netBeforeReserve - merchant.reserve_cents;
+
+    if (merchant.payout_cents > 0 && merchant.payout_cents < rules.minimum_payout_cents) {
+      merchant.reserve_cents += merchant.payout_cents;
+      merchant.payout_cents = 0;
+    }
+  }
+
+  const rows = [...merchants.values()];
+  return {
+    total_payout_cents: rows.reduce((total, merchant) => total + merchant.payout_cents, 0),
+    total_processing_fee_cents: rows.reduce((total, merchant) => total + merchant.processing_fee_cents, 0),
+    total_dispute_fee_cents: rows.reduce((total, merchant) => total + merchant.dispute_fee_cents, 0),
+    total_reserve_cents: rows.reduce((total, merchant) => total + merchant.reserve_cents, 0),
+    merchants: rows,
+  };
+}
+
+function writePayoutError(error) {
+  process.stderr.write(`${JSON.stringify({ error: error.error, ...error.details })}\n`);
+}
+
+function payout(argv) {
+  const inputPath = parseInputFlag(argv);
+  const events = readLedgerEvents(inputPath);
+  const rules = readPayoutRules();
+  process.stdout.write(`${JSON.stringify(calculatePayout(events, rules))}\n`);
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
@@ -53,6 +257,20 @@ function main(argv) {
       console.log(readPackageVersion());
       return;
     }
+    case 'payout': {
+      try {
+        payout(rest);
+      } catch (error) {
+        if (error instanceof PayoutError) {
+          writePayoutError(error);
+          process.exitCode = 2;
+          return;
+        }
+        writePayoutError(new PayoutError('payout_failed'));
+        process.exitCode = 2;
+      }
+      return;
+    }
     default:
       console.error(`Unknown command: ${command}`);
       process.stderr.write(USAGE);
