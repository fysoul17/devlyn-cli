  warehouses: [{ id: "W1", distance: 1, lots: [{ sku: "SKU1", lot: "L1", qty: 10, expires: "2027-01-01" }] }],
  orders: [{ id: "O1", priority: 5, submitted_at: "2026-01-01T00:00:00Z", lines: [{ sku: "SKU1", qty: 4, single_warehouse: false }] }]
};

const numeric = structuredClone(base);
numeric.orders[0].submitted_at = 0;
const numericRun = invoke(numeric);
assert.equal(numericRun.status, 2);
assert.equal(numericRun.stdout, "");
parseObject(numericRun.stderr);

