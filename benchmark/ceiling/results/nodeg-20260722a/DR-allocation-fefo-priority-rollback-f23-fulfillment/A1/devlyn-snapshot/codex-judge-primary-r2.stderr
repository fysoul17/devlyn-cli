    { id: "O-fail", priority: 5, submitted_at: "2026-01-01", lines: [
      { sku: "A", qty: 1, single_warehouse: false },
      { sku: "B", qty: 1, single_warehouse: false }
    ] },
    { id: "O-high", priority: 10, submitted_at: "2026-01-01", lines: [{ sku: "A", qty: 3, single_warehouse: false }] }
  ]
};
const combinedRun = invoke(combined);
assert.equal(combinedRun.status, 0);
assert.equal(combinedRun.stderr, "");
assert.deepEqual(JSON.parse(combinedRun.stdout), {
  accepted: [
    { id: "O-high", allocations: [
      { sku: "A", warehouse: "W1", lot: "L-early", qty: 1 },
      { sku: "A", warehouse: "W1", lot: "L-late", qty: 1 },
