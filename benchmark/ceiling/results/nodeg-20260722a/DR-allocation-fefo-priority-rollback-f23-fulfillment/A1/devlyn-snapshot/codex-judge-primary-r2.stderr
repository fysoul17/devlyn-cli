  ],
  remaining: [
    { warehouse: "W1", sku: "Z", lot: "Z1", qty: 1, expires: "2029-01-01" },
    { warehouse: "W2", sku: "Z", lot: "Z2", qty: 1, expires: "2028-01-01" }
  ]
});

const singleWarehouse = {
  warehouses: [
    { id: "W1", distance: 1, lots: [
      { sku: "S", lot: "A", qty: 2, expires: "2027-01-01" },
      { sku: "S", lot: "B", qty: 2, expires: "2027-02-01" }
