assert.equal(isoRun.status, 0);
assert.equal(isoRun.stderr, "");
assert.deepEqual(JSON.parse(isoRun.stdout), {
  accepted: [{ id: "O1", allocations: [{ sku: "SKU1", warehouse: "W1", lot: "L1", qty: 4 }] }],
  rejected: [],
  remaining: [{ warehouse: "W1", sku: "SKU1", lot: "L1", qty: 6, expires: "2027-01-01" }]
});

