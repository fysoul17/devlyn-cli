    75	function validateFulfillWaveInput(input) {
    76	  assertObject(input, 'input');
    77	
    78	  if (!Array.isArray(input.warehouses) || !Array.isArray(input.orders)) {
    79	    throw new Error('warehouses and orders must be arrays');
    80	  }
    81	
    82	  for (const warehouse of input.warehouses) {
    83	    assertObject(warehouse, 'warehouse');
    84	    if (!isNonEmptyString(warehouse.id) || !Number.isFinite(warehouse.distance)) {
    85	      throw new Error('warehouse id and distance are invalid');
    86	    }
    87	    if (!Array.isArray(warehouse.lots)) {
    88	      throw new Error('warehouse lots must be an array');
    89	    }
    90	
    91	    for (const lot of warehouse.lots) {
    92	      assertObject(lot, 'lot');
    93	      if (!isNonEmptyString(lot.sku)
    94	        || !isNonEmptyString(lot.lot)
    95	        || !isPositiveInteger(lot.qty)
    96	        || !isNonEmptyString(lot.expires)
    97	        || !isValidCalendarDate(lot.expires)) {
    98	        throw new Error('lot is invalid');
    99	      }
   100	    }
   101	  }
   102	
   103	  const submittedAt = new Map();
   104	  const orderIds = new Set();
   105	  for (const order of input.orders) {
   106	    assertObject(order, 'order');
   107	    if (!isNonEmptyString(order.id) || !Number.isFinite(order.priority)) {
   108	      throw new Error('order id and priority are invalid');
   109	    }
   110	    if (orderIds.has(order.id)) {
   111	      throw new Error('order ids must be unique');
   112	    }
   113	    orderIds.add(order.id);
   114	    submittedAt.set(order, parseSubmittedAt(order.submitted_at));
   115	
   116	    if (!Array.isArray(order.lines)) {
   117	      throw new Error('order lines must be an array');
   118	    }
   119	    for (const line of order.lines) {
   120	      assertObject(line, 'order line');
   121	      if (!isNonEmptyString(line.sku)
   122	        || !isPositiveInteger(line.qty)
   123	        || typeof line.single_warehouse !== 'boolean') {
   124	        throw new Error('order line is invalid');
   125	      }
   126	    }
   127	  }
   128	
   129	  return submittedAt;
   130	}
   131	
   132	function compareWarehouses(left, right) {
   133	  return left.distance - right.distance || left.id.localeCompare(right.id);
   134	}
   135	
   136	function compareLots(left, right) {
   137	  return left.expires.localeCompare(right.expires) || left.lot.localeCompare(right.lot);
   138	}
   139	
   140	function matchingLots(warehouse, sku) {
   141	  return warehouse.lots
   142	    .filter((lot) => lot.sku === sku && lot.qty > 0)
   143	    .sort(compareLots);
   144	}
   145	
   146	function drawFromLots(lots, qty, warehouseId, sku) {
   147	  const allocations = [];
   148	  let remaining = qty;
   149	
   150	  for (const lot of lots) {
   151	    if (remaining === 0) break;
   152	    const drawn = Math.min(lot.qty, remaining);
   153	    lot.qty -= drawn;
   154	    remaining -= drawn;
   155	    allocations.push({ sku, warehouse: warehouseId, lot: lot.lot, qty: drawn });
   156	  }
   157	
   158	  return allocations;
   159	}
   160	
   161	function allocateLine(line, stock) {
   162	  const warehouses = [...stock].sort(compareWarehouses);
   163	
   164	  if (line.single_warehouse) {
   165	    for (const warehouse of warehouses) {
   166	      const lots = matchingLots(warehouse, line.sku);
   167	      const available = lots.reduce((total, lot) => total + lot.qty, 0);
   168	      if (available >= line.qty) {
   169	        return drawFromLots(lots, line.qty, warehouse.id, line.sku);
   170	      }
   171	    }
   172	    return null;
   173	  }
   174	
   175	  const allocations = [];
   176	  let remaining = line.qty;
   177	  for (const warehouse of warehouses) {
   178	    if (remaining === 0) break;
   179	    const drawn = drawFromLots(matchingLots(warehouse, line.sku), remaining, warehouse.id, line.sku);
   180	    allocations.push(...drawn);
   181	    remaining -= drawn.reduce((total, allocation) => total + allocation.qty, 0);
   182	  }
   183	
   184	  return remaining === 0 ? allocations : null;
   185	}
   186	
   187	function snapshotStock(stock) {
   188	  return stock.map((warehouse) => warehouse.lots.map((lot) => lot.qty));
   189	}
   190	
   191	function restoreStock(stock, snapshot) {
   192	  stock.forEach((warehouse, warehouseIndex) => {
   193	    warehouse.lots.forEach((lot, lotIndex) => {
   194	      lot.qty = snapshot[warehouseIndex][lotIndex];
   195	    });
   196	  });
   197	}
   198	
   199	function allocateFulfillWave(input, submittedAt) {
   200	  const stock = input.warehouses.map((warehouse) => ({
   201	    id: warehouse.id,
   202	    distance: warehouse.distance,
   203	    lots: warehouse.lots.map((lot) => ({ ...lot })),
   204	  }));
   205	  const processingOrder = [...input.orders].sort((left, right) => right.priority - left.priority
   206	    || submittedAt.get(left) - submittedAt.get(right)
   207	    || left.id.localeCompare(right.id));
   208	  const accepted = [];
   209	  const rejectedIds = new Set();
   210	
   211	  for (const order of processingOrder) {
   212	    const snapshot = snapshotStock(stock);
   213	    const allocations = [];
   214	    const fulfilled = order.lines.every((line) => {
   215	      const lineAllocations = allocateLine(line, stock);
   216	      if (!lineAllocations) return false;
   217	      allocations.push(...lineAllocations);
   218	      return true;
   219	    });
   220	
   221	    if (fulfilled) {
   222	      accepted.push({ id: order.id, allocations });
   223	    } else {
   224	      restoreStock(stock, snapshot);
   225	      rejectedIds.add(order.id);
   226	    }
   227	  }
   228	
   229	  const rejected = input.orders
   230	    .filter((order) => rejectedIds.has(order.id))
   231	    .map((order) => ({ id: order.id, reason: 'insufficient_stock' }));
   232	  const remaining = stock
   233	    .flatMap((warehouse) => warehouse.lots
   234	      .filter((lot) => lot.qty > 0)
   235	      .map((lot) => ({ warehouse: warehouse.id, sku: lot.sku, lot: lot.lot, qty: lot.qty, expires: lot.expires })))
   236	    .sort((left, right) => left.warehouse.localeCompare(right.warehouse)
   237	      || left.sku.localeCompare(right.sku)
   238	      || left.expires.localeCompare(right.expires)
   239	      || left.lot.localeCompare(right.lot));
   240	
   241	  return { accepted, rejected, remaining };
   242	}
   243	
   244	function fulfillWave(argv) {
   245	  const inputIndex = argv.indexOf('--input');
   246	  const inputPath = argv[inputIndex + 1];
   247	  if (inputIndex === -1 || !inputPath || inputPath.startsWith('-')) {
   248	    throw new Error('--input requires a path');
   249	  }
   250	
   251	  let input;
   252	  try {
   253	    input = JSON.parse(fs.readFileSync(inputPath, 'utf8'));
   254	  } catch (error) {
   255	    throw new Error(`unable to read input: ${error.message}`);
   256	  }
   257	
   258	  const submittedAt = validateFulfillWaveInput(input);
   259	  return allocateFulfillWave(input, submittedAt);
   260	}
   261	
   262	function runFulfillWave(argv) {
   263	  try {
   264	    process.stdout.write(`${JSON.stringify(fulfillWave(argv))}\n`);
   265	  } catch (error) {
   266	    process.stderr.write(`${JSON.stringify({ error: error.message })}\n`);
   267	    process.exitCode = 2;
   268	  }
   269	}
   270	
   271	function main(argv) {
   272	  const [command, ...rest] = argv;
   273	
   274	  if (!command || command === '--help' || command === '-h') {
   275	    process.stdout.write(USAGE);
   276	    return;
   277	  }
   278	
   279	  switch (command) {
   280	    case 'hello': {
   281	      const name = parseNameFlag(rest);
   282	      console.log(`Hello, ${name}!`);
   283	      return;
   284	    }
   285	    case 'version': {
   286	      console.log(readPackageVersion());
   287	      return;
   288	    }
   289	    case 'fulfill-wave': {
   290	      runFulfillWave(rest);
   291	      return;
   292	    }
   293	    default:
   294	      console.error(`Unknown command: ${command}`);
   295	      process.stderr.write(USAGE);
   296	      process.exit(1);
   297	  }
   298	}
   299	
   300	main(process.argv.slice(2));

