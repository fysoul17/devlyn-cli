+test('fulfill-wave accepts an allocation and leaves the input file unchanged', () => {
+  const fixture = {
+    warehouses: [{
+      id: 'W1',
+      distance: 1,
+      lots: [{ sku: 'SKU1', lot: 'L1', qty: 10, expires: '2027-01-01' }],
+    }],
+    orders: [{
+      id: 'O1',
+      priority: 5,
+      submitted_at: '2026-01-01T00:00:00Z',
+      lines: [{ sku: 'SKU1', qty: 4, single_warehouse: false }],
+    }],
+  };
+  const inputPath = path.join(os.tmpdir(), `fulfill-wave-accept-${process.pid}-${Date.now()}.json`);
+  const raw = JSON.stringify(fixture);
+  fs.writeFileSync(inputPath, raw);
+
+  try {
+    const data = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+    assert.strictEqual(fs.readFileSync(inputPath, 'utf8'), raw);
+    assert.deepStrictEqual(data, {
+      accepted: [{
+        id: 'O1',
+        allocations: [{ sku: 'SKU1', warehouse: 'W1', lot: 'L1', qty: 4 }],
+      }],
+      rejected: [],
+      remaining: [{ warehouse: 'W1', sku: 'SKU1', lot: 'L1', qty: 6, expires: '2027-01-01' }],
+    });
+  } finally {
+    fs.unlinkSync(inputPath);
+  }
+});
+
