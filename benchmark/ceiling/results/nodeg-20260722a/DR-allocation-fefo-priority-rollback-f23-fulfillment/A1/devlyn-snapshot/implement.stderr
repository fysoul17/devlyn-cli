+      accepted: [],
+      rejected: [{ id: 'O2', reason: 'insufficient_stock' }],
+      remaining: [{ warehouse: 'W1', sku: 'SKU1', lot: 'L1', qty: 5, expires: '2027-01-01' }],
+    });
+  } finally {
