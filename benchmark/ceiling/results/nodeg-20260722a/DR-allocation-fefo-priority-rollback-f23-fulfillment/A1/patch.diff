@@ -1,6 +1,8 @@
 const { test } = require('node:test');
 const assert = require('node:assert');
-const { execFileSync } = require('node:child_process');
+const { execFileSync, spawnSync } = require('node:child_process');
+const fs = require('node:fs');
+const os = require('node:os');
 const path = require('node:path');
 
 const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
@@ -23,3 +25,97 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('fulfill-wave accepts an allocation and leaves the input file unchanged', () => {
+  const fixture = {
+    warehouses: [{
+      id: 'W1',
+      distance: 1,
+      lots: [{ sku: 'SKU1', lot: 'L1', qty: 10, expires: '2027-01-01' }],
+    }],
+    orders: [{
+      id: 'O1',
+      priority: 5,
+      submitted_at: '2026-01-01T00:00:00Z',
+      lines: [{ sku: 'SKU1', qty: 4, single_warehouse: false }],
+    }],
+  };
+  const inputPath = path.join(os.tmpdir(), `fulfill-wave-accept-${process.pid}-${Date.now()}.json`);
+  const raw = JSON.stringify(fixture);
+  fs.writeFileSync(inputPath, raw);
+
+  try {
+    const data = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+    assert.strictEqual(fs.readFileSync(inputPath, 'utf8'), raw);
+    assert.deepStrictEqual(data, {
+      accepted: [{
+        id: 'O1',
+        allocations: [{ sku: 'SKU1', warehouse: 'W1', lot: 'L1', qty: 4 }],
+      }],
+      rejected: [],
+      remaining: [{ warehouse: 'W1', sku: 'SKU1', lot: 'L1', qty: 6, expires: '2027-01-01' }],
+    });
+  } finally {
+    fs.unlinkSync(inputPath);
+  }
+});
+
+test('fulfill-wave rejects an order and restores tentative stock deductions', () => {
+  const fixture = {
+    warehouses: [{
+      id: 'W1',
+      distance: 1,
+      lots: [{ sku: 'SKU1', lot: 'L1', qty: 5, expires: '2027-01-01' }],
+    }],
+    orders: [{
+      id: 'O2',
+      priority: 5,
+      submitted_at: '2026-01-01T00:00:00Z',
+      lines: [
+        { sku: 'SKU1', qty: 3, single_warehouse: false },
+        { sku: 'SKU1', qty: 10, single_warehouse: false },
+      ],
+    }],
+  };
+  const inputPath = path.join(os.tmpdir(), `fulfill-wave-reject-${process.pid}-${Date.now()}.json`);
+  fs.writeFileSync(inputPath, JSON.stringify(fixture));
+
+  try {
+    const data = JSON.parse(run(['fulfill-wave', '--input', inputPath]));
+    assert.deepStrictEqual(data, {
+      accepted: [],
+      rejected: [{ id: 'O2', reason: 'insufficient_stock' }],
+      remaining: [{ warehouse: 'W1', sku: 'SKU1', lot: 'L1', qty: 5, expires: '2027-01-01' }],
+    });
+  } finally {
+    fs.unlinkSync(inputPath);
+  }
+});
+
+test('fulfill-wave rejects a numeric submitted_at value', () => {
+  const fixture = {
+    warehouses: [{
+      id: 'W1',
+      distance: 1,
+      lots: [{ sku: 'SKU1', lot: 'L1', qty: 10, expires: '2027-01-01' }],
+    }],
+    orders: [{
+      id: 'O3',
+      priority: 5,
+      submitted_at: 0,
+      lines: [{ sku: 'SKU1', qty: 4, single_warehouse: false }],
+    }],
+  };
+  const inputPath = path.join(os.tmpdir(), `fulfill-wave-invalid-submitted-at-${process.pid}-${Date.now()}.json`);
+  fs.writeFileSync(inputPath, JSON.stringify(fixture));
+
+  try {
+    const result = spawnSync('node', [CLI, 'fulfill-wave', '--input', inputPath], { encoding: 'utf8' });
+    assert.strictEqual(result.status, 2);
+    assert.strictEqual(result.stdout, '');
+    const error = JSON.parse(result.stderr);
+    assert.ok(error && !Array.isArray(error) && typeof error === 'object');
+  } finally {
+    fs.unlinkSync(inputPath);
+  }
+});
