                 assert mock_job.call_count == 0
                 assert len(schedule.jobs) == 0
 
+    def test_max_runs_chainable_and_validated(self):
+        mock_job = make_mock_job()
+        job = every(5).seconds.max_runs(3)
+        assert job.max_runs(3) is job
+        assert job.do(mock_job) is job
+        assert every().max_runs(3).seconds.do(mock_job) in schedule.jobs
+
+        for value in (0, -1, 1.5, "1", None, True):
+            with self.assertRaises(ScheduleValueError) as context:
+                every().max_runs(value)
+            self.assertIsInstance(context.exception, ValueError)
+
+    def test_max_runs_with_run_pending(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            job = every().second.max_runs(2).do(mock_job)
+            assert not job.should_run
+            assert mock_job.call_count == 0
+
+            with mock_datetime(2020, 1, 1, 11, 35, 11):
+                schedule.run_pending()
+                assert mock_job.call_count == 1
+                assert schedule.jobs == [job]
+
+            with mock_datetime(2020, 1, 1, 11, 35, 12):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+                assert schedule.next_run() is None
+                assert schedule.idle_seconds() is None
+
+            with mock_datetime(2020, 1, 1, 11, 35, 13):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+
+    def test_max_runs_with_run_all(self):
+        scheduler = schedule.Scheduler()
+        mock_job = make_mock_job()
+        job = scheduler.every().second.max_runs(2).do(mock_job)
+
+        scheduler.run_all()
+        assert mock_job.call_count == 1
+        assert scheduler.jobs == [job]
+        scheduler.run_all()
+        assert mock_job.call_count == 2
+        assert scheduler.jobs == []
+
+    def test_max_runs_and_until_cancel_at_the_first_limit(self):
+        mock_job = make_mock_job()
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            every(5).seconds.max_runs(3).until(datetime.time(11, 35, 20)).do(
+                mock_job
+            )
+            with mock_datetime(2020, 1, 1, 11, 35, 15):
+                schedule.run_pending()
+                assert mock_job.call_count == 1
+                assert len(schedule.jobs) == 1
+            with mock_datetime(2020, 1, 1, 11, 35, 20):
+                schedule.run_pending()
+                assert mock_job.call_count == 2
+                assert len(schedule.jobs) == 0
+
+    def test_max_runs_reconfiguration_preserves_run_count(self):
+        scheduler = schedule.Scheduler()
+        mock_job = make_mock_job()
+        job = scheduler.every().second.max_runs(3).do(mock_job)
+
+        scheduler.run_all()
+        assert mock_job.call_count == 1
+        assert job.max_runs(2) is job
+        scheduler.run_all()
+        assert mock_job.call_count == 2
+        assert scheduler.jobs == []
+
+    def test_max_runs_are_isolated_per_job(self):
+        scheduler = schedule.Scheduler()
+        limited_once = make_mock_job()
+        limited_twice = make_mock_job()
+        unlimited = make_mock_job()
+        scheduler.every().second.max_runs(1).do(limited_once)
+        scheduler.every().second.max_runs(2).do(limited_twice)
+        scheduler.every().second.do(unlimited)
+
+        scheduler.run_all()
+        assert limited_once.call_count == 1
+        assert limited_twice.call_count == 1
+        assert unlimited.call_count == 1
+        scheduler.run_all()
+        assert limited_once.call_count == 1
+        assert limited_twice.call_count == 2
+        assert unlimited.call_count == 2
+        assert len(scheduler.jobs) == 1
+
