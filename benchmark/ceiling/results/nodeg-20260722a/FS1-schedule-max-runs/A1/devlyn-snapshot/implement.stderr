   270	    def __str__(self) -> str:
   570	
   571	        The job's interval will randomly vary from the value given
   572	        to  `every` to `latest`. The range defined is inclusive on
   573	        both ends. For example, `every(A).to(B).seconds` executes
   574	        the job function every N seconds such that A <= N <= B.
   575	
   576	        :param latest: Maximum interval between randomized job runs
   577	        :return: The invoked job instance
   578	        """
   579	        self.latest = latest
   580	        return self
   581	
   582	    def max_runs(self, n: int):
   583	        """
   584	        Schedule the job to run at most ``n`` times.
   585	
   586	        :param n: Maximum number of times the job may run
   587	        :return: The invoked job instance
   588	        """
   589	        if isinstance(n, bool) or not isinstance(n, int) or n < 1:
   590	            raise ScheduleValueError("max_runs() requires a positive integer")
   591	        self._max_runs = n
   592	        return self
   593	
   594	    def until(
   595	        self,
   596	        until_time: Union[datetime.datetime, datetime.timedelta, datetime.time, str],
   597	    ):
   598	        """
   599	        Schedule job to run until the specified moment.
   600	
   601	        The job is canceled whenever the next run is calculated and it turns out the
   602	        next run is after the until_time. The job is also canceled right before it runs,
   603	        if the current time is after until_time. This latter case can happen when the
   604	        the job was scheduled to run before until_time, but runs after until_time.
   605	
   606	        If until_time is a moment in the past, ScheduleValueError is thrown.
   607	
   608	        :param until_time: A moment in the future representing the latest time a job can
   609	           be run. If only a time is supplied, the date is set to today.
   610	           The following formats are accepted:
   611	
   612	           - datetime.datetime
   613	           - datetime.timedelta
   614	           - datetime.time
   615	           - String in one of the following formats: "%Y-%m-%d %H:%M:%S",
   616	             "%Y-%m-%d %H:%M", "%Y-%m-%d", "%H:%M:%S", "%H:%M"
   617	             as defined by strptime() behaviour. If an invalid string format is passed,
   618	             ScheduleValueError is thrown.
   619	
   620	        :return: The invoked job instance
   680	            )
   681	        self.scheduler.jobs.append(self)
   682	        return self
   683	
   684	    @property
   685	    def should_run(self) -> bool:
   686	        """
   687	        :return: ``True`` if the job should be run now.
   688	        """
   689	        assert self.next_run is not None, "must run _schedule_next_run before"
   690	        return datetime.datetime.now() >= self.next_run
   691	
   692	    def run(self):
   693	        """
   694	        Run the job and immediately reschedule it.
   695	        If the job's deadline is reached (configured using .until()), the job is not
   696	        run and CancelJob is returned immediately. If the next scheduled run exceeds
   697	        the job's deadline, CancelJob is returned after the execution. In this latter
   698	        case CancelJob takes priority over any other returned value. If a maximum
   699	        run count is configured using .max_runs(), CancelJob is returned after the
   700	        final permitted execution.
   701	
   702	        :return: The return value returned by the `job_func`, or CancelJob if the job's
   703	                 deadline is reached.
   704	
   705	        """
   706	        if self._is_overdue(datetime.datetime.now()):
   707	            logger.debug("Cancelling job %s", self)
   708	            return CancelJob
   709	
   710	        logger.debug("Running job %s", self)
   711	        ret = self.job_func()
   712	        self.last_run = datetime.datetime.now()
   713	        self._schedule_next_run()
   714	        self._run_count += 1
   715	
   716	        if self._is_overdue(self.next_run):
   717	            logger.debug("Cancelling job %s", self)
   718	            return CancelJob
   719	        if self._max_runs is not None and self._run_count >= self._max_runs:
   720	            logger.debug("Cancelling job %s", self)
   365	
   366	        # Unschedule job after next_run passes the deadline
   367	        schedule.clear()
