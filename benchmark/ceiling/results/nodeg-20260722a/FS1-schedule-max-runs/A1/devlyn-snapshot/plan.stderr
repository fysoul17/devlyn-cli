   427	            raise IntervalError(
   428	                "Scheduling .friday() jobs is only allowed for weekly jobs. "
   429	                "Using .friday() on a job scheduled to run every 2 or more weeks "
   430	                "is not supported."
   431	            )
   432	        self.start_day = "friday"
   433	        return self.weeks
   434	
   435	    @property
   436	    def saturday(self):
   437	        if self.interval != 1:
   438	            raise IntervalError(
   439	                "Scheduling .saturday() jobs is only allowed for weekly jobs. "
   440	                "Using .saturday() on a job scheduled to run every 2 or more weeks "
   441	                "is not supported."
   442	            )
   443	        self.start_day = "saturday"
   444	        return self.weeks
   445	
   446	    @property
   447	    def sunday(self):
   448	        if self.interval != 1:
