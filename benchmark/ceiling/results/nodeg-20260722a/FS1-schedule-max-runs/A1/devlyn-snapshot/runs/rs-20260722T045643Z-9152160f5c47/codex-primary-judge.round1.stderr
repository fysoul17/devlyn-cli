test_schedule.py:1493:    def test_run_pending(self):
test_schedule.py:1494:        """Check that run_pending() runs pending jobs.
test_schedule.py-1495-        We do this by overriding datetime.datetime with mock objects
test_schedule.py-1496-        that represent increasing system times.
test_schedule.py-1497-
test_schedule.py:1498:        Please note that it is *intended behavior that run_pending() does not
test_schedule.py-1499-        run missed jobs*. For example, if you've registered a job that
test_schedule.py:1500:        should run every minute and you only call run_pending() in one hour
test_schedule.py-1501-        increments then your job won't be run 60 times in between but
test_schedule.py-1502-        only once.
test_schedule.py-1503-        """
test_schedule.py-1504-        mock_job = make_mock_job()
test_schedule.py-1505-
test_schedule.py-1506-        with mock_datetime(2010, 1, 6, 12, 15):
test_schedule.py-1507-            every().minute.do(mock_job)
test_schedule.py-1508-            every().hour.do(mock_job)
test_schedule.py-1509-            every().day.do(mock_job)
test_schedule.py-1510-            every().sunday.do(mock_job)
test_schedule.py:1511:            schedule.run_pending()
test_schedule.py-1512-            assert mock_job.call_count == 0
test_schedule.py-1513-
test_schedule.py-1514-        with mock_datetime(2010, 1, 6, 12, 16):
test_schedule.py:1515:            schedule.run_pending()
test_schedule.py-1516-            assert mock_job.call_count == 1
test_schedule.py-1517-
test_schedule.py-1518-        with mock_datetime(2010, 1, 6, 13, 16):
test_schedule.py-1519-            mock_job.reset_mock()
test_schedule.py:1520:            schedule.run_pending()
test_schedule.py-1521-            assert mock_job.call_count == 2
test_schedule.py-1522-
test_schedule.py-1523-        with mock_datetime(2010, 1, 7, 13, 16):
test_schedule.py-1524-            mock_job.reset_mock()
test_schedule.py:1525:            schedule.run_pending()
test_schedule.py-1526-            assert mock_job.call_count == 3
test_schedule.py-1527-
test_schedule.py-1528-        with mock_datetime(2010, 1, 10, 13, 16):
test_schedule.py-1529-            mock_job.reset_mock()
test_schedule.py:1530:            schedule.run_pending()
test_schedule.py-1531-            assert mock_job.call_count == 4
test_schedule.py-1532-
