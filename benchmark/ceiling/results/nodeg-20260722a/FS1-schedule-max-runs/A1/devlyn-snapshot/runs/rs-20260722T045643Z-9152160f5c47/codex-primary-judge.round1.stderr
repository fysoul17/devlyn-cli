   370	            every(5).seconds.until(datetime.time(11, 35, 20)).do(mock_job)
   371	            with mock_datetime(2020, 1, 1, 11, 35, 15):
   372	                schedule.run_pending()
   373	                assert mock_job.call_count == 1
   374	                assert len(schedule.jobs) == 1
   375	            with mock_datetime(2020, 1, 1, 11, 35, 20):
   376	                schedule.run_all()
   377	                assert mock_job.call_count == 2
   378	                assert len(schedule.jobs) == 0
   379	
   380	        # Unschedule job because current execution time has passed deadline
   381	        schedule.clear()
   382	        with mock_datetime(2020, 1, 1, 11, 35, 10):
   383	            mock_job.reset_mock()
   384	            every(5).seconds.until(datetime.time(11, 35, 20)).do(mock_job)
   385	            with mock_datetime(2020, 1, 1, 11, 35, 50):
   386	                schedule.run_pending()
   387	                assert mock_job.call_count == 0
   388	                assert len(schedule.jobs) == 0
   389	
   390	    def test_max_runs_chainable_and_validated(self):
   391	        mock_job = make_mock_job()
   392	        job = every(5).seconds.max_runs(3)
   393	        assert job.max_runs(3) is job
   394	        assert job.do(mock_job) is job
   395	        assert every().max_runs(3).seconds.do(mock_job) in schedule.jobs
   396	
   397	        for value in (0, -1, 1.5, "1", None, True):
   398	            with self.assertRaises(ScheduleValueError) as context:
   399	                every().max_runs(value)
   400	            self.assertIsInstance(context.exception, ValueError)
   401	
   402	    def test_max_runs_with_run_pending(self):
   403	        mock_job = make_mock_job()
   404	        with mock_datetime(2020, 1, 1, 11, 35, 10):
   405	            job = every().second.max_runs(2).do(mock_job)
   406	            assert not job.should_run
   407	            assert mock_job.call_count == 0
   408	
   409	            with mock_datetime(2020, 1, 1, 11, 35, 11):
   410	                schedule.run_pending()
   411	                assert mock_job.call_count == 1
   412	                assert schedule.jobs == [job]
   413	
   414	            with mock_datetime(2020, 1, 1, 11, 35, 12):
   415	                schedule.run_pending()
   416	                assert mock_job.call_count == 2
   417	                assert schedule.next_run() is None
   418	                assert schedule.idle_seconds() is None
   419	
   420	            with mock_datetime(2020, 1, 1, 11, 35, 13):
   421	                schedule.run_pending()
   422	                assert mock_job.call_count == 2
   423	
   424	    def test_max_runs_with_run_all(self):
   425	        scheduler = schedule.Scheduler()
   426	        mock_job = make_mock_job()
   427	        job = scheduler.every().second.max_runs(2).do(mock_job)
   428	
   429	        scheduler.run_all()
   430	        assert mock_job.call_count == 1
   431	        assert scheduler.jobs == [job]
   432	        scheduler.run_all()
   433	        assert mock_job.call_count == 2
   434	        assert scheduler.jobs == []
   435	
   436	    def test_max_runs_and_until_cancel_at_the_first_limit(self):
   437	        mock_job = make_mock_job()
   438	        with mock_datetime(2020, 1, 1, 11, 35, 10):
   439	            every(5).seconds.max_runs(3).until(datetime.time(11, 35, 20)).do(
   440	                mock_job
   441	            )
   442	            with mock_datetime(2020, 1, 1, 11, 35, 15):
   443	                schedule.run_pending()
   444	                assert mock_job.call_count == 1
   445	                assert len(schedule.jobs) == 1
   446	            with mock_datetime(2020, 1, 1, 11, 35, 20):
   447	                schedule.run_pending()
   448	                assert mock_job.call_count == 2
   449	                assert len(schedule.jobs) == 0
   450	
   451	            every(5).seconds.max_runs(2).until(datetime.time(11, 35, 30)).do(
   452	                mock_job
   453	            )
   454	            with mock_datetime(2020, 1, 1, 11, 35, 15):
   455	                schedule.run_pending()
   456	                assert mock_job.call_count == 3
   457	                assert len(schedule.jobs) == 1
   458	            with mock_datetime(2020, 1, 1, 11, 35, 20):
   459	                schedule.run_pending()
   460	                assert mock_job.call_count == 4
   461	                assert len(schedule.jobs) == 0
   462	
   463	    def test_max_runs_reconfiguration_preserves_run_count(self):
   464	        scheduler = schedule.Scheduler()
   465	        mock_job = make_mock_job()
   466	        job = scheduler.every().second.max_runs(3).do(mock_job)
   467	
   468	        scheduler.run_all()
   469	        assert mock_job.call_count == 1
   470	        scheduler.run_all()
   471	        assert mock_job.call_count == 2
   472	        assert job.max_runs(1) is job
   473	        scheduler.run_all()
   474	        assert mock_job.call_count == 2
   475	        assert scheduler.jobs == []
   476	
   477	    def test_max_runs_are_isolated_per_job(self):
   478	        scheduler = schedule.Scheduler()
   479	        limited_once = make_mock_job()
   480	        limited_twice = make_mock_job()
   481	        unlimited = make_mock_job()
   482	        scheduler.every().second.max_runs(1).do(limited_once)
   483	        scheduler.every().second.max_runs(2).do(limited_twice)
   484	        scheduler.every().second.do(unlimited)
   485	
   486	        scheduler.run_all()
   487	        assert limited_once.call_count == 1
   488	        assert limited_twice.call_count == 1
   489	        assert unlimited.call_count == 1
   490	        scheduler.run_all()
   491	        assert limited_once.call_count == 1
   492	        assert limited_twice.call_count == 2
   493	        assert unlimited.call_count == 2
   494	        assert len(scheduler.jobs) == 1
   495	
   496	    def test_weekday_at_todady(self):
   497	        mock_job = make_mock_job()
   498	
   499	        # This date is a wednesday
   500	        with mock_datetime(2020, 11, 25, 22, 38, 5):
   501	            job = every().wednesday.at("22:38:10").do(mock_job)
   502	            assert job.next_run.hour == 22
   503	            assert job.next_run.minute == 38
   504	            assert job.next_run.second == 10
   505	            assert job.next_run.year == 2020
   506	            assert job.next_run.month == 11
   507	            assert job.next_run.day == 25
   508	
   509	            job = every().wednesday.at("22:39").do(mock_job)
   510	            assert job.next_run.hour == 22
   511	            assert job.next_run.minute == 39
   512	            assert job.next_run.second == 00
   513	            assert job.next_run.year == 2020
   514	            assert job.next_run.month == 11
   515	            assert job.next_run.day == 25
