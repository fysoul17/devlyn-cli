   943	def _move_to_next_weekday(moment: datetime.datetime, weekday: str):
   944	    """
   945	    Move the given timestamp to the nearest given weekday. May be this week
   946	    or next week. If the timestamp is already at the given weekday, it is not
   947	    moved.
   948	    """
   949	    weekday_index = _weekday_index(weekday)
   950	
   951	    days_ahead = weekday_index - moment.weekday()
   952	    if days_ahead < 0:
   953	        # Target day already happened this week, move to next week
   954	        days_ahead += 7
   955	    return moment + datetime.timedelta(days=days_ahead)
   956	
   957	
   958	def _weekday_index(day: str) -> int:
   959	    weekdays = (
   960	        "monday",
   961	        "tuesday",
   962	        "wednesday",
   963	        "thursday",
   964	        "friday",
   965	        "saturday",
   966	        "sunday",
   967	    )
   968	    if day not in weekdays:
   969	        raise ScheduleValueError(
   970	            "Invalid start day (valid start days are {})".format(weekdays)
   971	        )
   972	    return weekdays.index(day)
