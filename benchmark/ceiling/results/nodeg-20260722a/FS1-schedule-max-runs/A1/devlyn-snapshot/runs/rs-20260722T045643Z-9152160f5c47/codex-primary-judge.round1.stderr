   789	        if self.unit in ["days", "hours"] or self.start_day is not None:
   790	            kwargs["minute"] = self.at_time.minute
   791	
   792	        moment = moment.replace(**kwargs)  # type: ignore
   793	
   794	        # When we set the time elements, we might end up in a different UTC-offset than the current offset.
   795	        # This happens when we cross into or out of daylight saving time.
   796	        moment = self._correct_utc_offset(moment, fixate_time=True)
   797	
   798	        return moment
   799	
   800	    def _correct_utc_offset(
   801	        self, moment: datetime.datetime, fixate_time: bool
   802	    ) -> datetime.datetime:
   803	        """
   804	        Given a datetime, corrects any mistakes in the utc offset.
   805	        This is similar to pytz' normalize, but adds the ability to attempt
   806	        keeping the time-component at the same hour/minute/second.
   807	        """
   808	        if self.at_time_zone is None:
   809	            return moment
   810	        # Normalize corrects the utc-offset to match the timezone
   811	        # For example: When a date&time&offset does not exist within a timezone,
   812	        # the normalization will change the utc-offset to where it is valid.
   813	        # It does this while keeping the moment in time the same, by moving the
   814	        # time component opposite of the utc-change.
   815	        offset_before_normalize = moment.utcoffset()
