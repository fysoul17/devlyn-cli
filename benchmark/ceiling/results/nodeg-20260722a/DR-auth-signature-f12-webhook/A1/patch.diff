+test('POST /webhook accepts a valid signed event', async () => {
+  const server = await startServer();
+  try {
+    const body = JSON.stringify({ id: 'event-happy', type: 'order.created', timestamp: 1721618860, data: {} });
+    const { status, body: responseBody } = await post(server, '/webhook', body, sign(body));
+    assert.strictEqual(status, 200);
+    assert.deepStrictEqual(responseBody, { accepted: true, id: 'event-happy' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a replayed event id', async () => {
+  const server = await startServer();
+  try {
+    const body = JSON.stringify({ id: 'event-replay', type: 'order.created', timestamp: 1721618861, data: {} });
+    await post(server, '/webhook', body, sign(body));
+    const { status, body: responseBody } = await post(server, '/webhook', body, sign(body));
+    assert.strictEqual(status, 409);
+    assert.deepStrictEqual(responseBody, { error: 'duplicate_event', id: 'event-replay' });
+  } finally {
+    server.close();
+  }
+});
