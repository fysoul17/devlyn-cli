const { test } = require('node:test');
const assert = require('node:assert');
const crypto = require('node:crypto');
const fs = require('node:fs');
const http = require('node:http');
const { app } = require('../server');

function startServer() {
  return new Promise((resolve) => {
    const server = http.createServer(app);
    server.listen(0, () => resolve(server));
  });
}

function get(server, path) {
  return new Promise((resolve, reject) => {
    const { port } = server.address();
    http
      .get(`http://127.0.0.1:${port}${path}`, (res) => {
        let body = '';
        res.on('data', (chunk) => (body += chunk));
        res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(body) }));
      })
      .on('error', reject);
  });
}

function post(server, path, body, signature) {
  return new Promise((resolve, reject) => {
    const { port } = server.address();
    const request = http.request({
      hostname: '127.0.0.1',
      port,
      path,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
        'X-Signature': signature,
      },
    }, (res) => {
      let responseBody = '';
      res.on('data', (chunk) => (responseBody += chunk));
      res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(responseBody) }));
    });
    request.on('error', reject);
    request.end(body);
  });
}

function sign(body) {
  const secret = fs.readFileSync(`${__dirname}/../data/webhook-secret.txt`, 'utf8').replace(/\r?\n$/, '');
  return crypto.createHmac('sha256', secret).update(body).digest('hex');
}

test('GET /health returns ok', async () => {
  const server = await startServer();
  try {
    const { status, body } = await get(server, '/health');
    assert.strictEqual(status, 200);
    assert.deepStrictEqual(body, { status: 'ok' });
  } finally {
    server.close();
  }
});

test('GET /items returns list', async () => {
  const server = await startServer();
  try {
    const { status, body } = await get(server, '/items');
    assert.strictEqual(status, 200);
    assert.ok(Array.isArray(body.items));
    assert.ok(body.items.length >= 2);
  } finally {
    server.close();
  }
});

test('GET /items/:id returns 404 for missing', async () => {
  const server = await startServer();
  try {
    const { status, body } = await get(server, '/items/99999');
    assert.strictEqual(status, 404);
    assert.strictEqual(body.error, 'not_found');
  } finally {
    server.close();
  }
});

test('POST /webhook accepts a valid signed event', async () => {
  const server = await startServer();
  try {
    const body = JSON.stringify({ id: 'event-happy', type: 'order.created', timestamp: 1721618860, data: {} });
    const { status, body: responseBody } = await post(server, '/webhook', body, sign(body));
    assert.strictEqual(status, 200);
    assert.deepStrictEqual(responseBody, { accepted: true, id: 'event-happy' });
  } finally {
    server.close();
  }
});

test('POST /webhook rejects a replayed event id', async () => {
  const server = await startServer();
  try {
    const body = JSON.stringify({ id: 'event-replay', type: 'order.created', timestamp: 1721618861, data: {} });
    await post(server, '/webhook', body, sign(body));
    const { status, body: responseBody } = await post(server, '/webhook', body, sign(body));
    assert.strictEqual(status, 409);
    assert.deepStrictEqual(responseBody, { error: 'duplicate_event', id: 'event-replay' });
  } finally {
    server.close();
  }
});

test('POST /webhook rejects a tampered body with a stale signature', async () => {
  const server = await startServer();
  try {
    const originalBody = JSON.stringify({ id: 'event-tampered', type: 'order.created', timestamp: 1721618862, data: {} });
    const tamperedBody = JSON.stringify({ id: 'event-tampered', type: 'order.created', timestamp: 1721618863, data: {} });
    const { status, body: responseBody } = await post(server, '/webhook', tamperedBody, sign(originalBody));
    assert.strictEqual(status, 401);
    assert.deepStrictEqual(responseBody, { error: 'invalid_signature' });
  } finally {
    server.close();
  }
});

