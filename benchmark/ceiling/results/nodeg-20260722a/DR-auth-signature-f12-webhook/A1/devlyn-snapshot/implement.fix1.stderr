diff --git a/tests/server.test.js b/tests/server.test.js
index 352227e2a250833e63821029bd8d50a8b6d5abb4..a9739dac38e18b392f84429245ac5de5f15b17a6
--- a/tests/server.test.js
+++ b/tests/server.test.js
@@ -124,3 +124,26 @@
     server.close();
   }
 });
+
+test('POST /webhook rejects malformed JSON before parsing when the signature is invalid', async () => {
+  const server = await startServer();
+  try {
+    const { status, body } = await post(server, '/webhook', 'not-json-at-all{{{', 'invalid-signature');
+    assert.strictEqual(status, 401);
+    assert.deepStrictEqual(body, { error: 'invalid_signature' });
+  } finally {
+    server.close();
+  }
+});
+
+test('POST /webhook rejects a correctly signed JSON primitive as an invalid body', async () => {
+  const server = await startServer();
+  try {
+    const body = '42';
+    const { status, body: responseBody } = await post(server, '/webhook', body, sign(body));
+    assert.strictEqual(status, 400);
+    assert.deepStrictEqual(responseBody, { error: 'invalid_body' });
+  } finally {
+    server.close();
+  }
+});

