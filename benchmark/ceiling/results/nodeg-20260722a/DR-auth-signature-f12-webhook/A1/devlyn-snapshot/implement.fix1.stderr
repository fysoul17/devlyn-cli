// Tiny Express server with a deliberately small API surface.
const crypto = require('crypto');
const express = require('express');
const fs = require('fs');

const app = express();
app.use(express.json({ verify: (req, _res, buffer) => { req.rawBody = buffer; } }));

const webhookSecret = fs.readFileSync(`${__dirname}/../data/webhook-secret.txt`, 'utf8').replace(/\r?\n$/, '');
const acceptedWebhookIds = new Set();

const items = [
  { id: 1, name: 'alpha', qty: 3 },
  { id: 2, name: 'beta', qty: 5 },
];

app.get('/health', (_req, res) => {
  res.json({ status: 'ok' });
});

app.get('/items', (_req, res) => {
  res.json({ items });
});

app.get('/items/:id', (req, res) => {
  const id = Number(req.params.id);
  const item = items.find((it) => it.id === id);
  if (!item) {
    res.status(404).json({ error: 'not_found', id });
    return;
  }
  res.json({ item });
});

app.post('/webhook', (req, res) => {
  const signature = req.get('X-Signature');
  const signatureBuffer = typeof signature === 'string' && /^[0-9a-f]+$/i.test(signature) && signature.length % 2 === 0
    ? Buffer.from(signature, 'hex')
    : null;
  const expectedSignature = Buffer.isBuffer(req.rawBody)
    ? Buffer.from(crypto.createHmac('sha256', webhookSecret).update(req.rawBody).digest('hex'), 'hex')
    : null;

  if (!expectedSignature || !signatureBuffer || expectedSignature.length !== signatureBuffer.length
    || !crypto.timingSafeEqual(expectedSignature, signatureBuffer)) {
    res.status(401).json({ error: 'invalid_signature' });
    return;
  }

  const { id, type, timestamp, data } = req.body;
  if (typeof id !== 'string' || id.length === 0
    || typeof type !== 'string' || type.length === 0
    || typeof timestamp !== 'number' || !Number.isFinite(timestamp)
    || typeof data !== 'object' || data === null || Array.isArray(data)) {
    res.status(400).json({ error: 'invalid_body' });
    return;
  }

  if (acceptedWebhookIds.has(id)) {
    res.status(409).json({ error: 'duplicate_event', id });
    return;
  }

  acceptedWebhookIds.add(id);
  res.json({ accepted: true, id });
});

if (require.main === module) {
  const port = Number(process.env.PORT) || 3000;
  app.listen(port, () => {
    console.log(`harbor-tools server listening on :${port}`);
  });
}

module.exports = { app };
