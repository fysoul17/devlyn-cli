/bin/zsh -lc "sed -n '1,220p' package.json && npm test && node <<'NODE'
const crypto = require('node:crypto');
const fs = require('node:fs');
const http = require('node:http');
const { app } = require('./server');
const secret = fs.readFileSync('./data/webhook-secret.txt', 'utf8').replace(/\\r?\\n"'$/, '"'');
const sign = body => crypto.createHmac('sha256', secret).update(body).digest('hex');
function post(server, body, signature, includeSignature = true) {
  return new Promise((resolve, reject) => {
    const { port } = server.address();
    const headers = {
      'Content-Type': 'application/json',
      'Content-Length': Buffer.byteLength(body),
    };
    if (includeSignature) headers['X-Signature'] = signature;
    const req = http.request({ hostname: '127.0.0.1', port, path: '/webhook', method: 'POST', headers }, res => {
      let responseBody = '';
      res.on('data', chunk => { responseBody += chunk; });
      res.on('end', () => resolve({ status: res.statusCode, contentType: res.headers['content-type'], body: responseBody }));
    });
    req.on('error', reject);
    req.end(body);
  });
}
(async () => {
  const server = http.createServer(app);
  await new Promise(resolve => server.listen(0, resolve));
  try {
    const first = JSON.stringify({ id: 'verify-adversarial', type: 'first', timestamp: 1, data: { original: true } });
    const second = JSON.stringify({ id: 'verify-adversarial', type: 'changed', timestamp: 999, data: { replacement: true } });
    const malformed = '{\"id\":';
    const results = {
      first: await post(server, first, sign(first)),
      duplicateChangedFields: await post(server, second, sign(second)),
      malformedMissingSignature: await post(server, malformed, undefined, false),
      malformedValidSignature: await post(server, malformed, sign(malformed)),
    };
    process.stdout.write("'`${JSON.stringify(results, null, 2)}'"\\n"'`);
  } finally {
    await new Promise(resolve => server.close(resolve));
  }
})().catch(error => { console.error(error); process.exitCode = 1; });
