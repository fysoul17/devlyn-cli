  process.stdout.write("'`LIVE_BIND_ERROR ${error.code}: ${error.message}'"\\n"'`);
});
server.listen(0, '"'127.0.0.1', () => {
  process.stdout.write("'`LIVE_BIND_OK ${JSON.stringify(server.address())}'"\\n"'`);
  server.close();
});
