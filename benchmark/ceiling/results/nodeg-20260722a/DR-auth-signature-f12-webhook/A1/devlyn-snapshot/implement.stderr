const assert = require('node:assert');
const crypto = require('node:crypto');
const fs = require('node:fs');
const { app } = require('./server');

const layer = app._router.stack.find((entry) => entry.route && entry.route.path === '/webhook');
assert.ok(layer, 'POST /webhook route is registered');
const webhook = layer.route.stack[0].handle;
const secret = fs.readFileSync('./data/webhook-secret.txt', 'utf8').replace(/\\r?\\n"'$/, '"'');
const sign = (body) => crypto.createHmac('sha256', secret).update(body).digest('hex');
const deliver = (body, signature) => {
  const result = {};
  webhook({
    rawBody: Buffer.from(body),
    body: JSON.parse(body),
    get: (name) => (name.toLowerCase() === 'x-signature' ? signature : undefined),
  }, {
    status(code) {
      result.status = code;
      return this;
    },
    json(payload) {
      result.body = payload;
      return this;
    },
  });
  return result;
};

const happy = JSON.stringify({ id: 'manual-happy', type: 'order.created', timestamp: 1, data: {} });
assert.deepStrictEqual(deliver(happy, sign(happy)), { body: { accepted: true, id: 'manual-happy' } });
const replay = JSON.stringify({ id: 'manual-replay', type: 'order.created', timestamp: 2, data: {} });
deliver(replay, sign(replay));
assert.deepStrictEqual(deliver(replay, sign(replay)), { status: 409, body: { error: 'duplicate_event', id: 'manual-replay' } });
const original = JSON.stringify({ id: 'manual-tampered', type: 'order.created', timestamp: 3, data: {} });
const tampered = JSON.stringify({ id: 'manual-tampered', type: 'order.created', timestamp: 4, data: {} });
assert.deepStrictEqual(deliver(tampered, sign(original)), { status: 401, body: { error: 'invalid_signature' } });
console.log('manual webhook route checks: 3 passed');
