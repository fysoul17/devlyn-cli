/bin/zsh -lc "node <<'NODE'
const http = require('node:http');
const { app } = require('./server');

function request(server, method, path, body, sendBody = true) {
  return new Promise((resolve, reject) => {
    const payload = sendBody ? JSON.stringify(body) : '';
    const { port } = server.address();
    const req = http.request({
      hostname: '127.0.0.1', port, path, method,
      headers: sendBody ? {
        'content-type': 'application/json',
        'content-length': Buffer.byteLength(payload),
      } : { 'content-length': 0 },
    }, (res) => {
      let raw = '';
      res.on('data', (chunk) => { raw += chunk; });
      res.on('end', () => resolve({ status: res.statusCode, raw, body: JSON.parse(raw) }));
    });
    req.on('error', reject);
    req.end(payload);
  });
}

const server = app.listen(0, '127.0.0.1', async () => {
  try {
    const initial = await request(server, 'GET', '/items', undefined, false);

    const emptyBody = await request(server, 'POST', '/items/import', undefined, false);
    const afterEmptyBody = await request(server, 'GET', '/items', undefined, false);

    const valid = await request(server, 'POST', '/items/import', {
      items: [
        { name: '  probe-a  ', qty: 7, extra: 'drop' },
        { name: 'probe-b', qty: 8, extra: 'drop' },
      ],
    });
    const afterValid = await request(server, 'GET', '/items', undefined, false);
    const appended = afterValid.body.items.slice(initial.body.items.length);

    const invalidMiddle = await request(server, 'POST', '/items/import', {
      items: [
        { name: 'would-append', qty: 1 },
        { name: '   ', qty: 0 },
        { name: 'also-would-append', qty: 2 },
      ],
    });
    const afterInvalidMiddle = await request(server, 'GET', '/items', undefined, false);

    const earlierQtyWins = await request(server, 'POST', '/items/import', {
      items: [
        { name: 'first', qty: 0 },
        { name: '', qty: 3 },
      ],
    });
    const afterEarlierQty = await request(server, 'GET', '/items', undefined, false);

    const emptyArray = await request(server, 'POST', '/items/import', { items: [] });
    const afterEmptyArray = await request(server, 'GET', '/items', undefined, false);

    const checks = {
      empty_body_exact: emptyBody.status === 400 && emptyBody.raw === JSON.stringify({ error: 'invalid_body' }),
      empty_body_unchanged: afterEmptyBody.raw === initial.raw,
      valid_response: valid.status === 201 && valid.raw === JSON.stringify({ inserted: 2 }),
      valid_rows_and_ids: JSON.stringify(appended) === JSON.stringify([
        { id: 3, name: 'probe-a', qty: 7 },
        { id: 4, name: 'probe-b', qty: 8 },
      ]),
      invalid_middle_name_first: invalidMiddle.status === 400 && invalidMiddle.raw === JSON.stringify({ error: 'invalid_batch', index: 1, field: 'name' }),
      invalid_middle_unchanged: afterInvalidMiddle.raw === afterValid.raw,
      first_invalid_index_wins: earlierQtyWins.status === 400 && earlierQtyWins.raw === JSON.stringify({ error: 'invalid_batch', index: 0, field: 'qty' }),
      later_rejection_unchanged: afterEarlierQty.raw === afterValid.raw,
      empty_array_vacuous_valid: emptyArray.status === 201 && emptyArray.raw === JSON.stringify({ inserted: 0 }) && afterEmptyArray.raw === afterValid.raw,
    };
    console.log(JSON.stringify({ checks, responses: { emptyBody, valid, appended, invalidMiddle, earlierQtyWins, emptyArray } }));
    if (Object.values(checks).some((value) => "'!value)) process.exitCode = 1;
  } catch (error) {
    console.error(error);
    process.exitCode = 1;
  } finally {
    server.close();
  }
});
