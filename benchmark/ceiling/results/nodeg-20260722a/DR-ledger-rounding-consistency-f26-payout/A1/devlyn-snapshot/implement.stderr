+  for (const event of ledger.events) {
+    if (!event || typeof event !== 'object' || Array.isArray(event)) {
+      payoutError('invalid_event');
+      return;
+    }
+    if (!['charge', 'refund', 'dispute'].includes(event.type)) {
+      payoutError('unknown_type');
+      return;
+    }
+    if (typeof event.merchant_id !== 'string' || event.merchant_id.length === 0) {
+      payoutError('missing_merchant_id');
+      return;
+    }
+    if (typeof event.id !== 'string' || event.id.length === 0) {
+      payoutError('missing_id');
+      return;
+    }
+    if (!Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
+      payoutError('invalid_amount_cents');
+      return;
+    }
+
+    const existing = eventsById.get(event.id);
+    if (existing) {
+      if (!isDeepStrictEqual(existing, event)) {
+        payoutError('conflicting_duplicate', { id: event.id });
+        return;
+      }
+      continue;
+    }
+    eventsById.set(event.id, event);
+
+    let merchant = merchantsById.get(event.merchant_id);
+    if (!merchant) {
+      merchant = {
+        merchant_id: event.merchant_id,
+        gross_charge_cents: 0,
+        refund_cents: 0,
+        dispute_cents: 0,
+        processing_fee_cents: 0,
+        dispute_fee_cents: 0,
+      };
+      merchantsById.set(event.merchant_id, merchant);
+    }
+
+    if (event.type === 'charge') {
+      merchant.gross_charge_cents += event.amount_cents;
+      merchant.processing_fee_cents += Math.round(
+        (event.amount_cents * rules.processing_fee_percent) / 100,
+      ) + rules.fixed_fee_cents;
+    } else if (event.type === 'refund') {
+      merchant.refund_cents += event.amount_cents;
+    } else {
+      merchant.dispute_cents += event.amount_cents;
+      merchant.dispute_fee_cents += rules.dispute_fee_cents;
+    }
+  }
+
+  const merchants = Array.from(merchantsById.values(), (merchant) => {
+    const netBeforeReserve = merchant.gross_charge_cents - merchant.refund_cents
+      - merchant.dispute_cents - merchant.processing_fee_cents - merchant.dispute_fee_cents;
+    let reserve_cents = netBeforeReserve > 0
+      ? Math.round((netBeforeReserve * rules.reserve_percent) / 100)
+      : 0;
+    let payout_cents = netBeforeReserve - reserve_cents;
+
+    if (payout_cents > 0 && payout_cents < rules.minimum_payout_cents) {
+      reserve_cents += payout_cents;
+      payout_cents = 0;
+    }
+
+    return { ...merchant, reserve_cents, payout_cents };
+  });
+
+  const output = {
+    total_payout_cents: 0,
+    total_processing_fee_cents: 0,
+    total_dispute_fee_cents: 0,
+    total_reserve_cents: 0,
+    merchants,
+  };
+  for (const merchant of merchants) {
+    output.total_payout_cents += merchant.payout_cents;
+    output.total_processing_fee_cents += merchant.processing_fee_cents;
+    output.total_dispute_fee_cents += merchant.dispute_fee_cents;
+    output.total_reserve_cents += merchant.reserve_cents;
+  }
+
+  console.log(JSON.stringify(output));
+}
+
 function main(argv) {
   const [command, ...rest] = argv;
 
