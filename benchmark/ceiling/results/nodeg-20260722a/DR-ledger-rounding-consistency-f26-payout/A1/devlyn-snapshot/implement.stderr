@@ -23,3 +25,48 @@
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+function writePayoutInput(t, ledger) {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
+  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
+  const inputPath = path.join(dir, 'ledger.json');
+  fs.writeFileSync(inputPath, JSON.stringify(ledger));
+  return inputPath;
+}
+
+test('payout calculates charges, refunds, disputes, and reserves', (t) => {
+  const inputPath = writePayoutInput(t, {
+    events: [
+      { id: 'charge-1', merchant_id: 'merchant-1', type: 'charge', amount_cents: 100000 },
+      { id: 'refund-1', merchant_id: 'merchant-1', type: 'refund', amount_cents: 1000 },
+      { id: 'dispute-1', merchant_id: 'merchant-1', type: 'dispute', amount_cents: 500 },
+    ],
+  });
+
+  const output = JSON.parse(run(['payout', '--input', inputPath]));
+  assert.deepStrictEqual(output, {
+    total_payout_cents: 84663,
+    total_processing_fee_cents: 2930,
+    total_dispute_fee_cents: 1500,
+    total_reserve_cents: 9407,
+    merchants: [{
+      merchant_id: 'merchant-1',
+      gross_charge_cents: 100000,
+      refund_cents: 1000,
+      dispute_cents: 500,
+      processing_fee_cents: 2930,
+      dispute_fee_cents: 1500,
+      reserve_cents: 9407,
+      payout_cents: 84663,
+    }],
+  });
+});
+
+test('payout reports a JSON validation error', (t) => {
+  const inputPath = writePayoutInput(t, {});
+  const result = spawnSync('node', [CLI, 'payout', '--input', inputPath], { encoding: 'utf8' });
+
+  assert.strictEqual(result.status, 2);
+  assert.strictEqual(result.stdout, '');
+  assert.strictEqual(result.stderr, '{"error":"missing_events"}\n');
+});

