#!/usr/bin/env node
// harbor-tools — small command-line utilities for local workflows.
// Keep the core commands minimal and easy to understand.

const fs = require('fs');
const path = require('path');
const { isDeepStrictEqual } = require('util');

const USAGE = `Usage: bench-cli <command> [options]

Commands:
  hello [--name NAME]        Print a greeting (default name: "world")
  version                    Print the CLI version from package.json
  --help, -h                 Show this help

Examples:
  bench-cli hello
  bench-cli hello --name alice
  bench-cli version
`;

function readPackageVersion() {
  const pkgPath = path.join(__dirname, '..', 'package.json');
  const raw = fs.readFileSync(pkgPath, 'utf8');
  return JSON.parse(raw).version;
}

function parseNameFlag(argv) {
  const idx = argv.indexOf('--name');
  if (idx === -1) return 'world';
  const value = argv[idx + 1];
  if (!value || value.startsWith('-')) {
    console.error('--name requires a value');
    process.exit(1);
  }
  return value;
}

function parseInputFlag(argv) {
  const idx = argv.indexOf('--input');
  if (idx === -1) return null;
  const value = argv[idx + 1];
  return value && !value.startsWith('-') ? value : null;
}

function payoutError(error, extra = {}) {
  console.error(JSON.stringify({ error, ...extra }));
  process.exitCode = 2;
}

function runPayout(argv) {
  const inputPath = parseInputFlag(argv);
  if (!inputPath) {
    payoutError('missing_input');
    return;
  }

  let ledger;
  try {
    ledger = JSON.parse(fs.readFileSync(inputPath, 'utf8'));
  } catch (error) {
    payoutError(error instanceof SyntaxError ? 'invalid_json' : 'input_unreadable');
    return;
  }

  if (ledger === null || typeof ledger !== 'object' || Array.isArray(ledger)) {
    payoutError('invalid_json');
    return;
  }
  if (!Object.prototype.hasOwnProperty.call(ledger, 'events')) {
    payoutError('missing_events');
    return;
  }
  if (!Array.isArray(ledger.events)) {
    payoutError('invalid_events');
    return;
  }

  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
  const rules = JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
  const eventsById = new Map();
  const merchantsById = new Map();

  for (const event of ledger.events) {
    if (!event || typeof event !== 'object' || Array.isArray(event)) {
      payoutError('invalid_event');
      return;
    }
    if (!['charge', 'refund', 'dispute'].includes(event.type)) {
      payoutError('unknown_type');
      return;
    }
    if (typeof event.merchant_id !== 'string' || event.merchant_id.length === 0) {
      payoutError('missing_merchant_id');
      return;
    }
    if (typeof event.id !== 'string' || event.id.length === 0) {
      payoutError('missing_id');
      return;
    }
    if (!Number.isInteger(event.amount_cents) || event.amount_cents <= 0) {
      payoutError('invalid_amount_cents');
      return;
    }

    const existing = eventsById.get(event.id);
    if (existing) {
      if (!isDeepStrictEqual(existing, event)) {
        payoutError('conflicting_duplicate', { id: event.id });
        return;
      }
      continue;
    }
    eventsById.set(event.id, event);

    let merchant = merchantsById.get(event.merchant_id);
    if (!merchant) {
      merchant = {
        merchant_id: event.merchant_id,
        gross_charge_cents: 0,
        refund_cents: 0,
        dispute_cents: 0,
        processing_fee_cents: 0,
        dispute_fee_cents: 0,
      };
      merchantsById.set(event.merchant_id, merchant);
    }

    if (event.type === 'charge') {
      merchant.gross_charge_cents += event.amount_cents;
      merchant.processing_fee_cents += Math.round(
        (event.amount_cents * rules.processing_fee_percent) / 100,
      ) + rules.fixed_fee_cents;
    } else if (event.type === 'refund') {
      merchant.refund_cents += event.amount_cents;
    } else {
      merchant.dispute_cents += event.amount_cents;
      merchant.dispute_fee_cents += rules.dispute_fee_cents;
    }
  }

  const merchants = Array.from(merchantsById.values(), (merchant) => {
    const netBeforeReserve = merchant.gross_charge_cents - merchant.refund_cents
      - merchant.dispute_cents - merchant.processing_fee_cents - merchant.dispute_fee_cents;
    let reserve_cents = netBeforeReserve > 0
      ? Math.round((netBeforeReserve * rules.reserve_percent) / 100)
      : 0;
    let payout_cents = netBeforeReserve - reserve_cents;

    if (payout_cents > 0 && payout_cents < rules.minimum_payout_cents) {
      reserve_cents += payout_cents;
      payout_cents = 0;
    }

    return { ...merchant, reserve_cents, payout_cents };
  });

  const output = {
    total_payout_cents: 0,
    total_processing_fee_cents: 0,
    total_dispute_fee_cents: 0,
    total_reserve_cents: 0,
    merchants,
  };
  for (const merchant of merchants) {
    output.total_payout_cents += merchant.payout_cents;
    output.total_processing_fee_cents += merchant.processing_fee_cents;
    output.total_dispute_fee_cents += merchant.dispute_fee_cents;
    output.total_reserve_cents += merchant.reserve_cents;
  }

  console.log(JSON.stringify(output));
}

function main(argv) {
  const [command, ...rest] = argv;

  if (!command || command === '--help' || command === '-h') {
    process.stdout.write(USAGE);
    return;
  }

  switch (command) {
    case 'hello': {
      const name = parseNameFlag(rest);
      console.log(`Hello, ${name}!`);
      return;
    }
    case 'version': {
      console.log(readPackageVersion());
      return;
    }
    case 'payout': {
      runPayout(rest);
      return;
    }
    default:
      console.error(`Unknown command: ${command}`);
      process.stderr.write(USAGE);
      process.exit(1);
  }
}

main(process.argv.slice(2));

