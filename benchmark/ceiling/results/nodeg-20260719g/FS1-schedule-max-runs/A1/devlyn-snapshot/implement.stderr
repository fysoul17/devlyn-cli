   569	        to  `every` to `latest`. The range defined is inclusive on
   570	        both ends. For example, `every(A).to(B).seconds` executes
   571	        the job function every N seconds such that A <= N <= B.
   572	
   573	        :param latest: Maximum interval between randomized job runs
   574	        :return: The invoked job instance
   575	        """
   576	        self.latest = latest
   577	        return self
   578	
   579	    def max_runs(self, n: int):
   580	        """
   581	        Limit the job to running ``n`` times.
   582	
   583	        :param n: Number of times the job may run
   584	        :return: The invoked job instance
   585	        """
   586	        if not isinstance(n, int) or n < 1:
   587	            raise ScheduleValueError("max_runs() requires an integer greater than 0")
   588	        self._runs_remaining = n
   589	        return self
   590	
   591	    def until(
   592	        self,
   593	        until_time: Union[datetime.datetime, datetime.timedelta, datetime.time, str],
   594	    ):
   595	        """
   596	        Schedule job to run until the specified moment.
   597	
   598	        The job is canceled whenever the next run is calculated and it turns out the
   599	        next run is after the until_time. The job is also canceled right before it runs,
   600	        if the current time is after until_time. This latter case can happen when the
   684	        :return: ``True`` if the job should be run now.
   685	        """
   686	        assert self.next_run is not None, "must run _schedule_next_run before"
   687	        return datetime.datetime.now() >= self.next_run
   688	
   689	    def run(self):
   690	        """
   691	        Run the job and immediately reschedule it.
   692	        If the job's deadline is reached (configured using .until()), the job is not
   693	        run and CancelJob is returned immediately. If the next scheduled run exceeds
   694	        the job's deadline, CancelJob is returned after the execution. In this latter
   695	        case CancelJob takes priority over any other returned value.
   696	        If the job's run limit (configured using .max_runs()) is reached, CancelJob is
   697	        returned after the execution.
   698	
   699	        :return: The return value returned by the `job_func`, or CancelJob if the job's
   700	                 deadline or run limit is reached.
   701	
   702	        """
   703	        if self._is_overdue(datetime.datetime.now()):
   704	            logger.debug("Cancelling job %s", self)
   705	            return CancelJob
   706	
   707	        logger.debug("Running job %s", self)
   708	        ret = self.job_func()
   709	        self.last_run = datetime.datetime.now()
   710	        self._schedule_next_run()
   711	
   712	        if self._runs_remaining is not None:
   713	            self._runs_remaining -= 1
   714	            if self._runs_remaining == 0:
   715	                logger.debug("Cancelling job %s", self)
   716	                return CancelJob
   717	
   718	        if self._is_overdue(self.next_run):
   719	            logger.debug("Cancelling job %s", self)
   720	            return CancelJob
   721	        return ret
   722	
