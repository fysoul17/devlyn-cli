const { app } = require('./server');
const { Readable } = require('node:stream');

const rawBody = Buffer.from('not valid json{{{');
const req = new Readable({ read() { this.push(rawBody); this.push(null); } });
req.method = 'POST';
req.url = '/webhook';
req.originalUrl = '/webhook';
req.headers = {
  'content-type': 'application/json',
  'content-length': String(rawBody.length),
  'x-signature': '0'.repeat(64),
};
Object.setPrototypeOf(req, app.request);

const headers = new Map();
let responseBody = '';
const res = {
  statusCode: 200,
  locals: {},
  setHeader(name, value) { headers.set(name.toLowerCase(), value); },
  getHeader(name) { return headers.get(name.toLowerCase()); },
  getHeaderNames() { return [...headers.keys()]; },
  removeHeader(name) { headers.delete(name.toLowerCase()); },
  write(chunk) { responseBody += chunk; return true; },
  end(chunk) {
    if (chunk) responseBody += chunk;
    console.log(JSON.stringify({ status: this.statusCode, contentType: this.getHeader('content-type'), body: JSON.parse(responseBody) }));
  },
};
Object.setPrototypeOf(res, app.response);

app.handle(req, res, (err) => {
  console.error(err);
  process.exitCode = 1;
});
