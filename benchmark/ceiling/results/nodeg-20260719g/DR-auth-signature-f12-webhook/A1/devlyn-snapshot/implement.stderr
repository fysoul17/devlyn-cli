    32	{
    33	  "verification_commands": [
    34	    {
    35	      "cmd": "npm test",
    36	      "exit_code": 0,
    37	      "stdout_contains": ["# fail 0"],
    38	      "stdout_not_contains": []
    39	    }
    40	  ]
    41	}
    42	```

