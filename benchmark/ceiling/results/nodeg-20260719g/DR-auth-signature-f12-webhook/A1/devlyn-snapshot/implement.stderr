     1	// Tiny Express server with a deliberately small API surface.
     2	const crypto = require('crypto');
     3	const express = require('express');
     4	const fs = require('fs');
     5	const path = require('path');
     6	
     7	const app = express();
     8	app.use(express.json({ verify: (req, _res, buf) => { req.rawBody = buf; } }));
     9	
    10	const items = [
