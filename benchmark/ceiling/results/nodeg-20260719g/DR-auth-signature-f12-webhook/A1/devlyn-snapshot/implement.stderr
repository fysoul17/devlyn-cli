/bin/zsh -lc "node <<'NODE'
const assert = require('node:assert/strict');
const crypto = require('node:crypto');
const fs = require('node:fs');
const http = require('node:http');
const path = require('node:path');
const { app } = require('./server');

const secret = fs.readFileSync(path.join(__dirname, 'data/webhook-secret.txt'), 'utf8').trim();
const socketPath = path.join('/private/tmp', "'`harbor-tools-webhook-${process.pid}.sock`);
const server = http.createServer(app);
const listen = new Promise((resolve, reject) => {
  server.once('"'error', reject);
  server.listen(socketPath, resolve);
});
const request = (rawBody, signature) => new Promise((resolve, reject) => {
  const request = http.request({
    socketPath,
    path: '/webhook',
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Content-Length': Buffer.byteLength(rawBody),
      'X-Signature': signature,
    },
  }, (response) => {
    let body = '';
    response.on('data', (chunk) => { body += chunk; });
    response.on('end', () => resolve({ status: response.statusCode, body: JSON.parse(body) }));
  });
  request.once('error', reject);
  request.end(rawBody);
});
const sign = (rawBody) => crypto.createHmac('sha256', secret).update(rawBody).digest('hex');

(async () => {
  await listen;
  const event = JSON.stringify({ id: 'unix-socket-accept', type: 'test.event', timestamp: 1, data: {} });
  assert.deepEqual(await request(event, sign(event)), { status: 200, body: { accepted: true, id: 'unix-socket-accept' } });
  const replay = JSON.stringify({ id: 'unix-socket-replay', type: 'test.event', timestamp: 2, data: {} });
  await request(replay, sign(replay));
  assert.deepEqual(await request(replay, sign(replay)), { status: 409, body: { error: 'duplicate_event', id: 'unix-socket-replay' } });
  const invalid = JSON.stringify({ id: 'unix-socket-invalid' });
  assert.deepEqual(await request(invalid, sign(invalid)), { status: 400, body: { error: 'invalid_body' } });
  const signed = JSON.stringify({ id: 'unix-socket-tampered', type: 'test.event', timestamp: 3, data: {} });
  const tampered = signed.replace('test.event', 'test.other');
  assert.deepEqual(await request(tampered, sign(signed)), { status: 401, body: { error: 'invalid_signature' } });
  await new Promise((resolve) => server.close(resolve));
  console.log('unix-socket webhook verification passed');
})().catch(async (error) => {
  await new Promise((resolve) => server.close(resolve));
  throw error;
});
