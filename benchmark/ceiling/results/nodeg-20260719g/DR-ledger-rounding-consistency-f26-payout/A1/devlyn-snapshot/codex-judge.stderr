     1	#!/usr/bin/env node
     2	// harbor-tools — small command-line utilities for local workflows.
     3	// Keep the core commands minimal and easy to understand.
     4	
     5	const fs = require('fs');
     6	const path = require('path');
     7	const { isDeepStrictEqual } = require('node:util');
     8	
     9	const USAGE = `Usage: bench-cli <command> [options]
    10	
    11	Commands:
    12	  hello [--name NAME]        Print a greeting (default name: "world")
    13	  version                    Print the CLI version from package.json
    14	  --help, -h                 Show this help
    15	
    16	Examples:
    17	  bench-cli hello
    18	  bench-cli hello --name alice
    19	  bench-cli version
    20	  bench-cli payout --input events.json
    21	`;
    22	
    23	function readPackageVersion() {
    24	  const pkgPath = path.join(__dirname, '..', 'package.json');
    25	  const raw = fs.readFileSync(pkgPath, 'utf8');
    26	  return JSON.parse(raw).version;
    27	}
    28	
    29	function parseNameFlag(argv) {
    30	  const idx = argv.indexOf('--name');
    31	  if (idx === -1) return 'world';
    32	  const value = argv[idx + 1];
    33	  if (!value || value.startsWith('-')) {
    34	    console.error('--name requires a value');
    35	    process.exit(1);
    36	  }
    37	  return value;
    38	}
    39	
    40	function parseInputFlag(argv) {
    41	  const idx = argv.indexOf('--input');
    42	  const value = argv[idx + 1];
    43	  if (idx === -1 || !value || value.startsWith('-')) {
    44	    console.error('--input requires a value');
    45	    process.exit(1);
    46	  }
    47	  return value;
    48	}
    49	
    50	function exitPayoutError(error, id) {
    51	  const payload = id === undefined ? { error } : { error, id };
    52	  process.stderr.write(JSON.stringify(payload));
    53	  process.exit(2);
    54	}
    55	
    56	function readPayoutInput(inputPath) {
    57	  try {
    58	    return JSON.parse(fs.readFileSync(inputPath, 'utf8'));
    59	  } catch (error) {
    60	    exitPayoutError('invalid_input');
    61	  }
    62	}
    63	
    64	function readPayoutRules() {
    65	  const rulesPath = path.join(__dirname, '..', 'data', 'payout-rules.json');
    66	  try {
    67	    return JSON.parse(fs.readFileSync(rulesPath, 'utf8'));
    68	  } catch (error) {
    69	    exitPayoutError('invalid_rules');
    70	  }
    71	}
    72	
    73	function isValidEvent(event) {
    74	  return event
    75	    && typeof event === 'object'
    76	    && !Array.isArray(event)
    77	    && typeof event.id === 'string'
    78	    && typeof event.merchant_id === 'string'
    79	    && ['charge', 'refund', 'dispute'].includes(event.type)
    80	    && Number.isInteger(event.amount_cents)
    81	    && event.amount_cents > 0;
    82	}
    83	
    84	function isSameEvent(left, right) {
    85	  return isDeepStrictEqual(left, right);
    86	}
    87	
    88	function createMerchant(merchantId) {
    89	  return {
    90	    merchant_id: merchantId,
    91	    gross_charge_cents: 0,
    92	    refund_cents: 0,
    93	    dispute_cents: 0,
    94	    processing_fee_cents: 0,
    95	    dispute_fee_cents: 0,
    96	  };
    97	}
    98	
    99	function runPayout(argv) {
   100	  const inputPath = parseInputFlag(argv);
   101	  const input = readPayoutInput(inputPath);
   102	  const rules = readPayoutRules();
   103	
   104	  if (!input || typeof input !== 'object' || !Array.isArray(input.events)) {
   105	    exitPayoutError('invalid_input');
   106	  }
   107	
   108	  const seenEvents = new Map();
   109	  const merchantsById = new Map();
   110	
   111	  for (const event of input.events) {
   112	    if (!isValidEvent(event)) exitPayoutError('invalid_input');
   113	
   114	    const seenEvent = seenEvents.get(event.id);
   115	    if (seenEvent) {
   116	      if (!isSameEvent(seenEvent, event)) {
   117	        exitPayoutError('conflicting_duplicate', event.id);
   118	      }
   119	      continue;
   120	    }
   121	    seenEvents.set(event.id, event);
   122	
   123	    let merchant = merchantsById.get(event.merchant_id);
   124	    if (!merchant) {
   125	      merchant = createMerchant(event.merchant_id);
   126	      merchantsById.set(event.merchant_id, merchant);
   127	    }
   128	
   129	    if (event.type === 'charge') {
   130	      merchant.gross_charge_cents += event.amount_cents;
   131	      merchant.processing_fee_cents += Math.round(
   132	        event.amount_cents * rules.processing_fee_percent / 100,
   133	      ) + rules.fixed_fee_cents;
   134	    } else if (event.type === 'refund') {
   135	      merchant.refund_cents += event.amount_cents;
   136	    } else {
   137	      merchant.dispute_cents += event.amount_cents;
   138	      merchant.dispute_fee_cents += rules.dispute_fee_cents;
   139	    }
   140	  }
   141	
   142	  const merchants = Array.from(merchantsById.values(), (merchant) => {
   143	    const netBeforeReserve = merchant.gross_charge_cents
   144	      - merchant.refund_cents
   145	      - merchant.dispute_cents
   146	      - merchant.processing_fee_cents
   147	      - merchant.dispute_fee_cents;
   148	    let reserveCents = netBeforeReserve > 0
   149	      ? Math.round(netBeforeReserve * rules.reserve_percent / 100)
   150	      : 0;
   151	    let payoutCents = netBeforeReserve - reserveCents;
   152	
   153	    if (payoutCents > 0 && payoutCents < rules.minimum_payout_cents) {
   154	      reserveCents += payoutCents;
   155	      payoutCents = 0;
   156	    }
   157	
   158	    return {
   159	      ...merchant,
   160	      reserve_cents: reserveCents,
   161	      payout_cents: payoutCents,
   162	    };
   163	  });
   164	
   165	  const result = {
   166	    total_payout_cents: merchants.reduce((total, merchant) => total + merchant.payout_cents, 0),
   167	    total_processing_fee_cents: merchants.reduce(
   168	      (total, merchant) => total + merchant.processing_fee_cents,
   169	      0,
   170	    ),
   171	    total_dispute_fee_cents: merchants.reduce(
   172	      (total, merchant) => total + merchant.dispute_fee_cents,
   173	      0,
   174	    ),
   175	    total_reserve_cents: merchants.reduce((total, merchant) => total + merchant.reserve_cents, 0),
   176	    merchants,
   177	  };
   178	
   179	  process.stdout.write(JSON.stringify(result));
   180	}
   181	
   182	function main(argv) {
   183	  const [command, ...rest] = argv;
   184	
   185	  if (!command || command === '--help' || command === '-h') {
   186	    process.stdout.write(USAGE);
   187	    return;
   188	  }
   189	
   190	  switch (command) {
   191	    case 'hello': {
   192	      const name = parseNameFlag(rest);
   193	      console.log(`Hello, ${name}!`);
   194	      return;
   195	    }
   196	    case 'version': {
   197	      console.log(readPackageVersion());
   198	      return;
   199	    }
   200	    case 'payout': {
   201	      runPayout(rest);
   202	      return;
   203	    }
   204	    default:
   205	      console.error(`Unknown command: ${command}`);
   206	      process.stderr.write(USAGE);
   207	      process.exit(1);
   208	  }
   209	}
   210	
   211	main(process.argv.slice(2));
     1	const { test } = require('node:test');
     2	const assert = require('node:assert');
     3	const { execFileSync } = require('node:child_process');
     4	const fs = require('node:fs');
     5	const os = require('node:os');
     6	const path = require('node:path');
     7	
     8	const CLI = path.join(__dirname, '..', 'bin', 'cli.js');
     9	
    10	function run(args) {
    11	  return execFileSync('node', [CLI, ...args], { encoding: 'utf8' });
    12	}
    13	
    14	test('hello default', () => {
    15	  const out = run(['hello']);
    16	  assert.match(out, /Hello, world!/);
    17	});
    18	
    19	test('hello with --name', () => {
    20	  const out = run(['hello', '--name', 'alice']);
    21	  assert.match(out, /Hello, alice!/);
    22	});
    23	
    24	test('version prints package version', () => {
    25	  const out = run(['version']);
    26	  assert.match(out, /\d+\.\d+\.\d+/);
    27	});
    28	
    29	function writeInput(events) {
    30	  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'bench-cli-'));
    31	  const inputPath = path.join(dir, 'events.json');
    32	  fs.writeFileSync(inputPath, JSON.stringify({ events }));
    33	  return { dir, inputPath };
    34	}
    35	
    36	test('payout calculates merchant totals', () => {
    37	  const { dir, inputPath } = writeInput([
    38	    { id: 'charge-1', merchant_id: 'merchant-1', type: 'charge', amount_cents: 10000 },
    39	    { id: 'refund-1', merchant_id: 'merchant-1', type: 'refund', amount_cents: 2000 },
    40	    { id: 'charge-2', merchant_id: 'merchant-2', type: 'charge', amount_cents: 500 },
    41	  ]);
    42	
    43	  try {
    44	    assert.deepStrictEqual(JSON.parse(run(['payout', '--input', inputPath])), {
    45	      total_payout_cents: 6912,
    46	      total_processing_fee_cents: 365,
    47	      total_dispute_fee_cents: 0,
    48	      total_reserve_cents: 1223,
    49	      merchants: [
    50	        {
    51	          merchant_id: 'merchant-1',
    52	          gross_charge_cents: 10000,
    53	          refund_cents: 2000,
    54	          dispute_cents: 0,
    55	          processing_fee_cents: 320,
    56	          dispute_fee_cents: 0,
    57	          reserve_cents: 768,
    58	          payout_cents: 6912,
    59	        },
    60	        {
    61	          merchant_id: 'merchant-2',
    62	          gross_charge_cents: 500,
    63	          refund_cents: 0,
    64	          dispute_cents: 0,
    65	          processing_fee_cents: 45,
    66	          dispute_fee_cents: 0,
    67	          reserve_cents: 455,
    68	          payout_cents: 0,
    69	        },
    70	      ],
    71	    });
    72	  } finally {
    73	    fs.rmSync(dir, { recursive: true });
    74	  }
    75	});
    76	
    77	test('payout rejects invalid events', () => {
    78	  const { dir, inputPath } = writeInput([
    79	    { id: 'charge-1', type: 'charge', amount_cents: 10000 },
    80	  ]);
    81	
    82	  try {
    83	    assert.throws(
    84	      () => run(['payout', '--input', inputPath]),
    85	      (error) => {
    86	        assert.strictEqual(error.status, 2);
    87	        assert.strictEqual(error.stdout, '');
    88	        assert.deepStrictEqual(JSON.parse(error.stderr), { error: 'invalid_input' });
    89	        return true;
    90	      },
    91	    );
    92	  } finally {
    93	    fs.rmSync(dir, { recursive: true });
    94	  }
    95	});
    96	
