    12	
    13	function get(server, path) {
    14	  return new Promise((resolve, reject) => {
    15	    const { port } = server.address();
    16	    http
    17	      .get(`http://127.0.0.1:${port}${path}`, (res) => {
    18	        let body = '';
    19	        res.on('data', (chunk) => (body += chunk));
    20	        res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(body), text: body }));
    21	      })
    22	      .on('error', reject);
    23	  });
    24	}
    25	
    26	function post(server, path, body) {
    27	  return new Promise((resolve, reject) => {
    28	    const { port } = server.address();
    29	    const request = http.request(
    30	      `http://127.0.0.1:${port}${path}`,
    31	      {
    32	        method: 'POST',
    33	        headers: { 'content-type': 'application/json' },
    34	      },
    35	      (res) => {
    36	        let responseBody = '';
    37	        res.on('data', (chunk) => (responseBody += chunk));
    38	        res.on('end', () => {
    39	          resolve({ status: res.statusCode, body: JSON.parse(responseBody) });
    40	        });
    41	      },
    42	    );
    43	    request.on('error', reject);
    44	    request.end(JSON.stringify(body));
    45	  });
    46	}
