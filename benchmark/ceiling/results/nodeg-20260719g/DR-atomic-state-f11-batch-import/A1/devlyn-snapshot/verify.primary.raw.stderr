const assert = require('node:assert/strict');
const { app } = require('./server');
const routes = app._router.stack.filter((layer) => layer.route).map((layer) => layer.route);
const handler = (method, path) => routes.find((route) => route.path === path && route.methods[method]).stack[0].handle;
const importItems = handler('post', '/items/import');
const getItems = handler('get', '/items');
function invoke(fn, body) {
  const result = { status: 200 };
  const res = {
    status(code) { result.status = code; return this; },
    json(value) { result.body = value; result.text = JSON.stringify(value); return this; },
