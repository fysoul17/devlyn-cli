diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..dd654eb 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,12 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints package version as JSON', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.strictEqual(out, '{"version":"0.1.0"}\n');
+});
+
+test('version rejects unsupported --format value', () => {
+  assert.throws(() => run(['version', '--format', 'yaml']), (err) => err.status === 1);
