/bin/zsh -lc "node <<'NODE'
const assert = require('node:assert/strict');
const { spawnSync } = require('node:child_process');
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');

const cli = path.resolve('bin/cli.js');
const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'devlyn-cart-manual-'));
const inputPath = path.join(directory, 'cart.json');

function writeCart(cart) {
  fs.writeFileSync(inputPath, JSON.stringify(cart));
}

function run(cart) {
  writeCart(cart);
  return spawnSync(process.execPath, [cli, 'cart', '--input', inputPath], { encoding: 'utf8' });
}

function runWithCatalogFailure(mode) {
  writeCart({ state: 'CA', coupon: null, items: [{ sku: 'MUG', qty: 1 }] });
  const bootstrap = "'`
    const fs = require('"'fs');
    const originalReadFileSync = fs.readFileSync;
    fs.readFileSync = function (file, ...args) {
      if (String(file).endsWith('/data/catalog.json')) {
        if ("'${JSON.stringify(mode)} === '"'missing') throw new Error('simulated missing catalog');
        return '{';
      }
      return originalReadFileSync.call(this, file, ...args);
    };
    process.argv = ['node', "'${JSON.stringify(cli)}, '"'cart', '--input', "'${JSON.stringify(inputPath)}];
    require(${JSON.stringify(cli)});
  `;
  return spawnSync(process.execPath, ['"'-e', bootstrap], { encoding: 'utf8' });
}

for (const mode of ['missing', 'broken']) {
  const result = runWithCatalogFailure(mode);
  assert.equal(result.status, 2);
  assert.equal(result.stdout, '');
  assert.equal(result.stderr, '{\"error\":\"invalid_catalog\"}\\n');
}

const precedence = run({
  state: 'CA',
  coupon: null,
  items: [{ sku: 'MUG', qty: 0 }, { sku: 'NOPE', qty: 1 }],
});
assert.equal(precedence.status, 2);
assert.equal(precedence.stdout, '');
assert.equal(precedence.stderr, '{\"error\":\"invalid_sku\",\"sku\":\"NOPE\"}\\n');

const nullCoupon = run({ state: 'CA', coupon: null, items: [{ sku: 'MUG', qty: 1 }] });
const omittedCoupon = run({ state: 'CA', items: [{ sku: 'MUG', qty: 1 }] });
assert.equal(nullCoupon.status, 0);
assert.equal(omittedCoupon.status, 0);
assert.equal(nullCoupon.stderr, '');
assert.equal(omittedCoupon.stderr, '');
assert.deepEqual(JSON.parse(omittedCoupon.stdout), JSON.parse(nullCoupon.stdout));

fs.rmSync(directory, { recursive: true, force: true });
console.log('manual catalog failure, validation precedence, and omitted-coupon checks: PASS');
