    12	}
    13	
    14	function writeCart(t, cart) {
    15	  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'harbor-tools-cart-'));
    16	  const inputPath = path.join(directory, 'cart.json');
    17	  fs.writeFileSync(inputPath, JSON.stringify(cart));
    18	  t.after(() => fs.rmSync(directory, { recursive: true, force: true }));
    19	  return inputPath;
