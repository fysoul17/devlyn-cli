     1	#!/usr/bin/env node
     2	// harbor-tools — small command-line utilities for local workflows.
     3	// Keep the core commands minimal and easy to understand.
     4	
     5	const fs = require('fs');
     6	const path = require('path');
     7	
     8	const USAGE = `Usage: bench-cli <command> [options]
     9	
    10	Commands:
    11	  hello [--name NAME]        Print a greeting (default name: "world")
    12	  version                    Print the CLI version from package.json
    13	  --help, -h                 Show this help
    14	
    15	Examples:
    16	  bench-cli hello
    17	  bench-cli hello --name alice
    18	  bench-cli version
    19	`;
    20	
    21	function readPackageVersion() {
    22	  const pkgPath = path.join(__dirname, '..', 'package.json');
    23	  const raw = fs.readFileSync(pkgPath, 'utf8');
    24	  return JSON.parse(raw).version;
    25	}
    26	
    27	function parseNameFlag(argv) {
    28	  const idx = argv.indexOf('--name');
    29	  if (idx === -1) return 'world';
    30	  const value = argv[idx + 1];
    31	  if (!value || value.startsWith('-')) {
    32	    console.error('--name requires a value');
    33	    process.exit(1);
    34	  }
    35	  return value;
    36	}
    37	
    38	function failCart(error) {
    39	  process.stderr.write(`${JSON.stringify(error)}\n`);
    40	  process.exit(2);
    41	}
    42	
    43	function runCart(argv) {
    44	  const inputIndex = argv.indexOf('--input');
    45	  const inputPath = argv[inputIndex + 1];
    46	  if (inputIndex === -1 || !inputPath || inputPath.startsWith('-')) {
    47	    failCart({ error: 'invalid_input' });
    48	  }
    49	
    50	  let input;
    51	  try {
    52	    input = fs.readFileSync(inputPath, 'utf8');
    53	  } catch {
    54	    failCart({ error: 'invalid_input' });
    55	  }
    56	
    57	  let cart;
    58	  try {
    59	    cart = JSON.parse(input);
    60	  } catch {
    61	    failCart({ error: 'invalid_json' });
    62	  }
    63	
