diff --git a/bin/cli.js b/bin/cli.js
index fcff156..efacd6f 100644
--- a/bin/cli.js
+++ b/bin/cli.js
@@ -57,6 +57,16 @@ function main(argv) {
       return;
     }
     case 'version': {
+      const formatIndex = rest.indexOf('--format');
+      if (formatIndex !== -1) {
+        const format = rest[formatIndex + 1];
+        if (format !== 'json') {
+          console.error(`Unsupported version format: ${format}`);
+          process.exit(1);
+        }
+        console.log(JSON.stringify({ version: readPackageVersion() }));
+        return;
+      }
       console.log(readPackageVersion());
       return;
     }
diff --git a/tests/cli.test.js b/tests/cli.test.js
index c7363e8..0b3b31d 100644
--- a/tests/cli.test.js
+++ b/tests/cli.test.js
@@ -23,3 +23,9 @@ test('version prints package version', () => {
   const out = run(['version']);
   assert.match(out, /\d+\.\d+\.\d+/);
 });
+
+test('version prints JSON when requested', () => {
+  const out = run(['version', '--format', 'json']);
+  const version = JSON.parse(out.trim());
+  assert.match(version.version, /^\d+\.\d+\.\d+$/);
+});
