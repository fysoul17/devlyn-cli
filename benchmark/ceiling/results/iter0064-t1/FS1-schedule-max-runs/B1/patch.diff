+    def test_max_runs_cancels_after_budget_with_run_pending(self):
+        mock_job = make_mock_job()
+
+        with mock_datetime(2020, 1, 1, 0, 0, 0):
+            job = every().max_runs(2).second.do(mock_job)
+            assert job in schedule.jobs
+            assert schedule.next_run() == job.next_run
+
+        with mock_datetime(2020, 1, 1, 0, 0, 1):
+            schedule.run_pending()
+            assert mock_job.call_count == 1
+            assert job in schedule.jobs
+
+        with mock_datetime(2020, 1, 1, 0, 0, 2):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+            assert job not in schedule.jobs
+            assert schedule.next_run() is None
