+    def max_runs(self, n: int):
+        """
+        Schedule the job to run no more than ``n`` times in total.
+
+        The job is canceled after the ``n``th execution. If the configured
+        limit has already been reached, the job is canceled without running
+        again.
+
+        :param n: Maximum number of job executions. Must be an integer >= 1.
+        :return: The invoked job instance
+        """
+        if not isinstance(n, int) or isinstance(n, bool) or n < 1:
+            raise ValueError(
+                "max_runs() requires an integer greater than or equal to 1"
+            )
+        self._max_runs = n
+        return self
