+    def test_max_runs_validation(self):
+        job = every()
+        assert job.max_runs(1) is job
+
+        for invalid in (0, -1, 1.5, "1", None, True, False):
+            with self.assertRaises(ValueError):
+                job.max_runs(invalid)
+
+    def test_max_runs_cancels_after_run_pending_budget(self):
+        mock_job = make_mock_job()
+
+        with mock_datetime(2020, 1, 1, 11, 35, 10):
+            job = every(5).seconds.max_runs(2).do(mock_job)
+            assert job in schedule.jobs
+
+        with mock_datetime(2020, 1, 1, 11, 35, 15):
+            schedule.run_pending()
+            assert mock_job.call_count == 1
+            assert job in schedule.jobs
+
+        with mock_datetime(2020, 1, 1, 11, 35, 20):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+            assert job not in schedule.jobs
+            assert schedule.next_run() is None
+            assert schedule.idle_seconds() is None
+
+        with mock_datetime(2020, 1, 1, 11, 35, 25):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+
+    def test_max_runs_cancels_after_run_all_budget(self):
+        mock_job = make_mock_job()
+        every().day.max_runs(2).do(mock_job)
+
+        schedule.run_all()
+        assert mock_job.call_count == 1
+        assert len(schedule.jobs) == 1
+
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert len(schedule.jobs) == 0
+
+        schedule.run_all()
+        assert mock_job.call_count == 2
+
+    def test_max_runs_counts_failing_job_execution(self):
