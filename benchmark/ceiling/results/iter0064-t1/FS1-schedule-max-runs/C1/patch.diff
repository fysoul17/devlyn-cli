+    def max_runs(self, n: int):
+        """
+        Schedule the job to cancel itself after it has run a fixed number of times.
+
+        The job function is still executed on the nth run. After that execution,
+        the job is cancelled before it can run again.
+
+        :param n: Maximum number of times the job function can execute
+        :raises ValueError: If ``n`` is not an integer greater than or equal to 1
+        :return: The invoked job instance
+        """
+        if not isinstance(n, int) or isinstance(n, bool) or n < 1:
+            raise ValueError(
+                "max_runs() requires an integer greater than or equal to 1"
+            )
+        self._max_runs = n
+        return self
+
