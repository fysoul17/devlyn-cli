+
+        with self.assertRaises(RuntimeError):
+            schedule.run_all()
+
+        assert mock_job.call_count == 1
+        assert len(schedule.jobs) == 0
+
+        schedule.run_all()
+        assert mock_job.call_count == 1
+
+    def test_max_runs_can_be_chained_before_time_unit(self):
