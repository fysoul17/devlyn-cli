@@ -176,6 +176,25 @@ class SyndicationFeedTest(FeedTestCase):
                 item.getElementsByTagName('guid')[0].attributes.get(
                     'isPermaLink').value, "true")
 
+    def test_rss2_feed_comments(self):
+        paths = [
+            '/syndication/rss2/comments/',
+            '/syndication/rss2/comments-extra-kwargs/',
+        ]
+        for path in paths:
+            with self.subTest(path=path):
+                response = self.client.get(path)
+                doc = minidom.parseString(response.content)
+                chan = doc.getElementsByTagName(
+                    'rss')[0].getElementsByTagName('channel')[0]
+                items = chan.getElementsByTagName('item')
+                for item in items:
+                    link = item.getElementsByTagName(
+                        'link')[0].firstChild.wholeText
+                    comments = item.getElementsByTagName(
+                        'comments')[0].firstChild.wholeText
+                    self.assertEqual(comments, '%scomments/' % link)
+
