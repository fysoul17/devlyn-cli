+
+    @classmethod
+    def _condition_references_order_field(cls, condition):
+        if condition is None:
+            return False
+        for child in condition.children:
+            if isinstance(child, tuple):
+                if child[0].split(LOOKUP_SEP, 1)[0] == '_order':
+                    return True
+            elif hasattr(child, 'children') and cls._condition_references_order_field(child):
+                return True
+        return False
