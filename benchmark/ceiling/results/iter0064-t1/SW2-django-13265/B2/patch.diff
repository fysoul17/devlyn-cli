+    def test_create_model_with_order_with_respect_to_index(self):
+        """
+        An index on order_with_respect_to's _order field is created after the
+        option adds the field.
+        """
+        look = ModelState('testapp', 'Look', [
+            ('id', models.AutoField(primary_key=True)),
+        ])
+        look_image = ModelState('testapp', 'LookImage', [
+            ('id', models.AutoField(primary_key=True)),
+            ('look', models.ForeignKey('testapp.Look', models.CASCADE)),
+            ('image_url', models.URLField(blank=True, max_length=10000, null=True)),
+        ], {
+            'order_with_respect_to': 'look',
+            'indexes': [models.Index(fields=['look', '_order'], name='look_image_look_order_idx')],
+        })
+        changes = self.get_changes([look], [look, look_image])
+        added_index = models.Index(fields=['look', '_order'], name='look_image_look_order_idx')
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, ['CreateModel', 'AddIndex'])
+        self.assertOperationAttributes(
+            changes, 'testapp', 0, 0,
+            name='LookImage',
+            options={'order_with_respect_to': 'look'},
+        )
+        self.assertNotIn('_order', [name for name, field in changes['testapp'][0].operations[0].fields])
+        self.assertOperationAttributes(changes, 'testapp', 0, 1, model_name='lookimage', index=added_index)
+
     def test_add_indexes(self):
