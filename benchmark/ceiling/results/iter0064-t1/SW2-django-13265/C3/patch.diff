+            'order_with_respect_to': 'look',
+            'indexes': [
+                models.Index(fields=['look', '_order'], name='look_image_look_order_idx'),
+            ],
+        })
+        changes = self.get_changes([look], [look, look_image])
+        added_index = models.Index(fields=['look', '_order'], name='look_image_look_order_idx')
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, ['CreateModel', 'AddIndex'])
+        self.assertOperationAttributes(
+            changes, 'testapp', 0, 0, name='LookImage',
+            options={'order_with_respect_to': 'look'},
+        )
+        self.assertOperationAttributes(changes, 'testapp', 0, 1, model_name='lookimage', index=added_index)
