+        Indexes on the generated _order field are created after the field.
+        """
+        look = ModelState('otherapp', 'Look', [
+            ('id', models.AutoField(primary_key=True)),
+        ])
+        look_image = ModelState('testapp', 'LookImage', [
+            ('id', models.AutoField(primary_key=True)),
+            ('look', models.ForeignKey('otherapp.Look', models.CASCADE)),
