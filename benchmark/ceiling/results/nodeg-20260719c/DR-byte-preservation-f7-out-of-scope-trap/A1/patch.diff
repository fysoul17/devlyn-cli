+
+test('version prints JSON with --format json', () => {
+  const out = run(['version', '--format', 'json']);
+  assert.strictEqual(out, `${JSON.stringify({ version })}\n`);
+});
+
+test('version --format yaml exits with error', () => {
+  assert.throws(
