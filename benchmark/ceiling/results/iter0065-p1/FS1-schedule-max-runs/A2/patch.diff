+    def test_max_runs_is_chainable_before_and_after_time_unit(self):
+        mock_job = make_mock_job()
+
+        after_unit = every(5).seconds
+        assert after_unit.max_runs(3) is after_unit
+        assert after_unit.do(mock_job) is after_unit
+        assert after_unit in schedule.jobs
+
+        schedule.clear()
+
+        before_unit = every().max_runs(3)
+        assert before_unit.seconds is before_unit
+        assert before_unit.do(mock_job) is before_unit
+        assert before_unit in schedule.jobs
+
+    def test_max_runs_rejects_invalid_values(self):
+        for value in (True, False, 0, -1, 1.5, "1", None):
+            with self.subTest(max_runs=value):
+                self.assertRaises(ValueError, every().max_runs, value)
+
+    def test_max_runs_cancels_after_nth_run_pending_execution(self):
+        mock_job = make_mock_job()
+
+        with mock_datetime(2020, 1, 1, 0, 0, 0):
+            every().second.max_runs(2).do(mock_job)
+
+        with mock_datetime(2020, 1, 1, 0, 0, 1):
+            schedule.run_pending()
+            assert mock_job.call_count == 1
+            assert len(schedule.jobs) == 1
+
+        with mock_datetime(2020, 1, 1, 0, 0, 2):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+            assert len(schedule.jobs) == 0
+
+        with mock_datetime(2020, 1, 1, 0, 0, 3):
+            schedule.run_pending()
+            assert mock_job.call_count == 2
+
+    def test_max_runs_cancels_via_run_all_without_extra_execution(self):
+        mock_job = make_mock_job()
+
+        every().second.max_runs(1).do(mock_job)
+        schedule.run_all()
+        assert mock_job.call_count == 1
+        assert len(schedule.jobs) == 0
+
+        schedule.run_all()
+        assert mock_job.call_count == 1
+
+    def test_max_runs_repeated_calls_last_wins_without_resetting_counter(self):
+        mock_job = make_mock_job()
+
+        job = every().second.max_runs(1).max_runs(3).do(mock_job)
+        schedule.run_all()
+        assert mock_job.call_count == 1
+        assert len(schedule.jobs) == 1
+
+        job.max_runs(2)
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert len(schedule.jobs) == 0
+
+        schedule.run_all()
+        assert mock_job.call_count == 2
+
+    def test_max_runs_shrinking_below_completed_cancels_without_extra_execution(self):
+        mock_job = make_mock_job()
+
+        job = every().second.max_runs(5).do(mock_job)
+        schedule.run_all()
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert len(schedule.jobs) == 1
+
+        job.max_runs(1)
+        schedule.run_all()
+        assert mock_job.call_count == 2
+        assert len(schedule.jobs) == 0
+
