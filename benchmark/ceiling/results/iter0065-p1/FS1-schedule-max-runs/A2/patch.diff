+
+        schedule.run_all()
+        assert once.call_count == 1
+        assert twice.call_count == 1
+        assert len(schedule.jobs) == 1
+
+        schedule.run_all()
+        assert once.call_count == 1
+        assert twice.call_count == 2
+        assert len(schedule.jobs) == 0
