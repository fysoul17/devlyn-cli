+    def test_max_runs_removal_updates_next_run_and_idle_seconds(self):
+        first_job = make_mock_job()
+        later_job = make_mock_job()
+
+        with mock_datetime(2020, 12, 9, 21, 46):
+            exhausted = every().minute.max_runs(1).do(first_job)
+            later = every().hour.do(later_job)
+            assert schedule.next_run() == exhausted.next_run
+
+        with mock_datetime(2020, 12, 9, 21, 47):
+            schedule.run_pending()
+            assert first_job.call_count == 1
+            assert later_job.call_count == 0
+            assert schedule.next_run() == later.next_run
+            assert schedule.idle_seconds() == (
+                later.next_run - datetime.datetime.now()
+            ).total_seconds()
+
