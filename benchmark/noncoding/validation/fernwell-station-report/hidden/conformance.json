{
  "schema_version": "hidden-conformance-2",
  "channels": [
    {
      "id": "csv-header",
      "bindings": [
        {
          "path": "task.txt",
          "sha256": "07f3971abe2658c48c82cd2f3b537f9ab34d5508e7e40d00ff332e2a6558f1fc",
          "excerpt": "The first line is the header, exactly: station,trips,avg_minutes"
        },
        {
          "path": "seed/report/loader.py",
          "sha256": "92f77b516b93815e7ed304b07cb171264e4a8bc23457200c8eecdc5665d60590",
          "excerpt": "    \"StationSummary\", [\"station\", \"trips\", \"total_minutes\", \"avg_minutes\"]"
        }
      ],
      "validator": {
        "type": "regex",
        "pattern": "^station,trips,avg_minutes$"
      },
      "values": [
        "station,trips,avg_minutes"
      ]
    },
    {
      "id": "csv-rows",
      "bindings": [
        {
          "path": "task.txt",
          "sha256": "07f3971abe2658c48c82cd2f3b537f9ab34d5508e7e40d00ff332e2a6558f1fc",
          "excerpt": "       station,trips,avg_minutes\n       Birch Gate,5,9.2\n       Alder Quay,3,13.0\n       Cedar Row,3,21.0\n       Dunes Landing,1,30.0"
        },
        {
          "path": "seed/data/stations.csv",
          "sha256": "73fd552352e86006d29f4a81194fc91330cf43aaac15278f89e6d056bcbfab71",
          "excerpt": "st-2,Birch Gate"
        }
      ],
      "validator": {
        "type": "regex",
        "pattern": "^[A-Za-z ]+,[0-9]+,[0-9]+\\.[0-9]$"
      },
      "values": [
        "Birch Gate,5,9.2",
        "Alder Quay,3,13.0",
        "Cedar Row,3,21.0",
        "Dunes Landing,1,30.0"
      ]
    },
    {
      "id": "row-order",
      "bindings": [
        {
          "path": "task.txt",
          "sha256": "07f3971abe2658c48c82cd2f3b537f9ab34d5508e7e40d00ff332e2a6558f1fc",
          "excerpt": "Rows are ordered by TRIP COUNT, HIGHEST FIRST. Stations with the same trip\n     count are ordered by station name, A to Z."
        },
        {
          "path": "seed/report/loader.py",
          "sha256": "92f77b516b93815e7ed304b07cb171264e4a8bc23457200c8eecdc5665d60590",
          "excerpt": "    summaries.sort(key=lambda summary: summary.station)"
        }
      ],
      "validator": {
        "type": "regex",
        "pattern": "^[A-Za-z ]+$"
      },
      "values": [
        "Birch Gate",
        "Alder Quay",
        "Cedar Row",
        "Dunes Landing"
      ]
    },
    {
