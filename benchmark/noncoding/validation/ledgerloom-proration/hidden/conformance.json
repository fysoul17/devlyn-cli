    {
      "id": "worked-examples",
      "bindings": [
        {
          "path": "task.txt",
          "sha256": "d4a1dbaa069de097820bd35edcc515cc3f0a0e20b7cbbbd691e85fac251da7aa",
          "excerpt": "prorate_cents(999, 10, 30)  == 333"
        },
        {
          "path": "seed/billing/plans.py",
          "sha256": "deea87d6cc82eb78f01c24620c921fe6ec044c1a36e1f07b3eff0ea9e1ea03ca",
