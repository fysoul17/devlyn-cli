node_modules/
.DS_Store
*.log
config/skills/preflight-workspace/
config/skills/devlyn:ideate-workspace/
config/skills/roadmap-archival-workspace/
config/skills/devlyn:auto-resolve-workspace/

# Ephemeral agent worktrees — disposable per-agent copies
.claude/worktrees/

# auto-resolve harness state — run-local, archived to .devlyn/runs/
.devlyn/

# devlyn-cli installer output — runtime install artifacts under project's own .claude/
# (the tracked source-of-truth for skills lives in config/skills/ — these are install dumps)
.claude/skills/
.claude/templates/
.claude/commit-conventions.md
.claude/settings.json
.claude/settings.local.json
.claude/*.lock

# benchmark runtime artifacts — kept per-run only, actual history goes to benchmark/auto-resolve/history/
benchmark/auto-resolve/results/
benchmark/auto-resolve/external/
benchmark/auto-resolve/fixtures/test-repo/node_modules/

# Lane B (instruction-sensitivity) per-run measurement artifacts.
# Run summaries land in HANDOFF.md and individual run-ids are reproducible from pinned refs.
benchmark/instruction-sensitivity/results/

# Compliance-probe / drift-bait per-run measurement artifacts (iter-0042).
# Curated baseline numbers land in autoresearch/iterations/0042-*.md.
benchmark/probes/results/

# Python bytecode caches — regenerated by idgen / lint / preflight scripts on each run
__pycache__/
*.pyc
benchmark/probes/judge-quality/results/
